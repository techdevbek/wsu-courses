Cell[CellGroupData[{

Cell[TextData[StyleBox["The following interactive figures are an opportunity \
for you to play around with several examples and see if you can predict how \
different matrix operations affect the eigenvalues.  You may notice some \
properties that are useful in better understanding your regular homework. \
Remember that eigenvalues have been rounded to two decimal places and thus \
you can ignore slight differences in the last digit compared to what you \
might expect.  ",
 FontFamily->"Times New Roman",
 FontSize->16,
 FontWeight->"Normal",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.906463272727418*^9, 3.9064632891404886`*^9}, {
   3.9064633554291744`*^9, 3.9064634238608665`*^9}, {3.906463541459958*^9, 
   3.906463550923628*^9}, 3.906463607163826*^9, {3.906464185640617*^9, 
   3.906464392231412*^9}},ExpressionUUID->"028ff176-a19f-4821-b995-\
0013880a58bb"],

