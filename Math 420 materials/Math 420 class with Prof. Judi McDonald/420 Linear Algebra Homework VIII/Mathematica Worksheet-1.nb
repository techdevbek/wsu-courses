Cell[TextData[{
 "3. We can evaluate a polynomial at a square matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "0e31efe7-3787-4d44-9a67-24e0701f855a"],
 ".  For example, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"j", "=", "0"}], "n"], 
     RowBox[{
      SubscriptBox["a", "j"], 
      SuperscriptBox["x", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "1c5bde6b-8875-4c87-8089-fbe3d212993c"],
 "\nthen ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "(", "A", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"j", "=", "0"}], "n"], 
     RowBox[{
      SubscriptBox["a", "j"], 
      SuperscriptBox["A", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "d2c4e043-5969-442e-9582-511de5885dc4"],
 ".  Recall that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "0"], "=", "I"}], TraditionalForm]],ExpressionUUID->
  "3ce13dbb-ab79-4105-9f06-9301875ac529"],
 ".  Use the interactive figure below to investigate the relationship between \
the eigenvalues and eigenvectors of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "0d3e4667-40ab-482e-bfd9-2276e4460a99"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "(", "A", ")"}], TraditionalForm]],ExpressionUUID->
  "98d77bf6-ceb7-497b-9d81-8e1bc2fdad7d"],
