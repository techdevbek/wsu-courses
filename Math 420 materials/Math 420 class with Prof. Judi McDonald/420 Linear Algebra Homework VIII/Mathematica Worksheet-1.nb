Notebook[{
Cell[TextData[{
 "In each of the interactive figures below, we are investigating the \
eigenvalues and eigenvectors of a linear transformation ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "956bfe0b-8349-4858-b5da-d36f8e3eee79"],
 ".  In each case, we will assume that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"A", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"1d6dfab3-ed4c-4362-a563-3db552b36391"],
 " for the given matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ".", " "}], TraditionalForm]],ExpressionUUID->
  "8c3821d2-ac07-4b35-b579-0cdca3b0cad6"],
 " In the first set up the figures I have set up the matrices so they have \
\[OpenCurlyDoubleQuote]nice\[CloseCurlyDoubleQuote] integer eigenvalues and \
eigenvectors.  In the second set of figures I have set up, the matrices \
themselves have \[OpenCurlyDoubleQuote]nice\[CloseCurlyDoubleQuote] integer \
entries, but the eigenvalues and eigenvectors are rounded to two decimal \
places.  "
}], "Text",
 CellChangeTimes->{{3.8751292670407343`*^9, 3.875129356189418*^9}, {
  3.8751293871236467`*^9, 3.8751294270774527`*^9}, {3.8751296154736433`*^9, 
  3.875129690597286*^9}, {3.906464009408283*^9, 3.906464176898058*^9}},
 FontFamily->"Times New Roman",
 FontSize->14,
 FontWeight->"Normal",ExpressionUUID->"2b718192-befc-49e7-be89-59a267391d84"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["The following interactive figures are directly \
related to next week\[CloseCurlyQuote]s homework.",
 FontFamily->"Times New Roman",
 FontSize->16,
 FontWeight->"Normal",
 FontColor->RGBColor[0, 0, 1]]], "Subsubsection",
 CellChangeTimes->{{3.906463272727418*^9, 
  3.9064632891404886`*^9}},ExpressionUUID->"280a252b-d45a-48c4-bedf-\
57889b8ebcf9"],

Cell["\<\
1. In the interactive figure below, click the \[OpenCurlyDoubleQuote]singular\
\[CloseCurlyDoubleQuote] or \[OpenCurlyDoubleQuote]nonsingular\
\[CloseCurlyDoubleQuote] button each several times to generate several \
singular and nonsingular matrices. Also adjust the size of the matrix to see \
if size has any effect. When you get a singular matrix, do you notice \
anything special about its eigenvalues, eigenvectors, nullspace, and range?\
\>", "Text",
 CellChangeTimes->{{3.906462911574835*^9, 3.906462927664637*^9}, 
   3.9064629637573967`*^9, {3.9064629975533752`*^9, 3.906463016499804*^9}},
 FontFamily->"Times New Roman",
 FontSize->14,
 FontWeight->"Normal",ExpressionUUID->"229a5f29-f8aa-4e38-996a-10933936731d"],

