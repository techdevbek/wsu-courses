Cell[TextData[{
 "2. What relationships do you see between the eigenvalues and eigenvectors \
of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "f0bb37b4-a066-441b-a5e7-e69d71af5df5"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["A", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "7d07ca1d-d0c3-46b2-acf2-04f03f791aea"],
 "? Use the buttons at the bottom of the interactive figure to change the \
size of your matrix, and to look at several examples. "
}], "Text",
 CellChangeTimes->{{3.8751294526626253`*^9, 3.8751295278257027`*^9}, {
  3.8751314555071545`*^9, 3.875131458848021*^9}, {3.875132075652213*^9, 
