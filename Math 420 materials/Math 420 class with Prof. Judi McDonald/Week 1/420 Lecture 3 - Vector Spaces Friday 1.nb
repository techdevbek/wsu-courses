Cell["\<\
I will be unavailable to teach on November 17.  Since we will have an evening \
exam,  I would like to use this date as the \[OpenCurlyDoubleQuote]class off\
\[CloseCurlyDoubleQuote] to make up for the evening exam.  Is this OK (other \
options include a guest lecture, out of class activities, ...)? \
\>", "Text",
 CellChangeTimes->{{3.90179236317712*^9, 3.901792367062813*^9}, {
  3.9019645892134576`*^9, 3.901964639430628*^9}, {3.901964674952685*^9, 
  3.9019647991742344`*^9}},ExpressionUUID->"1eceb30e-88da-4380-b74a-\
b75dac38e7e4"],

Cell["Did anyone have difficulty downloading and opening the HW?", "Text",
 CellChangeTimes->{{3.9019678405861025`*^9, 3.9019678598019037`*^9}, {
  3.9019678996840715`*^9, 
  3.9019679146841536`*^9}},ExpressionUUID->"98d7dd59-023a-4bbb-8992-\
0f06f837a3fa"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Question:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsection",
 CellChangeTimes->{{3.838308109671286*^9, 3.8383081155635614`*^9}, {
