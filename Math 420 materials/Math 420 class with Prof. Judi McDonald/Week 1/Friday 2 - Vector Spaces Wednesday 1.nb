7b4d5e788f5c"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {GridBox[{
       {
        RowBox[{
         RowBox[{"\[ForAll]", "x"}], ",", 
         RowBox[{"y", " ", "\[Element]", "V"}], ",", " ", 
         RowBox[{
          RowBox[{"x", "+", "y"}], "=", 
          RowBox[{"y", "+", "x"}]}]}]}
      },
      GridBoxAlignment->{"Columns" -> {{"Center"}}}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
