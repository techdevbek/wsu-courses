Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {GridBox[{
       {
        RowBox[{
         RowBox[{"\[ForAll]", "a"}], ",", 
         RowBox[{"b", " ", "\[Element]", "\[DoubleStruckCapitalF]"}], ",", 
         RowBox[{"\[ForAll]", 
          RowBox[{"x", "\[Element]", "V"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"a", "\[VeryThinSpace]", "b"}], ")"}], "x"}], "=", 
          RowBox[{"a", "(", 
           RowBox[{"b", "\[VeryThinSpace]", "x"}], ")"}]}]}]}
      },
      GridBoxAlignment->{"Columns" -> {{"Center"}}}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"ea94c8eb-0d57-4c3b-95c1-71b65ae7a7df"]], \
"Text",
 CellChangeTimes->{{3.8383074003136263`*^9, 3.838307409228769*^9}, {
  3.8383077308138895`*^9, 
  3.8383077794027033`*^9}},ExpressionUUID->"de470776-f212-490f-a82f-\
1e4f3114ce07"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["",
 FontSlant->"Plain"]], "Subsubsubsection",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047879845123`*^9}, 
   3.901791854630119*^9},ExpressionUUID->"e6329a19-a221-49aa-8ff6-\
59581f2c0815"],

Cell[TextData[StyleBox["(VS7) Distributive Law holds for Vectors",
 FontSlant->"Plain"]], "Text",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047751843767`*^9}, 
   3.8383048140948668`*^9},ExpressionUUID->"9c8ad92a-7dad-4ee3-b9b3-\
bed74acbfdee"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{
      RowBox[{"\[ForAll]", 
       RowBox[{"a", "\[Element]", "\[DoubleStruckCapitalF]"}]}], ",", GridBox[{
        {
         RowBox[{
          RowBox[{"\[ForAll]", "x"}], ",", 
          RowBox[{"y", " ", "\[Element]", "V"}], ",", " ", 
          RowBox[{
           RowBox[{"a", "(", 
            RowBox[{"x", "+", "y"}], ")"}], "=", 
           RowBox[{
            RowBox[{"a", "\[VeryThinSpace]", "x"}], "+", 
            RowBox[{"a", "\[VeryThinSpace]", "y"}]}]}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{"Center"}}}]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"9e13d2e2-cd6c-413b-aa32-b8690a872746"]], \
"Text",
 CellChangeTimes->{{3.8383074003136263`*^9, 3.838307409228769*^9}, {
  3.838307794297886*^9, 
  3.838307823149288*^9}},ExpressionUUID->"48c58d0f-767d-451d-8566-\
a99278db41b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["",
 FontSlant->"Plain"]], "Subsubsubsection",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047879845123`*^9}, 
   3.901791854630119*^9},ExpressionUUID->"1773f2f5-4dd0-4bc1-870e-\
5bc06dafe271"],

Cell[TextData[StyleBox["(VS8) Distributive Law holds for Scalars",
 FontSlant->"Plain"]], "Text",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047262849894`*^9}, 
   3.8383048165495367`*^9, {3.8383076067049475`*^9, 
   3.838307614698036*^9}},ExpressionUUID->"89752624-3b9e-49de-abbc-\
99e28a90912e"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{
      RowBox[{"\[ForAll]", "a"}], ",", 
      RowBox[{"b", "\[Element]", "\[DoubleStruckCapitalF]"}], ",", GridBox[{
        {
         RowBox[{
          RowBox[{"\[ForAll]", 
           RowBox[{"x", " ", "\[Element]", "V"}]}], ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"a", "+", "b"}], ")"}], "x"}], "=", 
           RowBox[{
            RowBox[{"a", "\[VeryThinSpace]", "x"}], "+", 
            RowBox[{"b", "\[VeryThinSpace]", "x"}]}]}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{"Center"}}}]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"defcc35c-79ff-4baf-a84f-227d543d6784"]], \
"Text",
 CellChangeTimes->{{3.8383074003136263`*^9, 3.838307409228769*^9}, {
  3.838307836167249*^9, 
  3.838307855155458*^9}},ExpressionUUID->"8c34d2d3-58fc-4ef7-a120-\
7ee2c526211c"],

Cell["NOTE:  \[DoubleStruckCapitalF] usually represents the real or complex \
numbers.", "Text",
 CellChangeTimes->{{3.901808179194717*^9, 
  3.9018081965840206`*^9}},ExpressionUUID->"4f1b9b87-6648-4092-83a1-\
c981d5463130"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Examples",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsection",
 CellChangeTimes->{{3.838308109671286*^9, 3.8383081155635614`*^9}, {
  3.9017930210066795`*^9, 3.901793024233918*^9}},
 TextAlignment->Left,ExpressionUUID->"a8853b21-5b79-41f7-92a1-3def9a2e04c3"],

Cell[CellGroupData[{

Cell[TextData[Cell[BoxData[
 FormBox[
  SuperscriptBox["\[DoubleStruckCapitalR]", "n"], 
  TraditionalForm]],ExpressionUUID->"e586772f-5cb9-494f-9b88-f42ad649231d"]], \
"Subsubsubsection",
 CellChangeTimes->{{3.8383081726422586`*^9, 3.8383081944918795`*^9}, {
  3.8383082784432564`*^9, 
  3.8383082784432564`*^9}},ExpressionUUID->"e76f4e7d-f1ff-4b66-9a47-\
d707ab80e9c3"],

Cell[TextData[{
 "Columns of real numbers, so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"2"},
       {
        RowBox[{"-", "1"}]},
       {"4"},
       {"6"}
      }], "\[NoBreak]", ")"}], " ", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalR]", "4"]}], TraditionalForm]],
  ExpressionUUID->"564c767f-30fa-4f25-9314-ffd72785f20f"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0"},
       {"0"},
       {"0"},
       {"0"}
      }], "\[NoBreak]", ")"}], " "}], TraditionalForm]],ExpressionUUID->
  "a2bcaad3-f241-4e38-9495-02021e0a4786"]
}], "Text",
 CellChangeTimes->{{3.8389081040366125`*^9, 3.838908159029978*^9}, {
  3.8389082150129027`*^9, 3.838908240070599*^9}, {3.838908272198564*^9, 
  3.8389082884625015`*^9}, {3.9017921049270487`*^9, 
  3.9017921056490383`*^9}},ExpressionUUID->"04cbd347-1196-40da-8c38-\
d8f1edd8b111"],

Cell[TextData[{
 "Reviewing the properties, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"96ccce48-0bbe-4f74-bbc7-c7e186e33a9d"],
 " is a vector space over ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalR]", TraditionalForm]],ExpressionUUID->
  "54fc83b4-59cf-4c89-b984-23adee1ab4b8"],
 "."
}], "Text",
 CellChangeTimes->{{3.8389083139097795`*^9, 
  3.838908337723691*^9}},ExpressionUUID->"640632b6-5ed4-4e9d-a999-\
2c894e815e45"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Polynomials", "Subsubsubsection",
 CellChangeTimes->{{3.8383081726422586`*^9, 3.8383081944918795`*^9}, {
  3.8383083029600396`*^9, 
  3.8383083052107134`*^9}},ExpressionUUID->"88fafcaa-3239-4e12-a9b1-\
328d0b8a3210"],

Cell[TextData[{
 StyleBox["DEFINITION:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " The degree of a polynomial refers to the largest exponent on ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "77648aa0-48dd-410e-b07b-120ec0ea9159"],
 " for which there is a nonzero coefficient."
}], "Text",
 CellChangeTimes->{{3.8389086201799736`*^9, 3.8389086381027794`*^9}, {
  3.8389087245832043`*^9, 3.8389087760970545`*^9}, {3.8389088208110404`*^9, 
  3.8389088710657306`*^9}, {3.838908913358145*^9, 
  3.838908913359109*^9}},ExpressionUUID->"f2c30d9b-4b1c-4f30-a6bb-\
2725f0b1080c"],

Cell["\<\
This definition works great, except for the zero polynomial.  Conventions \
differ by text. The multiplicative identity is the real number 1.  The \
additive identity is obtained by negating every coefficient of the original \
polynomial.  \
\>", "Text",
 CellChangeTimes->{{3.8389086201799736`*^9, 3.8389086381027794`*^9}, {
  3.8389087245832043`*^9, 3.8389087760970545`*^9}, {3.8389088208110404`*^9, 
  3.8389088710657306`*^9}, {3.8389089274490805`*^9, 3.8389089485362735`*^9}, {
  3.8389090564057035`*^9, 
  3.8389091177545743`*^9}},ExpressionUUID->"d345946d-82dc-4064-af8a-\
a92a9d4a7a00"],

Cell["Are all the polynomials of degree two a vector space?", "Text",
 CellChangeTimes->{{3.9017921533673773`*^9, 
  3.9017921704436073`*^9}},ExpressionUUID->"8fc77822-0ea4-45ee-be9f-\
4c9880df9e2a"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["x", "2"], " ", "+", " ", "x", " ", "+", " ", "1"}], 
     ")"}], "+", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"2", "x"}], "+", "3"}], ")"}]}], "=", 
   RowBox[{
    RowBox[{"3", "x"}], "+", "4"}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"d9d9e34e-f123-478d-a053-d1e2b1f16431"]], \
"Text",
 CellChangeTimes->{{3.901808627689308*^9, 
  3.901808694729738*^9}},ExpressionUUID->"9feacc6d-8167-45e9-ae41-\
a9e442a81f73"],

Cell["\<\
NO.  The polynomials of degree two fail to be closed under addition.\
\>", "Text",
 CellChangeTimes->{{3.9018086995794377`*^9, 
  3.9018087149612174`*^9}},ExpressionUUID->"fed0bb49-9e75-43db-a9c9-\
5368aa8834dd"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["",
 FontSlant->"Plain"]], "Subsubsubsection",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047879845123`*^9}, 
   3.901791854630119*^9},ExpressionUUID->"9f53ff79-fcd3-4e54-bf42-\
9e876cf9cf18"],

Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "n"], TraditionalForm]],
  ExpressionUUID->"28144319-e24b-44e1-baab-1d20bcb21fa2"],
 " represents the polynomials of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8e37cfa9-364b-4721-ace2-91d041d26ff4"],
 " ",
 StyleBox["or less (including the zero polynomial)",
  FontColor->RGBColor[1, 0, 0]],
 ".  It is a vector space. "
}], "Text",
 CellChangeTimes->{{3.8389091404898634`*^9, 3.838909176063944*^9}, {
  3.838910589928608*^9, 3.8389105946301622`*^9}, {3.839058039902954*^9, 
  3.8390580524465384`*^9}},ExpressionUUID->"48318fad-83f6-4403-8cb1-\
b60f002a96ee"],

Cell[TextData[{
 "How about ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalP]", "=", 
    RowBox[{"\[Union]", 
     SubscriptBox["\[DoubleStruckCapitalP]", "n"]}]}], TraditionalForm]],
  ExpressionUUID->"f8efc2b0-67df-43d6-af39-497d013d3a90"],
 "= polynomials of any degree (and the zero polynomial)?  Yes.  The set of \
all polynomials is a vector space."
}], "Text",
 CellChangeTimes->{{3.8389091404898634`*^9, 3.838909256199357*^9}, {
   3.8389092928062077`*^9, 3.838909300064171*^9}, 3.9018087519393473`*^9, {
   3.901808788571443*^9, 3.90180879910928*^9}, {3.901809192518506*^9, 
   3.901809192754422*^9}},ExpressionUUID->"6808a6bd-f52c-4f5d-aa94-\
faf449565d73"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Signals", "Subsubsubsection",
 CellChangeTimes->{{3.8383081726422586`*^9, 3.8383081944918795`*^9}, {
  3.8383083029600396`*^9, 
  3.8383083111423593`*^9}},ExpressionUUID->"0c2df935-daf6-4083-8a02-\
0efd241aa507"],

Cell["\<\
The set of signals is the collection of doubly infinite sequences of real \
numbers:\
\>", "Text",
 CellChangeTimes->{{3.8389093363310137`*^9, 
  3.838909359456252*^9}},ExpressionUUID->"3751b2fb-d5d5-46e7-b428-\
86633e0b3b13"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"(", 
   RowBox[{
    RowBox[{"...", "."}], ",", " ", "0", " ", ",", "1", " ", ",", " ", "0", 
    " ", ",", "0", ",", "..."}], ")"}], 
  TraditionalForm]],ExpressionUUID->"bee42bbc-d2d3-4061-8931-94216c68845c"]], \
"Text",
 CellChangeTimes->{{3.838909364276827*^9, 
  3.838909383995282*^9}},ExpressionUUID->"a289c90d-5302-4e3d-8adf-\
caee383a6438"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Matrices", "Subsubsubsection",
 CellChangeTimes->{{3.8383081726422586`*^9, 3.8383081944918795`*^9}, {
  3.8383083029600396`*^9, 
  3.8383083147723446`*^9}},ExpressionUUID->"c6c95f16-94ef-4152-9a48-\
95c01e96bf20"],

Cell["\<\
Is the set of all matrices a vector space? NO.  We cannot add matrices of \
different sizes.\
\>", "Text",
 CellChangeTimes->{{3.9017922175713806`*^9, 3.901792225335884*^9}, {
  3.901809208021499*^9, 
  3.901809217020069*^9}},ExpressionUUID->"90451de6-714a-47b4-8c1e-\
8d95144301db"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["",
 FontSlant->"Plain"]], "Subsubsubsection",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
   3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
   3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047879845123`*^9}, 
   3.901791854630119*^9},ExpressionUUID->"a1b74ff3-f6cc-4dc4-849e-\
851e8831eb47"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalM]", 
      RowBox[{"m", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalR]", ")"}], 
    "="}], TraditionalForm]],ExpressionUUID->
  "28ea4336-db27-49b3-9408-df78460b5a94"],
 " set of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "b53a4720-9236-4f51-8a99-0db003602750"],
 " matrices over the real numbers. The additive identity is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "2db2193c-8454-4abb-a687-a0b1805b698c"],
 " matrix, all of whose entries are zero. The multiplicative identity sits in \
the real numbers, so it is the number 1. "
}], "Text",
 CellChangeTimes->{{3.8389097375110683`*^9, 3.8389097986027956`*^9}, {
  3.838909873563448*^9, 3.838909899224752*^9}, {3.8389099744545608`*^9, 
  3.838909990271551*^9}, {3.901809234375307*^9, 
  3.9018092414101057`*^9}},ExpressionUUID->"80a7c29c-9916-4d70-bef0-\
bc8ef7fcb3cb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Functions", "Subsubsubsection",
 CellChangeTimes->{{3.8383081726422586`*^9, 3.8383081944918795`*^9}, {
   3.8383083029600396`*^9, 3.838308326611795*^9}, 
   3.838308543047843*^9},ExpressionUUID->"4ff0e729-81cb-478e-b05e-\
10837a78f6f6"],

Cell["\<\
Consider the set of functions defined over \[DoubleStruckCapitalR] using \
addition. Is it a vector space over \[DoubleStruckCapitalR]? YES.\
\>", "Text",
 CellChangeTimes->{{3.8389100084149456`*^9, 3.8389100242179823`*^9}, {
  3.8389100732050905`*^9, 3.838910088789158*^9}, {3.838910140736393*^9, 
  3.8389101425481076`*^9}, {3.9017922614275637`*^9, 3.901792274692308*^9}, {
  3.9018093677101192`*^9, 
  3.901809370430252*^9}},ExpressionUUID->"08d77d03-e93b-421b-a9dd-\
caf38bb8174b"],

Cell["\<\
Consider the set of functions defined over \[DoubleStruckCapitalR] using \
composition.  Is it a vector space? NO\
\>", "Text",
 CellChangeTimes->{{3.838910147840265*^9, 3.838910252523364*^9}, {
  3.9017922817749434`*^9, 3.9017922983119555`*^9}, {3.9018095673051987`*^9, 
  3.901809574334255*^9}},ExpressionUUID->"962877f2-8bf1-4134-8d11-\
c1c74081ee18"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "=", 
    RowBox[{"x", "+", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d849c177-74be-413e-9580-71d5e3af6ecc"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    SuperscriptBox["x", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e384031a-5b73-44b0-8323-166b6bf52e99"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "\[SmallCircle]", 
     RowBox[{"g", "(", "x", ")"}]}], "=", 
    RowBox[{
     SuperscriptBox["x", "2"], "+", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "accf6013-dcb0-40a6-8e9c-53ad7e1a5cde"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"g", "\[SmallCircle]", "f"}], 
     RowBox[{"(", "x", ")"}]}], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"x", "+", "1"}], ")"}], "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e80deb3b-653c-4a62-a9ed-d565d31b538d"]
}], "Text",
 CellChangeTimes->{{3.9018093934664536`*^9, 3.9018094171705112`*^9}, {
  3.901809451217518*^9, 3.9018094680680723`*^9}, {3.9018095013587666`*^9, 
  3.9018095552037787`*^9}},ExpressionUUID->"e7077f1f-7552-4c1c-a36b-\
6f62e5c6fee8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\[DoubleStruckCapitalC] over \[DoubleStruckCapitalR]", \
"Subsubsubsection",
 CellChangeTimes->{{3.838309026894106*^9, 
  3.8383090539041357`*^9}},ExpressionUUID->"f46a2285-1c1f-4a51-a83d-\
b34be7af5ffe"],

Cell[TextData[{
 "Is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalC]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"a", "+", 
        RowBox[{"b", "\[VeryThinSpace]", "i"}]}], "|", "a"}], ",", 
      RowBox[{"b", " ", "\[Element]", " ", "\[DoubleStruckCapitalR]"}]}], 
     "}"}]}], TraditionalForm]],ExpressionUUID->
  "18b26bee-838f-464e-b8fb-6f71d37698d2"],
 " a vector space over \[DoubleStruckCapitalR]? YES."
}], "Text",
 CellChangeTimes->{{3.838910287639574*^9, 3.8389103224145665`*^9}, {
  3.838910386237482*^9, 3.8389104002234135`*^9}, {3.901792303135604*^9, 
  3.9017923141656384`*^9}, {3.901809617565586*^9, 
  3.9018096191719637`*^9}},ExpressionUUID->"523a5e42-a1aa-4606-a0a9-\
d84ec9dc5e9a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GQE Fall 2022", "Subsubsubsection",
 CellChangeTimes->{{3.8703441448741117`*^9, 
  3.870344157409378*^9}},ExpressionUUID->"0cf1c241-9fc3-42ec-abc7-\
383cce76091c"],

Cell["Part A of a three part question: ", "Text",
 CellChangeTimes->{{3.8703441448741117`*^9, 3.870344255772803*^9}, {
  3.870344327366113*^9, 
  3.870344338601174*^9}},ExpressionUUID->"e0ef6473-4d06-4f44-996f-\
76829bdfd569"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", 
