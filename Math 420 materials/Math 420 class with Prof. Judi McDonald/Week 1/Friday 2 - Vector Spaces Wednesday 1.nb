Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition of a Vector Space",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsection",
 CellChangeTimes->{{3.8383071396494527`*^9, 3.838307144548066*^9}, {
  3.9017930078122845`*^9, 3.9017930180940943`*^9}},
 TextAlignment->Left,ExpressionUUID->"343e7ed1-d0dd-4449-bb36-98ee98008379"],

Cell[TextData[{
 "A vector space is ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "1e3294d0-3a20-462e-815b-078f9a57567f"],
 " over a field \[DoubleStruckCapitalF] (in this class, the \
\[DoubleStruckCapitalR]eal or \[DoubleStruckCapitalC]omplex numbers) a set on \
which two operations (addition and scalar multiplication) are defined so that \
for each pair of elements ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", " ", "\[Element]", " ", "V"}]}], TraditionalForm]],
  ExpressionUUID->"14af8e15-1390-4ff8-a818-00b286362940"],
 ", there is a unique element ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "+", "y"}], " ", "\[Element]", " ", "V"}], TraditionalForm]],
  ExpressionUUID->"77f71175-8c7b-4849-b617-1f986c9f2a22"],
 ", and for each scalar ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"838daa1c-839a-4390-b32b-e63178bd9052"],
 " there is a unique element ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", " ", "x"}], " ", "\[Element]", "V"}], TraditionalForm]],
  ExpressionUUID->"f755c8d6-3c85-4d34-bc68-24b8b66a0ec9"],
 " such that the following hold:"
}], "Text",
 CellChangeTimes->{{3.617969201521633*^9, 3.617969204743789*^9}, {
  3.617969236581134*^9, 3.617969587270246*^9}, {3.8383044864990582`*^9, 
  3.8383045081046867`*^9}, {3.8383047015010986`*^9, 3.8383047594348707`*^9}, {
  3.870174948993927*^9, 
  3.8701749794842777`*^9}},ExpressionUUID->"2c3402c2-7408-4714-868b-\
dddcb86a9d86"],

