 FormBox[GridBox[{
    {GridBox[{
       {
        RowBox[{
         RowBox[{"\[ForAll]", "x"}], ",", "y", ",", 
         RowBox[{"z", " ", "\[Element]", "V"}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"x", "+", "y"}], ")"}], "+", "z"}], "=", 
          RowBox[{"x", "+", 
