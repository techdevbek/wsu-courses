Cell[CellGroupData[{

Cell[TextData[StyleBox["Q & A",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.9070768180153503`*^9, 
   3.907076824916872*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5d27fedc-ed0b-4c65-92a0-3c2519f58976"],

Cell[TextData[{
 "The book uses the Notation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "A"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4fc2b08a-1bfc-463e-ac5c-584a756aac66"],
 " to represent the linear transformation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{"A", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aa0944f1-f8dd-4b90-bf26-6e091fc7d32a"],
 "."
}], "Text",
 CellChangeTimes->{{3.90707741159809*^9, 
  3.9070774443155384`*^9}},ExpressionUUID->"627689d3-b2db-48dc-9e93-\
41766adcb104"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["L", "A"], "(", "x", ")"}], "=", 
    RowBox[{"A", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f6caa4a5-ed0d-4415-8fcb-f3aefc1d27eb"],
 "."
}], "Text",
 CellChangeTimes->{{3.907077622095668*^9, 
  3.907077632132281*^9}},ExpressionUUID->"7fbb7122-a75e-42e0-a41e-\
f0b1698898f6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ":", 
    RowBox[{"V", "\[LongRightArrow]", "W"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ff50b6e8-e857-45fd-8d5f-0fde385154b5"],
 " is ONTO if every animal gets fed.  "
}], "Text",
 CellChangeTimes->{{3.907077904730137*^9, 3.9070779204354305`*^9}, {
  3.9070779755174575`*^9, 
  3.9070779992935944`*^9}},ExpressionUUID->"3117176e-df74-4e6e-920e-\
9fd205d24da9"],

Cell["Theoretically there are two main approaches:", "Text",
 CellChangeTimes->{{3.907077904730137*^9, 
  3.907077934969189*^9}},ExpressionUUID->"82fd6586-d03d-443b-9d67-\
9b2e396fdd55"],

Cell[TextData[{
 "1. Show ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Rank", " ", 
     RowBox[{"(", "T", ")"}]}], "=", 
    RowBox[{"Dim", " ", 
     RowBox[{"(", "W", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0a05ab40-1ba1-41db-8006-23ff63316bd6"]
}], "Text",
 CellChangeTimes->{{3.907077904730137*^9, 
  3.9070779677984715`*^9}},ExpressionUUID->"1bcf939d-19be-4351-98b6-\
1fca2f301e27"],

Cell[TextData[{
 "2. Take an arbitrary (generic) element ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "32d2241a-01cc-4d0b-ad91-102f0a037aa1"],
 " and show that there is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5325b37e-8621-4802-9eb7-bc1305ec4691"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "v", ")"}], "=", "w"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b8450c6e-ad0a-43ab-9596-41987853008f"],
 "."
}], "Text",
 CellChangeTimes->{{3.907077904730137*^9, 3.907077972206009*^9}, {
  3.907078004016852*^9, 
  3.9070780804326267`*^9}},ExpressionUUID->"446b11d1-5882-4968-a470-\
2d214168d86c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ":", 
    RowBox[{"V", "\[LongRightArrow]", "W"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c96e4666-52f0-44bf-a870-b3de5c85d2c1"],
 " is ONE-TO-ONE if no animal gets fed more than once.  "
}], "Text",
 CellChangeTimes->{{3.907077904730137*^9, 3.9070779204354305`*^9}, {
  3.9070779755174575`*^9, 3.9070779992935944`*^9}, {3.9070781152558327`*^9, 
  3.9070781393335915`*^9}},ExpressionUUID->"9a4aeab6-2c29-4f34-b280-\
e42aa8bf3e5b"],

Cell["Theoretically there are four main approaches:", "Text",
 CellChangeTimes->{{3.907077904730137*^9, 3.907077934969189*^9}, {
  3.9070783536628532`*^9, 
  3.90707835548672*^9}},ExpressionUUID->"2c095d19-0dc1-4089-af4b-\
8ba3f0fb8b2b"],

Cell[TextData[{
 "1. Show that Nullity",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", "T", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "90c3ded8-4531-4eca-8cbf-5badf63fb893"],
 "."
}], "Text",
 CellChangeTimes->{{3.9070781553485904`*^9, 
  3.907078181114303*^9}},ExpressionUUID->"78880d5f-da5c-41e8-95d6-\
4c5ff3af25e2"],

Cell[TextData[{
 "2. Show that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3d6f321c-556f-4604-aabd-0e907f9d7456"]
}], "Text",
 CellChangeTimes->{{3.9070781553485904`*^9, 
  3.9070781926525393`*^9}},ExpressionUUID->"26edec1c-7a0d-4292-877a-\
81d72545d38d"],

Cell["\<\
3. Suppose some nonzero element gets mapped to zero and show this leads to a \
contradiction.\
\>", "Text",
 CellChangeTimes->{{3.907078201819481*^9, 3.9070782294544067`*^9}, {
  3.907078277718547*^9, 
  3.9070782777205477`*^9}},ExpressionUUID->"c0cd2c8b-d4e4-458e-b941-\
4b5578ba8b2e"],

Cell[TextData[{
 "4. Suppose ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"T", "(", "y", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "804f8ebb-2056-496b-a3ef-79b2600b67b3"],
 " and show that this forces ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"y", "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2c9becb0-14d4-4613-944e-4351a45345f9"]
}], "Text",
 CellChangeTimes->{{3.907078201819481*^9, 3.9070782294544067`*^9}, {
  3.90707827934699*^9, 3.9070782819732814`*^9}, {3.9070783199294205`*^9, 
  3.907078350626156*^9}},ExpressionUUID->"45918a77-d0d5-4a43-a63f-\
9f7db9699a30"],

Cell[TextData[{
 "HANDY FORMULA:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"rank", 
      RowBox[{"(", "T", ")"}]}], "+", 
     RowBox[{"nullity", 
      RowBox[{"(", "T", ")"}]}]}], "=", 
    RowBox[{"dim", 
     RowBox[{"(", "V", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a19fda3a-a7b5-4e4a-a918-1674e8b0367f"]
}], "Text",
 CellChangeTimes->{{3.907078376024358*^9, 
  3.9070784002755814`*^9}},ExpressionUUID->"b9ee9bb1-935a-46f0-b43f-\
406329e18de1"],

Cell[TextData[{
 "If you are given an actual ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a9e8ea3c-5944-4647-8a5c-fb27b5915935"],
 ", start with a basis for the domain V, apply T to this basis to get a \
spanning set.  Toss out anything that is linearly dependent.  What is left is \
a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", 
    RowBox[{"(", "T", ")"}], " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d02d8df5-e796-4a9a-9047-943e5ca5d7b7"],
 "with rank",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "T", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "74c91a46-cc54-4f4d-bf86-3e92a3c717d6"],
 " elements."
}], "Text",
 CellChangeTimes->{{3.9070784498421783`*^9, 
  3.9070785168313594`*^9}},ExpressionUUID->"12662ce1-7090-468f-9a68-\
2366b77a1422"],

