Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "1"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a52240e3-43ad-48d7-bc22-1ee90acf431f"],
 ".  The characteristic equation of ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "43cd7c83-1f8b-4839-aa0a-0109b393b519"],
 " is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"t", "-", "1"}], ")"}], "2"], TraditionalForm]],ExpressionUUID->
  "b7fbe323-1c0e-4894-b08c-a0ce18f00ed1"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "e61f828d-d854-4be7-abf4-851713182414"],
 " has algebraic multiplicity 2, but nullity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"I", "-", "B"}], ")"}], TraditionalForm]],ExpressionUUID->
  "bfe02915-9ce2-487c-b722-49a9cfccbc03"],
 " is 1. "
}], "Text",
