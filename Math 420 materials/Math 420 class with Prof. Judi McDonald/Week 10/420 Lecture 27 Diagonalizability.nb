   3.843725824410988*^9}, {3.9068147444221196`*^9, 3.9068147706644955`*^9}, {
   3.907251998344756*^9, 3.907252109125148*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"3ad15d0a-b4c2-4908-9e11-be8ab8f049d1"]
}, Open  ]],

