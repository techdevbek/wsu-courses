Cell[TextData[StyleBox["Theorem:  ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, 3.8437254030030375`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5c58599d-052b-4378-aae3-81d96b577e23"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", " "}], TraditionalForm]],ExpressionUUID->
  "738d5e5e-2190-4ac4-a254-0def33c49eb5"],
 "be a linear operator on a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "fc00e826-97ce-4631-9f8e-c71ea25ffa3e"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", "...", ",", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "795f0a60-808b-4a61-b207-bc67d76c9d96"],
 " be distinct eigenvalues of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "1c0559ac-e259-42f3-9f44-18743c8b17a1"],
 " with corresponding eigenvectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", " ", "...", ",", " ", 
    RowBox[{
     SubscriptBox["v", "k"], ".", "  "}]}], TraditionalForm]],ExpressionUUID->
  "5eac3077-f754-47ef-a16c-ff829f878dc3"],
 "Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", "...", ",", " ", 
      SubscriptBox["v", "k"]}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"5233ff01-b40a-41f8-8a2a-0ee36fbc1e8f"],
 " is linearly independent.  "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"6d5a88fa-e5e8-4596-b3e7-d36f75c1488e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["PROOF:", "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.622375298178881*^9}, {
   3.62237534841584*^9, 3.622375360557118*^9}, {3.622552991754034*^9, 
   3.6225530172540627`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"efe7725c-6a07-437c-ac2f-39081456e553"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", "...", ",", " ", 
      SubscriptBox["v", "k"]}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"4a8410fc-4708-418b-9d17-6ecdf27f081a"],
 " is linearly dependent. Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "j"], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "j"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "d74fdd29-3c60-4032-9648-7ec72b423fa1"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.8437475741314087`*^9, 3.8437478170027213`*^9}, 
   3.907187006014244*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9e979009-79e9-4593-9e85-396fd51e0c1b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"1448f687-a884-41db-88b9-6ade7def1675"],

Cell[TextData[{
 "Certainly ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],ExpressionUUID->
  "388cbd00-bf28-4634-a5ed-98400a083774"],
 " is linearly independent and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "k"], TraditionalForm]],ExpressionUUID->
  "4cac0b7f-de22-476e-9a71-4ff29e6bd734"],
 " is assumed to be linearly dependent (looking for a contradication).  "
}], "Text",
 CellChangeTimes->{{3.8437475741314087`*^9, 3.8437478170027213`*^9}, {
  3.907187041482417*^9, 3.9071870414834223`*^9}, {3.9072507751852713`*^9, 
  3.9072507853546023`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"da823d0a-7bcc-4836-aaa1-fc617c03b067"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.8437475741314087`*^9, 3.8437478170027213`*^9}, {
  3.907187041954708*^9, 3.9071870419556274`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f5693323-c014-41c6-86bb-8ad1d6da218d"],

Cell[TextData[{
 "Choose the smallest ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "799174ce-7d0a-4b71-bc7b-b991b9944c54"],
 " so that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "m"], TraditionalForm]],ExpressionUUID->
  "67ce2b09-8d83-47b3-94c6-73a2a4394907"],
 " is linearly dependent.  Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<", "m", "\[LessEqual]", "k"}], TraditionalForm]],
  ExpressionUUID->"527ded18-5dee-4701-b8eb-d09c35a64182"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.8437475741314087`*^9, 3.8437478170027213`*^9}, {
  3.907187058889609*^9, 3.9071870588922772`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ec591008-0b5c-426b-97a9-e376e991fef6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"9ba046a4-4bc9-4b49-9977-7994f13af680"],

Cell[TextData[{
 "Choose coefficients ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    RowBox[{"...", "."}], ",", 
    SubscriptBox["a", "m"]}], TraditionalForm]],ExpressionUUID->
  "abd9b62c-4fdb-41bc-9169-91aac9ce0e1c"],
 ", not all zero, so that ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "1"], 
         SubscriptBox["v", "1"]}], "+", 
        RowBox[{
         SubscriptBox["a", "2"], 
         SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", "m"], 
       SubscriptBox["v", "m"]}]}], "=", "0"}],
    FontColor->RGBColor[0, 0, 1]], TraditionalForm]],ExpressionUUID->
  "39f1bea0-f585-4afb-a284-cfcdccfddb55"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"m", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "99c52cf3-cac1-4dc7-80ff-c1bfad473e92"],
 " is linearly independent, we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "m"], "\[NotEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"f5da0c0d-ab38-45ec-8a9d-982493360217"]
}], "Text",
 CellChangeTimes->{{3.8437475741314087`*^9, 3.8437478170027213`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"cd4c39c5-3f4a-47f1-9da9-efc2f8abbde6"],

Cell["", "Text",ExpressionUUID->"8625270e-6c25-4256-8993-bbade3d83859"],

Cell[TextData[{
 "Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "1"], 
         SubscriptBox["v", "1"]}], "+", 
        RowBox[{
         SubscriptBox["a", "2"], 
         SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", "m"], 
       SubscriptBox["v", "m"]}]}], ")"}], "=", 
    RowBox[{
     RowBox[{"T", "(", "0", ")"}], "=", "0"}]}], TraditionalForm]],
  ExpressionUUID->"5934d968-c0d9-4394-a78b-66b96e046ffd"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        RowBox[{"T", "(", 
         SubscriptBox["v", "1"], ")"}]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        RowBox[{"T", "(", 
         SubscriptBox["v", "2"], ")"}]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "m"], 
      RowBox[{"T", "(", 
       SubscriptBox["v", "m"], ")"}]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"89e17558-c6dd-4dc3-8344-3221ac3ff14d"],
 " and thus ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "1"], 
         RowBox[{
          SubscriptBox["\[Lambda]", "1"], "(", 
          SubscriptBox["v", "1"], ")"}]}], "+", 
        RowBox[{
         SubscriptBox["a", "2"], 
         RowBox[{
          SubscriptBox["\[Lambda]", "2"], "(", 
          SubscriptBox["v", "2"], ")"}]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", "m"], 
       RowBox[{
        SubscriptBox["\[Lambda]", "m"], "(", 
        SubscriptBox["v", "m"], ")"}]}]}], "=", "0"}],
    FontColor->RGBColor[0, 0, 1]], TraditionalForm]],ExpressionUUID->
  "822cd8af-51ec-4c7d-80cb-4de3d21b8baf"]
}], "Text",
 CellChangeTimes->{{3.84374785294923*^9, 3.8437478826693497`*^9}, {
  3.9071871888835115`*^9, 3.9071871999346647`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"aed06c00-8cf9-47bf-a5c7-66d0a07406f7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.84374789628263*^9, 3.8437479500088778`*^9}, 
   3.9071871871754436`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e001df2f-ba01-4d38-99eb-8ad7e0526eb0"],

Cell[TextData[{
 "Subtract ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "m"], "("}], TraditionalForm]],ExpressionUUID->
  "f6f4c056-5cbf-45c7-b3d4-2f241ceb5b0f"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["a", "1"], 
       SubscriptBox["v", "1"]}], "+", 
      RowBox[{
       SubscriptBox["a", "2"], 
       SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
    RowBox[{
     SubscriptBox["a", "m"], 
     SubscriptBox["v", "m"]}]}], TraditionalForm]],ExpressionUUID->
  "0b341707-55ce-44ad-80d0-477209768b6f"],
 ") from both sides of this equation."
}], "Text",
 CellChangeTimes->{{3.84374789628263*^9, 3.843747979579466*^9}, {
  3.843748018649357*^9, 3.8437480481852555`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"26b8fc29-4895-4446-b983-6b6e40594ea0"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], "(", 
        RowBox[{
         SubscriptBox["\[Lambda]", "1"], "-", 
         SubscriptBox["\[Lambda]", "m"]}], ")"}], 
       RowBox[{"(", 
        SubscriptBox["v", "1"], ")"}]}], "+", 
      RowBox[{
       RowBox[{
        SubscriptBox["a", "2"], "(", 
        RowBox[{
         SubscriptBox["\[Lambda]", "2"], "-", 
         SubscriptBox["\[Lambda]", "m"]}], ")"}], 
       RowBox[{"(", 
        SubscriptBox["v", "2"], ")"}]}], "+"}], "..."}], "+", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "m"], "(", 
      RowBox[{
       SubscriptBox["\[Lambda]", "m"], "-", 
       SubscriptBox["\[Lambda]", "m"]}], ")"}], 
     RowBox[{"(", 
      SubscriptBox["v", "m"], ")"}]}]}], "=", "0"}], 
  TraditionalForm]],ExpressionUUID->"08d534ae-c540-4624-87f5-153ace083a7e"]], \
"Text",
 CellChangeTimes->{{3.8437480687237377`*^9, 3.8437481029477534`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5c5d38ae-ac02-4e60-915b-d28595385783"],

Cell[TextData[{
 "so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "1"], "(", 
         RowBox[{
          SubscriptBox["\[Lambda]", "1"], "-", 
          SubscriptBox["\[Lambda]", "m"]}], ")"}], 
        RowBox[{"(", 
         SubscriptBox["v", "1"], ")"}]}], "+", 
       RowBox[{
        RowBox[{
         SubscriptBox["a", "2"], "(", 
         RowBox[{
          SubscriptBox["\[Lambda]", "2"], "-", 
          SubscriptBox["\[Lambda]", "m"]}], ")"}], 
        RowBox[{"(", 
         SubscriptBox["v", "2"], ")"}]}], "+"}], "..."}], "+", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"m", "-", "1"}]], "(", 
       RowBox[{
        SubscriptBox["\[Lambda]", 
         RowBox[{"m", "-", "1"}]], "-", 
        SubscriptBox["\[Lambda]", "m"]}], ")"}], 
      RowBox[{"(", 
       SubscriptBox["v", 
        RowBox[{"m", "-", "1"}]], ")"}]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"7cce9066-cd56-4cab-be78-eb64b98bf9a1"]
}], "Text",
 CellChangeTimes->{{3.843748171740757*^9, 3.843748204472289*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"7e6a3a4b-e116-4823-90ce-eb54eef77971"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"f335581e-8cc6-4b96-935d-4c1171a34eee"],

Cell[TextData[{
 "Because the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "j"], TraditionalForm]],ExpressionUUID->
  "605b30b3-47e4-474c-bf03-15c3f59f7e5c"],
 " are distinct, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "-", 
     SubscriptBox["\[Lambda]", "m"]}], "\[NotEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"b6dca409-ebd6-487a-a1c3-837a9cdaa6c5"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", "j", "\[LessEqual]", "m"}], TraditionalForm]],
  ExpressionUUID->"b2d8780c-d16a-4c7b-be42-638f6d9aee53"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "m"], "\[NotEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"602eca4b-f08c-4c04-9b33-b91db3346f94"],
 ", at least one value of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "j"], " "}], TraditionalForm]],ExpressionUUID->
  "83008148-9ed0-43e2-8a9d-c9ed0f49c0a7"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", "j", "\[LessEqual]", 
    RowBox[{"m", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "e1fa0d27-01c9-47e9-b035-96ffa253b90e"],
 " is nonzero, so such an ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "j"], "(", 
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "-", 
     SubscriptBox["\[Lambda]", "m"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"e82760a9-41a7-475f-af23-9dbc04ee3c72"],
 " is nonzero, contradicting that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"m", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "2be59da9-9b5f-413e-9e43-75a71e9f5f21"],
 " was a linearly independent set. "
}], "Text",
 CellChangeTimes->{{3.843748227182061*^9, 3.843748331234704*^9}, {
  3.8437483871878157`*^9, 3.8437484322971396`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"85abfef6-1d8c-45ce-b5a7-857344e17c6e"],

Cell[TextData[{
 "Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", "...", ",", " ", 
      SubscriptBox["v", "k"]}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"2d55e6ae-2537-4c7c-a2e3-71328a8d9f7c"],
 "cannot be linearly dependent."
}], "Text",
 CellChangeTimes->{{3.843748227182061*^9, 3.843748331234704*^9}, {
  3.8437483871878157`*^9, 3.84374845021131*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9bace010-e5b5-4b46-aa6c-d2d1bfc8f778"]
}, Open  ]],

