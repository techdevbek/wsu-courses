Cell[TextData[{
 "The example ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "1"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c9bd1e86-04ce-48c3-8903-12b45ea8d9b6"],
 " has characteristic polynomial ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"x", "-", "1"}], ")"}], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d2b404aa-f024-4f5f-8b0b-173fc6aef0bd"],
 " and shows that even though the characteristic polynomial splits, the \
linear transformation may not be diagonalizable. "
}], "Text",
 CellChangeTimes->{{3.843919202234004*^9, 3.8439192513440247`*^9}, {
  3.8751829150263753`*^9, 3.875182960047551*^9}, {3.9071875899578986`*^9, 
  3.9071876742901*^9}},
 FontFamily->
