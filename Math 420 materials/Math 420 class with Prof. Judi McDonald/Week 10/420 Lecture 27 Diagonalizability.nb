Cell[TextData[{
 StyleBox["Definition",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 ": "
}], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.6228073004808025`*^9}, {
   3.622807447858322*^9, 3.6228076204295917`*^9}, {3.6228076515139194`*^9, 
   3.6228076536859045`*^9}, {3.622811468111659*^9, 3.622811468267922*^9}, 
   3.84372584673676*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"fc0a40f7-a5c3-4bcc-8533-b516cc438b51"],

Cell[TextData[{
 "A polynomial ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "f12ba674-a130-4796-a8c1-b12c58c2e106"],
 " ",
 StyleBox["splits",
  FontSlant->"Italic"],
 " over \[DoubleStruckCapitalF] if there are scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", ",", " ", 
    SubscriptBox["a", "1"], ",", 
    SubscriptBox["a", "2"], ",", "...", ",", " ", 
    SubscriptBox["a", "n"]}], TraditionalForm]],ExpressionUUID->
  "0fa66963-08ae-42f7-a320-5075fa227cb0"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{"c", "(", 
      RowBox[{"t", "-", 
       SubscriptBox["a", "1"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"t", "-", 
       SubscriptBox["a", "2"]}], ")"}], 
     RowBox[{"\[CenterEllipsis]", "(", 
      RowBox[{"t", "-", 
       SubscriptBox["a", "n"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5fcaf0a3-f2f1-4627-8ef9-c968905c5be3"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.6228073004808025`*^9}, {
   3.622807447858322*^9, 3.6228076204295917`*^9}, {3.6228076515139194`*^9, 
   3.6228076536859045`*^9}, {3.622811468111659*^9, 3.622811468267922*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c4dc3ab8-f74e-49cf-9edc-03a8918164df"],

Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "j"], TraditionalForm]],ExpressionUUID->
  "7d0e61b5-7456-4782-881b-34de9c9122e5"],
 " are the roots (zeros) of the polynomial. "
}], "Text",
 CellChangeTimes->{{3.8751870479514823`*^9, 
  3.875187065822122*^9}},ExpressionUUID->"9890e5a2-cf98-425b-a2a0-\
0db2a89214a6"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Example: ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.6228073004808025`*^9}, {
   3.622807447858322*^9, 3.6228076204295917`*^9}, {3.6228076515139194`*^9, 
   3.622807690422111*^9}, {3.622811474174466*^9, 3.6228114745481176`*^9}, {
   3.622811716237259*^9, 3.6228117195343037`*^9}, 3.8437258723806553`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"6454b041-70b2-4cf6-b17b-efd07ebe559a"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["t", "2"], "+", "1"}], "=", 
     RowBox[{"(", 
      RowBox[{"t", "-", "\[ImaginaryI]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e2864611-234e-4a4e-80ad-f490580e45a9"],
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"t", "+", "\[ImaginaryI]"}], ")"}], TraditionalForm]],
  ExpressionUUID->"53960aeb-674d-4a4c-b4a6-4ce42a4829f3"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
