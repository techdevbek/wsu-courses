Cell[TextData[{
 "The ",
 StyleBox["algebraic multiplicity",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " of a root \[Lambda] of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "c94bb8a4-382f-4ed6-a7c0-de175ef4dbc6"],
 " refers to the largest power ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "e8281cd5-f9a1-4b83-bdea-d1a57d7ac865"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"t", "-", "\[Lambda]"}], ")"}], "k"], " "}], TraditionalForm]],
  ExpressionUUID->"b42c31c2-27c3-455a-a1f6-80db0d6b870a"],
 "divides ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "t", ")"}], "."}], TraditionalForm]],ExpressionUUID->
  "ee336699-839c-45a7-8a26-6eaab67ec8c5"],
 " The ",
 StyleBox["algebraic multiplicity",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " of an eigenvalue of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "45af8ffd-fab6-41aa-833f-82e30a6ee73f"],
 " is the algebraic multiplicity of the eigenvalue as a root of the \
characteristic equation.  "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
