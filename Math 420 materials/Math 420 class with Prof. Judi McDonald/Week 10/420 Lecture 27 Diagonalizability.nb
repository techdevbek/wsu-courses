Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "be3b34ed-9c75-42c8-8961-ad2a5ab26321"],
 " is diagonalizable, choose a basis \[Beta] so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox["d", "11"], "0", "\[CenterEllipsis]", "0"},
       {"0", 
        SubscriptBox["d", "22"], " ", "\[VerticalEllipsis]"},
       {"\[VerticalEllipsis]", " ", "\[Continuation]", "0"},
       {"0", "\[CenterEllipsis]", "0", 
        SubscriptBox["d", 
         RowBox[{"n", "\[VeryThinSpace]", "n"}]]}
      }], "\[NoBreak]", ")"}], " "}], TraditionalForm]],ExpressionUUID->
  "faadbe92-8e1b-4da7-aead-1ecf183a10cc"],
 "."
}], "Text",
 CellChangeTimes->{{3.622811816529376*^9, 3.6228118176700573`*^9}, {
  3.8439189355818605`*^9, 3.8439191405835524`*^9}, {3.8751828833113394`*^9, 
  3.8751828876364627`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"729beda6-677a-492d-a87c-2c7daccb918a"],

Cell[TextData[{
 "det",
 Cell[BoxData[
  FormBox["(", TraditionalForm]],ExpressionUUID->
  "fcae7600-1691-4161-b4e9-651d29d4ff90"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "(", "\[NoBreak]", GridBox[{
      {"1", "0", "\[CenterEllipsis]", "0"},
      {"0", "1", " ", "\[VerticalEllipsis]"},
      {"\[VerticalEllipsis]", " ", "\[Continuation]", "0"},
      {"0", "\[CenterEllipsis]", "0", "1"}
     }], "\[NoBreak]", ")"}], TraditionalForm]],ExpressionUUID->
  "acd3c572-96fe-4c7e-9c12-d58d281c00e0"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          SubscriptBox["d", "11"], "0", "\[CenterEllipsis]", "0"},
         {"0", 
          SubscriptBox["d", "22"], " ", "\[VerticalEllipsis]"},
         {"\[VerticalEllipsis]", " ", "\[Continuation]", "0"},
         {"0", "\[CenterEllipsis]", "0", 
          SubscriptBox["d", 
           RowBox[{"n", "\[VeryThinSpace]", "n"}]]}
        }], "\[NoBreak]", ")"}]}], ")"}], "="}], TraditionalForm]],
  ExpressionUUID->"109a205c-24e3-4ffa-a909-61ec235b383d"]
}], "Text",
 CellChangeTimes->{{3.8751872732977448`*^9, 3.875187304627364*^9}, {
  3.875187361149988*^9, 
  3.875187411559456*^9}},ExpressionUUID->"f2927e3c-a679-43ce-8f42-\
57278ecf6ff1"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"det", "(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"\[Lambda]", "-", 
        SubscriptBox["d", "11"]}], "0", "\[CenterEllipsis]", "0"},
      {"0", 
       RowBox[{"\[Lambda]", "-", 
        SubscriptBox["d", "22"]}], " ", "\[VerticalEllipsis]"},
      {"\[VerticalEllipsis]", " ", "\[Continuation]", "0"},
      {"0", "\[CenterEllipsis]", "0", 
       RowBox[{"\[Lambda]", "-", 
        SubscriptBox["d", 
         RowBox[{"n", "\[VeryThinSpace]", "n"}]]}]}
     }], "\[NoBreak]", ")"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "-", 
       SubscriptBox["d", "11"]}], ")"}], "..."}], 
    RowBox[{"(", 
     RowBox[{"\[Lambda]", "-", 
      SubscriptBox["d", "nn"]}], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"e13e8832-307f-4011-849e-51925b5f6163"]], \
"Text",
 CellChangeTimes->{{3.8751874172709236`*^9, 
  3.8751874351257324`*^9}},ExpressionUUID->"25abde4c-7cb7-49ef-b6bc-\
664964addeb2"]
}, Open  ]],

