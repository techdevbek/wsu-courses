Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "If ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "bb50dd31-fa89-4c4a-8330-0bf4ae7ad625"],
 " has ",
 Cell[BoxData[
  FormBox[
   RowBox[{"dim", "(", "V", ")"}], TraditionalForm]],ExpressionUUID->
  "c7e0d7c3-c2a5-4d0b-8f73-3cd87e151fc4"],
 " distinct eigenvalues, then ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "469fe092-aaad-47c0-8263-092c2029b14a"],
 " is diagonalizable.  "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
