   3.62280824673111*^9, 3.6228082605599356`*^9}, {3.6228084146190205`*^9, 
   3.6228084146190205`*^9}, 3.6228085539385853`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9084a5b1-0577-4b83-8fde-b15036dc4edf"],

Cell[TextData[{
 "REMARK: ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fec1ed9d-a0e2-4b93-8942-60bde63488cc"],
 " having ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Dim", 
     RowBox[{"(", "V", ")"}]}], "=", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b6d783fe-9d54-4f56-8e6c-2c0918bbd6ac"],
 " distinct eigenvalues is sufficient, but not necessary for ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c3125c34-5f42-4dca-9926-38fa630cf7fd"],
 " to be diagonalizable."
}], "Text",
 CellChangeTimes->{{3.907251703435547*^9, 
  3.9072517661484427`*^9}},ExpressionUUID->"bcae44d7-946c-4433-b8c4-\
2b14898e9427"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Examples",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 ":  "
}], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.622807300496413*^9}, {
   3.622807337279559*^9, 3.6228074369440107`*^9}, {3.6228084344637756`*^9, 
   3.622808536875219*^9}, {3.6228109875786505`*^9, 3.622810988547448*^9}, {
   3.622811189090134*^9, 3.622811217405246*^9}, 3.8437257562113447`*^9, 
   3.9068146678369317`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"9a026657-6529-49a7-b560-3ce61f196978"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "0"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "d9869f50-7bf1-45f2-a770-18549d4b357f"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"A", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"058a03c7-3490-4ad6-9783-852beadd338f"],
 " is diagonalizable over any ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalF]", TraditionalForm]],ExpressionUUID->
  "91eda2b3-e683-48d2-8c26-bc941fd48a8a"],
 " even though it does not have distinct roots."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.622807300496413*^9}, {
   3.622807337279559*^9, 3.6228074369440107`*^9}, {3.6228084344637756`*^9, 
   3.622808536875219*^9}, {3.6228109875786505`*^9, 3.622810988547448*^9}, {
   3.622811189090134*^9, 3.622811217405246*^9}, {3.843725808772664*^9, 
   3.843725812825336*^9}, {3.906814673254079*^9, 3.9068146880177855`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ad594e7d-26dd-4aea-b8a6-3bae17f22ed0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"c397cbbd-a743-4618-bbfd-9c9a0bb6bd84"],

Cell[TextData[{
 "However if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "1"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "7ca3ae8b-b3e4-4390-af99-d36668d5fbd8"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"B", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"9e7bdae9-9650-400a-bd68-a44c73e0fd84"],
 " is not diagonalizable over \[DoubleStruckCapitalR] or ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalC]", TraditionalForm]],ExpressionUUID->
  "b42e38ca-96e0-4bb1-bead-b108ec86e6c6"],
 " or any other ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalF]", "."}], TraditionalForm]],ExpressionUUID->
  "5a1211d9-c0a1-4bee-9091-f3d5675af7c5"],
 " "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.622807300496413*^9}, {
   3.622807337279559*^9, 3.6228074369440107`*^9}, {3.6228084344637756`*^9, 
   3.622808536875219*^9}, {3.6228109875786505`*^9, 3.622810988547448*^9}, {
   3.622811189090134*^9, 3.622811217405246*^9}, {3.843725808772664*^9, 
   3.843725830189576*^9}, {3.906814699651571*^9, 3.9068147166981916`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c5028926-7b8b-485e-9c6b-647897d3bf0d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"c68b7ef3-5e42-418a-aa13-0b5fc5fb71b2"],

Cell[TextData[{
 "Notice if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"C", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0", 
        RowBox[{"-", "1"}]},
       {"1", "0"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "dd4a6a81-889b-4048-8b90-64017ee164a1"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"C", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"2c8f2100-8378-4ebe-a23d-3067127904c0"],
 " is not diagonalizable over \[DoubleStruckCapitalR], but is diagonalizable \
over \[DoubleStruckCapitalC]. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Det", "(", 
     RowBox[{"C", "-", 
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[Lambda]", "2"], "+", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "42f72a7d-3d97-4795-93cc-47c61028dc94"],
 ", which has NO real roots, but roots ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "i"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "300b0c7d-9ded-47e7-b489-02b993747644"],
 " in ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalC]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dba935d7-7c1f-4e51-9aa8-0dd722485352"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.622807300496413*^9}, {
   3.622807337279559*^9, 3.6228074369440107`*^9}, {3.6228084344637756`*^9, 
