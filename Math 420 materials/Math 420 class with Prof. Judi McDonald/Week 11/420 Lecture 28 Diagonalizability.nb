99d1a2631f49"],

Cell[TextData[{
 "The vectors in this solution are the basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "\[Lambda]"], "."}], TraditionalForm]],ExpressionUUID->
