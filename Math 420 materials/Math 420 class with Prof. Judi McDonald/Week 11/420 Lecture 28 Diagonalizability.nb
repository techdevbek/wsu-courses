Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6234136980152283`*^9, 3.62341375078366*^9}, 
   3.623585014787781*^9, 3.8437267533224306`*^9, {3.9074114667560744`*^9, 
   3.9074114723721237`*^9}},
 FontSize->12,ExpressionUUID->"9ca1903e-6999-4314-bfb2-3df5e2af1298"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["W", "1"], ",", " ", 
    SubscriptBox["W", "2"], ",", " ", "...", " ", ",", " ", 
    SubscriptBox["W", "k"]}], TraditionalForm]],ExpressionUUID->
  "94a6139e-3267-4374-a81d-a6b33505f0f3"],
 " be subspaces of a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c15b85ff-d2a8-4425-bc0f-cca012ccde86"],
 ".  Then ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "38dd4df2-32a8-4382-8219-ff6b6e452568"],
 " is the direct sum of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["W", "1"], ",", " ", 
    SubscriptBox["W", "2"], ",", " ", "...", " ", ",", " ", 
    SubscriptBox["W", "k"]}], TraditionalForm]],ExpressionUUID->
  "269951e3-ed3e-4125-9031-3032ebd75327"],
 " provided "
}], "Text",
 CellChangeTimes->{{3.907411523976689*^9, 
  3.9074116297930155`*^9}},ExpressionUUID->"abc4ded2-80a3-4162-a14f-\
5d695a1cbaa3"],

Cell[TextData[{
 "(a) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["W", "1"], "+", 
       SubscriptBox["W", "2"], "+"}], "..."}], "+", 
     SubscriptBox["W", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "e3cc2d51-a510-4950-8ebb-6ed338179029"]
}], "Text",
 CellChangeTimes->{{3.9074116368396387`*^9, 
  3.9074116732322674`*^9}},ExpressionUUID->"c23f0470-a404-43bd-9d9f-\
56525e903bb8"],

Cell["and", "Text",
 CellChangeTimes->{{3.9074117525682073`*^9, 
  3.907411752824218*^9}},ExpressionUUID->"56cc8adb-d596-49b9-9267-\
9c63011f3c55"],

Cell[TextData[{
 "(b) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["W", "j"], "\[Intersection]", 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{" ", 
        RowBox[{"i", "\[NotEqual]", "j"}]}]], 
      SubscriptBox["W", "i"]}]}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],ExpressionUUID->
  "faff8984-a505-4ba3-8528-10d382d58c20"]
}], "Text",
 CellChangeTimes->{{3.907411768079488*^9, 3.907411770843318*^9}, {
  3.90785532451362*^9, 
  3.907855330360203*^9}},ExpressionUUID->"d8c634de-0244-421c-b873-\
0e97a55d2002"],

Cell[TextData[{
 "We write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["W", "1"], "\[CirclePlus]", 
       SubscriptBox["W", "2"], "\[CirclePlus]"}], "..."}], "\[CirclePlus]", 
     SubscriptBox["W", "k"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e197768f-3bc2-4116-a1e2-a009b7589fbe"]
}], "Text",
 CellChangeTimes->{{3.907855315569133*^9, 
  3.907855387605991*^9}},ExpressionUUID->"7ecfc71b-04a9-4da8-a011-\
3c6c41b64482"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Question:",
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontSlant->"Italic"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.907411799399165*^9, 
  3.907411811030877*^9}},ExpressionUUID->"5db2b398-f656-4260-a55e-\
d087a6c10a76"],

Cell[TextData[{
 "How do direct sums and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "baf202f6-32b9-4ea7-b0aa-ff4fd545d412"],
 "-invariant subspaces help us?  We can chop big problems into smaller ones :)"
}], "Text",
 CellChangeTimes->{{3.9074118188685856`*^9, 3.907411859601396*^9}, {
  3.907855619181517*^9, 
  3.907855633969073*^9}},ExpressionUUID->"3f5a4c05-bd0e-42c8-b719-\
f38b784391de"],

Cell[TextData[{
 "RECALL:  ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d110575c-e2d6-4d99-808a-c77d70533403"],
 " is ",
 StyleBox["T",
  FontSlant->"Italic"],
 "-invariant if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "w", ")"}], "\[Element]", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b0fd2d4d-f02a-4216-8d44-0141ec3a4859"],
 " for every ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c37bd5e2-20ba-4444-bd01-d59cbbbe2b8f"],
 "."
}], "Text",
 CellChangeTimes->{{3.9078555081024218`*^9, 
  3.907855536859538*^9}},ExpressionUUID->"76277184-bfcb-4413-bf25-\
ea39a80fe2ab"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Notation:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6234136980152283`*^9, 3.62341375078366*^9}, 
   3.623585014787781*^9, 3.8437267533224306`*^9, {3.9074112471372404`*^9, 
   3.9074112501908045`*^9}},
 FontSize->12,ExpressionUUID->"25c60b0e-d2ae-4525-b07d-13679f283ed5"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Sigma]", "(", "T", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Lambda]", "\[Element]", "\[DoubleStruckCapitalF]"}], "|", 
      RowBox[{
      "\[Lambda]", " ", "is", " ", "an", " ", "eigenvalue", " ", "of", " ", 
       "T"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "1ef8422e-48b4-4e7b-a547-daaf067f2886"]
}], "Text",
 CellChangeTimes->{{3.9074111983149815`*^9, 
  3.907411233106784*^9}},ExpressionUUID->"3f56a647-6a01-4d9d-aa25-\
9042a883222c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6234136980152283`*^9, 3.62341375078366*^9}, 
   3.623585014787781*^9, 3.8437267533224306`*^9},
 FontSize->12,ExpressionUUID->"11de0c63-283f-49a9-9f42-7274f01fbeda"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "dcfa6d7a-9710-488a-9b90-6c1ebc27a553"],
 " is diagonalizable if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", 
      RowBox[{"\[Lambda]", "\[Element]", 
       RowBox[{"\[Sigma]", "(", "T", ")"}]}]], 
     SubscriptBox["E", "\[Lambda]"]}]}], TraditionalForm]],ExpressionUUID->
  "1e90cda4-ba2c-4104-995c-2672a8cae3a1"],
 "."
}], "Text",
 CellChangeTimes->{{3.6234136980152283`*^9, 3.62341375078366*^9}, 
   3.623585014787781*^9, {3.907411107267347*^9, 3.907411190729457*^9}, {
   3.907411256618286*^9, 
   3.9074114519597893`*^9}},ExpressionUUID->"ddbbb21c-7e8f-4a20-9772-\
7fbe3e5fe029"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.623589343266079*^9, 3.623589347485035*^9}, {
  3.6235893997648935`*^9, 3.6235893997648935`*^9}},
 FontSize->12,ExpressionUUID->"9a1fc0fb-40cc-4a13-9413-38123061e9aa"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7e308792-8f2c-46d7-bd49-b6f7d105db33"],
 " is an eigenvector with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", " ", "and", " ", "\[Lambda]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6c625a0d-fde5-4698-971d-56b48be57236"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}], "=", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], "=", 
     RowBox[{"\[Mu]", "\[VeryThinSpace]", "x"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f14b7804-ce82-4293-a43c-00c913d0d44a"],
 ", which means that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "-", "\[Mu]"}], ")"}], "x"}], "=", "0"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a660f2d6-65e3-48f0-8f5e-fa63533a2aed"],
 ".  Since ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "328ca396-9922-41f7-898c-62453edd8919"],
 " is an eigenvector it is nonzero, forcing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", "\[Mu]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e368d978-2a86-44e8-b935-6bf6d84448b5"],
 ". However this is not enough to show it is a direct sum.  "
}], "Text",
 CellChangeTimes->{{3.907855732924877*^9, 
  3.9078558810118465`*^9}},ExpressionUUID->"1b2c147a-7db3-4cb8-9a41-\
cae7922b914e"],

Cell[TextData[{
 "However, from a previous lemma, we know that if ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "75aa6321-5b58-4067-ad41-a0ab0d64cc4a"],
 " is diagonalizable, it has a basis of eigenvectors.  This basis can be \
partitioned into bases for the individual eigenspaces.  Pick out an \
eigenspace.  The remaining eigenspaces are spanned by the remaining vectors \
from our bases of eigenvectors.  By uniqueness of representation of a vector \
in terms of a basis, only the zero vector can be in the intersection. "
}], "Text",
 CellChangeTimes->{{3.9078558912826424`*^9, 
  3.907856005392744*^9}},ExpressionUUID->"eb749aaa-cd79-454d-a2d1-\
d01941e8f1af"],

Cell[TextData[{
 "Conversely, if a direct sum of the eigenspaces covers all of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f67439cc-f80a-4a0d-9fc5-6db99f07ac91"],
 ", then there must be a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "082ff669-2dea-43e0-a8df-b3845afc4aac"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f3026e53-8c76-4a7b-bc1d-af15150b6f0c"],
 " and hence ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f876eea0-daf3-47bf-b038-478cca4f132c"],
 " is diagonalizable."
}], "Text",
