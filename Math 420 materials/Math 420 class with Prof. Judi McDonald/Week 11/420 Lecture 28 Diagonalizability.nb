Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "c6f56fc2-9590-427e-bd6e-025ef4ccda59"],
 " is a linear operator on a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "87753c49-c483-4e1f-af5a-0702d5a8f652"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", 
    RowBox[{"(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6aa3f886-0856-4f3a-9696-eb100301e437"],
 " is a polynomial, then we can make a new linear operator by finding ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "(", "T", ")"}], "."}], TraditionalForm]],ExpressionUUID->
  "802cabb1-6ab7-420f-9dbf-c32557274cdc"],
 "  "
}], "Text",
