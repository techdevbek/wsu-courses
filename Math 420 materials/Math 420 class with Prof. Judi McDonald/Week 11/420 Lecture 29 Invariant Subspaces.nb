   RowBox[{"v", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "375ced88-8aca-49fe-ba06-1f84406b1dc7"],
 "  Consider the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "-", 
    RowBox[{"cyclic", " ", "subspace", " ", "generated", " ", "by", " ", 
     RowBox[{"v", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "aa6f8526-3dab-491f-b349-7b01c3f791fa"],
 "  Call it ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "."}], TraditionalForm]],ExpressionUUID->
  "5da234df-e61d-426d-8692-c173574c25e9"]
}], "Text",
