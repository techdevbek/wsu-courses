 FontFamily->
  "Times New Roman",ExpressionUUID->"a0ee8933-9bed-4487-a8da-4db655f941a8"],

Cell[TextData[{
 "This process works for every ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "c5835347-7527-4453-86e6-d7c76644096a"],
 " establishing the result.  Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"p", "(", "T", ")"}], 
     RowBox[{"(", "v", ")"}]}], "=", "0", " "}], TraditionalForm]],
  ExpressionUUID->"993fae14-3def-484f-b7e0-b61ca2f874fe"],
 " for every ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "92ef7150-1cbe-4f63-b915-f26b2fbad905"],
 ", it must be that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "db18ad2a-c3e8-4c8e-abdb-2143229c67ce"],
 " is the zero transformation."
}], "Text",
 CellChangeTimes->{{3.6237584372435007`*^9, 3.62375852570215*^9}, {
