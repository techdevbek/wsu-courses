Cell[TextData[{
 "Then [",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"T", "]"}], "\[Beta]"], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
