Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"Det", "(", 
      RowBox[{
       RowBox[{"t", " ", "I"}], "-", "A"}], ")"}], "Det", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"t", " ", "I"}], " ", "-", " ", "B"}], ")"}]}], "=", Cell[
    TextData[{
     Cell[BoxData[
      FormBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             SubscriptBox["a", "0"], "+", 
             RowBox[{
              SubscriptBox["a", "1"], "t"}], "+"}], "..."}], ".", 
           RowBox[{"+", 
            SubscriptBox["a", 
             RowBox[{"k", "-", "1"}]]}]}], 
