 "NOTATION: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", 
    SubscriptBox["|", "W"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0044d7f1-4ad0-4c96-8ab7-7323008817b4"],
 "  is the linear transformation ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "edf6e61e-a49a-41b3-a84a-4c9d2ee27726"],
