Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f29fa6ed-e96b-44be-a10a-b47efb63f406"],
 " be a ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "8f7058e3-f4e1-4053-8cb2-e2ac49d037da"],
 "-invariant subspace of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "7296378e-8e09-40fd-8a02-77bd866e33fb"],
 "  Then the characteristic polynomial of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", 
    SubscriptBox["|", "W"]}], TraditionalForm]],ExpressionUUID->
  "1c21df4c-db31-4819-bab8-4de2b173b053"],
 " divides the characteristic polynomial of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "30394d9c-6570-46c9-a018-1cdd9c5ff60f"]
}], "Text",
 CellGroupingRules->{"GroupTogetherGrouping", 10001.},
