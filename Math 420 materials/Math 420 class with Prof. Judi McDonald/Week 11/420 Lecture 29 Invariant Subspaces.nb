Cell["\<\
Note: Because it is the span of a set of vectors, it is indeed a subspace.\
\>", "Text",
 CellChangeTimes->{{3.908028994433687*^9, 
  3.9080290107971497`*^9}},ExpressionUUID->"ea05d25c-a54a-4a20-896d-\
fb5a0cc765d0"],

