 FontFamily->
  "Times New Roman",ExpressionUUID->"8dc23e08-f32c-4482-86c6-3274ca7d949c"],

Cell[TextData[{
 "Let \[Alpha] be the basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
