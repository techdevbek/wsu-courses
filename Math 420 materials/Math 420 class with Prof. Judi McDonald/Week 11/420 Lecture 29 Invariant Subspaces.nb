Cell[TextData[{
 "From your homework, you know that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      RowBox[{"...", 
       SubscriptBox["x", "m"]}], ",", 
      SubscriptBox["x", 
       RowBox[{"m", "+", "1"}]], ",", " ", 
      RowBox[{"...", 
       SubscriptBox["x", "n"]}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "225631d9-a6a1-40dc-a356-b12a089a7030"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", "...", ",", 
      SubscriptBox["x", "m"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "1966fd89-d92d-494a-8f66-61c2f7a84075"],
 " is a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "bbe531a7-6f70-465e-bb5f-74b8bad2a83d"],
 " that has been extended to a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "cb13062a-3d11-463a-9de4-dad605610279"],
 ", then"
}], "Text",
 CellChangeTimes->{{3.87622163254494*^9, 3.8762217245352683`*^9}, {
  3.8762218602006016`*^9, 
  3.876221861335533*^9}},ExpressionUUID->"3d382bc1-9e7f-4292-bb05-\
e7cc9356439b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Beta]"], "=", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"A", "B"},
        {"0", "C"}
       }], "\[NoBreak]", ")"}]}], ","}], TraditionalForm]],ExpressionUUID->
  "f8f26510-7b61-4508-a319-35414702c375"],
 " where ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "58681475-e574-46f4-ac37-e89238c3b85e"],
 " and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "30652564-e37f-47f9-a586-71c71e97a307"],
 " are square matrices.  Then "
}], "Text",
 CellChangeTimes->{{3.87622163254494*^9, 
  3.8762218197838726`*^9}},ExpressionUUID->"93a3636a-1fd8-465c-aeed-\
da79143865d2"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"det", "(", 
    RowBox[{
     RowBox[{"t", "\[VeryThinSpace]", "I"}], "-", 
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Beta]"]}], ")"}], "=", 
   RowBox[{
    RowBox[{"det", "(", 
     RowBox[{
      RowBox[{"t", "\[VeryThinSpace]", "I"}], "-", "A"}], ")"}], 
    RowBox[{"det", "(", 
     RowBox[{
      RowBox[{"t", "\[VeryThinSpace]", "I"}], "-", "C"}], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"63c8f52e-d7df-4ac4-bf03-6b8cf2c6e498"]], \
"Text",
 CellChangeTimes->{{3.87622163254494*^9, 
  3.8762218157958536`*^9}},ExpressionUUID->"2519fe54-e983-4693-b054-\
8ca52896cebc"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", "(", 
     RowBox[{
      RowBox[{"t", "\[VeryThinSpace]", "I"}], "-", 
      SubscriptBox[
       RowBox[{"[", 
        RowBox[{"T", 
         SubscriptBox["|", "W"]}], "]"}], "\[Alpha]"]}], ")"}], "=", 
    RowBox[{"det", "(", 
     RowBox[{
      RowBox[{"t", "\[VeryThinSpace]", "I"}], "-", "A"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"e49ab74f-ff10-4576-af26-ff4f28d8edd9"]
}], "Text",
 CellChangeTimes->{{3.8762218239073877`*^9, 
  3.876221889928991*^9}},ExpressionUUID->"8846a0d8-957d-4ba1-bccd-\
9c15aed69834"],

Cell["Establishing the result.", "Text",
 CellChangeTimes->{{3.8762218239073877`*^9, 
  3.8762219059607086`*^9}},ExpressionUUID->"b5e9f5db-19a3-48cc-a2e9-\
77adc3aa4f7b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ", "Subsubsubsection",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578504751034`*^9}, {
   3.6237580074043837`*^9, 3.623758016811137*^9}, {3.6237581477486897`*^9, 
   3.6237581577234907`*^9}, 3.84429455707234*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"670f189a-8dff-4d75-8199-1147e7a22cd2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "25494317-b709-4e98-b02d-ccb160f996cf"],
 " be a nonzero vector.  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"v", ",", 
       RowBox[{"T", "(", "v", ")"}], ",", " ", 
       RowBox[{
        SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "..."}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"67e70f55-35fa-4661-b79e-224b3a8afdfd"],
 " be the ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "88a4f2ee-b3c5-4a9e-bd81-902d3d2c9bbc"],
 "-cyclic subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "0ddbc9e4-09fe-4156-ab47-527a83b15e2b"],
 " generated by ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "3ee51395-7a74-4fd0-a4eb-b7d0e644ec58"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", 
    RowBox[{"dim", " ", 
     RowBox[{"W", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "3db862ee-4768-4cf5-836c-32c4a0191b99"],
 "  Then"
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578504751034`*^9}, {
  3.6237580074043837`*^9, 3.623758016811137*^9}, {3.6237581477486897`*^9, 
  3.6237581577234907`*^9}, {3.844956391306241*^9, 3.8449563929497256`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"cb6c6bdc-5a98-4b78-bc05-11897b15ac6b"],

Cell[TextData[{
 "(a) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", " ", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
     RowBox[{
      SuperscriptBox["T", 
       RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"ba65bfeb-a5cb-4bba-b6fd-d86ca70c86a9"],
 " is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "."}], TraditionalForm]],ExpressionUUID->
  "8b4ac3dd-ecec-4518-a682-d2013cef4c95"]
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578944350853`*^9}, {
  3.623758023475793*^9, 3.62375803612772*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5c567dcc-1dd1-4c9a-bccb-dcc714bae18c"],

Cell[TextData[{
 "(b) If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"0", " "}]], 
         RowBox[{
          SuperscriptBox["T", "0"], "(", "v", ")"}]}], "+", 
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"1", " "}]], 
         RowBox[{"T", "(", "v", ")"}]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"k", "-", "1"}]], 
       RowBox[{
        SuperscriptBox["T", 
         RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "+", 
      RowBox[{
       SuperscriptBox["T", "k"], "(", "v", ")"}]}], "=", "0"}], ","}], 
   TraditionalForm]],ExpressionUUID->"aec219aa-b5da-4737-859e-2083c4fd36ba"],
 " then the characteristic polynomial of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", 
    SubscriptBox["|", "W"]}], TraditionalForm]],ExpressionUUID->
  "25827790-e591-4e21-a0a5-59923b20876d"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"0", " "}]], "+", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"1", " "}]], "t"}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], 
      SuperscriptBox["t", 
       RowBox[{"k", "-", "1"}]]}], "+", 
     SuperscriptBox["t", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "045dea19-7a0b-454c-85b5-3a9f3aa1b3bf"]
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237580007946997`*^9}, {
  3.623758040940431*^9, 3.6237581332223816`*^9}, {3.623760945025549*^9, 
  3.623760945025549*^9}, {3.6237614171900997`*^9, 3.6237614171900997`*^9}, {
  3.844956525654223*^9, 3.8449565364657593`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9c204798-6122-434e-b2eb-92dbbe4cc08f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Proof: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.623758173202615*^9, 3.6237581821874456`*^9}, {
  3.8757871179951105`*^9, 3.875787119420252*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"27e02a68-6152-4568-8441-1960d62310f0"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"Let", " ", Cell[TextData[Cell[BoxData[
     FormBox[
      RowBox[{
       SubscriptBox["\[Beta]", "j"], "="}], TraditionalForm]],ExpressionUUID->
     "0ba60a12-b3c7-4b50-b4f7-3f6bdbd8e4f6"]],ExpressionUUID->
     "0f38374d-7b66-4fad-9275-3f7b726dbde8"], 
    RowBox[{"{", 
     RowBox[{"v", ",", 
      RowBox[{"T", "(", "v", ")"}], ",", " ", 
      RowBox[{
       SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
      RowBox[{
       SuperscriptBox["T", "j"], "(", "v", ")"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"825c43a4-d31e-4bff-baa2-9db7558c51f7"],
 "."
}], "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.9080159871761074`*^9}},ExpressionUUID->"16245a65-6913-4818-a5d6-\
fb5fa8a4f24c"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"f78af054-80fc-4f98-84d1-\
f50005891d12"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Beta]", "0"], "=", 
    RowBox[{"{", "v", "}"}]}], TraditionalForm]],ExpressionUUID->
  "f9ad1c17-1d65-4973-9a08-3dff0048b91c"],
 " is independent since it consists of one nonzero vector."
}], "Text",
 CellChangeTimes->{{3.6237582501143713`*^9, 3.623758282585687*^9}, {
  3.6237607582959833`*^9, 3.623760758561628*^9}, {3.6237611137829638`*^9, 
  3.623761135487181*^9}, {3.8762222209274163`*^9, 3.8762222248069572`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"55a91ba1-e640-4b94-9137-7319e2eb1429"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"ac34b303-b311-46dd-9aac-\
4729f8fb5465"],

Cell[TextData[{
 "Certainly ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "n"], TraditionalForm]],ExpressionUUID->
  "c5603555-f3e7-4856-8cc2-cfccd671b3b5"],
 " is linearly dependent, since it has ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "fa907c1d-babf-48c2-84c2-85c994fcd294"],
 " vectors in ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "35fdebf2-0df5-4dba-82a8-dbcf21015cb7"],
 " where dim ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", "n"}], TraditionalForm]],ExpressionUUID->
  "418c38c9-46ab-4fd9-afce-f865e589f3fb"],
 ".  So somewhere in between it switches for the first time from independent \
to dependent.  Choose ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "292254e4-cfba-4463-b6f8-621432e97721"],
 " so that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "k"], TraditionalForm]],ExpressionUUID->
  "81e970ba-2cf5-416f-a031-73974078f94d"],
 " is linearly dependent, but ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "ce9b9fec-84d9-4763-b6f4-18b7b800e434"],
 " is linearly independent. "
}], "Text",
 CellChangeTimes->{{3.8762222412865114`*^9, 
  3.8762224346845846`*^9}},ExpressionUUID->"30771823-6714-4b30-a1c1-\
285c0e1e783c"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"549d99e5-7271-40e3-badf-\
097a4caef01f"],

Cell[TextData[{
 "We know ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", " ", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
     RowBox[{
      SuperscriptBox["T", 
       RowBox[{"k", "-", "1"}]], "(", "v", ")"}], ",", 
     RowBox[{
      SuperscriptBox["T", "k"], "(", "v", ")"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"f05abcf7-6b19-48ca-b105-3c15dd605f85"],
 " is a linearly dependent set, so there exists scalars, not all zero, so \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "0"], "v"}], "+", 
        RowBox[{
         SubscriptBox["a", "1"], 
         RowBox[{"T", "(", "v", ")"}]}], "+", 
        RowBox[{
         SubscriptBox["a", "2"], " ", 
         RowBox[{
          SuperscriptBox["T", "2"], "(", "v", ")"}]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"k", "-", "1"}]], 
       RowBox[{
        SuperscriptBox["T", 
         RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "+", 
      RowBox[{
       SubscriptBox["a", "k"], 
       RowBox[{
        SuperscriptBox["T", "k"], "(", "v", ")"}]}]}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"95eaf0b8-4476-4099-a4b7-d01bf24e7837"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "8c7ea902-139b-456e-a000-8efbcca6d72b"],
 " is linearly independent, it must be the case that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], "\[NotEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"2da0eee9-2d29-495c-b277-7353fe411ccd"],
 ".  WLOG we assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "4a3c7bb6-2050-46a8-ae64-15af2b6c056f"],
 "."
}], "Text",
 CellChangeTimes->{{3.8762222412865114`*^9, 
  3.876222607706279*^9}},ExpressionUUID->"e8da2332-681a-496f-b43a-\
1719628368ff"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"1b821c43-ba36-458f-8f28-\
30f63f297615"],

Cell[TextData[{
 "Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox["a", "0"]}], "v"}], "-", 
       RowBox[{
        SubscriptBox["a", "1"], 
        RowBox[{"T", "(", "v", ")"}]}], "-", 
       RowBox[{
        SubscriptBox["a", "2"], " ", 
        RowBox[{
         SuperscriptBox["T", "2"], "(", "v", ")"}]}], "-"}], "..."}], "-", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], 
      RowBox[{
       SuperscriptBox["T", 
        RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}]}], "=", 
    RowBox[{
     SuperscriptBox["T", "k"], "(", "v", ")"}]}], TraditionalForm]],
  ExpressionUUID->"696ef0cb-56b2-4f7c-aab6-b82dd06fafb2"],
 " "
}], "Text",
 CellChangeTimes->{{3.876222721860444*^9, 
  3.876222766686369*^9}},ExpressionUUID->"b6e13c8b-b81b-40a2-b6a6-\
44252d29a151"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"a2780b63-ee1c-4f28-bee8-\
0ca5395a3561"],

Cell[TextData[{
 "So ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox["a", "0"]}], 
        RowBox[{"T", "(", "v", ")"}]}], "-", 
       RowBox[{
        SubscriptBox["a", "1"], 
        RowBox[{
         SuperscriptBox["T", "2"], "(", "v", ")"}]}], "-", 
       RowBox[{
        SubscriptBox["a", "2"], " ", 
        RowBox[{
         SuperscriptBox["T", "3"], "(", "v", ")"}]}], "-"}], "..."}], "-", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], 
      RowBox[{
       SuperscriptBox["T", "k"], "(", "v", ")"}]}]}], "=", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"k", "+", "1"}]], "(", "v", ")"}]}], TraditionalForm]],
  ExpressionUUID->"ec0fa50a-775f-441b-8a58-075c9fb72290"]
}], "Text",
 CellChangeTimes->{{3.8762228161146884`*^9, 
  3.8762228467690616`*^9}},ExpressionUUID->"89608d13-a9c8-40bb-91c6-\
125012b311c8"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"3c8d878d-cd88-45b6-86d0-\
0a33e5404f4e"],

Cell[TextData[{
 "and thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SubscriptBox["a", "0"]}], 
        RowBox[{"T", "(", "v", ")"}]}], "-", 
       RowBox[{
        SubscriptBox["a", "1"], 
        RowBox[{
         SuperscriptBox["T", "2"], "(", "v", ")"}]}], "-", 
       RowBox[{
        SubscriptBox["a", "2"], " ", 
        RowBox[{
         SuperscriptBox["T", "3"], "(", "v", ")"}]}], "-"}], "..."}], "-", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], "(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["a", "0"]}], "v"}], "-", 
         RowBox[{
          SubscriptBox["a", "1"], 
          RowBox[{"T", "(", "v", ")"}]}], "-", 
         RowBox[{
          SubscriptBox["a", "2"], " ", 
          RowBox[{
           SuperscriptBox["T", "2"], "(", "v", ")"}]}], "-"}], "..."}], "-", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"k", "-", "1"}]], 
        RowBox[{
         SuperscriptBox["T", 
          RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}]}], ")"}]}], "=", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"k", "+", "1"}]], "(", "v", ")"}]}], TraditionalForm]],
  ExpressionUUID->"c7a0dcb6-d40f-40f4-b01d-2ab4866ed3cb"]
}], "Text",
 CellChangeTimes->{{3.8762228628140182`*^9, 
  3.8762228935773335`*^9}},ExpressionUUID->"92d502be-6353-4288-ac23-\
62314ff12a8c"],

Cell["", "Text",
 CellChangeTimes->{{3.9080159784722*^9, 
  3.908015986618094*^9}},ExpressionUUID->"bc62f931-ce63-40a7-a78c-\
bef35308cbc9"],

Cell[TextData[{
 "and so on. We can show using induction that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "a4d8f063-61bb-4d34-b6ca-d3ffe2b25b8c"],
 " spans ",
 StyleBox["W",
  FontSlant->"Italic"],
 ". Thus ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "db478947-7383-4d1b-9ffd-1aaeb6eb75f6"],
 " is a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "e37d1c42-5833-4a4f-ac86-4614e30bd335"],
 " is ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "f9a9905f-d365-4d20-9ac0-0d2ddbfd1180"],
 " elements. "
}], "Text",
 CellChangeTimes->{{3.8762228979792643`*^9, 3.876222991659444*^9}, 
   3.9080168698413258`*^9},ExpressionUUID->"f91a0e39-04fd-43a6-90c2-\
2358f129350b"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   RowBox[{"v", ",", 
    RowBox[{"T", "(", "v", ")"}], ",", " ", 
    RowBox[{
     SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "}"}], 
  TraditionalForm]],ExpressionUUID->"a6322033-ca2d-49fc-abce-8fe57029e261"]], \
"Text",
 CellChangeTimes->{{3.87622312082347*^9, 
  3.8762231253763924`*^9}},ExpressionUUID->"a399b897-9676-473a-b0a3-\
e08a1745c720"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"[", 
     RowBox[{"T", 
      SubscriptBox["|", "W"]}], "]"}], 
    SubscriptBox["\[Beta]", 
     RowBox[{"k", "-", "1"}]]], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"0", "0", "\[CenterEllipsis]", "0", 
       RowBox[{"-", 
        SubscriptBox["a", "0"]}]},
      {"1", "0", "\[DescendingEllipsis]", "\[VerticalEllipsis]", 
       RowBox[{"-", 
        SubscriptBox["a", "1"]}]},
      {"0", "1", "\[DescendingEllipsis]", "0", "\[VerticalEllipsis]"},
      {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
       "\[DescendingEllipsis]", "0", 
       RowBox[{"-", 
        SubscriptBox["a", 
         RowBox[{"k", "-", "2"}]]}]},
      {"0", "\[CenterEllipsis]", "0", "1", 
       RowBox[{"-", 
        SubscriptBox["a", 
