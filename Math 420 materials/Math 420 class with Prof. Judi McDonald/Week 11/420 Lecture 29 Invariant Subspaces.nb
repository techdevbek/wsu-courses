           RowBox[{"k", "-", "1"}]]}], "+", 
         SuperscriptBox["t", "k"]}]}], TraditionalForm]],ExpressionUUID->
      "b5bd9477-c53d-41b1-9313-d0a154ec506e"],
     ")(",
     Cell[BoxData[
