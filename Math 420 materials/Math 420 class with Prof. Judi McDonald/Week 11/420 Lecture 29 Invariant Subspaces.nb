Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
   "T", " ", "is", " ", "a", " ", "linear", " ", "operator", " ", "on", " ", 
    "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "54b1e864-886b-43c4-be28-4a95f5ce7a44"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "e37ac9a0-5f39-4e4e-9ef9-4206ef9c5d34"],
 "  Then the subspace ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"T", "(", "x", ")"}], ",", " ", 
       RowBox[{
        SuperscriptBox["T", "2"], "(", "x", ")"}], ",", "..."}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"d44464f1-2288-4032-8dcc-ec75916b4e56"],
 " is referred to as the ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "c4337523-502c-428c-bddd-6fe4063da62b"],
 "-cyclic subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "6fe6cd08-4987-4598-8c1e-14c6d58167b5"],
 " generated by ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "b0543089-d764-4cc6-aa8a-e422e4eb680e"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
