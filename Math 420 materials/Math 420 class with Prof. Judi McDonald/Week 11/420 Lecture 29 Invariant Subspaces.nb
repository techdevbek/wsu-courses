Cell[TextData[{
 "Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"p", "(", "T", ")"}], 
     RowBox[{"(", "v", ")"}]}], "="}], TraditionalForm]],ExpressionUUID->
  "a9f8dfb5-2636-4371-9c7d-87156d295893"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"g", "(", "T", ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", 
           RowBox[{"0", " "}]], "v"}], "+", 
         RowBox[{
          SubscriptBox["a", 
           RowBox[{"1", " "}]], 
          RowBox[{"T", "(", "v", ")"}]}], "+"}], "..."}], "+", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"k", "-", "1"}]], 
        RowBox[{
         SuperscriptBox["T", 
          RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "+", 
       RowBox[{
        SuperscriptBox["T", "k"], "(", "v", ")"}]}], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"g", "(", "T", ")"}], 
      RowBox[{"(", "0", ")"}]}], "=", "0."}]}], TraditionalForm]],
  ExpressionUUID->"8f4bff4d-a6f9-40f4-80fd-64ba566d1f8f"]
}], "Text",
 CellChangeTimes->{{3.6237584372435007`*^9, 3.62375852570215*^9}, {
