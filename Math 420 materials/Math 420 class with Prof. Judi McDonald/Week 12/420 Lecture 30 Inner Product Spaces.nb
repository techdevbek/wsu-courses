Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"fcb673b4-4d45-4d81-9bf3-71f44377c9bf"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{"||", "x", 
     SuperscriptBox["||", "2"], 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"+", 
         RowBox[{"(", 
          RowBox[{"-", "c"}], ")"}]}], 
        OverscriptBox[
         RowBox[{
          RowBox[{"<", "x"}], ",", 
          RowBox[{"y", ">"}]}], "_"]}], "  ", "+", 
       RowBox[{"(", 
        OverscriptBox[
         RowBox[{"-", "c"}], "_"], ")"}]}], "<", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{"y", ">", 
     RowBox[{
      RowBox[{"+", 
       RowBox[{"(", 
        RowBox[{"-", "c"}], ")"}]}], 
      RowBox[{"(", 
       OverscriptBox[
        RowBox[{"-", "c"}], "_"], ")"}]}]}], "||", "y", 
    SuperscriptBox["||", "2"]}]}], 
  TraditionalForm]],ExpressionUUID->"82bb5d90-f66b-4b3a-87d3-a060882d2c5d"]], \
"Text",
 CellChangeTimes->{{3.8453772550168533`*^9, 3.84537725983611*^9}, {
  3.845377327320217*^9, 3.845377327699281*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f3f3443a-8bde-4243-a8c9-afe56fbee3b4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"110bc7b4-18b3-439d-afd6-a40e0442945a"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"=", 
   RowBox[{
    RowBox[{"||", "x", 
     SuperscriptBox["||", "2"], "+"}], "|", "c", 
    SuperscriptBox["|", "2"], 
    RowBox[{"||", "y", 
     SuperscriptBox["||", "2"], 
     RowBox[{
      RowBox[{"+", "2"}], 
      RowBox[{"Re", " ", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          OverscriptBox[
           RowBox[{"-", "c"}], "_"], ")"}], "<", "x"}], ",", 
        RowBox[{"y", ">"}]}], "]"}]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"26867b26-c16a-4cdc-8386-0a9fddf789ce"]], \
"Text",
 CellChangeTimes->{3.845377313936183*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c7703848-b978-4354-be82-6edf6e14176a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"baefc069-27a9-4726-8eec-5973471044ca"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{"||", "x", 
     SuperscriptBox["||", "2"], 
     RowBox[{"+", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"|", 
         RowBox[{"<", "x"}]}], ",", 
        RowBox[{
         RowBox[{"y", ">"}], 
         SuperscriptBox["|", "2"]}]}], 
       RowBox[{"||", "y", 
        SuperscriptBox["||", "4"]}]]}], "||", "y", 
     SuperscriptBox["||", "2"], 
     RowBox[{
      RowBox[{"+", "2"}], 
      RowBox[{"Re", "(", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{
          RowBox[{"|", 
           RowBox[{"<", "x"}]}], ",", 
          RowBox[{
           RowBox[{"y", ">"}], 
           SuperscriptBox["|", "2"]}]}], 
         RowBox[{"||", "y", 
          SuperscriptBox["||", "2"]}]]}], " ", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"dfc83b14-19bf-4de5-ba2f-0fcde7301804"],
 "   Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       RowBox[{"|", 
        RowBox[{"<", "x"}]}], ",", 
       RowBox[{
        RowBox[{"y", ">"}], 
        SuperscriptBox["|", "2"]}]}], 
      RowBox[{"||", "y", 
       SuperscriptBox["||", "2"]}]]}], " ", ")"}], TraditionalForm]],
  ExpressionUUID->"79422859-2c4e-46a0-9e41-589100e6784e"],
 " is already real, it is equal to its real part."
}], "Text",
 CellChangeTimes->{{3.8453772360521092`*^9, 3.8453772364382715`*^9}, {
  3.845565003603633*^9, 3.84556502206478*^9}, {3.845565146093556*^9, 
