Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ", "Subsubsubsection",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578504751034`*^9}, {
   3.6237580074043837`*^9, 3.623758016811137*^9}, {3.6237581477486897`*^9, 
   3.6237581577234907`*^9}, 3.84429455707234*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"7d7624df-06f4-464a-b317-87972765c4e6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "8797aa96-e2b9-429d-bef3-a5e22a6f4887"],
 " be a nonzero vector.  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"v", ",", 
       RowBox[{"T", "(", "v", ")"}], ",", " ", 
       RowBox[{
        SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "..."}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"87e8d26f-f07f-467e-9473-b35a4b000e68"],
 " be the ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "273fbaae-1c64-4217-85c0-0319ebe26ee8"],
 "-cyclic subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ad926f22-d44d-423c-b081-35c425c89747"],
 " generated by ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "dd845d53-8103-4d3d-bc46-4d2df2d1d54d"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", 
    RowBox[{"dim", " ", 
     RowBox[{"W", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "1445d1c0-c5d5-45c5-ae98-d316124112e2"],
 "  Then"
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578504751034`*^9}, {
  3.6237580074043837`*^9, 3.623758016811137*^9}, {3.6237581477486897`*^9, 
  3.6237581577234907`*^9}, {3.844956391306241*^9, 3.8449563929497256`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5e85b553-a2f4-4953-b05b-aca5fd9ea94b"],

Cell[TextData[{
 "(a) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", " ", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
     RowBox[{
      SuperscriptBox["T", 
       RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"377bd38e-e2bf-4ab7-97c2-820dfab0142b"],
 " is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "."}], TraditionalForm]],ExpressionUUID->
  "0afb209b-e469-417d-8d36-75aa42908981"]
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237578944350853`*^9}, {
  3.623758023475793*^9, 3.62375803612772*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"697ab88a-d18b-4622-bb6a-0df45b13ac69"],

Cell[TextData[{
 "(b) If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"0", " "}]], 
         RowBox[{
          SuperscriptBox["T", "0"], "(", "v", ")"}]}], "+", 
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"1", " "}]], 
         RowBox[{"T", "(", "v", ")"}]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"k", "-", "1"}]], 
       RowBox[{
        SuperscriptBox["T", 
         RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "+", 
      RowBox[{
       SuperscriptBox["T", "k"], "(", "v", ")"}]}], "=", "0"}], ","}], 
   TraditionalForm]],ExpressionUUID->"4126f7ed-4d68-4eaf-baa6-f294f3e0a656"],
 " then the characteristic polynomial of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", 
    SubscriptBox["|", "W"]}], TraditionalForm]],ExpressionUUID->
  "cb0b3bb0-b52a-4d27-98cc-c341e695ef1b"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"0", " "}]], "+", 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"1", " "}]], "t"}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", 
       RowBox[{"k", "-", "1"}]], 
      SuperscriptBox["t", 
       RowBox[{"k", "-", "1"}]]}], "+", 
     SuperscriptBox["t", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "c92489ad-e9be-4f8c-84b5-a55842e75bcf"]
}], "Text",
 CellChangeTimes->{{3.6237577927210712`*^9, 3.6237580007946997`*^9}, {
  3.623758040940431*^9, 3.6237581332223816`*^9}, {3.623760945025549*^9, 
  3.623760945025549*^9}, {3.6237614171900997`*^9, 3.6237614171900997`*^9}, {
  3.844956525654223*^9, 3.8449565364657593`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"eee9ce04-6c7b-4af6-87d9-710258fc9567"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Proof: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.623758173202615*^9, 3.6237581821874456`*^9}, {
  3.8757871179951105`*^9, 3.875787119420252*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b4876f9f-ec48-4b39-b490-3582a119d084"],

Cell[TextData[{
 "(a) Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c49184f5-49a7-43a4-8031-ad637cf3b8b7"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", " ", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
     RowBox[{
      SuperscriptBox["T", "j"], "(", "v", ")"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"57b5885c-a249-451f-9380-3be33b1727dd"],
 " .  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f716d23d-fe64-4ebc-9e37-7e061c3996aa"],
 ", then ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "0"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b3deef28-ec4a-4e49-8568-b01fa099a130"],
 " is linearly independent.  Choose the smallest ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ec440277-3044-4baf-958d-38289364d873"],
 " so that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "209d5a22-a140-4f03-8b30-19a304aebbd3"],
 " is linearly dependent.  Then there exist scalars, not all zero, so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "0"], "v"}], "+", 
       RowBox[{
        SubscriptBox["a", "1"], 
        RowBox[{"T", "(", "v", ")"}]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "j"], 
      RowBox[{
       SuperscriptBox["T", "j"], "(", "v", ")"}]}]}], "=", "0"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "755285df-adca-48b8-ab2a-d8991465f05e"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"j", "-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c528d9aa-7ad4-4b5f-bb18-56d52aa34ef9"],
 " is linearly independent, we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "j"], "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "77a29a2a-45f8-4e1b-b756-8fddf18af981"],
 ", so we can solve for  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", "j"], "(", "v", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "32400632-9574-45cf-ae81-9a5529fefa79"],
 ", makin it a linear combination of the vectors in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"j", "-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5ce3e21c-6838-4c19-bc85-a2b7c96be795"],
 ".  But then we can write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", 
     RowBox[{"j", "+", "i"}]], "(", "v", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19a27e7e-cd17-4790-97f3-b37d988a8376"],
 " in terms of the vectors in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"j", "-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7302a20c-b0db-43c6-92b3-c6a58a47cdf9"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"j", "-", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "46f472df-be5a-479a-9453-173700d10f6e"],
 " is a linearly independent spanning set and hence a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "40f11ee5-6baf-4efe-bd60-8897419ac380"],
 ".  In particular, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "=", "k"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e6a40702-5dcb-421e-a61c-647f1fcfc757"],
 "."
}], "Text",
 CellChangeTimes->{{3.9082903813910103`*^9, 
  3.9082908006867647`*^9}},ExpressionUUID->"a93fee2f-4df0-433a-8b20-\
82346996002d"],

Cell[" ", "Text",
 CellChangeTimes->{
  3.9082907170165143`*^9},ExpressionUUID->"29280710-fdd9-43ec-a92c-\
26012cb48efe"],

Cell[TextData[{
 "(b) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"v", ",", 
     RowBox[{"T", "(", "v", ")"}], ",", " ", 
     RowBox[{
      SuperscriptBox["T", "2"], "(", "v", ")"}], ",", "...", ",", 
     RowBox[{
      SuperscriptBox["T", 
       RowBox[{"k", "-", "1"}]], "(", "v", ")"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"a59ebf23-e2a8-411a-b3c4-00b3b4692ce4"]
}], "Text",
 CellChangeTimes->{{3.87622312082347*^9, 3.8762231253763924`*^9}, {
  3.9082903865481715`*^9, 
  3.9082903893718557`*^9}},ExpressionUUID->"b272a241-f567-4d4e-a32d-\
4d636546162e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{
  3.9082792043811197`*^9},ExpressionUUID->"87e51988-4001-4379-8060-\
0e553eabb59e"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"[", 
     RowBox[{"T", 
      SubscriptBox["|", "W"]}], "]"}], 
    SubscriptBox["\[Beta]", 
     RowBox[{"k", "-", "1"}]]], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"0", "0", "\[CenterEllipsis]", "0", 
       RowBox[{"-", 
        SubscriptBox["a", "0"]}]},
      {"1", "0", "\[DescendingEllipsis]", "\[VerticalEllipsis]", 
       RowBox[{"-", 
        SubscriptBox["a", "1"]}]},
      {"0", "1", "\[DescendingEllipsis]", "0", "\[VerticalEllipsis]"},
      {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
       "\[DescendingEllipsis]", "0", 
       RowBox[{"-", 
        SubscriptBox["a", 
         RowBox[{"k", "-", "2"}]]}]},
      {"0", "\[CenterEllipsis]", "0", "1", 
       RowBox[{"-", 
        SubscriptBox["a", 
         RowBox[{"k", "-", "1"}]]}]}
     }], "\[NoBreak]", ")"}], " "}], 
  TraditionalForm]],ExpressionUUID->"d5eb698d-2057-4a27-b841-38bbec578f33"]], \
"Text",
 CellChangeTimes->{{3.876223008701699*^9, 3.87622309170717*^9}, {
  3.8762231468456473`*^9, 3.8762231963602867`*^9}, {3.8762232654392242`*^9, 
  3.8762232968530965`*^9}, {3.8763941267881336`*^9, 
  3.8763941685511165`*^9}},ExpressionUUID->"65b5c06f-3f8c-4639-8e3d-\
8623a6a7ab8e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"73215d07-53e2-414c-9acc-0221c2f7a398"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"det", "(", 
    RowBox[{
     RowBox[{"t", "\[VeryThinSpace]", "I"}], "-"}]}], TraditionalForm]],
  ExpressionUUID->"1d2e49fb-7743-4db2-b238-79a86f35a894"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"[", 
       RowBox[{"T", 
        SubscriptBox["|", "W"]}], "]"}], 
      SubscriptBox["\[Beta]", 
       RowBox[{"k", "-", "1"}]]], ")"}], "="}], TraditionalForm]],
  ExpressionUUID->"920acb04-54ab-46d5-bb0c-f932477fd099"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["a", "0"], "+", 
      RowBox[{
       SubscriptBox["a", "1"], "t"}], "+"}], "..."}], "+", 
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"k", "-", "2"}]], 
     SuperscriptBox["t", 
      RowBox[{"k", "-", "2"}]]}], "+", 
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"k", "-", "1"}]], 
     SuperscriptBox["t", 
      RowBox[{"k", "-", "1"}]]}], "+", 
    SuperscriptBox["t", "k"]}], TraditionalForm]],ExpressionUUID->
  "fb7ede46-c8f1-49ba-aee2-7dde3eb37080"]
}], "Text",
 CellChangeTimes->{{3.8762233642279296`*^9, 3.8762234844602838`*^9}, {
