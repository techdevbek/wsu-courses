Cell[TextData[{
 "Note:",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     RowBox[{"a", "+", 
      RowBox[{"b", "\[VeryThinSpace]", "i"}]}], "|"}], "=", 
    RowBox[{
     SqrtBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"a", "+", 
         RowBox[{"b", "\[VeryThinSpace]", "i"}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"a", "-", 
         RowBox[{"b", "\[VeryThinSpace]", "i"}]}], ")"}]}]], "=", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       SuperscriptBox["b", "2"]}]]}]}], TraditionalForm]],ExpressionUUID->
