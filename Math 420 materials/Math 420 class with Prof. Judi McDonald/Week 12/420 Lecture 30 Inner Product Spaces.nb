Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "c85560db-5e66-42ff-9ff9-6d539e742bba"],
 "  Then the subspace ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"T", "(", "x", ")"}], ",", " ", 
       RowBox[{
        SuperscriptBox["T", "2"], "(", "x", ")"}], ",", "..."}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"d06dc5d8-ae36-465b-9245-e760cddd0cfc"],
 " is referred to as the ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "ee74ddbd-3075-4fda-8dbb-ee074e7c45c5"],
 "-cyclic subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "5d3b0ed9-1840-4992-828d-a3ba43649c1b"],
 " generated by ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "5e3bb634-a134-4a82-82bb-f60d3d3b7a05"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.622807116966751*^9, 3.622807234977497*^9}, {
   3.62280824673111*^9, 3.6228082605599356`*^9}, {3.6228084146190205`*^9, 
