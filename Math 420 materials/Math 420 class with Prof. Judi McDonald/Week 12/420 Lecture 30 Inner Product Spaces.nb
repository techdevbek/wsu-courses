   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209772124643`*^9}, {3.624021028531245*^9, 
   3.624021180886636*^9}, {3.6241945890140033`*^9, 3.6241945890295954`*^9}, {
   3.6241951215410004`*^9, 3.6241951584335647`*^9}, {3.845127241686601*^9, 
   3.8451272622680287`*^9}, {3.845127312448947*^9, 3.8451273494048295`*^9}, {
   3.8453916443060503`*^9, 3.845391692319317*^9}, {3.876395906128262*^9, 
   3.8763959105219917`*^9}, {3.908291756731368*^9, 3.9082917765174003`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5ed8ece5-9ea9-401d-a6db-109efde80fd2"],

Cell[TextData[{
 "REMARK: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"c", "\[VeryThinSpace]", "y"}], ">"}], " ", "=", 
