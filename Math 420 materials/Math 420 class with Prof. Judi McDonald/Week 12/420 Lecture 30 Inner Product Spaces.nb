04e6984d620d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["6.1 Inner Product Spaces and Norms",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.6225494720298038`*^9, 
   3.622549507234743*^9}, {3.6235856366612887`*^9, 3.623585653224654*^9}, {
   3.6240206450382576`*^9, 3.6240206470696516`*^9}, {3.6240206789248157`*^9, 
   3.6240206887691174`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"c8f3ea9e-db63-4928-9753-c06309b90070"],

Cell[TextData[{
 "We have seen that choosing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "-"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aee5075b-139e-49d1-a400-c54b3876846f"],
 "invariant subspaces, particularly eigenspaces, can help us get \
\[OpenCurlyDoubleQuote]prettier\[CloseCurlyDoubleQuote] matrices.  Are there \
good choices for bases independent of linear transformation?  Can we choose \
bases in a way that simplifies calculations and has other \
\[OpenCurlyDoubleQuote]pretty\[CloseCurlyDoubleQuote] advantages? "
}], "Text",
 CellChangeTimes->{{3.8763912439043694`*^9, 3.8763913563378286`*^9}, {
  3.876392014542875*^9, 
  3.876392024997405*^9}},ExpressionUUID->"347d9337-069a-4091-a25a-\
bca9954e0878"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Remark: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209084275255`*^9}, {3.6241937616904435`*^9, 
   3.624193771581601*^9}, {3.8451271045020185`*^9, 3.8451271296301193`*^9}, {
   3.8763911848255825`*^9, 3.876391185883312*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"d359f69c-b08e-47e4-9f8b-a9f766400659"],

Cell["Throughout Chapter 6 our fields, \[DoubleStruckCapitalF], must be \
either \[DoubleStruckCapitalR] or \[DoubleStruckCapitalC].", "Text",
 CellChangeTimes->{{3.876391192105402*^9, 
  3.8763912322418623`*^9}},ExpressionUUID->"1906f6fe-cab6-4be3-a50e-\
12299efc0d56"],

Cell[TextData[{
 "Note: if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"a", "+", 
     RowBox[{"b", "\[VeryThinSpace]", "i"}]}]}], TraditionalForm]],
  ExpressionUUID->"776d9735-96b8-46c1-9160-4607c1f4cbe1"],
 ", then the conjugate transpose of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "f7d1784a-380a-4841-930e-fadfc915a512"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["x", "_"], "=", 
    RowBox[{"a", "-", 
     RowBox[{"b", "\[VeryThinSpace]", "i"}]}]}], TraditionalForm]],
  ExpressionUUID->"e15e952d-db7b-48ee-85de-ed7ed6d6df30"]
}], "Text",
 CellChangeTimes->{{3.8763951955444517`*^9, 
  3.8763952417415447`*^9}},ExpressionUUID->"b1b5f444-e717-435b-ae7d-\
aa1cacd88c28"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Example:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 "  "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6241946855379333`*^9, 3.624194785125888*^9}, {
   3.624194815690009*^9, 3.624194866567735*^9}, {3.6243664330423665`*^9, 
   3.624366433839278*^9}, 3.624366539704352*^9, {3.6243704285602446`*^9, 
   3.6243704293727884`*^9}, 3.845377079744113*^9, {3.8763915100426655`*^9, 
   3.8763915109109893`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"1314f3ad-f80c-41e2-ae49-3239dbcf62f9"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalF]", "n"]}]}], TraditionalForm]],
  ExpressionUUID->"e51a2458-5aef-4acf-82a7-cfa30e4bcdbc"],
 ".  Define ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", " ", "x"}], ",", " ", 
    RowBox[{
     RowBox[{"y", " ", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{
      RowBox[{
       SuperscriptBox["y", "*"], "x"}], " ", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"[", 
         RowBox[{
          RowBox[{
           RowBox[{
            SubscriptBox[
             OverscriptBox["y", "_"], "1"], " ", 
            SubscriptBox[
             OverscriptBox["y", "_"], "2"]}], " ", "..."}], " ", 
          SubscriptBox[
           OverscriptBox[
            RowBox[{" ", "y"}], "_"], "n"]}], "]"}], 
        GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]},
         ImageSize->{7, 65}], GridBox[{
          {
           SubscriptBox["x", "1"]},
          {
           SubscriptBox["x", "2"]},
          {"\[VerticalEllipsis]"},
          {
           SubscriptBox["x", "n"]}
         }], "\[NoBreak]", 
        GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]},
         ImageSize->{7, 65}]}], "=", "  ", 
       RowBox[{
        SubsuperscriptBox["\[Sum]", 
         RowBox[{"j", "=", "1"}], "n"], 
        RowBox[{
         SubscriptBox[
          OverscriptBox["y", "_"], "j"], 
         SubscriptBox["x", "j"]}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "44eedf6f-0d87-47cb-b784-e4687d784722"],
 ".  This is commonly referred to as an inner product, specifically the dot \
product. "
}], "Text",
 CellChangeTimes->{{3.8763915164532456`*^9, 3.8763916566571913`*^9}, {
  3.8763916928686967`*^9, 3.8763920031293716`*^9}, {3.8763920591496625`*^9, 
  3.876392080037197*^9}, {3.876395263741903*^9, 3.876395303594734*^9}, {
  3.876395446890033*^9, 3.876395446890033*^9}, {3.908279292876413*^9, 
  3.90827929579834*^9}, {3.908291384232692*^9, 
  3.9082913904210725`*^9}},ExpressionUUID->"4d6920ec-e483-404f-a946-\
bc8d3b9d012c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"ce9f05be-4dc1-4048-9388-ce82d03c2559"],

Cell["We extend this to a more generic context as follow:", "Text",
 CellChangeTimes->{{3.8763923070869203`*^9, 
  3.8763923246395087`*^9}},ExpressionUUID->"dcc7fb48-293b-456a-ab33-\
8eef7895c260"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209084275255`*^9}, {3.6241937616904435`*^9, 
   3.624193771581601*^9}, {3.8451271045020185`*^9, 3.8451271296301193`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"83df9c68-8c07-453e-8e66-a4c87b36700f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "aa94d957-13cd-45c7-821a-b3862a1c0a9a"],
 " be a vector space over a field \[DoubleStruckCapitalF], where ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalF]", TraditionalForm]],ExpressionUUID->
  "f86dedcf-94f1-4f90-adcc-d33dde2ad0f2"],
 " is \[DoubleStruckCapitalC] or \[DoubleStruckCapitalR].  An inner product \
on ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "19cf7dcc-48aa-42b1-8fed-356ca73a9e1e"],
 " is a function that assigns, to every ordered pair of vectors ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "c1bb5877-3fe0-4b73-8119-1e97c7f43e88"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "5098c21e-36fa-4a13-8c67-8d62d67f85ac"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ","}], TraditionalForm]],ExpressionUUID->
  "4c427f53-4943-4677-aff1-f153057cfa1a"],
 " a scalar in \[DoubleStruckCapitalF], denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{"y", ">"}], ","}], TraditionalForm]],ExpressionUUID->
  "7054faf4-d3db-42e1-8059-d42020c17466"],
 " such that for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", "y", ",", "z", ",", 
    RowBox[{"\[Element]", " ", "V"}]}], TraditionalForm]],ExpressionUUID->
  "dc8e8626-da8c-4a02-9624-5f43f305a506"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"b1f6b9a8-7d38-4aa8-9d3c-a58a0b436b9e"],
 ", the following hold: "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209084275255`*^9}, {3.6241937616904435`*^9, 
   3.624193771581601*^9}, 3.8451271045020185`*^9, {3.8451272696033735`*^9, 
   3.8451273008450556`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"abcaeb69-2a65-4598-84b0-b573b3434c14"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"x", "+", "z"}]}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], " ", "=", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{"y", ">", 
     RowBox[{"+", 
      RowBox[{"<", "z"}]}]}], ",", 
    RowBox[{"y", ">"}]}], TraditionalForm]],ExpressionUUID->
  "9397a083-e057-454a-8cce-cb0fda2cf984"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209661649733`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f4cec785-878d-4273-925a-9dfb1f46125d"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"c", " ", "x"}]}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], " ", "=", 
     RowBox[{"c", "<", "x"}]}], ",", 
    RowBox[{"y", ">"}]}], TraditionalForm]],ExpressionUUID->
  "af11637e-4929-46a2-a656-3bca3d68eb5d"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209772124643`*^9}, {3.624021028531245*^9, 
   3.624021044750857*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4048169e-86c1-4648-bf0e-c15f814dcea8"],

Cell[TextData[{
 "(iii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      RowBox[{
       RowBox[{"<", "x"}], ",", 
       RowBox[{"y", ">", " "}]}], "_"], "=", 
     RowBox[{"<", "y"}]}], ",", 
    RowBox[{"x", ">"}]}], TraditionalForm]],ExpressionUUID->
  "e58d50f0-69cf-42c7-a047-6660793c20c3"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209772124643`*^9}, {3.624021028531245*^9, 
   3.624021110014248*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"dfd3e4a3-f58a-4111-ae23-e52c82f0f419"],

Cell[TextData[{
 "(iv) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{"x", ">"}]}], TraditionalForm]],ExpressionUUID->
  "6c493db2-119f-4a11-a589-8477ba4b2fc6"],
 " is in \[DoubleStruckCapitalR] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{"x", ">"}]}], TraditionalForm]],ExpressionUUID->
  "06b03b20-2b37-4b1c-adb8-4062f2ebdb51"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{">", "0"}], TraditionalForm]],ExpressionUUID->
  "5c613a02-9637-468f-b2f0-582a4156a25d"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "1c8e167c-a871-4a80-8661-730d57f9bb4b"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
