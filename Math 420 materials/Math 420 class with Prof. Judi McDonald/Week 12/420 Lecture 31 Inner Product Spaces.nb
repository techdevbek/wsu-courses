       RowBox[{"-", "c"}], " ", "y"}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c"}], " ", "y"}], ">", 
    RowBox[{"+", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "c"}], " ", "y"}], ">"}]}], 
