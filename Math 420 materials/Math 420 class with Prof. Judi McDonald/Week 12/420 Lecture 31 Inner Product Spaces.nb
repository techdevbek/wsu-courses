Cell["", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"98df6839-4234-4caf-87a9-87822e69880d"],

Cell[TextData[{
 "(iv) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"||", " ", 
    RowBox[{"x", "+", "y"}], "||", 
    RowBox[{"\[LessEqual]", 
     RowBox[{"||", "x", "||", 
      RowBox[{"+", 
       RowBox[{"||", "y", "||"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "d53d1bb5-713d-4a10-a1a8-9d92d961ec3f"],
 " (Triangle Inequality) "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209772124643`*^9}, {3.624021028531245*^9, 
   3.624021180886636*^9}, {3.6241945890140033`*^9, 3.624194589967144*^9}, {
   3.6243664768103437`*^9, 3.6243664787323217`*^9}, {3.624366572096711*^9, 
   3.624366634681602*^9}, {3.6243717543740263`*^9, 3.624371755108441*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5f37ee56-8bd0-4890-8064-6c6bbefb9635"],

Cell[TextData[Cell[BoxData[{
 FormBox[
  StyleBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"||", " ", 
       RowBox[{"x", "+", "y"}], 
       SuperscriptBox["||", "2"]}], "=", 
      RowBox[{"<", 
       RowBox[{"x", "+", "y"}]}]}], ",", 
     RowBox[{
      RowBox[{"x", "+", "y"}], ">"}]}], "\[LineSeparator]", 
    RowBox[{
     RowBox[{"=", 
      RowBox[{"<", "x"}]}], ",", 
     RowBox[{"x", ">", 
      RowBox[{"+", 
       RowBox[{"<", "x"}]}]}], ",", 
     RowBox[{"y", ">", 
      RowBox[{"+", 
       RowBox[{"<", "y"}]}]}], ",", 
     RowBox[{"x", ">", 
      RowBox[{"+", 
       RowBox[{"<", "y"}]}]}], ",", 
     RowBox[{"y", ">", "\[IndentingNewLine]", 
      RowBox[{"=", 
       RowBox[{"||", "x", 
        SuperscriptBox["||", "2"], 
        RowBox[{
         RowBox[{
          RowBox[{"+", "2"}], "Re"}], "<", "x"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"y", ">", "+"}], "||", "y", 
       SuperscriptBox["||", "2"], "\[IndentingNewLine]", 
       RowBox[{"\[LessEqual]", 
        RowBox[{"||", "x", 
         SuperscriptBox["||", "2"], 
         RowBox[{"+", "2"}]}]}]}], "|", 
      RowBox[{"<", "x"}]}], ",", 
     RowBox[{
      RowBox[{"y", ">"}], "|", 
      RowBox[{"+", 
       RowBox[{"||", "y", 
        SuperscriptBox["||", "2"], "\[IndentingNewLine]", 
        RowBox[{"\[LessEqual]", 
         RowBox[{"||", "x", 
          SuperscriptBox["||", "2"], 
          RowBox[{"+", "2"}], "||", "x", "||", "||", "y", "||", 
          RowBox[{"+", 
           RowBox[{"||", "y", 
            SuperscriptBox["||", "2"]}]}]}]}]}]}]}]}]}],
   FontSize->12], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  StyleBox[
   RowBox[{"=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"||", "x", "||", 
       RowBox[{"+", 
        RowBox[{"||", "y", "||"}]}]}], ")"}], "2"]}],
   FontSize->12], TraditionalForm]}],
 FontSize->16,ExpressionUUID->"20802b54-1410-4ee6-84bc-3aa0a455c160"]], "Text",
 CellChangeTimes->{{3.6246296039753838`*^9, 3.624629691467688*^9}, {
  3.6246297651966743`*^9, 3.6246297923395524`*^9}, {3.6246298686433735`*^9, 
  3.6246299245901527`*^9}, {3.845377526062683*^9, 3.845377607304537*^9}, {
  3.876564734523487*^9, 3.8765647580440893`*^9}, {3.876567435977847*^9, 
  3.87656744691084*^9}},
 FontFamily->"Times New Roman",
 FontWeight->"Normal",ExpressionUUID->"88241e94-35ee-4185-b869-787d96274e2e"],

Cell["Taking the square root of both sides we get the result.", "Text",
 CellChangeTimes->{{3.6246296039753838`*^9, 3.624629691467688*^9}, {
  3.6246297651966743`*^9, 3.6246297923395524`*^9}, {3.6246298686433735`*^9, 
