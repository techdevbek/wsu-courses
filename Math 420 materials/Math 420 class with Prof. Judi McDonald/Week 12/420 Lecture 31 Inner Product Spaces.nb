        SuperscriptBox["||", "2"]}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "cc7b67a5-786f-4e11-85dc-2bfcceb67c36"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"||", "y", 
    SuperscriptBox["||", "2"]}], TraditionalForm]],ExpressionUUID->
  "e0a54657-bfe6-4e03-ab6b-a5035cf195e8"],
 " is positive,"
}], "Text",
