  FormBox[
   RowBox[{"0", "\[LessEqual]"}], TraditionalForm]],ExpressionUUID->
  "0e0a470f-8aa5-4fdd-981e-c4011d87648e"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", 
     RowBox[{"x", "-", 
      RowBox[{"c", " ", "y"}]}], 
     SuperscriptBox["||", "2"]}], "=", 
    RowBox[{"||", "x", 
     SuperscriptBox["||", "2"], 
     RowBox[{"-", " ", 
      FractionBox[
       RowBox[{
        RowBox[{"|", 
         RowBox[{"<", "x"}]}], ",", 
        RowBox[{
         RowBox[{"y", ">"}], 
