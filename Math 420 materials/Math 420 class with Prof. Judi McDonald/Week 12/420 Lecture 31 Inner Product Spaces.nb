Cell[CellGroupData[{

Cell[TextData[StyleBox["6.2 Gram-Schmidt and Orthogonality",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.6225494720298038`*^9, 
   3.622549507234743*^9}, {3.6235856366612887`*^9, 3.623585653224654*^9}, {
   3.6240206450382576`*^9, 3.6240206470696516`*^9}, {3.6240206789248157`*^9, 
   3.6240206887691174`*^9}, 3.624626589860346*^9, {3.62462665353562*^9, 
   3.6246266752906113`*^9}, {3.845546563262905*^9, 3.845546571680436*^9}, {
   3.8455471936593513`*^9, 3.845547207129469*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"0a242ebb-b24f-46d7-85e1-067849ff2da6"],

Cell[TextData[{
 "Definition:  A basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", " ", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "54eff254-d710-4b4f-9c65-e88cb7503aa8"],
 " is said to be orthogonal if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], "\[VeryThinSpace]", "=", " ", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"50e7f71b-7719-4b39-b3ef-3bf8fbe64a7a"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[NotEqual]", "j"}], TraditionalForm]],ExpressionUUID->
  "4d0d3c31-5053-4834-beab-380d02c8f971"],
 "."
}], "Text",
 CellChangeTimes->{{3.8765676114397535`*^9, 
  3.87656766386509*^9}},ExpressionUUID->"75ad2e51-5edc-41d4-8d91-\
fe531d4a326e"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6249728960450172`*^9, 3.6249729321250553`*^9}, {
  3.624973016928049*^9, 3.624973021975191*^9}, {3.8455471173402295`*^9, 
  3.845547117341186*^9}, {3.8455471478179646`*^9, 3.84554714898883*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5c4d2151-a666-40db-b1f9-ecd674448bf3"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", " ", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "ad71a06f-25ea-4629-9bcb-b309256f2576"],
 " be an orthogonal basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "f915bfe6-4fba-4cb7-92d7-78274255061e"],
 " Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Beta]"], "=", "A"}], ","}], 
   TraditionalForm]],ExpressionUUID->"76525376-ca70-4a95-ac99-240ed4ea8377"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", 
     RowBox[{"i", " ", "j"}]], "="}], TraditionalForm]],ExpressionUUID->
  "f1b1f98b-ec55-49ef-ac3e-8685ea291d6f"],
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     RowBox[{"<", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "j"], ")"}]}], ",", 
     RowBox[{
      SubscriptBox["v", "i"], ">"}]}], 
    RowBox[{
     RowBox[{"<", 
      SubscriptBox["v", "i"]}], ",", 
     RowBox[{
      SubscriptBox["v", "i"], ">"}]}]], TraditionalForm]],ExpressionUUID->
  "b5e4f950-2372-42eb-b5b8-248444dcdec3"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249728960450172`*^9, 3.6249729321250553`*^9}, {
  3.624973016928049*^9, 3.624973021975191*^9}, {3.8455471195577097`*^9, 
  3.84554714190839*^9}, {3.8765683544650307`*^9, 3.8765683710419664`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"39053422-f773-4623-bbfb-d1f5d60b93ea"],

Cell["Proof:", "Text",
 CellChangeTimes->{{3.8765676977370496`*^9, 
  3.8765677014636917`*^9}},ExpressionUUID->"a42ccf6c-de6f-40cf-bbc7-\
0ad6c0c148ae"],

Cell[TextData[{
 "The get the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"jth", " "}], TraditionalForm]],ExpressionUUID->
  "a1a2d1e8-9e95-4c80-8183-d46522e9e02a"],
 " column of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]"], TraditionalForm]],ExpressionUUID->
  "8faaf819-289c-48c0-a70e-3660b4e8f2f7"],
 ", we find ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", 
    SubscriptBox["v", "j"], ")"}], TraditionalForm]],ExpressionUUID->
  "b7af7e20-9544-4029-9568-c238ac93f4f1"],
 " and write this as a linear combination of the basis elements and write the \
coefficients down the jth column of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2bd3b955-9f51-492e-ad87-d5e35ca12812"],
 ".   Thus we have "
}], "Text",
 CellChangeTimes->{{3.8765676977370496`*^9, 3.8765676992412405`*^9}, {
  3.8765677396562915`*^9, 
  3.876567817942479*^9}},ExpressionUUID->"ec2d4622-6afa-44c9-9e23-\
444b4756eb27"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", 
    SubscriptBox["v", "j"], ")"}], "=", 
   RowBox[{
    SubsuperscriptBox["\[Sum]", 
     RowBox[{"k", "=", "1"}], "n"], 
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"k", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["v", "k"]}]}]}], 
  TraditionalForm]],ExpressionUUID->"3c2215f7-9c6f-4c58-a8ad-772578ecb955"]], \
"Text",
 CellChangeTimes->{{3.8765676977370496`*^9, 3.8765676992412405`*^9}, {
  3.8765677396562915`*^9, 3.876567848259552*^9}, {3.8765679438184147`*^9, 
  3.8765679522362394`*^9}},ExpressionUUID->"b8bb459e-671e-4493-bb75-\
759d23cc92ad"],

Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"<", 
     RowBox[{"T", "(", 
      SubscriptBox["v", "j"], ")"}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"k", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"k", "\[VeryThinSpace]", "j"}]], 
        SubscriptBox["v", "k"]}]}]}]}], ",", 
    RowBox[{
     SubscriptBox["v", "i"], ">"}]}], "\[VeryThinSpace]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "1"}], "n"], 
     RowBox[{"<", 
      RowBox[{
       SubscriptBox["a", 
        RowBox[{"k", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["v", "k"]}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "n"], 
      SubscriptBox["a", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}]]}], "<", 
     SubscriptBox["v", "k"]}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", 
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "<", 
     SubscriptBox["v", "i"]}]}], ",", 
   RowBox[{
    SubscriptBox["v", "i"], ">"}]}], 
  TraditionalForm]}],ExpressionUUID->"567ee2e8-fcd1-4c75-b578-a1ed55f1c759"]],\
 "Text",
 CellChangeTimes->{{3.876567913941947*^9, 3.8765679894220695`*^9}, {
  3.8765680216183257`*^9, 3.8765680675759025`*^9}, {3.8765681140554624`*^9, 
  3.8765681386633415`*^9}},ExpressionUUID->"80de850c-e9ce-4537-b8b1-\
20f993e8da08"],

Cell["so", "Text",
 CellChangeTimes->{{3.8765681826585684`*^9, 
  3.87656818289524*^9}},ExpressionUUID->"67fb51b3-c329-4dc5-84e9-\
8adc6042477c"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"<", 
    RowBox[{"T", "(", 
     SubscriptBox["v", "j"], ")"}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", 
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "<", 
     SubscriptBox["v", "i"]}]}], ",", 
   RowBox[{
    SubscriptBox["v", "i"], ">"}]}], 
  TraditionalForm]],ExpressionUUID->"1c9bf20c-1a9d-4ae6-ad44-5f56d8a7c121"]], \
"Text",
 CellChangeTimes->{{3.8765681680526056`*^9, 3.8765681791925364`*^9}, {
  3.876568214193296*^9, 
  3.876568214193296*^9}},ExpressionUUID->"afecb8c3-f5bc-47ad-a066-\
255016e8a84c"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "i"], TraditionalForm]],ExpressionUUID->
  "d2590f73-12f6-4cef-b2a3-a4cb3f944e19"],
 " is part of a basis, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["v", "i"], "\[NotEqual]", "0"}], ","}], TraditionalForm]],
  ExpressionUUID->"8489f011-92aa-4676-b009-2edf53aefda8"],
 "  and thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     SubscriptBox["v", "i"], ">", "\[VeryThinSpace]", ">", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"ad09ddd6-0f46-43c6-84b0-c67f1cf449f6"],
 " and"
}], "Text",
 CellChangeTimes->{{3.8765683769499702`*^9, 
  3.8765684838500156`*^9}},ExpressionUUID->"8df5e0cb-5640-46a3-a112-\
dd77f4805df7"],

Cell[TextData[{
 " so  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{
      RowBox[{"<", 
       RowBox[{"T", "(", 
        SubscriptBox["v", "j"], ")"}]}], ",", 
      RowBox[{
       SubscriptBox["v", "i"], ">"}]}], 
     RowBox[{
      RowBox[{"<", 
       SubscriptBox["v", "i"]}], ",", 
      RowBox[{
       SubscriptBox["v", "i"], ">"}]}]], "\[VeryThinSpace]", "=", 
    SubscriptBox["a", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"4ca38db4-400c-4b98-ac7b-c0dea97ed89d"]
}], "Text",
 CellChangeTimes->{{3.8765683769499702`*^9, 
  3.8765684975155926`*^9}},ExpressionUUID->"098ba667-8248-4683-99b8-\
620249ad281d"],

Cell[TextData[{
 StyleBox["Orthonormal",
  FontSlant->"Italic"],
 " is the term we use when an orthogonal basis also has the property that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", "1"}]}], 
   TraditionalForm]],ExpressionUUID->"310e64bf-2857-43fa-877a-8d75c348c041"]
}], "Text",
 CellChangeTimes->{{3.8765682534568567`*^9, 
  3.876568317072312*^9}},ExpressionUUID->"5664252e-fc5c-435d-a6bd-\
c78062016aa1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ",
  FontFamily->"Times New Roman"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.6249730262253847`*^9}, {
   3.6249740890491676`*^9, 3.6249742436276097`*^9}, 3.8455472870549746`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b414c003-4567-48d3-90f9-be251a0cf601"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "b5b5f8c4-a5a4-4580-a7d4-0c8bdcf5789e"],
 " be a subspace of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "7e9e9858-7cdf-4991-8e3b-6ee6c6574564"],
 "  The orthogonal complement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", ","}], TraditionalForm]],ExpressionUUID->
  "a02d093a-a44b-4b00-acd0-9981f5fa3eaa"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["W", "\[Perpendicular]"], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"v", "\[Element]", "V"}], "|", 
        RowBox[{"<", "v"}]}], ",", 
       RowBox[{
        RowBox[{"w", ">"}], "\[VeryThinSpace]", "=", "0"}], ",", " ", 
       RowBox[{"\[ForAll]", 
        RowBox[{"w", "\[Element]", "W"}]}]}], "}"}], "."}]}], 
   TraditionalForm]],ExpressionUUID->"2efb23c1-d5f2-4e12-ac87-8824fedd26c3"]
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.6249730262253847`*^9}, {
  3.6249740890491676`*^9, 3.6249742436276097`*^9}, {3.876568559832985*^9, 
  3.8765685601015034`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c15ffa2a-48c7-44ce-aa75-1713d316de35"],

Cell[TextData[{
 "Example:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"1"}
        }], "\[NoBreak]", ")"}], " ", "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"830a5628-93fc-4140-9ecf-4c7d8e143022"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["W", "\[Perpendicular]"], "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {
          RowBox[{"-", "1"}]}
        }], "\[NoBreak]", ")"}], " ", "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"0c724985-783a-4406-93f6-e94be55e4b45"],
 "."
}], "Text",
 CellChangeTimes->{{3.8765687452939577`*^9, 
  3.876568805852744*^9}},ExpressionUUID->"567136cb-4974-4884-a14e-\
1e90fbffd204"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Lemma:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.624973937459322*^9}, {3.624974284908164*^9, 
   3.624974347213564*^9}, 3.8455473257249393`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"175f41de-ed29-4063-9f4d-4bb7b82e444e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "c2ee8d1d-2434-48cc-98bf-2cf48503803c"],
 " be a subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "465383e2-97f1-4a72-8cc0-7f1961e7db9a"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["W", "\[Perpendicular]"], TraditionalForm]],ExpressionUUID->
  "95167f9d-74f0-425c-82e4-19e88cf56341"],
 " is a subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "36ba8583-1b55-497e-a8a0-1d09201b6330"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"W", "\[CirclePlus]", 
     SuperscriptBox["W", "\[Perpendicular]"]}]}], TraditionalForm]],
  ExpressionUUID->"fe2869d1-332e-4a6d-b447-32f6641eb236"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.624973937459322*^9}, {3.624974284908164*^9, 
  3.624974347213564*^9}, {3.8457263837907214`*^9, 3.845726422481479*^9}, {
  3.876568839626813*^9, 3.876568855966895*^9}, {3.8765689044365597`*^9, 
  3.8765689068852067`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"37959d55-b6e5-4745-8fa6-31f0c52ff91a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF: ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.6249739376624613`*^9}, {3.6249744033225927`*^9, 
   3.6249745601404004`*^9}, {3.624974625582996*^9, 3.6249749344228964`*^9}, {
   3.624975002278723*^9, 3.6249751402896194`*^9}, {3.6249753516270475`*^9, 
   3.624975356802971*^9}, {3.624975459694648*^9, 3.624975474312669*^9}, 
   3.8455473675173054`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"ffd8bc58-9276-4143-93b8-9664e803f4fb"],

Cell[TextData[{
 "Homework X goes over the direct sum portion of this proof.  Let\
\[CloseCurlyQuote]s still show ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["W", "\[Perpendicular]"], TraditionalForm]],ExpressionUUID->
  "12b1fbd6-9c12-4de9-824f-2217a963cd9f"],
 " is a subspace of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "a7c04e31-d49e-4b5c-bf43-129568e89826"]
}], "Text",
 CellChangeTimes->{{3.84572643745951*^9, 3.8457264403953667`*^9}, {
  3.87656895444403*^9, 3.8765689821670265`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"d7c00d54-810c-4f80-b681-6db54bf29b17"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[Element]", 
    SuperscriptBox["W", "\[Perpendicular]"]}], TraditionalForm]],
  ExpressionUUID->"00d9ec76-1785-44bb-bde0-95b208fc445d"],
 " since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ForAll]", 
    RowBox[{"w", "\[Element]", "W"}]}], TraditionalForm]],ExpressionUUID->
  "8142e21e-7296-4142-83ff-492c456e60d0"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "0"}], ",", 
    RowBox[{
     RowBox[{"w", ">"}], "\[VeryThinSpace]", "=", "0"}]}], TraditionalForm]],
  ExpressionUUID->"7175ccec-7ac9-465a-bb8f-7b4c1e199826"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[Element]", 
    SuperscriptBox["W", "\[Perpendicular]"]}], TraditionalForm]],
  ExpressionUUID->"cf5ae4b9-5dfb-4895-881d-8390252fffde"],
 "."
}], "Text",
 CellChangeTimes->{{3.84572643745951*^9, 3.8457264403953667`*^9}, {
  3.87656895444403*^9, 3.876569003409684*^9}, {3.876569090448617*^9, 
  3.876569165226323*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"199a417d-0028-4755-862f-b16645a019a3"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", "\[Element]", 
     SuperscriptBox["W", "\[Perpendicular]"]}]}], TraditionalForm]],
  ExpressionUUID->"6b1f2d80-d601-4c70-8316-2fdb1dc3ccf3"],
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"1a7f9961-5e9a-441b-9eaf-a139902ef171"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"c", "\[VeryThinSpace]", "x"}], "+", "y"}], "\[Element]", 
    SuperscriptBox["W", "\[Perpendicular]"]}], TraditionalForm]],
  ExpressionUUID->"0b0b057a-4e43-4f67-a031-69c4a71defe6"],
 " since ",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[ForAll]", 
      RowBox[{"w", "\[Element]", "W"}]}], ",", 
     RowBox[{"<", 
      RowBox[{
       RowBox[{"c", "\[VeryThinSpace]", "x"}], "+", "y"}]}], ",", 
     RowBox[{"w", ">"}]}], "\[VeryThinSpace]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"=", 
     RowBox[{"c", "<", "x"}]}], ",", 
    RowBox[{"w", ">", 
     RowBox[{"+", 
      RowBox[{"<", "y"}]}]}], ",", 
    RowBox[{"w", ">"}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"=", "0"}], TraditionalForm]}],ExpressionUUID->
  "2f69071e-302e-43f1-a227-e2d42b8f1281"]
}], "Text",
 CellChangeTimes->{{3.8765690093463955`*^9, 3.876569070596322*^9}, {
  3.876569171092208*^9, 
  3.876569216053045*^9}},ExpressionUUID->"84760532-7721-41e3-b17d-\
71f9e401e502"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["W", "\[Perpendicular]"], TraditionalForm]],ExpressionUUID->
  "34db2fd9-cf57-4caf-a1b5-1535acecc722"],
 " is a subspace."
}], "Text",
 CellChangeTimes->{{3.876569230234768*^9, 
  3.8765692436722775`*^9}},ExpressionUUID->"89143b54-f2a1-49b1-9913-\
3334cfe16c6d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Lemma:",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.6249739378343563`*^9}, {3.624975867616501*^9, 
   3.6249760737866645`*^9}, 3.845547493637847*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"fa3c0e9f-4e9c-4438-a5ff-c5e9a1eeddf9"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "600573c5-03f9-4c8e-a517-ae28e777ba2a"],
 " be an orthogonal basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "c56d3992-16de-430a-b224-d85719440448"],
 "  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "\[Subset]", 
    RowBox[{"\[Beta]", "."}]}], TraditionalForm]],ExpressionUUID->
  "744f4870-4f08-47c0-ba21-1400f0cf2760"],
 "  Let \[Gamma] be all the vectors in \[Beta] that are not contained in \
\[Alpha].  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"Span", " ", 
     RowBox[{"\[Alpha]", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "5d77d823-456c-414b-b38e-742fdac65568"],
 "  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["W", "\[Perpendicular]"], "=", 
    RowBox[{"Span", " ", "\[Gamma]"}]}], TraditionalForm]],ExpressionUUID->
  "86037d42-6796-4e18-b7aa-0cab2f20ce6b"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.6249739378343563`*^9}, {3.624975867616501*^9, 
  3.6249760737866645`*^9}, {3.8458119368880224`*^9, 3.8458119391716323`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"d2a256dc-2766-421b-a44b-6bc3f5995509"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.6249739378343563`*^9}, {3.624975867616501*^9, 
  3.62497607672434*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"926c2d21-3501-4afb-941f-21cf60cad55e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["x", 
        RowBox[{"1", ","}]], "..."}], ",", 
      SubscriptBox["x", "m"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "6f46c42d-cfe7-4a84-b246-9cfdf33681f0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", 
       RowBox[{"m", "+", "1"}]], ",", "...", ",", " ", 
      SubscriptBox["x", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "0c15f2e4-4794-4bb0-bee9-1f6fe793b028"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"Span", " ", "\[Alpha]"}]}], TraditionalForm]],ExpressionUUID->
  "12a1db1b-8033-4f35-922d-773a05f1e769"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"Span", " ", "\[Gamma]"}]}], TraditionalForm]],ExpressionUUID->
  "c86b3bc1-6e94-468f-a5c5-d7143a7057f5"],
 ".  So there exist scalars ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "1"], TraditionalForm]],ExpressionUUID->
  "ae0d8234-a7f9-4d2c-981b-427df03e6923"],
 ",...., ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "n"], TraditionalForm]],ExpressionUUID->
  "389bd4ee-7e3b-4736-81bb-980dcb1b300a"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"j", "=", "1"}], "m"], 
     RowBox[{
      SubscriptBox["a", "j"], 
      SubscriptBox["x", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "621be9eb-578c-4c41-bd97-5a6ab7db0960"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", 
       RowBox[{"m", "+", "1"}]}], "n"], 
     RowBox[{
      SubscriptBox["a", "k"], 
      SubscriptBox["x", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "7a0ea871-271b-43e7-b931-04abcdc1b9bf"]
}], "Text",
 CellChangeTimes->{{3.8765693219388638`*^9, 3.8765694795648966`*^9}, {
  3.908465280032612*^9, 
  3.9084652804516106`*^9}},ExpressionUUID->"94ec972d-fac5-4f44-9610-\
17b37795821e"],

Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "m"], 
       RowBox[{
        SubscriptBox["a", "j"], 
        SubscriptBox["x", "j"]}]}]}]}], ",", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", 
        RowBox[{"m", "+", "1"}]}], "n"], 
      RowBox[{
       SubscriptBox["a", "k"], 
       SubscriptBox["x", "k"]}]}], ">"}]}], "\[VeryThinSpace]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"=", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "m"], 
       SubscriptBox["a", "j"]}], "<", 
      SubscriptBox["x", "j"]}]}], ",", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", 
        RowBox[{"m", "+", "1"}]}], "n"], 
      RowBox[{
       SubscriptBox["a", "k"], 
       SubscriptBox["x", "k"]}]}], ">"}]}], "\[VeryThinSpace]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"=", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "m"], 
       RowBox[{
        SubsuperscriptBox["\[Sum]", 
         RowBox[{"k", "=", 
          RowBox[{"m", "+", "1"}]}], "n"], 
        SubscriptBox["a", "j"]}]}], "<", 
      SubscriptBox["x", "j"]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "k"], 
      SubscriptBox["x", "k"]}], ">"}]}], "\[VeryThinSpace]"}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "m"], 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"k", "=", 
         RowBox[{"m", "+", "1"}]}], "n"], 
       RowBox[{
        SubscriptBox["a", "j"], 
        SubscriptBox[
         OverscriptBox["a", "_"], "k"]}]}]}], "<", 
     SubscriptBox["x", "j"]}]}], ",", 
   RowBox[{
    RowBox[{
     SubscriptBox["x", "k"], ">"}], "\[VeryThinSpace]", "=", "0"}]}], 
  TraditionalForm]}],ExpressionUUID->"b742f9ce-8e82-4fe2-9000-d4112f067507"]],\
 "Text",
 CellChangeTimes->{{3.8765693219388638`*^9, 3.876569323018962*^9}, {
  3.8765695138931417`*^9, 3.8765696718504605`*^9}, {3.9084652836630087`*^9, 
  3.908465294511243*^9}, {3.9084653735697174`*^9, 3.9084653735935125`*^9}, {
  3.908465418686685*^9, 
  3.908465420780097*^9}},ExpressionUUID->"7cbdb1df-5cf0-4a0c-9b07-\
315426e580b8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Lemma:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, 
   3.845547218352953*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b4306f4d-8828-4dfb-b519-c2f9e16d9ea2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "b623192f-e4b1-46da-ae10-595165f4797d"],
 " be an orthogonal basis for a subspace ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "a0e3cf70-5626-4c77-a3f7-333b8972be24"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "d0436b9d-871e-4b52-85a5-97f237d04d5b"],
 "  Then ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "d2ab9954-6257-4d02-a6b6-91ef7c6ffe31"],
 " can be extended to an orthogonal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "8ec4adc6-e4de-42d6-8e42-2d5b0e95f950"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
  3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9bd23d93-3c48-45e9-a493-45fb0513ca97"],

Cell[TextData[StyleBox["PROOF:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.624973938349987*^9}, {3.6252331237260103`*^9, 
  3.625233125710514*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"b94462fc-1be9-41cb-bb0b-e39dfc8b76ae"],

Cell[TextData[{
 "Find a orthogonal basis for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["W", "\[Perpendicular]"], TraditionalForm]],ExpressionUUID->
  "340504bc-9061-4f76-af91-15adab82e024"],
 ".  Then the union of the bases will be an orthogonal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a6cd3605-0dc1-4e10-9327-727ee8d40570"],
 "."
}], "Text",
 CellChangeTimes->{{3.876569747417781*^9, 
  3.8765697847153144`*^9}},ExpressionUUID->"57608267-ecb9-46e9-b06e-\
b544f8c99b71"],

Cell["BUT, can we always find an orthogonal basis for a subspace?", "Text",
 CellChangeTimes->{{3.876569789698745*^9, 
  3.8765698018241863`*^9}},ExpressionUUID->"ae61b954-80f8-423e-8f97-\
45bfc41d4d66"],

Cell["Gram-Schmidt:", "Text",
 CellChangeTimes->{{3.8765698295595064`*^9, 
  3.8765698343406916`*^9}},ExpressionUUID->"e8910770-8968-4158-9647-\
87690c1872b7"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["w", "1"], ",", " ", 
     SubscriptBox["w", "2"], ",", " ", "...", ",", 
     SubscriptBox["w", "m"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "f6cafa31-fc4d-4663-8eb2-f069d9fd18a5"],
 " be a basis for a (finite) subspace ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "0696158c-d1e2-415d-84c0-cd21299d8b08"],
 " of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ca8a8faa-6b62-41d2-906f-236a2b6c77a6"],
 "."
}], "Text",
 CellChangeTimes->{{3.876569857088851*^9, 3.8765699005644875`*^9}, {
  3.8765713198490777`*^9, 
  3.8765713226741138`*^9}},ExpressionUUID->"48ea0b38-8dd0-4e10-9fdc-\
4b15aa4113d3"],

Cell[TextData[{
 "Start by setting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "1"], "=", 
    SubscriptBox["w", "1"]}], TraditionalForm]],ExpressionUUID->
  "55725eeb-0d86-4b11-bf22-a40be4028013"],
 ".  Next we want to cleverly choose a scalar ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "1"], TraditionalForm]],ExpressionUUID->
  "11f7795d-db49-4d88-8608-bbfd0690b520"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["x", "1"]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["w", "2"], "-", 
       RowBox[{
        SubscriptBox["c", "1"], "\[VeryThinSpace]", 
        SubscriptBox["x", "1"]}]}], ">"}], "\[VeryThinSpace]", "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"9bd82029-b573-4343-958b-fc730927f7db"],
 "  "
}], "Text",
 CellChangeTimes->{{3.8765699980358257`*^9, 3.8765700873043537`*^9}, {
  3.8765710491751547`*^9, 
  3.8765710534045806`*^9}},ExpressionUUID->"5dd3a108-5bc4-477c-abbb-\
f1b8153fb1c7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["x", "1"]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["w", "2"], "-", 
       RowBox[{
        SubscriptBox["c", "1"], "\[VeryThinSpace]", 
        SubscriptBox["x", "1"]}]}], ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{
       SubscriptBox["x", 
        RowBox[{"1", ","}]], 
       SubscriptBox["w", "2"]}], ">", 
      RowBox[{"-", 
       OverscriptBox[
        SubscriptBox["c", "1"], "_"]}], "<", 
      SubscriptBox["x", "1"]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], ">"}], "\[VeryThinSpace]", "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"a5555f9d-170d-4599-8065-8420c5b7486a"],
 ", so set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "1"], "=", 
    FractionBox[
     RowBox[{"<", 
      RowBox[{
       SubscriptBox["w", 
        RowBox[{"2", ","}]], 
       SubscriptBox["x", "1"]}], ">"}], 
     RowBox[{
      RowBox[{"<", 
       SubscriptBox["x", "1"]}], ",", 
      RowBox[{
       SubscriptBox["x", "1"], ">"}]}]]}], TraditionalForm]],ExpressionUUID->
  "f55f97d2-7fb5-4055-8d98-663f727f89c9"]
}], "Text",
 CellChangeTimes->{{3.876570100260395*^9, 3.876570214179838*^9}, {
  3.8765710648888583`*^9, 
  3.8765710766090474`*^9}},ExpressionUUID->"ebafab7d-6476-4d7e-a611-\
b90773c767be"],

Cell["set", "Text",
 CellChangeTimes->{{3.8765710954040346`*^9, 
  3.8765710957012568`*^9}},ExpressionUUID->"98c5ef8a-0d2a-40ea-9b3a-\
d0fd25c1cb37"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["x", "2"], "=", 
   RowBox[{
    SubscriptBox["w", "2"], "-", 
    RowBox[{
     FractionBox[
      RowBox[{"<", 
       RowBox[{
        SubscriptBox["w", 
         RowBox[{"2", ","}]], 
        SubscriptBox["x", "1"]}], ">"}], 
      RowBox[{
       RowBox[{"<", 
        SubscriptBox["x", "1"]}], ",", 
       RowBox[{
        SubscriptBox["x", "1"], ">"}]}]], 
     SubscriptBox["x", "1"]}]}]}], 
  TraditionalForm]],ExpressionUUID->"ba6a5920-c3e4-463c-99c9-d7b9c5a69ec5"]], \
"Text",
 CellChangeTimes->{{3.876570100260395*^9, 3.876570214179838*^9}, {
  3.8765710648888583`*^9, 
  3.8765711103974094`*^9}},ExpressionUUID->"d79635b2-b38c-42b4-8777-\
6f251af1d093"],

Cell["\<\
Now that you have the formula, it just extrapolates for every vector added:\
\>", "Text",
 CellChangeTimes->{{3.876570100260395*^9, 3.876570214179838*^9}, {
  3.8765710648888583`*^9, 
  3.8765711357708235`*^9}},ExpressionUUID->"ed05edcc-ccc8-42ad-8883-\
acea6a01db4f"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["x", "j"], "=", 
   RowBox[{
    SubscriptBox["w", "j"], "-", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "1"}], 
      RowBox[{"j", "-", "1"}]], 
     RowBox[{
      FractionBox[
       RowBox[{"<", 
        RowBox[{
         SubscriptBox["w", 
          RowBox[{"j", ","}]], 
         SubscriptBox["x", "k"]}], ">"}], 
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["x", "k"]}], ",", 
        RowBox[{
         SubscriptBox["x", "k"], ">"}]}]], 
      SubscriptBox["x", "k"]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"bda34460-6d69-48bc-b0d3-da2fb787cfb7"]], \
"Text",
 CellChangeTimes->{{3.876570100260395*^9, 3.876570214179838*^9}, {
  3.8765710648888583`*^9, 
  3.876571192209908*^9}},ExpressionUUID->"5aa611a8-7d1a-4aeb-b3ab-\
1a37ece1841a"],

Cell["This is known as the Gram-Schmidt Formula.  ", "Text",
 CellChangeTimes->{{3.876571200290571*^9, 3.876571214323129*^9}, {
  3.8765712736978493`*^9, 
  3.8765712736978493`*^9}},ExpressionUUID->"12d70d84-2214-4520-9bbf-\
1a38700e6ddd"],

Cell[TextData[{
 "Repeatedly applying this formula, we get an orthogonal basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", 
     RowBox[{"...", 
      SubscriptBox["x", "m"]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "a4679f26-2f6c-403b-8799-4bca2da05734"],
 " for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "a77b29db-61ec-499b-bd7f-cfdbee4c768f"],
 "."
}], "Text",
 CellChangeTimes->{{3.876571200290571*^9, 3.876571214323129*^9}, {
  3.876571274762959*^9, 
  3.87657131061858*^9}},ExpressionUUID->"5b3b3898-c0dc-460f-91db-\
1a571ddbff4d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Lemma:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, 
   3.845547218352953*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"0d7cb41e-47a9-424d-9f47-9dcff68a38d2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["w", "1"], ",", " ", 
     SubscriptBox["w", "2"], ",", " ", "...", ",", 
     SubscriptBox["w", "m"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "d90e618f-f7bb-4bdf-be90-5f57d8e9a4cd"],
 " be a basis for a subspace ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "5b3818ee-b187-443c-b19c-da42f42941df"],
 " of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c335ebb5-c478-40ff-9e10-1c0345f08739"],
 ".  Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "j"], "=", 
    RowBox[{
     SubscriptBox["w", "j"], "-", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], 
       RowBox[{"j", "-", "1"}]], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{"j", ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "7fc49452-c09f-44fc-95db-07db6f7f02de"],
 ".  Then for any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", "m"}], TraditionalForm]],ExpressionUUID->
  "c23ac71c-c84c-491c-b7c4-fbd6ed676ac2"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", " ", 
       RowBox[{"...", 
        SubscriptBox["w", "j"]}]}], "}"}]}], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", " ", "...", ",", " ", 
       SubscriptBox["x", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "8de27ad2-67bd-4ee2-9adf-e1751d484ef8"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
  3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, {
  3.876828533332502*^9, 3.8768286330670156`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4f8181c5-981c-4035-8ad0-63cd1fbdb78f"],

Cell[TextData[StyleBox["PROOF:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.624973938349987*^9}, {3.6252331237260103`*^9, 
  3.625233125710514*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5855f0d6-765b-4642-851a-d3d9c44fcaa4"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],ExpressionUUID->
  "4c2d8e03-88f8-410d-9a91-5f81ad90e080"],
 " is multiple of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "1"], TraditionalForm]],ExpressionUUID->
  "6d32eb6d-4d9a-404c-a303-220e1593999a"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      SubscriptBox["w", "1"], "}"}]}], "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      SubscriptBox["x", "1"], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "41a5245d-d31f-4c9c-bf0b-807331f909e2"]
}], "Text",
 CellChangeTimes->{{3.8768309160071974`*^9, 
  3.876830977740076*^9}},ExpressionUUID->"1965dba4-de43-41bd-aa22-\
078f4bfc54b0"],

Cell[TextData[{
 "Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"]}], "}"}]}], "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "f06b8c38-6666-4617-9eeb-35e65a33c670"]
}], "Text",
 CellChangeTimes->{{3.8768309904939833`*^9, 
  3.876831023888139*^9}},ExpressionUUID->"f17fe07a-2c45-42ae-ab4d-\
3e4e9ad21844"],

Cell[TextData[{
 "Then since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", 
    RowBox[{"j", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "3cfb820a-b260-43ca-894d-7fe9c274a7d9"],
 " is part of a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "c96167a0-bec6-48ed-b8af-c6255744bc91"],
 ", we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", 
     RowBox[{"j", "+", "1"}]], "\[NotElement]", " ", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "eedef037-f04c-4bc5-b5de-358a5fb10d14"],
 "."
}], "Text",
 CellChangeTimes->{{3.87683103359103*^9, 
  3.8768310956131563`*^9}},ExpressionUUID->"71540381-3a6b-4c3c-8444-\
dc031354cea5"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", 
     RowBox[{"j", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["w", 
      RowBox[{"j", "+", "1"}]], "-", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "j"], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{
            RowBox[{"j", "+", "1"}], ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "68dd2040-03dd-45a0-8798-e130a954fcf0"],
 ", is a linear combination of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", 
    RowBox[{"j", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "c4da42e7-9379-4de0-ac3b-4ce4471e5630"],
 " with vectors in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[" ",
     FontWeight->"Bold"], 
    StyleBox[
     RowBox[{
      RowBox[{"span", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["w", "1"], ",", "...", ",", 
         SubscriptBox["w", "j"]}], "}"}]}], ","}],
     FontWeight->"Plain"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"069af7a5-f09c-4f9e-9208-750002961db7"],
 " so by induction ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"], ",", 
       SubscriptBox["x", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}], "\[SubsetEqual]", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"9ef28379-640e-48f5-a0c5-8701e420a70b"],
 "."
}], "Text",
 CellChangeTimes->{{3.876831100971111*^9, 
  3.8768312399815598`*^9}},ExpressionUUID->"32c0bf3c-3188-433c-8e8b-\
cf7f0ff8e6bb"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", 
     RowBox[{"j", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["x", 
      RowBox[{"j", "+", "1"}]], "+", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "j"], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{
            RowBox[{"j", "+", "1"}], ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "92d5e40d-f8b1-4f31-95f6-35a885f4123f"],
 ", we also see that"
}], "Text",
 CellChangeTimes->{{3.8768314047052927`*^9, 
  3.8768314730899334`*^9}},ExpressionUUID->"db9d068c-4609-414b-af2a-\
d7aa7017a2b8"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"], ",", 
       SubscriptBox["w", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}], "\[SubsetEqual]", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"], ",", 
       SubscriptBox["x", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"8badfca1-117c-497d-9c13-3e3a07cede3e"]
}], "Text",
 CellChangeTimes->{{3.8768314047052927`*^9, 
  3.876831489786662*^9}},ExpressionUUID->"a4669dfc-63a4-40fd-935f-\
204aad1099aa"],

Cell["Hence the two sets are equal.  ", "Text",
 CellChangeTimes->{{3.8768314792714076`*^9, 
  3.87683150154622*^9}},ExpressionUUID->"92ef0811-5ff9-4235-b909-\
291d896b89af"],

Cell[TextData[{
 "Remark: Since the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["w", "j"], "'"}], "s"}], TraditionalForm]],ExpressionUUID->
  "94b2bc5c-093a-4c44-b314-f8190cb26699"],
 " were part of a basis, we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["w", "1"], ",", "...", ",", 
     SubscriptBox["w", "j"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "0723f832-8f0e-47eb-856b-ef3ab3381066"],
 " is linearly independent.  When we create the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "j"], TraditionalForm]],ExpressionUUID->
  "dbcbe268-fea8-480e-b148-89965cc13f43"],
 ", we get orthogonal vectors, and a nonzero set of orthogonal vectors is \
linearly independent, so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["x", "1"], ",", "...", ",", 
     SubscriptBox["x", "j"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "3b7416ce-0d29-4440-b439-73fef1c96ae7"],
 " are also linearly independent. "
}], "Text",
 CellChangeTimes->{{3.8768314792714076`*^9, 3.8768315119645567`*^9}, {
  3.876831679242244*^9, 
  3.8768317704291215`*^9}},ExpressionUUID->"21e378d0-0df1-45e2-9872-\
5dc21975a5de"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
