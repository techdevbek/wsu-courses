Cell[TextData[StyleBox["6.2 Gram-Schmidt and Orthogonality",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.6225494720298038`*^9, 
   3.622549507234743*^9}, {3.6235856366612887`*^9, 3.623585653224654*^9}, {
   3.6240206450382576`*^9, 3.6240206470696516`*^9}, {3.6240206789248157`*^9, 
   3.6240206887691174`*^9}, 3.624626589860346*^9, {3.62462665353562*^9, 
   3.6246266752906113`*^9}, {3.845546563262905*^9, 3.845546571680436*^9}, {
   3.8455471936593513`*^9, 3.845547207129469*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"0a242ebb-b24f-46d7-85e1-067849ff2da6"],

Cell[TextData[{
 "Definition:  A basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", " ", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "54eff254-d710-4b4f-9c65-e88cb7503aa8"],
 " is said to be ",
 StyleBox["orthogonal",
  FontSlant->"Italic"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], "\[VeryThinSpace]", "=", " ", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"50e7f71b-7719-4b39-b3ef-3bf8fbe64a7a"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[NotEqual]", "j"}], TraditionalForm]],ExpressionUUID->
  "4d0d3c31-5053-4834-beab-380d02c8f971"],
 ".  It is said to be ",
 StyleBox["orthonormal",
  FontSlant->"Italic"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], "\[VeryThinSpace]", "=", " ", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"904864cd-6c6d-4366-affc-eaef8c900ef2"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[NotEqual]", "j"}], TraditionalForm]],ExpressionUUID->
  "954edad5-3965-482d-8993-edc37f645c1e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "i"], ">"}], " ", "=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6a0d7eb5-1dce-40f9-ac6c-4725fa679557"],
 "."
}], "Text",
 CellChangeTimes->{{3.8765676114397535`*^9, 3.87656766386509*^9}, {
  3.9088867237645473`*^9, 
  3.908886775215268*^9}},ExpressionUUID->"75ad2e51-5edc-41d4-8d91-\
fe531d4a326e"],

