 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5e9cc772-9e95-48b4-938f-f136b2912973"],

Cell["\<\
An orthogonal set of nonzero vectors is linearly independent.  \
\>", "Text",
 CellChangeTimes->{{3.9088869200779305`*^9, 
  3.908886948902487*^9}},ExpressionUUID->"85ac0701-145a-47bd-8b9a-\
e33527829c67"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Proof:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, 
   3.845547218352953*^9, {3.9088869597550077`*^9, 3.9088869602581015`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"2f7ba655-409c-4623-979c-72ed85a24c34"],

Cell[TextData[{
 "let ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "3ab3b20a-0ed1-4a8b-9beb-7c3a7cdd949b"],
 " be an ",
 StyleBox["orthogonal",
  FontSlant->"Italic"],
 " set of nonzero vectors."
}], "Text",
 CellChangeTimes->{{3.9088869732823877`*^9, 
  3.9088871135733967`*^9}},ExpressionUUID->"d9cb2edf-985e-41f3-a373-\
054a3214879a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"f475b019-8cf8-4670-adc1-c54a78ac4b45"],

Cell[TextData[{
 "Suppose \[Beta] is linearly dependent.  Then there are nonzero vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", " ", 
    SubscriptBox["v", "2"], ",", "...", ",", " ", 
    SubscriptBox["v", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0feaa06e-5751-40bf-8561-1c1128bbc690"],
 " and nonzero scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", "...", ",", 
    SubscriptBox["a", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5e48ed06-2f12-4509-9b57-20c73a7db384"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", "0."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4ffbfb38-16e4-4183-904a-f01f96a2e0da"]
}], "Text",
 CellChangeTimes->{{3.9088869732823877`*^9, 
  3.9088871157482457`*^9}},ExpressionUUID->"c16188d1-5d25-4525-ac4d-\
cab1f1a4505c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"22c17ffb-30df-4d6d-8101-820ab73c7232"],

Cell[TextData[{
 "But for any ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "9980c916-81a2-4524-b85e-9162269be52e"],
 ","
}], "Text",
 CellChangeTimes->{{3.90888713274415*^9, 3.9088873565185003`*^9}, {
  3.9088951241339064`*^9, 
  3.9088951241358967`*^9}},ExpressionUUID->"c9e528fb-730a-460a-9e0d-\
0d4754db3b5e"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "=", 
     RowBox[{"<", 
      SubscriptBox["v", "j"]}]}], ",", 
    RowBox[{
     RowBox[{"0", ">"}], " ", "=", " ", 
     RowBox[{"<", 
      SubscriptBox["v", "j"]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", "1"], 
          SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
       RowBox[{
        SubscriptBox["a", "n"], 
        SubscriptBox["v", "n"]}]}], ">"}], " ", "=", 
     RowBox[{
      OverscriptBox[
       SubscriptBox["a", "1"], "_"], "<", 
      SubscriptBox["v", "j"]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["v", "1"], ">", "+"}], "..."}], "+", 
      OverscriptBox[
       SubscriptBox["a", "n"], "_"]}], "<", 
     SubscriptBox["v", "j"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "n"], ">"}], " ", "=", 
     RowBox[{
      OverscriptBox[
       SubscriptBox["a", "j"], "_"], "<", 
      SubscriptBox["v", "j"]}]}], ",", 
    RowBox[{
     SubscriptBox["v", "j"], ">"}]}], TraditionalForm]],ExpressionUUID->
  "74efeb5f-93d2-4ce8-806d-cb272fc200b6"],
 ", which implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "j"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "dff8c649-d750-4e42-b64f-f61285e48e02"],
 ", a contradiction. Thus \[Beta] must be linearly indepedent. "
}], "Text",
 CellChangeTimes->{{3.90888713274415*^9, 
  3.9088873565185003`*^9}},ExpressionUUID->"76ddef4d-4565-4046-8e46-\
acdf70708d13"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Lemma:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
