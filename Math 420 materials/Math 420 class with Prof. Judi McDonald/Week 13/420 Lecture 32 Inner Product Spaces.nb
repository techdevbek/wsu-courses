Solution",ExpressionUUID->"545c5afd-be0e-4bc2-bf4d-6aab6b7caf25"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"||", " ", "||"}], TraditionalForm]],ExpressionUUID->
  "735bb48c-ffd5-4705-adb4-8ced29a56af1"],
 "  be the norm on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"4227b649-5e03-43bd-b74a-886e1344b050"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", "x", "||"}], "=", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["x", "T"], "x", " "}]]}], TraditionalForm]],
  ExpressionUUID->"84916f9e-3d66-4879-a989-f8b6f9501850"],
 ". If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "n"]}], "->", 
    SuperscriptBox["\[DoubleStruckCapitalR]", "n"]}], TraditionalForm]],
  ExpressionUUID->"1474a20a-5d13-406c-9ce5-b1f2eb068462"],
 " is a linear operator and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "992ce72c-12d0-458e-bcac-47bcf50c6459"],
 " is in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"c8c20c0a-70ed-472f-9967-2e7b76f0ca43"],
 " a ",
 StyleBox["least-squares solution",
  FontWeight->"Bold"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "\[VeryThinSpace]", "x", ")"}], "=", "b"}], 
   TraditionalForm]],ExpressionUUID->"daa1ae06-0003-46fa-a5e3-e2ba1630471c"],
 " is an ",
 Cell[BoxData[
  FormBox[
   StyleBox[
    OverscriptBox["x", "^"],
    FontSlant->"Italic"], TraditionalForm]],ExpressionUUID->
  "3707b047-1cce-48b1-9638-b2b02e11ad1f"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"22f12c68-d387-4a40-9a9f-ba83898830ca"],
 " such that "
}], "Text",
 CellChangeTimes->{{3.6299181870017877`*^9, 3.629918229300873*^9}, {
   3.6299182730843825`*^9, 3.6299182871632447`*^9}, 3.6299184158498106`*^9, {
   3.6299189401479473`*^9, 3.6299189456638656`*^9}, {3.634467064146456*^9, 
   3.6344670719507303`*^9}, {3.634467159317587*^9, 3.634467252357836*^9}, {
   3.6365608974272203`*^9, 3.6365609010716753`*^9}, {3.8459819815396175`*^9, 
   3.845981995576762*^9}, {3.845982047217245*^9, 3.845982170384697*^9}, {
   3.845997653939934*^9, 3.84599765394095*^9}, {3.877603633582656*^9, 
   3.877603697451128*^9}, {3.8776038537078047`*^9, 3.877603917214605*^9}},
 FontFamily->"Times New Roman",
 CellTags->
  "DEFINITION Least-Squares \
Solution",ExpressionUUID->"19d6e6ac-ae49-4b86-8b6c-bef07f3c0bef"],

Cell[TextData[{
 "\n",
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"b", "-", 
         RowBox[{"T", "(", "\[VeryThinSpace]", 
          OverscriptBox["x", "^"], ")"}]}], "\[RightDoubleBracketingBar]"}], 
       "\[LessEqual]", 
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"b", "-", 
         RowBox[{"T", "(", "\[VeryThinSpace]", "x", ")"}]}], 
        "\[RightDoubleBracketingBar]"}]}]}
    },
    GridBoxItemSize->{"Columns" -> {{
         Scaled[0.96]}}}], TraditionalForm]],ExpressionUUID->
  "bee526cd-17df-4052-a4d3-d16bf4187dde"],
 "\nfor all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "61d80b1b-0321-4d52-8e77-be2e1b836104"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"6ae0d6db-e822-4a60-a220-687dbf2901c9"],
 ".   "
}], "Text",
 CellChangeTimes->{{3.6299181870017877`*^9, 3.629918229300873*^9}, {
   3.6299182730843825`*^9, 3.6299182871632447`*^9}, 3.6299184158498106`*^9, {
   3.6299189401479473`*^9, 3.6299189456638656`*^9}, {3.634467064146456*^9, 
