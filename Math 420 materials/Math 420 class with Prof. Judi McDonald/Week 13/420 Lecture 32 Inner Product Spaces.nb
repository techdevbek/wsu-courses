Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["w", "1"], ",", " ", 
     SubscriptBox["w", "2"], ",", " ", "...", ",", 
     SubscriptBox["w", "m"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "d90e618f-f7bb-4bdf-be90-5f57d8e9a4cd"],
 " be a basis for a subspace ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "5b3818ee-b187-443c-b19c-da42f42941df"],
 " of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c335ebb5-c478-40ff-9e10-1c0345f08739"],
 ".  Set"
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, {
   3.876828533332502*^9, 3.8768286330670156`*^9}, 3.9088873642356925`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4f8181c5-981c-4035-8ad0-63cd1fbdb78f"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "j"], "=", 
    RowBox[{
     SubscriptBox["w", "j"], "-", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], 
       RowBox[{"j", "-", "1"}]], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{"j", ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "efcf370f-f40f-41f0-9c7b-460831fcafce"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, {
   3.876828533332502*^9, 3.8768286330670156`*^9}, 3.908887372762212*^9},
 TextAlignment->Center,
 FontFamily->
  "Times New Roman",ExpressionUUID->"d99e486d-3a35-41ae-be53-83614a960833"],

Cell[TextData[{
 "Then for any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<=", "j", "<=", "m"}], TraditionalForm]],ExpressionUUID->
  "304d83f8-8bf7-447b-b6bd-b10eeaf6eda6"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", " ", 
       RowBox[{"...", 
        SubscriptBox["w", "j"]}]}], "}"}]}], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", " ", "...", ",", " ", 
       SubscriptBox["x", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "0f8273e7-5153-4eff-9370-53e30d800334"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
  3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, {
  3.876828533332502*^9, 3.8768286330670156`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5bf19f48-7677-4ecd-9da9-fc964bcd354b"],

Cell[TextData[StyleBox["PROOF:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
  3.624973937459322*^9, 3.624973938349987*^9}, {3.6252331237260103`*^9, 
  3.625233125710514*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5855f0d6-765b-4642-851a-d3d9c44fcaa4"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]],ExpressionUUID->
  "4c2d8e03-88f8-410d-9a91-5f81ad90e080"],
 " is multiple of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "1"], TraditionalForm]],ExpressionUUID->
  "6d32eb6d-4d9a-404c-a303-220e1593999a"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      SubscriptBox["w", "1"], "}"}]}], "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      SubscriptBox["x", "1"], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "41a5245d-d31f-4c9c-bf0b-807331f909e2"]
}], "Text",
 CellChangeTimes->{{3.8768309160071974`*^9, 
  3.876830977740076*^9}},ExpressionUUID->"1965dba4-de43-41bd-aa22-\
078f4bfc54b0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"48cd4b04-792f-49fc-bbf2-37da2db4eb56"],

Cell[TextData[{
 "Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"]}], "}"}]}], "=", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "f06b8c38-6666-4617-9eeb-35e65a33c670"]
}], "Text",
 CellChangeTimes->{{3.8768309904939833`*^9, 
  3.876831023888139*^9}},ExpressionUUID->"f17fe07a-2c45-42ae-ab4d-\
3e4e9ad21844"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"39d43423-a294-4822-b32e-e67e351d9cdd"],

Cell[TextData[{
 "Then since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", 
    RowBox[{"j", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "3cfb820a-b260-43ca-894d-7fe9c274a7d9"],
 " is part of a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "c96167a0-bec6-48ed-b8af-c6255744bc91"],
 ", we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", 
     RowBox[{"j", "+", "1"}]], "\[NotElement]", " ", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "eedef037-f04c-4bc5-b5de-358a5fb10d14"],
 "."
}], "Text",
 CellChangeTimes->{{3.87683103359103*^9, 
  3.8768310956131563`*^9}},ExpressionUUID->"71540381-3a6b-4c3c-8444-\
dc031354cea5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"7395013f-bf64-4550-af4e-ba2f0c1ee9b6"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", 
     RowBox[{"j", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["w", 
      RowBox[{"j", "+", "1"}]], "-", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "j"], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{
            RowBox[{"j", "+", "1"}], ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "68dd2040-03dd-45a0-8798-e130a954fcf0"],
 ", is a linear combination of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", 
    RowBox[{"j", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "c4da42e7-9379-4de0-ac3b-4ce4471e5630"],
 " with vectors in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[" ",
     FontWeight->"Bold"], 
    StyleBox[
     RowBox[{
      RowBox[{"span", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["w", "1"], ",", "...", ",", 
         SubscriptBox["w", "j"]}], "}"}]}], ","}],
     FontWeight->"Plain"]}], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"069af7a5-f09c-4f9e-9208-750002961db7"],
 " by induction ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"], ",", 
       SubscriptBox["x", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}], "\[SubsetEqual]", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"9ef28379-640e-48f5-a0c5-8701e420a70b"],
 "."
}], "Text",
 CellChangeTimes->{{3.876831100971111*^9, 3.8768312399815598`*^9}, {
  3.908887646743455*^9, 
  3.9088876600774527`*^9}},ExpressionUUID->"32c0bf3c-3188-433c-8e8b-\
cf7f0ff8e6bb"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", 
     RowBox[{"j", "+", "1"}]], "=", 
    RowBox[{
     SubscriptBox["x", 
      RowBox[{"j", "+", "1"}]], "+", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "j"], 
      RowBox[{
       FractionBox[
        RowBox[{"<", 
         RowBox[{
          SubscriptBox["w", 
           RowBox[{
            RowBox[{"j", "+", "1"}], ","}]], 
          SubscriptBox["x", "k"]}], ">"}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "k"]}], ",", 
         RowBox[{
          SubscriptBox["x", "k"], ">"}]}]], 
       SubscriptBox["x", "k"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "92d5e40d-f8b1-4f31-95f6-35a885f4123f"],
 ", we also see that"
}], "Text",
 CellChangeTimes->{{3.8768314047052927`*^9, 
  3.8768314730899334`*^9}},ExpressionUUID->"db9d068c-4609-414b-af2a-\
d7aa7017a2b8"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["w", "1"], ",", "...", ",", 
       SubscriptBox["w", "j"], ",", 
       SubscriptBox["w", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}], "\[SubsetEqual]", 
    RowBox[{"span", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "j"], ",", 
       SubscriptBox["x", 
        RowBox[{"j", "+", "1"}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"8badfca1-117c-497d-9c13-3e3a07cede3e"]
}], "Text",
 CellChangeTimes->{{3.8768314047052927`*^9, 
  3.876831489786662*^9}},ExpressionUUID->"a4669dfc-63a4-40fd-935f-\
204aad1099aa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"c00b4035-0346-4ee3-9547-684989f21df2"],

Cell["Hence the two sets are equal.  ", "Text",
 CellChangeTimes->{{3.8768314792714076`*^9, 
  3.87683150154622*^9}},ExpressionUUID->"92ef0811-5ff9-4235-b909-\
291d896b89af"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Question:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, 
   3.845547218352953*^9, {3.908887787935249*^9, 3.908887790458647*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"fa31e463-0b00-410f-b95e-3b899ff67533"],

Cell["\<\
What will happen if you apply Gram Schmidt to a linearly dependent set?\
\>", "Text",
 CellChangeTimes->{{3.876831792868677*^9, 3.8768318262703238`*^9}, {
  3.9088877160234537`*^9, 
  3.9088877562122164`*^9}},ExpressionUUID->"d8e26609-9e09-405e-aee3-\
51dbf1a40901"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Example:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.62497393816249*^9}, {3.6252314261267047`*^9, 
   3.625231473394867*^9}, {3.625233118053837*^9, 3.625233120600855*^9}, 
   3.845547218352953*^9, {3.9088878036878796`*^9, 3.9088878047684765`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"4fa4ea4d-86fd-48e8-ae19-a3373c003354"],

Cell[TextData[{
 "Try applying Gram Schmidt to the linearly dependent set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", ")"}], " ", ",", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"2"},
         {
          RowBox[{"-", "1"}]},
         {"0"}
        }], "\[NoBreak]", ")"}], ",", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", ")"}]}], "}"}], "  "}], TraditionalForm]],
  ExpressionUUID->"ea577aae-c3c5-4060-bfa3-b59d25c98246"],
 "using the dot product as the inner product"
}], "Text",
 CellChangeTimes->{{3.8768318889024024`*^9, 3.876831944319173*^9}, {
  3.876831980292601*^9, 3.8768319806032476`*^9}, {3.9088878077442656`*^9, 
  3.9088878232013617`*^9}, {3.908896025403095*^9, 
  3.908896031686596*^9}},ExpressionUUID->"b29b7a67-dbcb-42b9-afe4-\
6e17efb6ebf3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1"},
       {"1"},
       {"0"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e3725a04-100d-4355-9c7d-cb5b049a670f"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "2"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"2"},
         {
          RowBox[{"-", "1"}]},
         {"0"}
        }], "\[NoBreak]", ")"}], "-", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["x", "2"]}], ",", 
         RowBox[{
          SubscriptBox["v", "1"], ">"}]}], 
        RowBox[{
         RowBox[{"<", 
          SubscriptBox["v", "1"]}], ",", 
         RowBox[{
          SubscriptBox["v", "1"], ">"}]}]], 
       RowBox[{"(", "\[NoBreak]", GridBox[{
          {"1"},
          {"1"},
          {"0"}
         }], "\[NoBreak]", ")"}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "\[NoBreak]", GridBox[{
          {"2"},
          {
           RowBox[{"-", "1"}]},
          {"0"}
         }], "\[NoBreak]", ")"}], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"(", "\[NoBreak]", GridBox[{
           {"1"},
           {"1"},
           {"0"}
          }], "\[NoBreak]", ")"}]}]}], "=", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          RowBox[{"3", "/", "2"}]},
         {
          RowBox[{
           RowBox[{"-", "3"}], "/", "2"}]},
         {"0"}
        }], "\[NoBreak]", ")"}], " "}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b7c040f-fa34-40b8-af90-9e360e332a0e"]
}], "Text",
 CellChangeTimes->{{3.9088959453434916`*^9, 
  3.908896125101081*^9}},ExpressionUUID->"d109c09a-870c-4c37-a5fe-\
a1fa1071f30a"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["v", "3"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"1"},
        {"0"},
        {"0"}
       }], "\[NoBreak]", ")"}], "-", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["x", "3"]}], ",", 
        RowBox[{
         SubscriptBox["v", "1"], ">"}]}], 
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["v", "1"]}], ",", 
        RowBox[{
         SubscriptBox["v", "1"], ">"}]}]], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", ")"}]}], "-", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["x", "3"]}], ",", 
        RowBox[{
         SubscriptBox["v", "2"], ">"}]}], 
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["v", "2"]}], ",", 
        RowBox[{
         SubscriptBox["v", "2"], ">"}]}]], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          RowBox[{"3", "/", "2"}]},
         {
          RowBox[{
           RowBox[{"-", "3"}], "/", "2"}]},
         {"0"}
        }], "\[NoBreak]", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"1"},
        {"0"},
        {"0"}
       }], "\[NoBreak]", ")"}], "-", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", ")"}]}], "-", 
     RowBox[{
      FractionBox[
       RowBox[{"3", "/", "2"}], 
       RowBox[{"9", "/", "2"}]], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          RowBox[{"3", "/", "2"}]},
         {
          RowBox[{
           RowBox[{"-", "3"}], "/", "2"}]},
         {"0"}
        }], "\[NoBreak]", ")"}]}]}]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"00ee4a51-7673-41c3-a703-c10d86b7ad61"]], \
"Text",
 CellChangeTimes->{{3.9088959453434916`*^9, 3.9088962342044973`*^9}, {
  3.9088963526279545`*^9, 
  3.908896354623146*^9}},ExpressionUUID->"c4ceaa7b-3073-463b-9a84-\
23706ceb3ae0"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"1"},
        {"0"},
        {"0"}
       }], "\[NoBreak]", ")"}], "-", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", ")"}]}], "-", 
     RowBox[{
      FractionBox["1", "3"], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          RowBox[{"3", "/", "2"}]},
         {
          RowBox[{
           RowBox[{"-", "3"}], "/", "2"}]},
         {"0"}
        }], "\[NoBreak]", ")"}]}]}], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0"},
       {"0"},
       {"0"}
      }], "\[NoBreak]", ")"}], " "}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"178cc6d9-66c7-4b0b-a778-000a4868c7ba"]], \
"Text",
 CellChangeTimes->{{3.9088959453434916`*^9, 3.908896263549776*^9}, {
  3.9088962943601155`*^9, 3.908896300739915*^9}, {3.9088963786036787`*^9, 
  3.9088963842929335`*^9}},ExpressionUUID->"0609fc52-9823-4339-aa70-\
443e77086dd5"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["6.3 The Adjoint of a Linear Operator",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.6225494720298038`*^9, 
   3.622549507234743*^9}, {3.6235856366612887`*^9, 3.623585653224654*^9}, {
   3.6240206450382576`*^9, 3.6240206470696516`*^9}, {3.6240206789248157`*^9, 
   3.6240206887691174`*^9}, 3.624626589860346*^9, {3.62462665353562*^9, 
   3.6246266752906113`*^9}, {3.6252307815053463`*^9, 3.6252308090068398`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"478ff1ea-d165-43be-ac2a-cd182c307715"],

Cell[TextData[StyleBox["Question:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Text",
 CellChangeTimes->{{3.6246272366572657`*^9, 3.624627254345703*^9}, {
   3.6246301866462574`*^9, 3.624630192082405*^9}, {3.624630228897433*^9, 
   3.624630232151129*^9}, {3.625230969017006*^9, 3.6252310981749153`*^9}, {
   3.6252311400831985`*^9, 3.6252311400831985`*^9}, 3.625231273411934*^9, 
   3.84572657345975*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"2125b8d3-6df0-4174-9804-45a6e5d63845"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", "y"}], TraditionalForm]],ExpressionUUID->
  "d7b24509-bf63-499a-a6d0-6f82a34fc660"],
 " be vectors in an inner product space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "19ae3570-353a-48d5-b1e6-de200ed3060c"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "ead76ef7-0c34-4624-91bf-f059200fcf5a"],
 " a linear operator. Consider ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"T", "(", "x", ")"}]}], ",", " ", 
    RowBox[{"y", ">", "."}]}], TraditionalForm]],ExpressionUUID->
  "14e32cea-0df2-4eae-9a46-2d235e2b6753"],
 "  Can we move the ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "da661d6d-53cd-4c41-9133-726a2666ea28"],
 " across the comma and put it with the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "?"}], TraditionalForm]],ExpressionUUID->
  "a8309f66-aa0c-4aba-a4ff-b2c1fea47e6a"],
 " If we want ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"T", "(", "x", ")"}]}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{
     RowBox[{"U", "(", "y", ")"}], ">"}], ","}], TraditionalForm]],
  ExpressionUUID->"64e8ab0b-a9a0-42d7-8c59-c72d838d29a5"],
 " what is ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "5d59019a-7ffd-4126-8e4f-04556c6e895b"],
 "? "
}], "Text",
 CellChangeTimes->{{3.6246272366572657`*^9, 3.624627254345703*^9}, {
   3.6246301866462574`*^9, 3.624630192082405*^9}, {3.624630228897433*^9, 
   3.624630232151129*^9}, {3.625230969017006*^9, 3.6252310981749153`*^9}, {
   3.6252311400831985`*^9, 3.6252311400831985`*^9}, 3.625231273411934*^9, {
   3.8768289962041903`*^9, 3.876829014942156*^9}, {3.8768325550696535`*^9, 
   3.876832600469571*^9}, {3.8768326572687006`*^9, 3.8768327610256195`*^9}, 
   3.876832891417618*^9, 3.908896551983615*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f94b6852-2ac8-46aa-8ac1-c094add4b4bd"],

Cell[TextData[{
 "You can read the proof that such a ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d8ef6723-ea91-4114-8927-c352d7f99eae"],
 " exists and is a linear transformation from ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f7887637-536a-4d03-9531-5c7348d30cf3"],
 " to ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cbfc531f-f4d8-4208-bc75-6aaef57ef8d2"],
 " in the text or online.  "
}], "Text",
 CellChangeTimes->{{3.908892205672806*^9, 3.9088922596912704`*^9}, {
  3.9088925302934866`*^9, 
  3.908892551210826*^9}},ExpressionUUID->"98945747-738f-46b5-9b76-\
fe9e90c02730"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Observation: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6246272366572657`*^9, 3.624627254345703*^9}, {
   3.6246301866462574`*^9, 3.624630192082405*^9}, {3.624630228897433*^9, 
   3.624630232151129*^9}, {3.625230969017006*^9, 3.6252310981749153`*^9}, {
   3.6252311400831985`*^9, 3.625231248406314*^9}, {3.625231280798029*^9, 
   3.6252312816417894`*^9}, {3.6253488349812765`*^9, 3.6253489053910685`*^9}, 
   3.845726580322116*^9, {3.8769306868900447`*^9, 3.8769306919381065`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"7daf940f-51b7-4134-adff-33e5ad97271e"],

Cell[TextData[{
 "There is a function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], ":", "V"}], "->", "V"}], TraditionalForm]],
  ExpressionUUID->"cef83aac-459a-49bf-9b28-f1047a2b4f61"],
 " is a linear operator and"
}], "Text",
 CellChangeTimes->{{3.6246272366572657`*^9, 3.624627254345703*^9}, {
  3.6246301866462574`*^9, 3.624630192082405*^9}, {3.624630228897433*^9, 
  3.624630232151129*^9}, {3.625230969017006*^9, 3.6252310981749153`*^9}, {
  3.6252311400831985`*^9, 3.625231248406314*^9}, {3.625231280798029*^9, 
  3.6252312816417894`*^9}, {3.6253488349812765`*^9, 3.6253489053910685`*^9}, {
  3.876930700369631*^9, 3.8769307345250216`*^9}, {3.876931313833274*^9, 
  3.8769313165024014`*^9}, {3.8769313491006174`*^9, 3.8769313504949617`*^9}, {
  3.8769314402971087`*^9, 3.876931444991704*^9}, {3.8769321163922615`*^9, 
  3.8769321255307517`*^9}, {3.8770044677049785`*^9, 3.8770044677049785`*^9}, {
  3.90889220105504*^9, 3.9088922031605864`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"45842451-7ab2-4148-bb0d-e443c18d5f53"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"T", "(", "x", ")"}]}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], "(", "y", ")"}], ">"}], ",", 
    RowBox[{"\[ForAll]", " ", "x"}], ",", 
    RowBox[{"y", " ", "\[Element]", "V"}]}], TraditionalForm]],ExpressionUUID->
  "6a7531b6-8608-4512-9d91-1851bda79b9e"],
 ", "
}], "Text",
 CellChangeTimes->{{3.6246272366572657`*^9, 3.624627254345703*^9}, {
  3.6246301866462574`*^9, 3.624630192082405*^9}, {3.624630228897433*^9, 
  3.624630232151129*^9}, {3.625230969017006*^9, 3.6252310981749153`*^9}, {
  3.6252311400831985`*^9, 3.625231248406314*^9}, {3.625231280798029*^9, 
  3.6252312816417894`*^9}, {3.6253488349812765`*^9, 3.6253489108913507`*^9}, {
  3.876930512329398*^9, 3.8769305125728703`*^9}},
 TextAlignment->Center,
 FontFamily->
  "Times New Roman",ExpressionUUID->"903cfe6b-27af-4f80-9a05-5a66f4ef59c0"],

Cell[TextData[{
 "The operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["T", "*"], TraditionalForm]],ExpressionUUID->
  "2bb10a42-0440-4f97-8672-2e388dd99042"],
 " is referred to as the ",
 StyleBox["adjoint ",
  FontSlant->"Italic"],
 "of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FontSize->12,ExpressionUUID->"8f1fe487-35d4-44de-90ae-dc8e7f50a129"],
 "."
}], "Text",
 CellChangeTimes->{{3.8457277336045723`*^9, 3.8457277443647757`*^9}, {
  3.876930738350314*^9, 3.876930738650149*^9}, {3.87693133039624*^9, 
  3.8769313388388886`*^9}, {3.8769314515507975`*^9, 3.876931460675548*^9}, {
  3.8769321351384473`*^9, 3.8769321456756544`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"11bf779f-59e5-40e4-9fe6-a9cd914d17b8"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{" ", 
   RowBox[{
    RowBox[{"Let", " ", "A", " ", "be", " ", "an", " ", 
     RowBox[{"n", "\[Cross]", "n"}], " ", "complex", " ", 
     RowBox[{"matrix", ".", "  ", "Define"}], " ", "the", " ", 
     StyleBox["adjoint",
      FontSlant->"Italic"], " ", 
     StyleBox["of",
      FontSlant->"Plain"], 
     StyleBox[" ",
      FontSlant->"Plain"], 
     StyleBox[Cell[TextData[Cell[BoxData[
       FormBox["A", TraditionalForm]],ExpressionUUID->
       "2ac812d5-e515-4c9e-956a-96d9cf04adb4"]],ExpressionUUID->
       "6f7154e7-4a1d-4009-99fa-dc03890dec88"],
      FontSlant->"Plain"], "  ", "by", " ", 
     SuperscriptBox["A", "*"]}], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["A", "_"], "T"], " ", "."}]}]}], TraditionalForm]],
 FontWeight->
  "Normal",ExpressionUUID->"bcf187dd-47e2-4830-b87a-c0d3b7eee09c"]], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.624973938349987*^9}, 3.625348885037197*^9, 
   3.6253489405648084`*^9, {3.6253491877870417`*^9, 3.6253492626382627`*^9}, {
