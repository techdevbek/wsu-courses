}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Lemma:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8457278365259776`*^9, 3.845727838738633*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"db00629f-8635-4d41-991f-cc0a8a3051d2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "485be874-509b-4f9c-a6e7-f70721b1fa07"],
 " be an orthonormal basis for a finite-dimensional inner product space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "56c91353-c433-4e04-904f-29bd5884e4a5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "V"}], TraditionalForm]],
  ExpressionUUID->"e2c0483f-798e-4e1b-ba32-18a2322f6860"],
 " a linear transformation.  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", 
      SuperscriptBox["T", "*"], "]"}], "\[Beta]"], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Beta]"], ")"}], "*"]}], TraditionalForm]],
  ExpressionUUID->"12bbef32-7f7f-45a3-b780-7235c7711608"],
 "."
}], "Text",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.624973938553127*^9}, 3.6253488878654547`*^9, {
   3.6253489430180616`*^9, 3.625349182927412*^9}, {3.625349264732094*^9, 
   3.625349264732094*^9}, {3.6253494901478767`*^9, 3.625349494945038*^9}, {
   3.6253496879234257`*^9, 3.625349694142501*^9}, 3.8457280241151524`*^9, {
   3.8458126856686163`*^9, 3.84581268784818*^9}, {3.8769316449796267`*^9, 
   3.8769316582975836`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"7b329360-61d0-4ce1-9c1f-272fedfd145d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6249730262253847`*^9, 3.624973038757332*^9}, {
   3.624973937459322*^9, 3.624973938553127*^9}, 3.6253488878654547`*^9, {
   3.6253489430180616`*^9, 3.625349182927412*^9}, {3.625349264732094*^9, 
   3.625349274326377*^9}, {3.8769318554*^9, 3.8769318566794486`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"f16397f8-c473-445c-96b6-b2379a395bca"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"]}], TraditionalForm]],ExpressionUUID->
  "62b9f725-9e7e-4d31-bf27-12858813ee2c"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    SubscriptBox[
     RowBox[{"[", 
      SuperscriptBox["T", "*"], "]"}], "\[Beta]"]}], TraditionalForm]],
  ExpressionUUID->"71736eb8-7ee2-4bc3-9a60-ba2bdf3284c3"],
 ".  Recall"
}], "Text",
 CellChangeTimes->{{3.877005210692568*^9, 
  3.877005329333151*^9}},ExpressionUUID->"b6cfe34a-42b5-4f3b-a5ad-\
3251b995397a"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["a", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "j"], ")"}]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "i"], ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      SubscriptBox["v", "j"]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "*"], "(", 
       SubscriptBox["v", "i"], ")"}], ">"}], "\[VeryThinSpace] ", "=", 
     RowBox[{
      OverscriptBox[
       RowBox[{
        RowBox[{"<", 
         RowBox[{
          SuperscriptBox["T", "*"], 
          RowBox[{"(", 
           SubscriptBox["v", "i"], ")"}]}]}], ",", 
        RowBox[{
         SubscriptBox["v", "j"], ">", " "}]}], "_"], "=", "  ", 
      OverscriptBox[
       SubscriptBox["b", 
        RowBox[{"j", "\[VeryThinSpace]", "i"}]], "_"], 
      "\[VeryThinSpace]"}]}]}], TraditionalForm]],ExpressionUUID->
  "aba93b29-e991-452f-89d2-c91e5950a914"]
}], "Text",
 CellChangeTimes->{{3.877005210692568*^9, 
  3.8770054657139397`*^9}},ExpressionUUID->"23809fef-7168-40dd-8a51-\
7afb6e572ce9"],

Cell[TextData[{
 "REMARK.  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["w", "1"], ",", 
     SubscriptBox["w", "2"], ",", "...", ",", 
     SubscriptBox["w", "n"]}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4ff14974-e330-4b20-8691-9ba4aeac5666"],
 " is an orthogonal basis, create an orthonormal basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["v", "1"], ",", " ", 
     RowBox[{"...", " ", 
      SubscriptBox["v", "n"]}]}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6705a006-a9a8-40e6-ba7c-405a09bd9016"],
 " by setting ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "j"], "=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{
        RowBox[{"<", 
         SubscriptBox["w", "j"]}], ",", 
        RowBox[{
         SubscriptBox["w", "j"], ">"}]}]]], 
     SubscriptBox["w", "j"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3fb887f1-893f-47f6-bd3a-b1bb3f3553bf"]
}], "Text",
 CellChangeTimes->{{3.9088970146034093`*^9, 
  3.908897112604767*^9}},ExpressionUUID->"4f4fff71-8343-4292-8e50-\
d850850dc269"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Properties: ", "Subsubsubsection",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
   3.62534972865994*^9, 3.625349730206897*^9}, {3.6253497751324263`*^9, 
   3.6253497886175084`*^9}, 3.8457281384627237`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"7f411d58-6ec0-43c9-850d-abd2be4561dc"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", " "}], TraditionalForm]],ExpressionUUID->
  "7fdb72b1-822b-473f-b5af-875c5835f5d3"],
 "and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "fd2285ca-ec20-474e-b86a-91b9b15e912c"],
 " be linear operators on an inner product space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "1fa96fd6-9998-444b-8aab-23b912230bdb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "\[Element]", "\[DoubleStruckCapitalF]", " "}], 
   TraditionalForm]],ExpressionUUID->"0f2de6a0-e76c-4776-b02a-219871f94f97"],
 ".  Then"
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349730206897*^9}, {3.6253497751324263`*^9, 
  3.6253497886175084`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"2a3a0b84-7e6a-4917-8762-7b1e53042693"],

Cell[TextData[{
 "(i)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"T", "+", "U"}], ")"}], "*"], "=", 
    RowBox[{
     SuperscriptBox["T", "*"], "+", 
     SuperscriptBox["U", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "75307b9d-a00d-4be5-9951-f256ab2d1e55"]
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349759444126*^9}, {3.6253497942427983`*^9, 
  3.6253497942427983`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"66a54a45-caa5-401d-baa5-9bbbd898ab32"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"T", " ", "U"}], ")"}], "*"], "=", 
    RowBox[{
     SuperscriptBox["U", "*"], 
     SuperscriptBox["T", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "895c5b58-4e70-439e-9d8a-32f11da4ca3b"]
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349759444126*^9}, {3.6253497942427983`*^9, 
  3.6253498247288036`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"dce3c434-16f7-4e53-b4c7-55360add3a13"],

Cell[TextData[{
 "(iii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"c", " ", "T"}], ")"}], "*"], "=", 
    RowBox[{
     OverscriptBox["c", "_"], " ", 
     SuperscriptBox["T", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "0bc641f0-143f-4317-b0f7-654d9ea3fb03"]
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349759444126*^9}, {3.6253497942427983`*^9, 
  3.625349862885375*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e199b52d-a3e1-4510-88ed-d2d8f15c5217"],

Cell[TextData[{
 "(iv) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", "**"], "=", "T"}], TraditionalForm]],ExpressionUUID->
  "c6e7a1c5-e2c4-46dd-bebc-dbca2fb907cb"]
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349759444126*^9}, {3.6253497942427983`*^9, 
  3.625349889121089*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"108f4d64-af73-4122-9b2b-ac7f84615101"],

Cell[TextData[{
 "(v)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["I", "V"], "*"], "=", 
    SubscriptBox["I", "V"]}], TraditionalForm]],ExpressionUUID->
  "7d64c4bd-4d57-49d2-b943-5f87bd7b85c7"]
}], "Text",
 CellChangeTimes->{{3.6253496203197374`*^9, 3.625349683751301*^9}, {
  3.62534972865994*^9, 3.625349759444126*^9}, {3.6253497942427983`*^9, 
  3.625349931720605*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"508e05a6-adf4-45de-8408-0bf9dd7de35a"],

Cell["The analogous results hold for matrices.  ", "Text",
 CellChangeTimes->{{3.6253499490312877`*^9, 3.6253499641727085`*^9}, {
   3.6254070536253276`*^9, 3.6254070641960278`*^9}, {3.6254072215601196`*^9, 
   3.625407221575736*^9}, 3.845728193490714*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"912c4711-7303-46fe-9352-f3d13f2735b8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6254075773330603`*^9, 3.6254078295450864`*^9}, {
   3.6254078710302525`*^9, 3.6254078710302525`*^9}, 3.6254105349566*^9, {
   3.845728290475359*^9, 3.8457282904783487`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"81343942-71e6-403b-911f-9a2f4cf3433b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "986a4920-b24b-49e3-a858-262daf02b24f"],
 " and let ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "0d8f8c33-3788-420c-a4fe-973ec31ae4c0"],
 " be a subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "44487f49-89a3-4162-918c-96d3a7e1c757"],
 ".  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"w", "+", "u"}]}], TraditionalForm]],ExpressionUUID->
  "66ae7596-c45e-463a-8759-78c56b5a4857"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", "W"}], TraditionalForm]],ExpressionUUID->
  "04111ada-623b-4d6b-8641-7cf0581b8b91"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[Element]", 
    SuperscriptBox["W", "\[Perpendicular]"]}], TraditionalForm]],
  ExpressionUUID->"6a5eb942-a404-412f-b3a2-40a6405ac0a9"],
 ", then ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "bf1084f8-fadf-4eca-8574-512711e71553"],
 " is the closet point in ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f4ef68c2-1980-4bd1-bad2-f584eaeea63e"],
 " to ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "20f61bde-54ee-4cad-b4b8-ba257d7c2d91"],
 "."
}], "Text",
 CellChangeTimes->{{3.6254075773330603`*^9, 3.6254078295450864`*^9}, {
   3.6254078710302525`*^9, 3.6254078710302525`*^9}, 3.6254105349566*^9, {
   3.845728291971899*^9, 3.845728292350402*^9}, {3.8457283523697033`*^9, 
   3.8457283882057056`*^9}, {3.8769998680551805`*^9, 
   3.8769998839883327`*^9}, {3.876999985084261*^9, 3.877000070617979*^9}, {
   3.877000142632509*^9, 3.877000167124631*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f32d53af-e6ad-4432-8e85-270aaa8e49f3"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Question:", "DefinitionFont",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6299181870017877`*^9, 3.629918229300873*^9}, {
   3.6299182730843825`*^9, 3.6299182871632447`*^9}, 3.6299184158498106`*^9, {
   3.6299189401479473`*^9, 3.6299189456638656`*^9}, {3.634467064146456*^9, 
   3.6344670719507303`*^9}, {3.634467159317587*^9, 3.634467252357836*^9}, {
   3.6365608974272203`*^9, 3.6365609010716753`*^9}, {3.8459819543896103`*^9, 
   3.845981976745982*^9}, {3.8459969663604703`*^9, 3.845996967868334*^9}, {
   3.876932286299474*^9, 3.8769322897010007`*^9}, {3.8776040338249702`*^9, 
   3.8776040390604105`*^9}},
 FontFamily->"Times New Roman",
 CellTags->
  "DEFINITION Least-Squares \
Solution",ExpressionUUID->"e8529a05-d754-4d1f-9786-7d05ee863e40"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"||", " ", "||"}], TraditionalForm]],ExpressionUUID->
  "514511d8-7f89-4731-a50b-65eedfbb9185"],
 "  be the norm on ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "9f098e99-9442-4cc2-a81f-df1a49eb37ed"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", "x", "||"}], "=", 
    SqrtBox[
     RowBox[{
      RowBox[{"<", "x"}], ",", 
      RowBox[{"x", ">", " "}]}]]}], TraditionalForm]],ExpressionUUID->
  "a04f8e48-fe2e-4b25-9e86-560fcce7de76"],
 ". If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "ee59ca51-e20b-4967-ae1e-f9f22e971e7e"],
 " is a linear operator and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "69efc11a-f018-46c0-b01f-0da2efa4ac7a"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", "b"}], TraditionalForm]],
  ExpressionUUID->"f79c4449-e37e-4d43-9402-aa7cfdbed94f"],
 " does not have a solution, how do we choose  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox[
     OverscriptBox["x", "^"],
     FontSlant->"Italic"], 
    StyleBox["\[Element]",
     FontSlant->"Plain"], 
    StyleBox["\[VeryThinSpace]",
     FontSlant->"Plain"], "V"}], TraditionalForm]],ExpressionUUID->
  "d4c84dff-91fe-45fa-970b-693c485ad2ad"],
 " so that"
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.6299181870017877`*^9, 3.629918229300873*^9}, {
   3.6299182730843825`*^9, 3.6299182871632447`*^9}, 3.6299184158498106`*^9, {
   3.6299189401479473`*^9, 3.6299189456638656`*^9}, {3.634467064146456*^9, 
   3.6344670719507303`*^9}, {3.634467159317587*^9, 3.634467252357836*^9}, {
   3.6365608974272203`*^9, 3.6365609010716753`*^9}, {3.8459819815396175`*^9, 
   3.845981995576762*^9}, {3.845982047217245*^9, 3.845982170384697*^9}, {
   3.845997653939934*^9, 3.84599765394095*^9}, {3.877603633582656*^9, 
   3.877603697451128*^9}, {3.877603731366882*^9, 3.8776038065078607`*^9}, {
   3.8776038383161173`*^9, 3.8776038411734405`*^9}, {3.8776080703727446`*^9, 
   3.877608080167021*^9}},
 FontFamily->"Times New Roman",
 CellTags->
  "DEFINITION Least-Squares \
Solution",ExpressionUUID->"b6882af7-cb7f-4e7d-983e-8f542d75ea5a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"b", "-", 
         RowBox[{"T", "(", "\[VeryThinSpace]", 
          OverscriptBox["x", "^"], ")"}]}], "\[RightDoubleBracketingBar]"}], 
       "\[LessEqual]", 
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"b", "-", 
         RowBox[{"T", "(", "\[VeryThinSpace]", "x", ")"}]}], 
