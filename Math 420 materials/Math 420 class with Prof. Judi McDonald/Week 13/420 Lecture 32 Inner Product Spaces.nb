   3.8776039240531783`*^9, 3.8776039338293605`*^9}},
 FontFamily->"Times New Roman",
 CellTags->
  "DEFINITION Least-Squares \
Solution",ExpressionUUID->"23ad495b-f600-4866-b8e9-83457ec54e0f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Lemma: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6255758595575314`*^9, 3.625575913526128*^9}, 
   3.845728480547922*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"0bbd4998-d6e1-4000-9e8e-ff0585c22673"],

Cell[TextData[{
 " Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "1e4e08a3-4b89-4914-8b18-ca81b163c4ad"],
 " be a linear operator.  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Rank", 
    FormBox[
     RowBox[{
      RowBox[{"(", "T", ")"}], "=", 
      RowBox[{
       RowBox[{"Rank", "(", 
        RowBox[{
         SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
       RowBox[{"Rank", "(", 
        SuperscriptBox["T", "*"], ")"}]}]}],
     TraditionalForm]}], TraditionalForm]],ExpressionUUID->
  "a87257d7-d6b9-44f5-a492-eafe69fff71d"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}], "=", 
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ec12f275-3079-475c-a285-2afd6dc54f13"],
 "."
}], "Text",
 CellChangeTimes->{{3.6255758595575314`*^9, 3.625575913526128*^9}, {
   3.876932494693553*^9, 3.8769325279798684`*^9}, {3.8769327148775306`*^9, 
   3.8769327148775306`*^9}, {3.876932832350292*^9, 3.876932839081711*^9}, {
   3.876933063224183*^9, 3.876933066797783*^9}, 3.8769331858589497`*^9, {
   3.876933259855768*^9, 3.876933286439305*^9}, {3.8774317774105926`*^9, 
   3.877431779191613*^9}, {3.8776041161517158`*^9, 3.87760415262702*^9}, {
   3.908897897671797*^9, 3.9088979138565807`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"eb83d5cd-2f61-45c2-86bc-53e96829195c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760570961037`*^9}, {3.625578828328375*^9, 
  3.625578828328375*^9}, {3.8769323997170143`*^9, 3.8769324005178537`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4ffbba99-05cd-41d6-a713-415e62ecb3c8"],

Cell[TextData[{
 "We begin by showing that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"nullity", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"nullity", "(", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
     RowBox[{"nullity", "(", 
      SuperscriptBox["T", "*"], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "d9397be6-949e-4d28-9530-096cce1ef316"],
 "."
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.8459979732187614`*^9, 
  3.8459980429151506`*^9}, {3.876932345076832*^9, 3.8769323468669147`*^9}, {
  3.8769326791924906`*^9, 3.8769327034113874`*^9}, {3.876933303627364*^9, 
  3.876933303627364*^9}, {3.8776043263071938`*^9, 3.87760433162379*^9}, {
  3.8776084170733023`*^9, 3.8776084306272697`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"cac35b1a-3a99-42c1-b912-d20495a9baab"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", "T", ")"}]}], TraditionalForm]],ExpressionUUID->
  "2bf14511-224b-4e04-a052-14baaf7851e8"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "(", 
     RowBox[{"T", "(", "x", ")"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], "(", "0", ")"}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"0de807eb-dd95-49e0-9c32-016e14bdc208"],
 ", to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"6693d654-1cae-430a-aead-793c021cc9a9"],
 "."
}], "Text",
 CellChangeTimes->{{3.877608457959591*^9, 
  3.8776085209810867`*^9}},ExpressionUUID->"d46e5864-1986-45fb-9630-\
f99916723240"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"f2614746-5682-4fd8-94bd-789bf8a83fe2"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "=", 
     RowBox[{"<", "0"}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{
       SuperscriptBox["T", "*"], 
       RowBox[{"T", "(", "x", ")"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "**"], "(", "x", ")"}], ">"}], "\[VeryThinSpace]", 
     "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], ">"}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "42212792-1328-4781-9a1b-76224a1faed7"]
}], "Text",
 CellChangeTimes->{{3.8776086061364903`*^9, 3.877608620806423*^9}, {
  3.877608694883376*^9, 
  3.877608796951533*^9}},ExpressionUUID->"78f86529-890b-4176-958e-\
1ba9d0eb9982"],

Cell[TextData[{
 "Since the inner product of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6cbcb147-f232-415b-8e23-8b87d6d59437"],
 " with itself is ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],ExpressionUUID->
  "72be2276-7265-4c85-babf-9f2ff3832720"],
 ", we see ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"60ec5587-f7d7-47f9-af43-97ee7781124b"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", "T", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a5b5ece1-eb48-43e7-9997-3f6387c389d1"],
 "."
}], "Text",
 CellChangeTimes->{{3.877608824633918*^9, 
  3.8776088952346134`*^9}},ExpressionUUID->"443deca1-3886-47f7-9170-\
af68e5273ea9"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a8551912-fbdf-40fd-9072-96ec00e02524"],
 ".  Applying the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["", "*"], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "ea89b5f8-6452-45ea-b4f1-497601bf1214"],
 " to both transformations gives us"
}], "Text",
 CellChangeTimes->{{3.877608904885331*^9, 
  3.877608984415556*^9}},ExpressionUUID->"92d8507e-9eea-4f49-a9cd-\
9087e57d6139"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", 
     SuperscriptBox["T", "*"], ")"}], "=", 
    RowBox[{
     RowBox[{"N", "(", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["T", "*"], "T"}], ")"}], "*"], ")"}], "=", 
     RowBox[{
      RowBox[{"N", "(", 
       SuperscriptBox[
        RowBox[{
         SuperscriptBox["T", "*"], "(", 
         SuperscriptBox["T", "*"], ")"}], "*"], ")"}], "=", 
      RowBox[{
       RowBox[{"N", "(", 
        RowBox[{
         SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
       RowBox[{"N", "(", "T", ")"}]}]}]}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "90a559ef-3c2e-4cec-a1ee-3a1e32dab8d9"],
 "."
}], "Text",
 CellChangeTimes->{{3.877608904885331*^9, 
  3.8776090337003746`*^9}},ExpressionUUID->"244b26de-4cc0-451d-aaee-\
f16c83c3dfb2"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"nullity", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"nullity", "(", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
     RowBox[{"nullity", "(", 
      SuperscriptBox["T", "*"], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8463e5bf-038d-44a7-9ac2-592fda47eb85"],
 " and by the rank theorem"
}], "Text",
 CellChangeTimes->{{3.8776090455915747`*^9, 
  3.87760905990201*^9}},ExpressionUUID->"b9312d36-6cac-4787-9f67-\
80f99e9d652a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"rank", "(", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
     RowBox[{"rank", "(", 
      SuperscriptBox["T", "*"], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "454f0bf1-b0c7-4dcb-a257-e2e833883cda"],
 "."
}], "Text",
 CellChangeTimes->{{3.8776090455915747`*^9, 
  3.877609084822002*^9}},ExpressionUUID->"7703a63c-e9c3-4c22-8526-\
b120abf475ca"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"7e8216f2-c342-420e-853f-785d8137c181"],
 ".  Then exits ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "70d606ee-0f8c-44c5-82cb-580f2f97b531"],
 ", so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], 
      RowBox[{"T", "(", "x", ")"}]}], "=", 
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "*"], "(", 
       RowBox[{"T", "(", "x", ")"}], ")"}], "\[Element]", 
      RowBox[{"R", "(", 
       SuperscriptBox["T", "*"], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"b84fa9f5-1d2c-4163-81d7-bf5608fed778"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}], "\[SubsetEqual]", 
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "0b7066b5-f69e-49c3-9dcf-313bdc958b7a"],
 ". Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Rank", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
    RowBox[{"Rank", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "57028fff-6b8d-452e-8a87-52c058f55d2a"],
 ", and one is a subset of the other, they must be equal. "
}], "Text",
 CellChangeTimes->{{3.87760911909167*^9, 3.877609239034958*^9}, {
  3.8776092750362997`*^9, 
  3.8776093249098053`*^9}},ExpressionUUID->"88a3ae68-5d40-42b4-905a-\
f0f82e66dc14"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
