Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"||", 
     RowBox[{"y", "-", "x"}], 
     SuperscriptBox["||", "2"]}], "=", 
    RowBox[{"<", 
     RowBox[{"y", "-", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"y", "-", "x"}], ">"}], " ", "=", 
    RowBox[{"<", "y"}]}], ",", 
   RowBox[{"y", ">", 
    RowBox[{"-", 
     RowBox[{"<", "y"}]}]}], ",", 
   RowBox[{"x", ">", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"y", ">", 
    RowBox[{"+", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"x", ">"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{"<", 
     RowBox[{"w", "+", "u"}]}]}], ",", 
   RowBox[{
    RowBox[{"w", "+", "u"}], ">", 
    RowBox[{"-", 
     RowBox[{"<", 
      RowBox[{"w", "+", "u"}]}]}]}], ",", 
   RowBox[{"x", ">", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{"w", "+", "u"}], ">", 
    RowBox[{"+", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"x", ">"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{"<", "w"}]}], ",", 
   RowBox[{"w", ">", 
    RowBox[{"+", 
     RowBox[{"<", "w"}]}]}], ",", 
   RowBox[{"u", ">", 
    RowBox[{"+", 
     RowBox[{"<", "u"}]}]}], ",", 
   RowBox[{"w", ">", 
    RowBox[{"+", 
     RowBox[{"<", "u"}]}]}], ",", 
   RowBox[{"u", ">", 
    RowBox[{"-", 
     RowBox[{"<", "w"}]}]}], ",", 
   RowBox[{"x", ">", 
    RowBox[{"-", 
     RowBox[{"<", "u"}]}]}], ",", 
   RowBox[{"x", ">", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"w", ">", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"u", ">", 
    RowBox[{"+", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"x", ">"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{"<", "w"}]}], ",", 
   RowBox[{"w", ">", 
    RowBox[{
     RowBox[{"+", "0"}], "+", "0", "+"}], "<", "u"}], ",", 
   RowBox[{"u", ">", 
    RowBox[{"-", 
     RowBox[{"<", "w"}]}]}], ",", 
   RowBox[{"x", ">", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"w", ">", 
    RowBox[{"+", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{"x", ">"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{"<", 
     RowBox[{"w", "-", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{"w", "-", "x"}], ">", 
    RowBox[{"+", 
     RowBox[{"<", "u"}]}]}], ",", 
   RowBox[{
    RowBox[{"u", ">"}], " ", "=", 
    RowBox[{"||", 
     RowBox[{"w", "-", "x"}], 
     SuperscriptBox["||", "2"], 
     RowBox[{"+", 
      RowBox[{"||", "u", 
       SuperscriptBox["||", "2"]}]}]}]}]}], TraditionalForm]}],
 FormatType->
  TraditionalForm,ExpressionUUID->"8a7d275c-c6bd-488c-92c4-04ea3e4bd783"]], \
"Text",
 CellChangeTimes->{{3.9101046659093094`*^9, 
  3.9101049895743456`*^9}},ExpressionUUID->"e07b5a17-fea1-4155-a6e1-\
20a51eb987b9"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"||", 
    RowBox[{"y", "-", "w"}], 
    SuperscriptBox["||", "2"]}], "=", 
   RowBox[{
    RowBox[{"||", 
     RowBox[{"w", "+", "u", "-", "w"}], 
     SuperscriptBox["||", "2"]}], "=", 
    RowBox[{"||", "u", 
     SuperscriptBox["||", "2"]}]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"1a447aa1-b274-4c92-9aac-63429e64c6b8"]], \
"Text",
 CellChangeTimes->{{3.910105005520788*^9, 
  3.910105036536167*^9}},ExpressionUUID->"9ec4a1d6-56ec-4b67-8c62-\
c55098473444"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"||", 
    RowBox[{"y", "-", "x"}], "||", 
    RowBox[{">=", 
     RowBox[{"||", 
      RowBox[{"y", "-", "w"}], "||"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
