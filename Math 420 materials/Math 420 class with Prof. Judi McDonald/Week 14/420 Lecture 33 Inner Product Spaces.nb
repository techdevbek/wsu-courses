       RowBox[{"{", 
         RowBox[{"{", 
           RowBox[{"Bottom", ",", "Left"}], "}"}], "}"}]}], 
     "]"}]& )]], "Output",
 CellChangeTimes->{3.743072907345908*^9},
 CellTags->
  "TABLE A:  Perfect \
Fit",ExpressionUUID->"73daad9a-ce1f-4fa2-bccb-778d53338440"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[GridBox[{
     {GridBox[{
        {
         RowBox[{
          RowBox[{
           RowBox[{"X", "\[VeryThinSpace]", 
            StyleBox["\[Beta]",
             FontWeight->"Bold"]}], "=", 
           StyleBox["y",
            FontWeight->Bold,
            FontSlant->Plain]}], ",", " ", 
          RowBox[{
           RowBox[{"where", " ", "X"}], "=", 
           TemplateBox[{
             GraphicsBox[{
               LineBox[{{0, 0}, {0, 40}}], 
               LineBox[{{0, 40}, {2, 40}}], 
               LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
             TagBox[
              GridBox[{{"1", 
                 SubscriptBox["x", "1"]}, {"1", 
                 SubscriptBox["x", "2"]}, {
                "\[VerticalEllipsis]", "\[VerticalEllipsis]"}, {"1", 
                 SubscriptBox["x", "n"]}}, AutoDelete -> False, 
               GridBoxAlignment -> {"Columns" -> {{Center}}}, 
               GridBoxItemSize -> {
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
              "Grid"], 
             GraphicsBox[{
               LineBox[{{2, 0}, {2, 40}}], 
               LineBox[{{0, 40}, {2, 40}}], 
               LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
            "RowDefault"]}], ",", " ", 
          RowBox[{
           StyleBox["\[Beta]",
            FontWeight->"Bold"], "=", 
           TemplateBox[{
             GraphicsBox[{
               LineBox[{{0, 0}, {0, 10}}], 
               LineBox[{{0, 10}, {1, 10}}], 
               LineBox[{{0, 0}, {1, 0}}]}, ImageSize -> {5, 30}], 
             TagBox[
              GridBox[{{
                 FormBox[
                  SubscriptBox["\[Beta]", "0"], TraditionalForm]}, {
                 FormBox[
                  SubscriptBox["\[Beta]", "1"], TraditionalForm]}}, 
               AutoDelete -> False, 
               GridBoxAlignment -> {"Columns" -> {{Center}}}, 
               GridBoxItemSize -> {
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
              "Grid"], 
             GraphicsBox[{
               LineBox[{{1, 0}, {1, 10}}], 
               LineBox[{{0, 10}, {1, 10}}], 
               LineBox[{{0, 0}, {1, 0}}]}, ImageSize -> {5, 30}]},
            "RowDefault"]}], ",", " ", 
          RowBox[{
           FormBox[
            StyleBox["y",
             FontWeight->"Bold",
             FontSlant->"Plain"],
            TraditionalForm], "=", 
           TemplateBox[{
             GraphicsBox[{
               LineBox[{{0, 0}, {0, 40}}], 
               LineBox[{{0, 40}, {2, 40}}], 
               LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
             TagBox[
              GridBox[{{
                 SubscriptBox["y", "1"]}, {
                 SubscriptBox["y", "2"]}, {"\[VerticalEllipsis]"}, {
                 SubscriptBox["y", "n"]}}, AutoDelete -> False, 
               GridBoxAlignment -> {"Columns" -> {{Center}}}, 
               GridBoxItemSize -> {
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
              "Grid"], 
             GraphicsBox[{
               LineBox[{{2, 0}, {2, 40}}], 
               LineBox[{{0, 40}, {2, 40}}], 
               LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
            "RowDefault"]}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{"="}}}]}
    },
    GridBoxItemSize->{"Columns" -> {{
         Scaled[0.96]}}}], TraditionalForm]],ExpressionUUID->
  "e81db6a9-6bb4-4965-a0ee-01881a61def5"],
 "(1)"
}], "Text",
