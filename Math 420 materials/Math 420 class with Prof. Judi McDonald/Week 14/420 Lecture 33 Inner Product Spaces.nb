0128c49797f5"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {GridBox[{
       {
        RowBox[{
         SubscriptBox["y", "1"], "=", 
         RowBox[{
          FormBox[
           SubscriptBox["\[Beta]", "0"],
           TraditionalForm], "+", 
          FormBox[
           RowBox[{
            RowBox[{
             SubscriptBox["\[Beta]", "1"], 
             SubscriptBox["x", "1"]}], "+", 
            RowBox[{
             SubscriptBox["\[Beta]", "2"], 
             SubsuperscriptBox["x", "1", "2"]}]}],
           TraditionalForm], "+", 
          SubscriptBox["\[Epsilon]", "1"]}]}]}
      },
      GridBoxAlignment->{"Columns" -> {{"Center"}}}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
