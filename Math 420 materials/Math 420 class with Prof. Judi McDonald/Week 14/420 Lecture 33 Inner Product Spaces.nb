Cell[TextData[{
 "Suppose the actual values of the parameters are ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "0"], TraditionalForm]],ExpressionUUID->
  "7f45b3a7-2443-41dd-86a7-7e33d631e356"],
