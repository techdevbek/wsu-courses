                    LineBox[{{0, 25}, {1, 25}}], 
                    LineBox[{{0, 0}, {1, 0}}]}, ImageSize -> {5, 50}], 
                    TagBox[
                    GridBox[{{
                    SubscriptBox["\[Beta]", "0"]}, {
                    SubscriptBox["\[Beta]", "1"]}, {
                    SubscriptBox["\[Beta]", "2"]}}, AutoDelete -> False, 
