                    LineBox[{{0, 40}, {2, 40}}], 
                    LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]}], 
                    TagBox[
                    GridBox[{{"1", 
                    SubscriptBox["u", "1"], 
                    SubscriptBox["v", "1"]}, {"1", 
                    SubscriptBox["u", "2"], 
                    SubscriptBox["v", "2"]}, {
