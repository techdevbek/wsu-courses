Cell[TextData[{
 "Data points rarely lie on a line. Computing the least-squares solution of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", "\[VeryThinSpace]", 
     StyleBox["\[Beta]",
      FontWeight->"Bold"]}], "=", 
    StyleBox["y",
     FontWeight->Bold,
     FontSlant->Plain]}], TraditionalForm]],ExpressionUUID->
  "8b2808ae-3223-4d12-b376-41f5e6d1ed3e"],
 " is equivalent to finding the ",
 StyleBox["\[Beta]",
  FontWeight->"Bold"],
 " that determines the least-squares line in Figure 1."
}], "Text",
 CellChangeTimes->{{3.8461480340922728`*^9, 
  3.846148102510441*^9}},ExpressionUUID->"793ea709-72cc-4203-9e7f-\
2cf43649e79c"]
}, Open  ]],

