                    RowBox[{
                    StyleBox["y",
                    FontWeight->Bold,
                    FontSlant->Plain], "=", 
                    TemplateBox[{
                    GraphicsBox[{
                    LineBox[{{0, 0}, {0, 40}}], 
                    LineBox[{{0, 40}, {2, 40}}], 
                    LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
                    TagBox[
                    GridBox[{{
