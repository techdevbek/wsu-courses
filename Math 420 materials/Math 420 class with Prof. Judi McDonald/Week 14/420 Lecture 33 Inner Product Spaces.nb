Cell["", "Subsubsubsection",ExpressionUUID->"9311588e-157b-415c-8b27-dcb2a7781ece"],

Cell[TextData[{
 "It is a simple matter to write this system of equations in the form ",
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{
       FormBox[
        StyleBox["y",
         FontWeight->"Bold",
         FontSlant->"Plain"],
        TraditionalForm], "=", 
       RowBox[{
        FormBox[
         RowBox[{"X", "\[VeryThinSpace]", 
          StyleBox["\[Beta]",
           FontWeight->"Bold"]}],
         TraditionalForm], "+", "\[Epsilon]"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{"Center"}}}], TraditionalForm]],
  ExpressionUUID->"dff42c64-e016-4633-9930-d7dd4db12ae3"],
 ". To find ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "d2287f5b-ba6b-4b47-8654-98c5aadb4718"],
 ", inspect the first few rows of the system and look for the pattern."
}], "Text",
 CellChangeTimes->{{3.629999094190755*^9, 3.629999109285299*^9}, {
   3.629999223644648*^9, 3.6299992322701015`*^9}, 3.6299995873581715`*^9, {
