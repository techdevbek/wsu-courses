 "This system has the matrix form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["y",
     FontWeight->Bold,
     FontSlant->Plain], "=", 
    RowBox[{
     RowBox[{"X", "\[VeryThinSpace]", 
      StyleBox["\[Beta]",
       FontWeight->"Bold"]}], "+", 
     StyleBox["\[Epsilon]",
      FontWeight->"Bold"]}]}], TraditionalForm]],ExpressionUUID->
  "3b3a8036-8de3-44ce-9208-b9d337d9d2fd"],
 ", where "
}], "Text",
