  FormBox[
   SubscriptBox["\[Beta]", "2"], TraditionalForm]],ExpressionUUID->
  "4c13bdfb-dedd-41b7-b377-551cf5ee1578"],
 ". Then the coordinates of the first data point ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["y", "1"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "958d91e7-0c02-4855-8fba-ddce30627aca"],
 " satisfy an equation of the form"
}], "Text",
 CellChangeTimes->{{3.629999094190755*^9, 3.629999109285299*^9}, {
   3.629999223644648*^9, 3.6299992322701015`*^9}, 3.6299995873581715`*^9, {
