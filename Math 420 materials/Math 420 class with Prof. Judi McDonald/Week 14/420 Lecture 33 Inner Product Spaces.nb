Cell["", "Subsubsubsection",ExpressionUUID->"2570f6f4-34e2-47c1-ad57-0ca4d929a5ac"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", "1"], TraditionalForm]],ExpressionUUID->
  "a731427f-2fcc-4120-959b-27073c6c6056"],
