Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition:",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.846147903126877*^9, 
  3.8461479189654493`*^9}},ExpressionUUID->"e547584a-584f-40f0-bd1b-\
f0f9626875b9"],

Cell[TextData[{
 "The ",
 StyleBox["least-squares line",
  FontWeight->"Bold"],
 " is the line ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     SubscriptBox["\[Beta]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[Beta]", "1"], "x"}]}]}], TraditionalForm]],
  ExpressionUUID->"17adac60-e507-4a3c-9002-773ff59e5559"],
 " that minimizes the sum of the squares of the residuals. This line is also \
called a ",
 StyleBox["line of regression",
  FontWeight->"Bold"],
 " ",
 StyleBox["of",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   StyleBox["y",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "d17b2590-173e-4c5f-88ab-8ec4d919539f"],
 " ",
 StyleBox["on",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   StyleBox["x",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "9d4a6a88-4085-4ea1-951c-dd830faecadb"],
 ", because any errors in the data are assumed to be only in the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "f6145b4d-c7cb-471f-862a-b76330af3a04"],
 "-coordinates. The coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "0"], TraditionalForm]],ExpressionUUID->
  "6afd0fdd-d8de-46ed-a28d-1f99ca2f2506"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "1"], TraditionalForm]],ExpressionUUID->
  "095bfa60-0cdf-42b0-a3f7-6cf01104a785"],
 " of the line are called (linear) ",
 StyleBox["regression coefficients",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{
  3.8461479308018446`*^9},ExpressionUUID->"7c5571d0-eddd-4355-985d-\
e366e771df60"],

Cell[BoxData[
 TemplateBox[{
   TagBox[
    GridBox[{{
       TagBox[
        GridBox[{{
           TagBox[
            
            GridBox[{{
              "\"Predicted \\!\\(TraditionalForm\\`y\\)-value\"", "\"\"", 
               "\"Observed \\!\\(TraditionalForm\\`y\\)-value\""}, {
              "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(\[Beta]\\), \
\\(0\\)] + \\*SubscriptBox[\\(\[Beta]\\), \\(1\\)] \\*SubscriptBox[\\(x\\), \
\\(1\\)]\\)\"", "\"=\"", 
               "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(y\\), \
\\(1\\)]\\)\""}, {
              "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(\[Beta]\\), \
\\(0\\)] + \\*SubscriptBox[\\(\[Beta]\\), \\(1\\)] \\*SubscriptBox[\\(x\\), \
\\(2\\)]\\)\"", "\"=\"", 
               "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(y\\), \
\\(2\\)]\\)\""}, {
              "\"\[VerticalEllipsis]\"", "\"\"", "\"\[VerticalEllipsis]\""}, {
              "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(\[Beta]\\), \
\\(0\\)] + \\*SubscriptBox[\\(\[Beta]\\), \\(1\\)] \\*SubscriptBox[\\(x\\), \
\\(n\\)]\\)\"", "\"=\"", 
               "\"\\!\\(TraditionalForm\\`\\*SubscriptBox[\\(y\\), \
\\(n\\)]\\)\""}}, AutoDelete -> False, 
             GridBoxDividers -> {
              "Columns" -> {False}, "Rows" -> {False, True, False}}, 
             GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             FrameStyle -> {
               Thickness[Tiny], 
               RGBColor[0, 0.7, 0.7]}, 
             BaseStyle -> {FontFamily -> "Times", 14}], "Grid"]}}, AutoDelete -> 
         False, GridBoxDividers -> {
          "Columns" -> {False}, "Rows" -> {True, True}}, 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, FrameStyle -> {
           Thickness[Large], 
           RGBColor[0, 0.7, 0.7]}, BaseStyle -> {FontFamily -> "Times", 14}], 
        "Grid"]}}, 
     GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Bottom}}}, 
     AutoDelete -> False, 
     GridBoxItemSize -> {
      "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
   StyleBox["\"TABLE A\"", "FigureFont", StripOnInput -> False]},
  "Labeled",
  DisplayFunction->(GridBox[{{
