   3.6300171873456125`*^9}},ExpressionUUID->"cd69984c-7fb0-4272-9b41-\
5133a5055b4a"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {GridBox[{
       {GridBox[{
          {GridBox[{
             {
              SubscriptBox["y", "1"], "=", 
              RowBox[{GridBox[{
                 {
                  RowBox[{
                   FormBox[
                    SubscriptBox["\[Beta]", "0"],
                    TraditionalForm], "+", 
                   FormBox[
                    RowBox[{
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], 
                    SubscriptBox["u", "1"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], 
                    SubscriptBox["v", "1"]}]}],
                    TraditionalForm]}]}
                },
                GridBoxAlignment->{"Columns" -> {{"Center"}}}], "+", 
               SubscriptBox["\[Epsilon]", "1"]}]},
             {
              SubscriptBox["y", "2"], "=", 
              RowBox[{GridBox[{
                 {
                  RowBox[{
                   FormBox[
                    SubscriptBox["\[Beta]", "0"],
                    TraditionalForm], "+", 
                   FormBox[
                    RowBox[{
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], 
                    SubscriptBox["u", "2"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], 
                    SubscriptBox["v", "2"]}]}],
                    TraditionalForm]}]}
                },
                GridBoxAlignment->{"Columns" -> {{"Center"}}}], "+", 
               SubscriptBox["\[Epsilon]", "2"]}]},
             {"\[VerticalEllipsis]", " ", "\[VerticalEllipsis]"},
             {
              SubscriptBox["y", "n"], "=", 
              RowBox[{GridBox[{
                 {
                  RowBox[{
                   FormBox[
                    SubscriptBox["\[Beta]", "0"],
                    TraditionalForm], "+", 
                   FormBox[
                    RowBox[{
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], 
                    SubscriptBox["u", "n"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], 
                    SubscriptBox["v", "n"]}]}],
                    TraditionalForm]}]}
                },
                GridBoxAlignment->{"Columns" -> {{"Center"}}}], "+", 
               SubscriptBox["\[Epsilon]", "n"]}]}
            }]}
         },
         GridBoxAlignment->{"Columns" -> {{"Center"}}}]}
      },
      GridBoxAlignment->{"Columns" -> {{"Center"}}}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"f8918f75-184a-4b59-a7ef-a204d1cf6652"]], \
