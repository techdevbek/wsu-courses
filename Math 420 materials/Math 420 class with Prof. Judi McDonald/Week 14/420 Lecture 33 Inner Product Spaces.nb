Cell[TextData[{
 "Although the result is about the rank, we will approach the proof by \
working with the nullity.  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", "T", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8d3d4b73-e260-4ecf-87f0-c59a2e17f1e6"],
 ". Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], 
     RowBox[{"T", "(", "x", ")"}]}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], "(", "0", ")"}], "=", "0"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "81670a95-e3b5-4406-8dff-6eba0a355372"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aa6a1705-a598-40dd-a992-44df845fab37"],
 ".  Conversely, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d03213e7-51df-4477-9f29-778ceaa3ed81"],
 "."
}], "Text",
 CellChangeTimes->{{3.9101053524865036`*^9, 
  3.9101054744150934`*^9}},ExpressionUUID->"cce8fe38-5d11-4e74-9666-\
b27823c1b034"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "=", 
     RowBox[{"<", "0"}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], " ", "=", 
     RowBox[{"<", 
      RowBox[{
       SuperscriptBox["T", "*"], 
       RowBox[{"T", "(", "x", ")"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], " ", "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "**"], "(", "x", ")"}], ">"}], " ", "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], ">"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "988e7968-d1cb-4e89-b58b-66bc70e61861"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7cabdee5-fb4b-4d33-af4b-c41040259074"],
 "  so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "82837e48-2e02-4a9c-b0ae-9efa4ccb2a70"],
 "."
}], "Text",
 CellChangeTimes->{{3.9101055062066708`*^9, 3.9101055817741475`*^9}, {
  3.9101056265120873`*^9, 
  3.9101056845396986`*^9}},ExpressionUUID->"d3802df7-bfd9-46c7-ae1e-\
bdaa6618c512"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"N", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9df332bb-bd8d-49f4-ace8-5f1adaf0d1cb"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"nullity", "(", "T", ")"}], "=", 
    RowBox[{"nullity", " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "887ec849-53f6-4792-bd3c-06aa5ceaee50"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "=", 
    RowBox[{"rank", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "58030814-8686-4128-b88a-ae20acfd17a3"],
 ".  But we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", 
     SuperscriptBox["T", "*"], ")"}], "=", 
    RowBox[{
     RowBox[{"rank", "(", "T", ")"}], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "48e60e22-a6b8-4c95-86aa-f669ed05b552"]
}], "Text",
 CellChangeTimes->{{3.9101053425427637`*^9, 3.91010534254535*^9}, {
  3.9101056880248384`*^9, 3.910105776466383*^9}, {3.910105825457331*^9, 
  3.9101059651335726`*^9}, {3.9101061298743*^9, 3.910106215877037*^9}, {
  3.9101062946423907`*^9, 
  3.9101063259094057`*^9}},ExpressionUUID->"899b57dd-2228-4210-9dea-\
fb7f2c9e366e"],

Cell[TextData[{
 "Notice that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7e4d4c6f-9efd-4ee7-a1c9-791b92066bc0"],
 ", there exists an ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8f981bbc-149a-4844-b979-41a87e922b27"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], 
      RowBox[{"T", "(", "x", ")"}]}], "=", 
     RowBox[{
      SuperscriptBox["T", "*"], "(", 
      RowBox[{"T", "(", "x", ")"}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0aa5c8d1-a830-4ead-8c18-a81423ef3e98"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ee3027ba-72a3-4384-9123-a063048c73dc"],
 ". Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}], "\[SubsetEqual]", 
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9ef89de1-b92b-4dfc-ae31-76b96f028abb"],
 " and since they have the same dimension, they must be equal. "
}], "Text",
 CellChangeTimes->{{3.9101053427461767`*^9, 3.9101053427481937`*^9}, {
  3.910106332664757*^9, 
  3.9101064424676943`*^9}},ExpressionUUID->"4b027d8e-f92a-4f58-acd9-\
0b1c90e3f51b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem: ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6255760536584167`*^9, 3.625576086948186*^9}, {
   3.6255761511506996`*^9, 3.625576389609288*^9}, {3.6255791594576654`*^9, 
   3.6255791894549723`*^9}, {3.625580233797457*^9, 3.625580234901795*^9}, {
   3.7213934842472315`*^9, 3.721393532243893*^9}, 3.845728705763352*^9, {
   3.877608844498805*^9, 3.877608845653677*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"a4988bc4-308c-488e-becf-0e7f24a9a882"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "b3e8d4e4-0dc7-4871-a3fc-5276ced7c79e"],
 " be a linear operator and let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "fe85ff25-ead8-499b-9646-c2a5ab8d01e7"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "V", ")"}]}], "=", "n"}], TraditionalForm]],ExpressionUUID->
  "02543d3d-2c0d-41fe-986d-8d7352ae65bd"],
 ".  (We want to solve ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], "=", "b"}], ","}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "12f91e76-17ca-4f50-95f1-f9df92aebf12"],
 " but there might not be a solution.) Then there exists ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "0a4616f4-e974-49bd-a8dc-f173f8ff80c5"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "T", " ", 
     RowBox[{"(", "u", ")"}]}], "=", 
    RowBox[{
     SuperscriptBox["T", "*"], "b"}]}], TraditionalForm]],ExpressionUUID->
  "093298d3-20c8-4327-9c11-bf4768ab7380"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"||", 
     RowBox[{
      RowBox[{"T", "(", "u", ")"}], "-", "b"}], "||", 
     RowBox[{"\[LessEqual]", 
      RowBox[{"||", 
       RowBox[{
        RowBox[{"T", "(", "x", ")"}], "-", "b"}], "||"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"3478cb41-071a-44d5-94b2-2e5acfb4253c"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "d6b13c9e-4156-419f-a0c3-ca095e8b3e62"],
 "  Moreover, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Rank", 
    FormBox[
     RowBox[{
      RowBox[{"(", "T", ")"}], "=", "n"}],
     TraditionalForm]}], TraditionalForm]],ExpressionUUID->
  "8ce65d1a-7ff0-4a1b-bc63-ad79b8602c47"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["T", "*"], "T"}], ")"}], 
      RowBox[{"-", "1"}]], 
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "*"], "(", " ", "b", ")"}], "."}]}]}], 
   TraditionalForm]],ExpressionUUID->"f8bc2c70-fb0d-4f25-93d0-e34fd144f86f"]
}], "Text",
 CellChangeTimes->{{3.6255760536584167`*^9, 3.625576086948186*^9}, {
  3.6255761511506996`*^9, 3.625576389609288*^9}, {3.6255791594576654`*^9, 
  3.6255791894549723`*^9}, {3.625580233797457*^9, 3.625580234901795*^9}, {
  3.7213934842472315`*^9, 3.721393532243893*^9}, {3.8769335742800264`*^9, 
  3.8769335742800264`*^9}, {3.877604342000478*^9, 3.877604412535342*^9}, {
  3.877610575288657*^9, 3.8776105917335205`*^9}, {3.9101064960517907`*^9, 
  3.9101065334984803`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"8cd06198-dfd7-48a2-b325-f2fbb9879bc8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625579425895611*^9, 3.6255794283020115`*^9}, {
  3.8769324081862154`*^9, 3.876932410231619*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e6cdbcc9-b329-4fed-af62-f966bba7207a"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}], ")"}], "=", 
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ae252202-1b9a-4749-9620-731c5a479b5e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "(", "b", ")"}], "\[Element]", 
    RowBox[{"R", "(", 
     SuperscriptBox["T", "*"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "33ea9fc4-10ed-4b56-99ba-13b20325773d"],
 ", there must be an element ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "778d2c79-0f1e-4779-b109-8a1ee0ca9469"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], 
     RowBox[{"T", "(", "u", ")"}]}], "=", 
    RowBox[{
     SuperscriptBox["T", "*"], "(", "b", ")"}]}], TraditionalForm]],
  ExpressionUUID->"253b9bb5-1467-4e70-b9c4-a126d90ad68f"],
 "."
}], "Text",
 CellChangeTimes->{{3.87760958653977*^9, 3.8776096810307546`*^9}, {
  3.9101022268231864`*^9, 3.9101022278264894`*^9}, {3.910102358288254*^9, 
  3.9101023875602074`*^9}},ExpressionUUID->"a10ef83b-0515-4817-9867-\
c803cd637aca"],

Cell[TextData[{
 "We will establish that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "u", ")"}], TraditionalForm]],ExpressionUUID->
  "6e28fa7f-d814-4902-9889-6dfb4af95e81"],
 " is the closest point to ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "c650410a-8ae0-4259-842b-4da6681d935c"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "a1e5eff0-df8e-43ed-ae2d-f9cd4f2c691b"],
 " by observing that "
}], "Text",
 CellChangeTimes->{{3.8776097688154883`*^9, 
  3.877609819947831*^9}},ExpressionUUID->"a7d7a73c-ee78-40bc-9796-\
19309665a954"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"b", "=", 
   RowBox[{
    RowBox[{"T", "(", "u", ")"}], "+", 
    RowBox[{"(", 
     RowBox[{"b", "-", 
      RowBox[{"T", "(", "u", ")"}]}], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"fcec2243-6d7e-4246-b95f-15815fa8e0fb"]], \
"Text",
 CellChangeTimes->{{3.8776097688154883`*^9, 3.8776098687704678`*^9}},
 TextAlignment->Center,ExpressionUUID->"3e49905e-c232-4f8a-88d4-bbce3061904d"],

Cell[TextData[{
 "Where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "u", ")"}], "\[Element]", 
    RowBox[{"R", "(", "T", ")"}]}], TraditionalForm]],ExpressionUUID->
  "46ab4574-242f-40e0-8504-52dafdc91eec"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "-", 
    RowBox[{"T", "(", "u", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "322b827c-b243-419b-bee3-8313619e7941"],
 " is in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"R", "(", "T", ")"}], "\[Perpendicular]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b477dfd-df4b-48c6-af52-59283a55273c"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8776098740231977`*^9, 3.8776099575374365`*^9}, {
  3.9101024555498753`*^9, 3.9101024907120657`*^9}, {3.910106776987217*^9, 
  3.910106791215353*^9}},ExpressionUUID->"5e4bd85c-b0e3-4067-9aa0-\
63519fba5461"],

Cell[TextData[{
 " Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    RowBox[{
     RowBox[{"R", "(", "T", ")"}], "."}]}], TraditionalForm]],ExpressionUUID->
  "c3ac5bd8-1c6e-4ddf-885f-c7edf0319f82"],
 " Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"T", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "87cdb737-93b3-4597-97d5-42c11ceaace8"],
 " for some ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "0228b4a1-7b5d-4749-a0ab-ab56e13d79a0"],
 ". Then"
}], "Text",
 CellChangeTimes->{{3.8776098740231977`*^9, 3.8776099575374365`*^9}, {
  3.9101024555498753`*^9, 3.9101024907120657`*^9}, {3.910106776987217*^9, 
  3.9101067878748236`*^9}},ExpressionUUID->"f4c79cd9-1179-499f-a40d-\
f502077168e5"],

Cell[TextData[{
 " ",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"<", 
      RowBox[{"b", "-", 
       RowBox[{"T", "(", "u", ")"}]}]}], ",", 
     RowBox[{
      RowBox[{"y", ">"}], "\[VeryThinSpace]", "=", 
      RowBox[{"<", 
       RowBox[{"b", "-", 
        RowBox[{"T", "(", "u", ")"}]}]}]}], ",", 
     RowBox[{
      RowBox[{"T", "(", "x", ")"}], ">"}]}], "\[VeryThinSpace]"}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"=", 
     RowBox[{"<", 
      RowBox[{
       SuperscriptBox["T", "*"], "(", 
       RowBox[{"b", "-", 
        RowBox[{"T", "(", "u", ")"}]}], ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], "\[VeryThinSpace]", "=", 
     RowBox[{"<", 
      RowBox[{
       RowBox[{
        SuperscriptBox["T", "*"], "(", "b", ")"}], "-", 
       RowBox[{
        SuperscriptBox["T", "*"], "(", 
        RowBox[{"T", "(", "u", ")"}], ")"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], "\[VeryThinSpace]", "=", "\[VeryThinSpace]", 
     RowBox[{"<", "0"}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], "\[VeryThinSpace]", "=", "0"}]}], TraditionalForm]}],
  InitializationCell->True,ExpressionUUID->
  "0e57f3ec-e302-4921-a9b7-587382ac1940"]
}], "Text",
 CellChangeTimes->{
  3.8776098013787622`*^9, {3.877609964214595*^9, 3.877610125117502*^9}, {
   3.8776106149795284`*^9, 
   3.8776106149795284`*^9}},ExpressionUUID->"852a343d-820a-478e-8b2f-\
c13d64f0b2c5"],

Cell[TextData[{
 "Thus our decomposition above of ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "0ad5d7e8-af14-490e-98e0-5b0ace04380f"],
 " into an element in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "+", 
    SuperscriptBox[
     RowBox[{"R", "(", "T", ")"}], "\[Perpendicular]"]}], TraditionalForm]],
  ExpressionUUID->"1bfe34a8-6888-4f04-87f9-7757ef7e3b33"],
 " is correct.  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "u", ")"}], TraditionalForm]],ExpressionUUID->
  "a5369c2b-e67a-48f9-955e-1e899632fc9b"],
 " is a closest point to ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "e24c1f0f-d28c-4855-bb24-b0c2397faf77"],
 " in ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "21b0f87c-6258-4e7a-8a8f-1c7421b9f23a"],
 "."
}], "Text",
 CellChangeTimes->{
  3.8776098013787622`*^9, {3.877609964214595*^9, 
   3.8776101903655357`*^9}},ExpressionUUID->"cd5b897c-30f0-4286-8c31-\
0e5c723de20b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.8776101154075737`*^9, 
  3.8776101181339*^9}},ExpressionUUID->"0488129b-a2bb-451d-a224-1ec53ea354fc"],

