Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "W"}], TraditionalForm]],ExpressionUUID->
  "874fb6f7-549f-4a6d-958c-e208287c33ec"],
