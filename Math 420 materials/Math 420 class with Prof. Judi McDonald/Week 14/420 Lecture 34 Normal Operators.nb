 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"852b0f3a-e8b6-402d-9792-a5ed1b8dd478"],

Cell[TextData[{
 "When can you have both? Specifically an orthonormal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "54f11701-b1cc-4bd8-b80f-7961c2c16baa"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "b8203024-007e-4b2a-87dc-df58ec22e2db"],
 "?"
}], "Text",
 CellChangeTimes->{{3.8789448943376513`*^9, 3.878944919653531*^9}, {
  3.878944990574691*^9, 3.878945047901456*^9}, {3.878945088880843*^9, 
  3.8789451241988797`*^9}},ExpressionUUID->"38afc4bb-a83b-48f4-a18a-\
9ccd275333ce"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760575180025`*^9}, {3.6255773136897373`*^9, 
   3.625577379824893*^9}, {3.6264406202550693`*^9, 3.6264406386935463`*^9}, {
   3.6264407017124095`*^9, 3.6264407159319067`*^9}, 3.8471859637356715`*^9},
 FontSize->12,ExpressionUUID->"c5ad731a-922d-4b62-9d7c-0709023d55e2"],

Cell[TextData[{
 "A linear transformation is said to be ",
 StyleBox["normal",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "T"}], "=", 
    RowBox[{"T", " ", 
     RowBox[{
      SuperscriptBox["T", "*"], "."}]}]}], TraditionalForm]],ExpressionUUID->
  "473b90d9-badc-4f54-87de-746218808cf8"],
 " "
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760575180025`*^9}, {3.6255773136897373`*^9, 
   3.625577379824893*^9}, {3.6264406202550693`*^9, 3.6264406386935463`*^9}, {
   3.6264407017124095`*^9, 3.6264407159319067`*^9}, 
   3.8471859653345447`*^9},ExpressionUUID->"470c2d7a-c715-4fa6-9a86-\
c45725667116"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439277903037*^9}, {
   3.6264401828552628`*^9, 3.6264401857929173`*^9}, 3.8471860273111115`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"4c30b98b-288b-49cd-b0aa-cd161e5ab32f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "263a463c-5cb2-43ae-9d32-df6ac41add48"],
 " be a normal operator on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "45ea124f-15df-433b-89bd-17ea4d5217f3"],
 "  Then"
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439277903037*^9}, {
  3.6264401828552628`*^9, 3.6264401857929173`*^9}, {3.847186028788455*^9, 
  3.847186029613823*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"bc4a6a4d-7b32-4fed-b89e-511d47f0b1c0"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"||", 
      FormBox[
       RowBox[{"T", "(", "x", ")"}],
       TraditionalForm], " ", "||"}], " ", "=", " ", 
     RowBox[{"||", 
      FormBox[
       RowBox[{
        SuperscriptBox["T", "*"], "(", "x", ")"}],
       TraditionalForm], " ", "||", "   ", 
      RowBox[{"\[ForAll]", 
       FormBox[
        RowBox[{"x", "\[Element]", 
         RowBox[{"V", "."}]}],
        TraditionalForm]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "d8b7abe1-1954-495a-9b32-a8aba6125803"]
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439430851683*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"b6c5e462-f9fe-43f9-9932-ce734c155e6a"],

Cell[TextData[{
 "(ii)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "-", 
    RowBox[{"c", " ", "I"}]}], TraditionalForm]],ExpressionUUID->
  "1739b189-bcf6-4742-9d77-63723b1458b2"],
 " is normal  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ForAll]", 
    RowBox[{"c", "\[Element]", 
     RowBox[{"\[DoubleStruckCapitalF]", "."}]}]}], TraditionalForm]],
  ExpressionUUID->"daaf69e3-e19a-4712-a85c-22a23344cf06"]
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
  3.6264394069129434`*^9, 3.626439460650107*^9}, {3.8473786870689406`*^9, 
  3.8473786895371437`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"eb766229-6022-41ed-babb-cef5200f13e4"],

Cell[TextData[{
 "(iii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "\[Lambda]"], "(", "T", ")"}], "=", 
    RowBox[{
     SubscriptBox["E", 
      OverscriptBox["\[Lambda]", "_"]], "(", 
     StyleBox[
      SuperscriptBox["T", "*"],
      FontWeight->"Normal",
      FontColor->RGBColor[0., 0., 0.]], ")"}]}], TraditionalForm]],
  ExpressionUUID->"893fe379-b9cf-4e44-beac-f89e7b288222"],
 " for every eigenvalue \[Lambda] of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "a04bc34c-eefe-4aee-ab1e-5372e7094da0"],
 "."
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
  3.6264394069129434`*^9, 3.626439606238497*^9}, {3.847380414035844*^9, 
  3.847380415034705*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"72ddb01e-0606-4b3a-9376-530c886510ca"],

Cell[TextData[{
 "(iv)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "\[Lambda]"], "(", "T", ")"}], TraditionalForm]],
  ExpressionUUID->"ccc1e996-f2e9-48d9-911b-009033463911"],
 " is orthogonal to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "\[Mu]"], "(", "T", ")"}], TraditionalForm]],
  ExpressionUUID->"c8e4dafe-f1f7-489e-b9a0-cda30f8a62d7"],
 ", whenever \[Mu] and \[Lambda] are distinct eigenvalues of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "7c8e482e-a016-4d15-9a11-621648f055b1"]
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
  3.6264394069129434`*^9, 3.626439753855568*^9}, {3.6264400414690704`*^9, 
  3.626440041484687*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"24762cf4-0aa0-4222-a03c-8212fd4ac1c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Proof:", "Subsubsubsection",
 CellChangeTimes->{{3.8473788082650857`*^9, 3.8473788118454275`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5a5332b6-81d1-413d-be16-28cb60afee07"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"||", 
      RowBox[{"T", "(", "x", ")"}], 
      SuperscriptBox["||", "2"]}], "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"T", "(", "x", ")"}], ">"}], "\[VeryThinSpace]", "=", " ", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], 
      RowBox[{"T", "(", "x", ")"}]}], ">"}]}], 
   TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"=", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"T", "\[VeryThinSpace]", 
       RowBox[{
        SuperscriptBox["T", "*"], "(", "x", ")"}]}], ">"}], 
     "\[VeryThinSpace]", "=", "\[VeryThinSpace]", 
     RowBox[{"<", 
      RowBox[{
       SuperscriptBox["T", "*"], "(", "x", ")"}]}]}], ",", "\[VeryThinSpace]", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "*"], "(", "x", ")"}], ">"}], "=", 
     RowBox[{"||", 
      RowBox[{
       SuperscriptBox["T", "*"], "(", "x", ")"}], 
      SuperscriptBox["||", "2"]}]}]}], TraditionalForm]}],ExpressionUUID->
  "eaeb4ab4-72f7-4760-9cc5-18e055ced2c4"]
}], "Text",
 CellChangeTimes->{{3.847378848790682*^9, 3.8473789936804276`*^9}, 
   3.878643376766112*^9, {3.87864675477486*^9, 3.878646840750966*^9}, {
   3.878646877243187*^9, 3.87864700571356*^9}, {3.8786470900310383`*^9, 
   3.878647092127427*^9}, {3.9102656792851934`*^9, 3.910265700946065*^9}, {
   3.910451066916213*^9, 3.910451076666031*^9}, {3.910451215696265*^9, 
   3.9104512756570168`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f9bed25f-7052-4c49-bf0a-ffccd070f3b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"4f0a0e01-52e2-454d-97a3-4d4016a00d86"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"T", "-", 
       RowBox[{"c", " ", "I"}]}], ")"}], "*"], 
    RowBox[{"(", 
     RowBox[{"T", "-", 
      RowBox[{"c", " ", "I"}]}], ")"}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "552affed-d0f4-4495-9333-8ea0f7da4592"]
}], "Text",
 CellChangeTimes->{{3.8788174346251755`*^9, 3.8788174346251755`*^9}, {
  3.87881755525804*^9, 3.878817559101976*^9}, {3.910265741251031*^9, 
  3.9102657703089156`*^9}, {3.9102658264995365`*^9, 
  3.9102658276842213`*^9}},ExpressionUUID->"f7b9d7a3-838d-4b88-a888-\
af42828f73f4"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["=", TraditionalForm]],ExpressionUUID->
  "6bcb17ad-84f9-4ec6-8276-0f1e41336add"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["T", "*"], "-", 
      RowBox[{
       SuperscriptBox["c", "*"], " ", 
       SuperscriptBox["I", "*"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{"T", "-", 
      RowBox[{"c", " ", "I"}]}], ")"}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "ff407287-5691-4296-be39-c0ee18cab2c2"]
}], "Text",
 CellChangeTimes->{{3.8788174350163274`*^9, 3.8788174350163274`*^9}, 
   3.878817659089382*^9, {3.9102657791800475`*^9, 3.9102657854070024`*^9}, {
   3.9102658352519855`*^9, 3.9102658352519855`*^9}, {3.9102658706192894`*^9, 
   3.9102658791334953`*^9}, {3.9104513170681515`*^9, 
   3.9104513320925055`*^9}},ExpressionUUID->"971756d6-cff4-40e3-b42a-\
02db6330f4f5"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"=", " ", 
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "T"}], "-", 
    RowBox[{
     SuperscriptBox["c", "*"], "I", "\[VeryThinSpace]", "T"}], "-", " ", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"*", " "}]], "c", "\[VeryThinSpace]", "I"}], "+", 
    RowBox[{
     SuperscriptBox["c", "*"], "\[VeryThinSpace]", "c", "\[VeryThinSpace]", 
     "I", "\[VeryThinSpace]", "I"}]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"d09687a8-fad7-4365-87e4-b03ce2ece31a"]], \
"Text",
 CellChangeTimes->{{3.878817672028549*^9, 3.8788177029657297`*^9}, {
  3.910265837901517*^9, 3.9102658421947703`*^9}, {3.9104513356644335`*^9, 
  3.910451431949568*^9}},ExpressionUUID->"a26ba5d3-0bd3-4eb4-96d0-\
1e9230f07333"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"=", " "}], TraditionalForm]],ExpressionUUID->
  "0d3c551f-0638-4b23-a940-c6a9f018d909"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "\[VeryThinSpace]", 
     SuperscriptBox["T", "*"]}], "-", " ", 
    RowBox[{"c", "\[VeryThinSpace]\[VeryThinSpace]", 
     SuperscriptBox["T", "*"], "I"}], "-", 
    RowBox[{
     SuperscriptBox["c", "*"], "T", "\[VeryThinSpace]", "I"}], 
    "\[VeryThinSpace]", "+", 
    RowBox[{"c", "\[VeryThinSpace]", 
     SuperscriptBox["c", "*"], "\[VeryThinSpace]", "I", "\[VeryThinSpace]", 
     "I"}]}], TraditionalForm]],ExpressionUUID->
  "3c379152-9469-4190-9759-d87dc51fd0f6"]
}], "Text",
 CellChangeTimes->{{3.878817730799579*^9, 3.8788177919629693`*^9}, {
  3.91026584758978*^9, 3.9102658761106215`*^9}, {3.9104514426713543`*^9, 
  3.9104514935481467`*^9}, {3.910451547405075*^9, 
  3.910451569257083*^9}},ExpressionUUID->"7832f2ce-71d4-46b7-8a43-\
5136e5bb63d9"],

Cell[TextData[Cell[BoxData[{
 FormBox[
  RowBox[{"=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"T", "-", 
      RowBox[{"c", "\[VeryThinSpace]", "I"}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["T", "*"], "-", 
      RowBox[{
       SuperscriptBox["c", "*"], 
       SuperscriptBox["I", "*"]}]}], ")"}]}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"T", "-", 
      RowBox[{"c", " ", "I"}]}], ")"}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"T", "-", 
       RowBox[{"c", " ", "I"}]}], ")"}], "*"]}]}], 
  TraditionalForm]}],ExpressionUUID->"04d700f0-9c1f-4b77-bf83-0131fad0ecf7"]],\
 "Text",
 CellChangeTimes->{{3.878817441985268*^9, 3.878817450194414*^9}, {
  3.910451489521293*^9, 
  3.9104515319491105`*^9}},ExpressionUUID->"9125fc92-0770-4e6d-ae72-\
