 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b9b45fd0-f885-484e-81c2-9f8560a3d4e4"],

Cell[TextData[{
 "Having a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e35b7170-409b-49d5-ace5-657a59bc4882"],
 " of eigenvectors of a linear operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "fa380696-0b44-4022-9aa2-73e53eea2ab8"],
 " is a good thing (your matrix representation of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "f718a824-f108-434a-9d0a-6c867964b454"],
 " is diagonal)."
}], "Text",
 CellChangeTimes->{{3.8789448943376513`*^9, 3.878944919653531*^9}, {
  3.878945051004754*^9, 3.8789450800733223`*^9}, {3.8789900150954103`*^9, 
  3.8789900288100977`*^9}},ExpressionUUID->"985ee0a4-adbc-4693-af10-\
d626896bbcfc"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theme 2: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760575180025`*^9}, {3.6255773136897373`*^9, 
   3.625577379824893*^9}, {3.6264406202550693`*^9, 3.6264406386935463`*^9}, {
   3.6264407017124095`*^9, 3.6264407159319067`*^9}, 3.8471859637356715`*^9, {
