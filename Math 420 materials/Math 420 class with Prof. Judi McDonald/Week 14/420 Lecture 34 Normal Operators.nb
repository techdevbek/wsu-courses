 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"616b138e-175b-4e1b-a337-55f07293c369"],

Cell[TextData[{
 "Having an orthonormal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ad48e6f0-9031-48f5-b36d-bc047dc28b3b"],
 " is great for simplifying calculations, etc.  "
}], "Text",
 CellChangeTimes->{{3.8789448943376513`*^9, 3.878944973819566*^9}, {
  3.878945005561621*^9, 
