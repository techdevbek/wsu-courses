Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"08d50c4d-163b-4da6-87a8-b1d7894876ac"],

Cell["(iii) ", "Text",
 CellChangeTimes->{{3.847380216297039*^9, 3.847380345196488*^9}, 
   3.878643405224536*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"20d9aec3-1fb3-4017-a231-b73fec8acbd8"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e79292e-06da-4c59-9a72-fd58c9d92c58"],
 " be an eigenvector of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "74e29208-e1b4-41c6-88fa-1d4e3a283ff3"],
 " with eigenvalue \[Lambda], so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"7a428db5-9696-42bb-b3aa-6a99c597f328"]
}], "Text",
 CellChangeTimes->{{3.847380216297039*^9, 3.8473804061723356`*^9}, {
   3.8473804390385923`*^9, 3.8473804963532*^9}, 3.8786434090650053`*^9, {
   3.878817834625183*^9, 3.8788178679456644`*^9}, {3.9102659258259935`*^9, 
   3.9102659555051837`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ce67288c-275a-465c-ae47-ee2a08792001"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "=", 
    RowBox[{
     RowBox[{"||", 
      RowBox[{
       RowBox[{"T", "\[VeryThinSpace]", "x"}], "-", 
       RowBox[{
       "\[Lambda]", "\[VeryThinSpace]", "I", "\[VeryThinSpace]", "x"}]}], 
      "||"}], "=", 
     RowBox[{
      RowBox[{"||", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"T", "\[VeryThinSpace]", "-", 
          RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], 
        RowBox[{"(", "\[VeryThinSpace]", "x", ")"}]}], "||"}], "=", 
      RowBox[{
       RowBox[{"||", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"T", "-", 
            RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], "*"], 
         RowBox[{"(", "x", ")"}]}], "||"}], "=", 
       RowBox[{"||", 
        RowBox[{
         RowBox[{
          SuperscriptBox["T", "*"], "(", "x", ")"}], "-", 
         RowBox[{
          OverscriptBox["\[Lambda]", "_"], "\[VeryThinSpace]", 
          RowBox[{"I", "(", "x", ")"}]}]}], "||"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"3a7fb463-fd1e-48ad-8e6c-091eeb765054"],
 ", "
}], "Text",
 CellChangeTimes->{{3.8788181803876357`*^9, 3.878818353190909*^9}, {
   3.9104516684044895`*^9, 3.910451678817687*^9}, 
   3.9104517663621407`*^9},ExpressionUUID->"3efae0b6-a5e6-4d99-8f09-\
88d1b61ec122"],

Cell[TextData[{
 "hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], "(", "x", ")"}], "-", 
     RowBox[{
      OverscriptBox["\[Lambda]", "_"], "\[VeryThinSpace]", 
      RowBox[{"I", "(", "x", ")"}]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"ddeb061e-2aff-4d82-bac9-e1659af76644"]
}], "Text",
 CellChangeTimes->{{3.8788181803876357`*^9, 3.878818353190909*^9}, {
  3.9104516684044895`*^9, 
  3.910451678817687*^9}},ExpressionUUID->"5ea8b34c-abf5-4686-b28f-\
224564033670"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"bc05a061-d5df-4e29-b768-777eaf89fa51"],

Cell["(iv) ", "Text",
 CellChangeTimes->{{3.847380538732668*^9, 3.8473805898684444`*^9}, 
   3.878643427217792*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"0958bff1-36de-44a7-95b7-2ba5f766eb72"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7ab64e7a-20c4-4453-9acc-1e2784e2898d"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "030112b0-8d51-4c53-8734-d3c8aa42ea57"],
 " be eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c96e00e7-d8b8-405e-81e3-71aebb9a2b1a"],
 " with eigenvalues \[Lambda] and \[Mu] respectively (where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[NotEqual]", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"c23b4af8-a135-4561-9136-ee2fa69c7972"],
 "), so  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  ExpressionUUID->"4750548b-9120-486d-9c3a-4595d36cd26f"],
 " and ",
 Cell[BoxData[
  FormBox[
   FormBox[
    RowBox[{
     RowBox[{"T", "(", "y", ")"}], "=", 
     RowBox[{"\[Mu]", "\[VeryThinSpace]", "y"}]}],
    TraditionalForm], TraditionalForm]],ExpressionUUID->
  "ad1489b6-0e2b-4635-a1d0-0fbd9e5dca0d"],
 " "
}], "Text",
 CellChangeTimes->{{3.847380538732668*^9, 3.8473807635638943`*^9}, 
   3.878643430520155*^9, {3.8788183835692043`*^9, 3.8788184183764524`*^9}, {
   3.9102660562789087`*^9, 3.910266095454259*^9}, {3.910266161968218*^9, 
   3.91026619184717*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"dc936095-8a19-4dbc-baa7-f6e684ae5f51"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Lambda]", "-", "\[Mu]"}], ")"}], "<", "x"}], ",", 
      RowBox[{
       RowBox[{"y", ">"}], " ", "=", 
       RowBox[{"\[Lambda]", "<", "x"}]}], ",", 
      RowBox[{"y", ">", 
       RowBox[{"-", "\[Mu]"}], "<", "x"}], ",", 
      RowBox[{
       RowBox[{"y", ">"}], " ", "\[IndentingNewLine]", "=", 
       RowBox[{"<", 
        RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}]}], ",", 
      RowBox[{"y", ">", 
       RowBox[{"-", " ", 
        RowBox[{"<", "x"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         OverscriptBox["\[Mu]", "_"], "y"}], ">"}], " ", "=", 
       RowBox[{"<", 
        RowBox[{"T", "(", "\[VeryThinSpace]", "x", ")"}]}]}], ",", "y"}], 
     ")"}], ">", " ", 
    RowBox[{"-", 
     RowBox[{"<", "x"}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], "(", "y", ")"}], ">"}], "\[IndentingNewLine]",
     "  ", "=", 
    RowBox[{"<", 
     RowBox[{"T", "(", "\[VeryThinSpace]", "x", ")"}]}]}], ",", 
   RowBox[{"y", ">", " ", 
    RowBox[{"-", 
     RowBox[{"<", 
      RowBox[{"T", "(", "x", ")"}]}]}]}], ",", 
   RowBox[{"y", ">"}]}], 
  TraditionalForm]],ExpressionUUID->"2361fd12-a814-491f-b241-0a09d3087ba6"]], \
"Text",
 CellChangeTimes->{{3.8473807704692335`*^9, 3.847380805874916*^9}, 
   3.8786434336848373`*^9, {3.8788184234242096`*^9, 3.878818578910595*^9}, 
   3.910266020103037*^9, {3.910266203455515*^9, 3.910266252792308*^9}, {
   3.910451909068424*^9, 3.9104521674830694`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"333f2547-0887-4257-8efe-0b2c82ce7500"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"=", "0"}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"5ea9543c-d86f-489d-84b0-34b5c52e2573"]], \
"Text",
 CellChangeTimes->{{3.878818588434248*^9, 3.8788186624899144`*^9}, 
   3.9102660237529263`*^9, {3.910266220029721*^9, 
   3.9102662241831837`*^9}},ExpressionUUID->"7eb2b2cf-a908-439f-8d8a-\
8677a708751d"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", "-", "\[Mu]"}], "!=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "71c1bb72-aed9-42d3-b089-4bf4a920aec5"],
 ", it follow that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], " ", "=", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e0025882-b43b-4c93-8c92-2f53cc806f47"]
}], "Text",
 CellChangeTimes->{{3.910452174514843*^9, 
  3.910452194844821*^9}},ExpressionUUID->"5eaf35fe-abfa-4f47-837f-\
9bec3f3d4d29"],

Cell[TextData[{
 "REMARK: the conjugate transpose of a number is just the conjugate of the \
number, so we use ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["c", "*"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f4381d33-bef1-4645-9b87-5d9df0026c3d"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["c", "_"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6da9dc9a-fe02-4989-8164-69a7c418ccea"],
 " interchangeably. "
}], "Text",
 CellChangeTimes->{{3.910452285030959*^9, 3.910452334150773*^9}, 
   3.9104523663588715`*^9},ExpressionUUID->"97ea7ee0-b8c1-42ec-9c11-\
f862429629af"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
   3.6264394069129434`*^9, 3.626439783501343*^9}, {3.626439880068418*^9, 
   3.6264398817716527`*^9}, {3.6264399823254027`*^9, 3.626439995841725*^9}, {
   3.6264404401716924`*^9, 3.6264405442623725`*^9}, {3.626441017076749*^9, 
   3.6264410188580914`*^9}, {3.6266156962121754`*^9, 3.6266156962121754`*^9}, 
   3.847186065939644*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"96ae020c-28f7-448e-a6db-4208779fd543"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2e840ef2-9173-4859-9532-d424fbade072"],
 " is a",
 StyleBox[" normal",
  FontWeight->"Bold"],
 " operator on a finite dimensional ",
 StyleBox["complex",
  FontWeight->"Bold"],
 " vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e6063710-c59e-4f42-aaf4-f002c8035d5f"],
 " if and only if  there is an orthogonal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "badb1952-afa1-4533-96f6-53b88d20e0f4"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "fe249e66-2ef8-44b0-8600-804cce63d182"],
 "."
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
  3.6264394069129434`*^9, 3.626439783501343*^9}, {3.626439880068418*^9, 
  3.6264398817716527`*^9}, {3.6264399823254027`*^9, 3.626439995841725*^9}, {
  3.6264404401716924`*^9, 3.6264405442623725`*^9}, {3.626441017076749*^9, 
  3.6264410188580914`*^9}, {3.6266156962121754`*^9, 3.6266156962121754`*^9}, {
  3.8471860676633835`*^9, 3.8471860960806274`*^9}, {3.910123431014946*^9, 
  3.9101234478448358`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"8b1d592c-58ad-4e3f-bbf9-d68f846cfa6c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
   3.6264394069129434`*^9, 3.626439783501343*^9}, {3.626439880068418*^9, 
   3.6264398817716527`*^9}, {3.6264399823254027`*^9, 3.626439995841725*^9}, {
   3.6264404401716924`*^9, 3.6264405442623725`*^9}, {3.626441017076749*^9, 
   3.6264410188580914`*^9}, {3.6266156962121754`*^9, 3.6266156962121754`*^9}, 
   3.847186065939644*^9, {3.8788150916676683`*^9, 3.8788150937917624`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"bb410aa8-4967-4e9c-a781-adba6838121f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "\[DoubleLongRightArrow]", ")"}], TraditionalForm]],
  ExpressionUUID->"2a797bf0-f354-4886-a0b9-f2b8e7f6a37b"],
 " Assume ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "5d181beb-af37-44e2-b2a9-211ea5c21b39"],
 " is normal. Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Beta]", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "c0782c80-3d7d-48e9-94e8-a15860902ce3"],
 " be an orthogonal basis for ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "4f382fe7-e49e-47cd-ac3e-e2f84e7a95e6"],
 ", for each eigenvalue \[Lambda].  Notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{
     SubscriptBox["\[Union]", "\[Lambda]"], 
     SubscriptBox["\[Beta]", "\[Lambda]"]}]}], TraditionalForm]],
  ExpressionUUID->"47870aa3-b19c-45a7-9efa-106ebab834f8"],
 " is an orthogonal set since the eigenvectors from different eigenspaces are \
orthogonal to each other.  Since it is an orthogonal set of nonzero vectors, \
it is a linearly indpendent set, but alas, maybe \[Beta] is too small to be a \
basis."
}], "Text",
 CellChangeTimes->{{3.8475314491526194`*^9, 3.8475314774337296`*^9}, {
   3.8475315530183144`*^9, 3.8475315600879927`*^9}, {3.8475316609442635`*^9, 
   3.8475318009591923`*^9}, {3.8475516481240206`*^9, 3.8475516499547668`*^9}, 
   3.8788151010637164`*^9, {3.878818737237321*^9, 3.878818860511374*^9}, {
   3.8788188976290913`*^9, 3.878818950177967*^9}, 3.910266348376832*^9, {
   3.91026665625146*^9, 3.9102666779387116`*^9}, {3.91045258308792*^9, 
   3.910452583634726*^9}, {3.910452652299512*^9, 3.910452690222719*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"1a1776e3-4c68-443a-a6dd-3378707dc2ed"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"acd31d23-3b5e-4b67-887a-d610e4e2a2d7"],

Cell[TextData[{
 "Suppose it is too small.  Extend \[Beta] to an orthogonal basis \[Alpha] \
for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "706c2a92-4208-45e6-a53c-22bbfb84ac30"],
 ".  Let \[Gamma] represent the vectors in \[Alpha] that are not already in \
\[Beta].  "
}], "Text",
 CellChangeTimes->{{3.8475314491526194`*^9, 3.8475314774337296`*^9}, {
   3.8475315530183144`*^9, 3.8475315600879927`*^9}, {3.8475316609442635`*^9, 
   3.8475318009591923`*^9}, {3.8475516481240206`*^9, 3.8475516499547668`*^9}, 
   3.8788151010637164`*^9, {3.878818737237321*^9, 3.878818860511374*^9}, {
   3.8788188976290913`*^9, 3.878818950177967*^9}, 3.9102663586117287`*^9, {
   3.9102665046350727`*^9, 3.910266541540983*^9}, {3.9104527055957212`*^9, 
   3.9104527070319276`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"06238619-e8ae-4062-b3be-b4ac094f150e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"b48ae37e-3e07-4b4c-9724-c7797e1f275b"],

Cell["Then ", "Text",
 CellChangeTimes->{{3.8475314491526194`*^9, 3.8475314774337296`*^9}, {
   3.8475315530183144`*^9, 3.8475315600879927`*^9}, {3.8475316609442635`*^9, 
   3.8475318009591923`*^9}, {3.8475516481240206`*^9, 3.8475516499547668`*^9}, 
   3.8788151010637164`*^9, {3.878818737237321*^9, 3.878818860511374*^9}, {
   3.8788188976290913`*^9, 3.878818950177967*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c5290d4a-4055-4fe4-9868-1e902e327e95"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Alpha]"], "=", 
     RowBox[{
      GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
        {"D", "B"},
        {"0", "C"}
       }], "\[NoBreak]", 
      GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}]}]}], " ", ","}], TraditionalForm]],ExpressionUUID->
  "029c80e1-e413-45d9-a3b1-79776ac0e5da"],
 " where ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "3e94c70a-5d13-4243-98e3-6bd9e97889b6"],
 " is a diagonal matrix with the eigenvalues on the diagonal. "
}], "Text",
 CellChangeTimes->{{3.8475314491526194`*^9, 3.8475314774337296`*^9}, {
   3.8475315530183144`*^9, 3.8475315600879927`*^9}, {3.8475316609442635`*^9, 
   3.8475318009591923`*^9}, {3.8475516481240206`*^9, 3.8475516499547668`*^9}, 
   3.8788151010637164`*^9, {3.878818737237321*^9, 3.878818860511374*^9}, {
   3.8788188976290913`*^9, 3.8788190167016006`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"8b14a261-34a1-4419-bc98-84d648ab2131"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"bc1b18c0-fd1c-42f5-8ce2-27d2e241604e"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{
     SuperscriptBox[
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Alpha]"], "*"], "[", "T", "]"}], 
    "\[Alpha]"], "=", 
   RowBox[{
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {
        SuperscriptBox["D", "*"], "0"},
       {
        SuperscriptBox["B", "*"], 
        SuperscriptBox["C", "*"]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], " ", 
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {"D", "B"},
       {"0", "C"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}]}], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {
        RowBox[{
         SuperscriptBox["D", "*"], "D"}], 
        RowBox[{
         SuperscriptBox["D", "*"], "B"}]},
       {
        RowBox[{
         SuperscriptBox["B", "*"], "D"}], 
        RowBox[{"          ", 
         RowBox[{
          RowBox[{
           SuperscriptBox["B", "*"], "B"}], "+", 
          RowBox[{
           SuperscriptBox["C", "*"], "C"}]}]}]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "  "}]}]}], TraditionalForm]],
 InitializationCell->
  True,ExpressionUUID->"5b3dbf72-38fa-43ae-b2af-f307d156af29"]], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.878819025442258*^9, 3.8788192178496776`*^9}, {
  3.910452974173551*^9, 
  3.9104529758151655`*^9}},ExpressionUUID->"9d83cdad-c9c4-4ee8-94bd-\
6e8614bc68d2"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    SubscriptBox[
     RowBox[{
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Alpha]"], "[", "T", "]"}], "\[Alpha]"], 
    "*"], "=", 
   RowBox[{
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {"D", "B"},
       {"0", "C"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], " ", 
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {
        SuperscriptBox["D", "*"], "0"},
       {
        SuperscriptBox["B", "*"], 
        SuperscriptBox["C", "*"]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}]}], "=", " ", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {
        RowBox[{
         RowBox[{"D", "\[VeryThinSpace]", 
          SuperscriptBox["D", "*"]}], "+", 
         RowBox[{"B", "\[VeryThinSpace]", 
          SuperscriptBox["B", "*"]}]}], 
        RowBox[{"       ", 
         RowBox[{"B", "\[VeryThinSpace]", 
          SuperscriptBox["C", "*"]}]}]},
       {
        RowBox[{"C", "\[VeryThinSpace]", 
         SuperscriptBox["B", "*"]}], 
        RowBox[{"       ", 
         RowBox[{"C", "\[VeryThinSpace]", 
          SuperscriptBox["C", "*"]}]}]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], " "}]}]}], TraditionalForm]],
 InitializationCell->
  True,ExpressionUUID->"70b9fdc3-c2e5-4a08-acb9-da6756395210"]], "Text",
 CellChangeTimes->{{3.87881908963403*^9, 3.878819155241501*^9}, {
  3.878819227018295*^9, 3.8788192979075994`*^9}, {3.9104529778147936`*^9, 
  3.910452981873204*^9}},ExpressionUUID->"db3b2991-bb7e-4143-b768-\
520686a42333"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"93c2ea19-7e92-4c6b-9474-2123a65d2136"],

Cell[TextData[{
 "Equating the top left blocks: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"B", "\[VeryThinSpace]", 
     SuperscriptBox["B", "*"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "dca9f0e7-51da-42c2-874c-d8f879fef7a7"],
 " (since ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "87b6f27f-f0e5-4988-a50e-da47cd0a4340"],
 " is diagonal, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["D", "*"], "D"}], "=", 
    RowBox[{"D", "\[VeryThinSpace]", 
     SuperscriptBox["D", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "40a37482-44e5-4a44-9993-939792e5068f"],
 ")"
}], "Text",
 CellChangeTimes->{{3.878819338828307*^9, 
  3.8788194471136446`*^9}},ExpressionUUID->"6a3e87da-7905-4f19-acde-\
e9017c2e8719"],

Cell[TextData[{
 "Recall that rank",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["B", "*"], "B"}], ")"}], "=", 
    RowBox[{"rank", "(", "B", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e1e3f558-229e-4888-b66e-08672ea5f318"],
 ", thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "B", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"bab42952-4f00-456d-8ac2-9af49dc12411"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", "0."}], TraditionalForm]],ExpressionUUID->
  "b5f9a9f7-cca5-444e-8940-24a9b264251f"]
}], "Text",
 CellChangeTimes->{{3.8788194508462296`*^9, 3.8788195332666187`*^9}, {
  3.9104530475840883`*^9, 
  3.910453048144513*^9}},ExpressionUUID->"e9d35469-e361-48d3-b236-\
38e2f736deb9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"fea17517-1ba0-425e-adc4-de30deeac94d"],

Cell[TextData[{
 "But then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Alpha]"], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {"D", "0"},
       {"0", "C"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}]}]}], TraditionalForm]],ExpressionUUID->
  "86495594-6969-4993-ade9-7f1c3b31fac2"],
 ", which means ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"span", " ", "\[Gamma]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "95bf278e-4a47-448b-9b5e-62b02803de30"],
 " is a T-invarient subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c4ac120f-937c-4408-89a0-88c92e5779e5"],
 "."
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.8788194508462296`*^9, 3.8788196086436443`*^9}, {
  3.8788196500162163`*^9, 3.878819788994017*^9}, {3.8788198364022155`*^9, 
  3.8788198635387106`*^9}, {3.9101235387718606`*^9, 3.9101235413215284`*^9}, {
  3.9102664536992607`*^9, 3.9102664903096104`*^9}, {3.910266562196272*^9, 
  3.910266646787738*^9}, {3.9102667072451153`*^9, 
  3.9102667085798893`*^9}},ExpressionUUID->"c85e5128-d2ff-4009-bd3a-\
7dc7f7fc109f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"689e3012-e2d1-420a-a79c-4edd20d488ce"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "a14c395c-1e62-4ebb-b99f-4535debf67f7"],
 " has an  eigenvector in ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69f8ccca-d84e-446f-b9ad-6be353cec372"],
 ", contradicting our assumption that \[Beta] contained all the eigenvectors."
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.8788194508462296`*^9, 3.8788196086436443`*^9}, {
  3.8788196500162163`*^9, 3.878819788994017*^9}, {3.8788198364022155`*^9, 
  3.8788198635387106`*^9}, {3.9101235387718606`*^9, 3.9101235413215284`*^9}, {
  3.9102664536992607`*^9, 3.9102664903096104`*^9}, {3.910266562196272*^9, 
  3.910266646787738*^9}, {3.9102667072451153`*^9, 
  3.910266722371075*^9}},ExpressionUUID->"4a02cfba-feef-4791-8dfe-\
aedd839e5637"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "\[DoubleLongLeftArrow]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8098d02e-0b27-4f52-bdda-daad0b678c20"],
 " Next suppose there is an orthogonal basis \[Beta] of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "0a23ce14-f31e-4375-9c1d-f952676f6049"],
 "."
}], "Text",
 CellChangeTimes->{{3.878819953716379*^9, 3.878819986876096*^9}, {
  3.9102667266275244`*^9, 
  3.9102667384057274`*^9}},ExpressionUUID->"4b385506-b8a3-4155-b3fb-\
0390d95f8c97"],

Cell[TextData[{
 "Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", "D"}], TraditionalForm]],
  ExpressionUUID->"f82410cd-be15-4268-9c86-c5a5e7871aa8"],
 " where ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "32bf2ea1-84f8-45ff-9e89-5ff350377c5c"],
 " is a diagonal matrix and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], "]"}], "\[Beta]"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["D", "*"], "D"}], "=", 
     RowBox[{
      RowBox[{"D", "\[VeryThinSpace]", 
       SuperscriptBox["D", "*"]}], "=", 
      SubscriptBox[
       RowBox[{"[", 
        RowBox[{"T", "\[VeryThinSpace]", 
         SuperscriptBox["T", "*"]}], "]"}], "\[Beta]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"1fff309c-9eb5-472a-88c2-4ecde7c13bd4"],
 "."
}], "Text",
 CellChangeTimes->{{3.8788199923869925`*^9, 3.878820156878233*^9}, {
  3.878820201052209*^9, 
  3.8788202403201466`*^9}},ExpressionUUID->"e520ec4e-582f-49ba-9074-\
ad3f6d0087ae"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
