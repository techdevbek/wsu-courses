Cell[CellGroupData[{

Cell[TextData[StyleBox["Observation: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760575180025`*^9}, {3.6255773136897373`*^9, 
   3.625577379824893*^9}, {3.6264406202550693`*^9, 3.6264406386935463`*^9}, {
   3.6264407017124095`*^9, 3.6264407159319067`*^9}, 3.8471859637356715`*^9, {
   3.878944887244769*^9, 3.8789448887119503`*^9}, {3.9104437149287195`*^9, 
   3.910443727423142*^9}, 3.9104440126904287`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"d7e4a4a6-de07-4bcf-918f-137372434f77"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "82b78e34-2cee-415f-a004-2119bb4f60c8"],
 " be the vector space of signals in ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalR]", TraditionalForm]],ExpressionUUID->
  "0ecd6a41-59c2-4a06-b9bc-4e23331557ca"],
 " with the additional property that the sum of the squares of the entries is \
finite.  Then ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7630b341-50e3-4875-9d73-02a7d6e636ca"],
 " is an inner product space with the inner product defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", "x"}], ",", 
    RowBox[{
     RowBox[{"y", ">"}], " ", "=", " ", 
     RowBox[{Cell[TextData[Cell[BoxData[
       FormBox["\[Sum]", TraditionalForm]],ExpressionUUID->
       "a71d7072-e76b-43b6-a54a-9b03e3f281df"]],ExpressionUUID->
       "05fc5f93-1223-45c2-b8d5-dae41b252691"], 
      SubscriptBox["y", "i"], 
      SubscriptBox["x", "i"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cbeec14e-2ff1-42a4-abc9-31c6a80db6b3"],
 ". A subspace of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "ced8c960-c936-4965-9b38-647676f01173"],
 " is the set ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "1f70ee5c-4e2a-4adc-ba45-ef3b3a687634"],
 " of all signals with fintely many nonzero entries.  Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["e", "j"], TraditionalForm]],ExpressionUUID->
  "f6e325ad-73c4-457b-aae2-52c1653a47ed"],
 " be the signal with a 1 in the j-th position, and zeros elsewhere.  Then \
each ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["e", "j"], TraditionalForm]],ExpressionUUID->
  "81199296-7d95-49f3-821d-856e880d29b1"],
 " is in ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "b7eeae95-9bc1-44da-9643-13a7138b0788"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "\[Perpendicular]"], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],ExpressionUUID->
  "8189e530-a8b0-41d1-821d-2c957ffcb042"],
 ", but ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", 
     RowBox[{"\[Perpendicular]", "\[Perpendicular]"}]], "=", 
    RowBox[{"S", "."}]}], TraditionalForm]],ExpressionUUID->
  "5b02217b-11d4-44fa-b87b-735aef0554dc"]
}], "Text",
 CellChangeTimes->{{3.9104437304715767`*^9, 3.9104437590183907`*^9}, {
  3.9104437949969263`*^9, 3.910443993705223*^9}, {3.9104497244802866`*^9, 
  3.91044992650877*^9}},ExpressionUUID->"b1e27a25-102a-46a7-ba6e-\
f95aa8ac0c2b"]
}, Open  ]],

Cell[CellGroupData[{

