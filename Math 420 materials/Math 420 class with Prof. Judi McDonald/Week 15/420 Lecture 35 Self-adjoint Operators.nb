Cell[TextData[{
 "A linear transformation is said to be ",
 StyleBox["Hermitian",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " or ",
 StyleBox["self-adjoint",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", "*"], "=", 
    RowBox[{"T", ".", " "}]}], TraditionalForm]],ExpressionUUID->
  "60652d8f-f5b6-4714-80b4-d2b9abc50a3b"]
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
