Cell[TextData[{
 "When can you have an orthogonal basis  for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f01981e0-3445-43a2-91e8-aec1d4340c73"],
 " consisting of eigenvectors ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "214f8711-6992-46c0-920f-ce472984675b"],
 " with REAL eigenvalues?"
}], "Text",
 CellChangeTimes->{{3.8789448943376513`*^9, 3.878944919653531*^9}, {
  3.878944990574691*^9, 3.878945047901456*^9}, {3.878945088880843*^9, 
