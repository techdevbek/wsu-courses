 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"dc1dd91c-4719-49b6-8bab-0f969218df50"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "5c61c940-8bd8-42f9-a4c6-770e9cfd3ced"],
 " be a linear operator on a finite-dimensional inner product  space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "b9c2ac77-aac2-4366-8d46-5ebf7c820f26"],
 "  Then the following are equivalent:"
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439277903037*^9}, {
   3.6264401828552628`*^9, 3.6264401857929173`*^9}, {3.62661313065482*^9, 
   3.626613154531094*^9}, {3.6266141477933493`*^9, 3.6266141477933493`*^9}, {
   3.6267889877933073`*^9, 3.6267889982001305`*^9}, 3.8473616890906477`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"164997af-be65-489e-a9df-454fda888eb5"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", 
     RowBox[{"T", "(", "x", ")"}], "||"}], "=", 
    RowBox[{"||", "x", "||"}]}], TraditionalForm]],ExpressionUUID->
  "2518fb0b-143a-4e3d-953a-08cf42e9bb01"],
 ", \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "0f5cc15d-db60-47cc-aa46-83859202b63b"],
 ", ie ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "56b3165e-f31c-4e95-9d85-422315205f8a"],
 " is unitary"
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439277903037*^9}, {
  3.6264401828552628`*^9, 3.6264401857929173`*^9}, {3.62661313065482*^9, 
  3.626613154531094*^9}, {3.6266141477933493`*^9, 3.6266141588720264`*^9}, {
  3.878991593512729*^9, 3.8789915992779083`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"8a268d46-90c9-4e10-b31a-9ec761371072"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"T", " ", 
      SuperscriptBox["T", "*"]}], "=", 
     RowBox[{
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], "=", 
      SubscriptBox["I", "V"], " "}]}]}], TraditionalForm]],ExpressionUUID->
  "2d3fa94c-3931-40c0-984b-dc2a2fce5b86"],
 ". (ie ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "=", 
     SuperscriptBox["T", 
      RowBox[{"-", "1"}]]}], ")"}], TraditionalForm]],ExpressionUUID->
  "feedffcf-3567-49c9-a621-30c562e08a0c"],
 "."
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
  3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
  3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439430851683*^9}, {
  3.626613927688936*^9, 3.626613955547408*^9}, {3.626614138167819*^9, 
  3.6266141616846957`*^9}, {3.62678976989328*^9, 3.626789770924589*^9}, {
  3.878992858475664*^9, 3.878992875886574*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5edf4cf2-07ea-4497-8ce4-d4d543dc4524"],

Cell[TextData[{
 "(iii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], ",", 
     RowBox[{"T", "(", "y", ")"}]}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"5d9fdbf8-ecb1-40d3-a613-7c0748b78cfb"],
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"x", ",", " ", "y"}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aad0dbc8-c578-4457-b923-81a53246114f"],
 ",  \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", "\[Element]", " ", 
     RowBox[{"V", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "22f775b5-9754-46b4-a4c8-b93a7d0fbe48"],
 " "
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
   3.6264394069129434`*^9, 3.626439460650107*^9}, {3.6266139631571712`*^9, 
   3.6266140103940296`*^9}, 3.626614163403535*^9, {3.6266142125935698`*^9, 
   3.626614212984234*^9}, 3.910127337093202*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f2962431-a7cc-48b4-8983-7fd5880e0234"],

Cell[TextData[{
 "(iv) \[ForAll] orthonormal basis \[Beta] for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7490d564-c42c-4a43-a483-8f1fa6e3f668"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],ExpressionUUID->
  "1fec9fbd-3842-48e3-857b-a747311a091e"],
 " is an orthonormal basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "6aa31e8c-6b0e-4bf4-ac48-cc82960af0fb"],
 "  "
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
   3.6264394069129434`*^9, 3.626439606238497*^9}, {3.6266140140348434`*^9, 
   3.6266141222763844`*^9}, {3.626614165825536*^9, 3.626614167731884*^9}, 
   3.6266173377054214`*^9, {3.626617493037599*^9, 3.6266175159919195`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"05c0420c-b72c-459f-90cc-2e47383dd436"],

Cell[TextData[{
 "(v) \[Exists] \[Beta], an orthonormal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a418acd1-4dd4-46d8-99f9-447dc658d752"],
 ", such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],ExpressionUUID->
  "ea80fa78-fe14-4902-837b-c2abe628a82f"],
 " is an orthonormal basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "8b8830f4-9fe3-41cc-9daf-c65a602be41f"],
 " "
}], "Text",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760582524166`*^9}, {3.626439145126526*^9, 
   3.626439208399403*^9}, {3.6264392756528873`*^9, 3.626439325499257*^9}, {
   3.6264394069129434`*^9, 3.626439753855568*^9}, {3.6264400414690704`*^9, 
   3.626440041484687*^9}, {3.626614091337269*^9, 3.6266141287142334`*^9}, 
   3.6266141722008667`*^9, 3.6266174307680707`*^9, {3.626617523804821*^9, 
   3.6266175252423944`*^9}, {3.6266175673719873`*^9, 3.6266175686533117`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4d7f58f5-addf-4eff-aca7-308e01d3736d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 "  "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6266178953637066`*^9, 3.626617899988949*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"42d004f7-d9ad-44de-b852-c10c2566e2ef"],

Cell[TextData[{
 "(i)\[DoubleLongRightArrow](ii)  Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", 
     RowBox[{"T", "(", "x", ")"}], "||"}], "=", 
    RowBox[{"||", "x", "||"}]}], TraditionalForm]],ExpressionUUID->
  "7808debf-344a-40ae-ab54-11a54803fca7"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "041f2c6a-49d2-4a81-a35c-61239824656e"]
}], "Text",
 CellChangeTimes->{{3.878991626005413*^9, 3.878991636883486*^9}, {
  3.8789916722936745`*^9, 
  3.8789916914483385`*^9}},ExpressionUUID->"5b489e89-b426-4018-b489-\
3a30aed04118"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"01fe420a-9ab0-448a-bc7c-7ba9d3b139cd"],

Cell[TextData[{
 "Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], ")"}], "*"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], 
      SuperscriptBox["T", "**"]}], "=", 
     RowBox[{
      SuperscriptBox["T", "*"], "T"}]}]}], TraditionalForm]],ExpressionUUID->
  "e7bb2186-35a5-4010-8643-a8b7eef98f91"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", "*"], "T"}], TraditionalForm]],ExpressionUUID->
  "f9841500-e145-46f6-a075-d20508d72e5c"],
 " is self-adjoint and hence has an orthonormal basis of eigenvectors with \
real eigenvalues.  ",
 Cell[BoxData[
  FormBox["Let", TraditionalForm]],ExpressionUUID->
  "e04b7c76-b6a3-4456-aad7-f1b4be0aaf16"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"702b2ff0-2e71-40ca-840d-7b7f864baf66"],
 " be an orthonormal basis of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["T", "*"], "T"}], TraditionalForm]],ExpressionUUID->
  "d1a35b6f-3336-46e5-bde1-2ca6f436aae9"],
 " with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", " ", 
    SubscriptBox["\[Lambda]", "2"], ",", 
    RowBox[{"...", " ", 
     SubscriptBox["\[Lambda]", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "c0cf9cab-d946-4f3e-a1ca-641e90aab5c1"],
 ".  Then"
}], "Text",
 CellChangeTimes->{{3.8789918203560815`*^9, 3.8789918312643833`*^9}, {
   3.8789918649324484`*^9, 3.878992106006817*^9}, {3.878992186368462*^9, 
   3.878992359437775*^9}, {3.9101274761454353`*^9, 3.9101275219231453`*^9}, 
   3.9102671289423866`*^9},ExpressionUUID->"3e65bd0a-9daa-4a1f-bc47-\
7bdaf7bb2a2c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"97238659-89fd-4bb7-a4df-b50cfc1beaf2"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"||", 
     SubscriptBox["v", "j"], 
     SuperscriptBox["||", "2"]}], "=", 
    RowBox[{
     RowBox[{"||", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "j"], ")"}], 
      SuperscriptBox["||", "2"]}], "=", " ", 
     RowBox[{"<", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "j"], ")"}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"T", "(", 
      SubscriptBox["v", "j"], ")"}], ">"}], " ", "=", 
    RowBox[{"<", 
     SubscriptBox["v", "j"]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["T", "*"], 
      RowBox[{"T", "(", 
       SubscriptBox["v", "j"], ")"}]}], ">"}], " ", "=", 
    RowBox[{"<", 
     SubscriptBox["v", "j"]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[Lambda]", "j"], 
      SubscriptBox["v", "j"]}], ">"}], " ", "=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], "||", 
     SubscriptBox["v", "j"], 
     SuperscriptBox["||", "2"], " "}]}]}], 
  TraditionalForm]],ExpressionUUID->"4aef46d2-4a1b-4d33-bf1f-0f551a3587da"]], \
"Text",
 CellChangeTimes->{{3.8789918203560815`*^9, 3.8789918312643833`*^9}, {
  3.8789918649324484`*^9, 3.878992106006817*^9}, {3.878992186368462*^9, 
  3.8789924117784257`*^9}, {3.87899247830187*^9, 3.878992561217656*^9}, {
  3.8789926671721616`*^9, 3.878992712022191*^9}, {3.878992747491658*^9, 
  3.8789927581067905`*^9}, {3.9101275275680947`*^9, 3.910127608399032*^9}, {
  3.9102672171623445`*^9, 3.9102672171623445`*^9}, {3.910267247675191*^9, 
  3.910267247675191*^9}, {3.910711999138149*^9, 3.9107121157957234`*^9}, {
  3.910712176547785*^9, 
  3.910712207186224*^9}},ExpressionUUID->"a0bb05cf-ef2c-472f-91d9-\
bfb05999688c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"3b837876-92ed-473d-8a21-6176efd4b965"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "j"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], "\[VeryThinSpace]", "=", "1"}]}], 
   TraditionalForm]],ExpressionUUID->"0e4cb5db-50ad-4dd4-ad69-9ccce7960aa0"],
 " it follows that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "j"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"fcac92c5-8b30-45f4-82ae-b78a376eeb07"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["T", "*"], "T"}], "]"}], "\[Beta]"], "=", "I"}], 
   TraditionalForm]],ExpressionUUID->"60df269c-7421-457e-ab7f-db58be9a0d21"],
 " and thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", "*"], "T"}], "=", 
    SubscriptBox["I", "V"]}], TraditionalForm]],ExpressionUUID->
  "4a7c2b9b-2ec3-437e-98c0-3aea77d74e90"],
 ".  Similarly ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "\[VeryThinSpace]", 
     SuperscriptBox["T", "*"]}], "=", 
    SubscriptBox[
     StyleBox["I",
      FontSlant->"Plain"], "V"]}], TraditionalForm]],ExpressionUUID->
  "74931dba-205f-4a8f-9815-debdd2cceff5"],
 "."
}], "Text",
 CellChangeTimes->{{3.8789918203560815`*^9, 3.8789918312643833`*^9}, {
  3.8789918649324484`*^9, 3.878992106006817*^9}, {3.878992186368462*^9, 
  3.8789924117784257`*^9}, {3.87899247830187*^9, 3.878992629720847*^9}, {
  3.8789927208385715`*^9, 3.8789927246357875`*^9}, {3.878992772479987*^9, 
  3.878992850275824*^9}, {3.910127621879635*^9, 3.910127656973672*^9}, {
  3.910712161012319*^9, 3.9107121620015407`*^9}, {3.9107122106900024`*^9, 
  3.910712211032251*^9}},ExpressionUUID->"3d14bdb9-bbc6-40f6-9a37-\
50a9c00806b2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"07fa07de-2c4b-466f-bb83-07695282795c"],

Cell[TextData[{
 "(ii)\[DoubleLongRightArrow](iii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     FormBox[
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        RowBox[{"T", "(", "x", ")"}], ",", 
        RowBox[{"T", "(", "y", ")"}]}], "\[RightAngleBracket]"}],
      TraditionalForm], " ", "=", "  ", 
     RowBox[{
      FormBox[
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{
         RowBox[{
          SuperscriptBox["T", "*"], 
          RowBox[{"T", "(", "x", ")"}]}], ",", "y"}], "\[RightAngleBracket]"}],
       TraditionalForm], " ", "=", 
      FormBox[
       RowBox[{"\[LeftAngleBracket]", 
        RowBox[{"x", ",", "y"}], "\[RightAngleBracket]"}],
       TraditionalForm]}]}]}], TraditionalForm]],ExpressionUUID->
  "14ce75e5-96eb-44aa-bd42-e2f46369182e"]
}], "Text",
 CellChangeTimes->{{3.878991626005413*^9, 3.878991636883486*^9}, {
  3.8789916722936745`*^9, 3.8789916914483385`*^9}, {3.8792470452626657`*^9, 
  3.879247096164798*^9}, {3.8792492544504724`*^9, 
  3.879249283717378*^9}},ExpressionUUID->"36844c9e-5e44-48a2-bbef-\
60ea77fff7df"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"264fe925-fea5-45cc-b367-1ded35a27c74"],

Cell[TextData[{
 "(iii)\[DoubleLongRightArrow](iv)  Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     SubscriptBox["v", "i"]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], " ", "=", 
     RowBox[{"<", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "i"], ")"}]}]}], ",", 
    RowBox[{
     RowBox[{"T", "(", 
      SubscriptBox["v", "j"], ")"}], ">"}]}], TraditionalForm]],
  ExpressionUUID->"c1a2f09e-ac3d-49d8-a86c-d5316464f027"],
 " so an othonormal basis is mapped to an orthonormal basis by ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "d17ce56a-8b7e-4c9d-b08c-e00b03d5d30b"]
}], "Text",
 CellChangeTimes->{{3.878991626005413*^9, 3.878991636883486*^9}, {
  3.8789916722936745`*^9, 3.8789916914483385`*^9}, {3.8792470452626657`*^9, 
  3.8792470989275513`*^9}, {3.8792493071499557`*^9, 3.879249336918174*^9}, {
  3.9101276992704406`*^9, 
  3.9101277968613625`*^9}},ExpressionUUID->"16d01ecc-455e-42c3-a0dc-\
7b548bed9057"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"2990eaa2-5dbf-47bd-91c1-44254eef56c2"],

Cell[TextData[{
 "(iv)\[DoubleLongRightArrow](v)  Certainly ",
 Cell[BoxData[
  FormBox["\[ForAll]", TraditionalForm]],ExpressionUUID->
  "18964158-7599-4284-881d-08f90ff138ff"],
 " implies ",
 Cell[BoxData[
  FormBox["\[Exists]", TraditionalForm]],ExpressionUUID->
  "a66725df-9d5c-473a-9e3c-42464ea68c26"]
}], "Text",
 CellChangeTimes->{{3.878991626005413*^9, 3.878991636883486*^9}, {
  3.8789916722936745`*^9, 3.8789916914483385`*^9}, {3.8792470452626657`*^9, 
  3.8792470503827305`*^9}, {3.879247085216421*^9, 3.87924710218386*^9}, {
  3.8792493549928007`*^9, 
  3.879249372731181*^9}},ExpressionUUID->"ad7e4021-8738-44aa-b7c8-\
6a5c8f6eca91"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"b10db61d-da71-4ee3-a7be-ca548677747b"],

Cell[TextData[{
 "(v)\[DoubleLongRightArrow](i)  Assume \[Exists] \[Beta], an orthonormal \
basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "5d0b9cb9-00c9-4d06-8f00-fa3a8fe007be"],
 ", such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],ExpressionUUID->
  "eaa9a8c9-8653-4623-9519-9b9ea3e60233"],
 " is an orthonormal basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "e5f968aa-7552-4963-be42-233e927b29e7"]
}], "Text",
 CellChangeTimes->{{3.878991626005413*^9, 3.878991636883486*^9}, {
  3.8789916722936745`*^9, 3.8789916914483385`*^9}, {3.8792470452626657`*^9, 
  3.8792470503827305`*^9}, {3.87924708995972*^9, 3.8792471053078365`*^9}, {
  3.8792494119370947`*^9, 
  3.879249416622895*^9}},ExpressionUUID->"5d6403a9-6c0b-4da0-a8fb-\
6e3d45962581"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"5716b8a4-d379-496a-b308-0dd7f522c2c6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "e98a20ec-4a2a-4965-817a-d45284743bb6"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "0e5bb061-785f-4cd9-b4ff-1e93aa62a822"],
 ".  Then there are scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "1"], ",", "...", ",", 
    SubscriptBox["c", "n"]}], TraditionalForm]],ExpressionUUID->
  "0d37e3ff-fd43-46a3-b834-18f8efb3b26c"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"i", "=", "1"}], "n"], 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["v", "i"]}]}]}], TraditionalForm]],ExpressionUUID->
  "541c32c2-7665-4a45-98dd-2f3ef6b7c416"],
 "."
}], "Text",
 CellChangeTimes->{{3.8792494557380953`*^9, 3.879249528580214*^9}, 
   3.9102673459786963`*^9},ExpressionUUID->"15260876-8a36-4d5c-8e65-\
c06f689b1f11"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"a629d560-71f4-46dc-b8cd-0328c5f569ea"],

Cell[TextData[{
 "Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"||", "x", 
      SuperscriptBox["||", "2"]}], "=", 
     RowBox[{"<", "x"}]}], ",", 
    RowBox[{
     RowBox[{"x", ">"}], " ", "=", " ", 
     RowBox[{"<", 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["c", "i"], 
        SubscriptBox["v", "i"]}]}]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["c", "j"], 
        SubscriptBox["v", "j"]}]}], ">"}], " ", "=", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "n"], 
       RowBox[{
        SubsuperscriptBox["\[Sum]", 
         RowBox[{"j", "=", "1"}], "n"], 
        RowBox[{
         SubscriptBox["c", "i"], 
         OverscriptBox[
          SubscriptBox["c", "j"], "_"]}]}]}], " ", "<", 
      SubscriptBox["v", "i"]}]}], ",", 
    RowBox[{
     SubscriptBox["v", "j"], ">"}]}], TraditionalForm]],ExpressionUUID->
  "4d5fa2c0-195a-4515-926e-e5d199544914"]
}], "Text",
 CellChangeTimes->{{3.879249537675043*^9, 3.8792496619640465`*^9}, {
  3.8792496963988447`*^9, 3.879249793422929*^9}, {3.910267380745676*^9, 
  3.9102673876589017`*^9}},ExpressionUUID->"54012727-4fd7-454f-a1b3-\
edea214f831f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"af677be3-b7a0-4f46-85b2-978875664094"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "n"], 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"j", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["c", "i"], 
        OverscriptBox[
         SubscriptBox["c", "j"], "_"]}]}]}], " ", "<", 
     RowBox[{"T", "(", 
      SubscriptBox["v", "i"], ")"}]}]}], ",", 
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "j"], ")"}], ">", " "}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"9a2de01a-7486-4cce-adbd-0e5e5a44b3a3"]], \
"Text",
 CellChangeTimes->{{3.9102673974466267`*^9, 
  3.9102674126195536`*^9}},ExpressionUUID->"17543af1-6595-4be0-b3a1-\
143ef299e2fb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"9f85551c-fbff-493d-abba-1a3d2f21ac61"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"=", " ", 
    RowBox[{"<", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "n"], 
      RowBox[{
       SubscriptBox["c", "i"], 
       RowBox[{"T", "(", 
        SubscriptBox["v", "i"], ")"}]}]}]}]}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"j", "=", "1"}], "n"], 
      RowBox[{
       SubscriptBox["c", "j"], 
       RowBox[{"T", "(", 
        SubscriptBox["v", "j"], ")"}]}]}], ">"}], " ", "=", 
    RowBox[{"<", 
     RowBox[{"T", "(", 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"i", "=", "1"}], "n"], 
       RowBox[{
        SubscriptBox["c", "i"], 
