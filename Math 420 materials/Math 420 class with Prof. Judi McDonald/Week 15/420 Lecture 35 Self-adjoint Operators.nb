Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.9102669222097797`*^9, 
  3.910266926706002*^9}},ExpressionUUID->"bb3069c0-0463-44ee-9466-\
0e6bf0aaa286"],

Cell[TextData[{
 "Suppose \[Beta] is an othogonal basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f20df048-9f81-4e04-adab-725ef31433c7"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "e4699aab-21d1-4742-8eb6-5d91022ffe1a"],
 ".  Then"
}], "Text",
 CellChangeTimes->{{3.8789451702174187`*^9, 3.8789453395404983`*^9}, {
  3.910266929359809*^9, 
  3.9102669646428895`*^9}},ExpressionUUID->"d3cbba50-cc3e-40e7-97ef-\
60b3e22b9bc0"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {
         SubscriptBox["\[Lambda]", "1"], "0", "\[CenterEllipsis]", "0"},
        {"0", 
         SubscriptBox["\[Lambda]", "2"], "\[DescendingEllipsis]", 
         "\[VerticalEllipsis]"},
        {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
         "\[DescendingEllipsis]", "0"},
        {"0", "\[CenterEllipsis]", "0", 
         SubscriptBox["\[Lambda]", "n"]}
       }], "\[NoBreak]", ")"}], " ", "=", "D"}]}], TraditionalForm]],
  ExpressionUUID->"2d712b21-df07-41e7-bdc1-81b9bc2b12af"],
 " "
}], "Text",
 CellChangeTimes->{{3.8789451702174187`*^9, 3.8789453395404983`*^9}, {
  3.910266929359809*^9, 3.9102669588390293`*^9}},
 TextAlignment->Center,ExpressionUUID->"bb6a1ad1-c08b-4c21-9ec9-f9ddb5cdac4b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{
  3.910266812417694*^9},ExpressionUUID->"1b88ce4a-b40d-4c50-86e5-\
6ae69196db1f"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"[", 
     SuperscriptBox["T", "*"], "]"}], "\[Beta]"], "=", 
   RowBox[{
    SuperscriptBox[
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Beta]"], "*"], "=", 
    RowBox[{
     SuperscriptBox["D", "*"], "=", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          SubscriptBox[
           OverscriptBox["\[Lambda]", "_"], "1"], "0", "\[CenterEllipsis]", 
          "0"},
         {"0", 
          SubscriptBox[
           OverscriptBox["\[Lambda]", "_"], "2"], "\[DescendingEllipsis]", 
          "\[VerticalEllipsis]"},
         {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
          "\[DescendingEllipsis]", "0"},
         {"0", "\[CenterEllipsis]", "0", 
          SubscriptBox[
           OverscriptBox["\[Lambda]", "_"], "n"]}
        }], "\[NoBreak]", ")"}], " ", "=", 
      RowBox[{
       RowBox[{"(", "\[NoBreak]", GridBox[{
          {
           SubscriptBox["\[Lambda]", "1"], "0", "\[CenterEllipsis]", "0"},
          {"0", 
           SubscriptBox["\[Lambda]", "2"], "\[DescendingEllipsis]", 
           "\[VerticalEllipsis]"},
          {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
           "\[DescendingEllipsis]", "0"},
          {"0", "\[CenterEllipsis]", "0", 
           SubscriptBox["\[Lambda]", "n"]}
         }], "\[NoBreak]", ")"}], "=", "D"}]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"73b0ddd0-6938-4a97-b0ae-b527f06b5884"]], \
"Text",
 CellChangeTimes->{{3.878945346704317*^9, 3.878945462667561*^9}, {
  3.8789455015287037`*^9, 3.878945531441122*^9}, {3.8789895242259183`*^9, 
  3.8789895382631044`*^9}, {3.878990253775796*^9, 3.878990256289979*^9}, {
  3.910266791485752*^9, 3.9102667919309072`*^9}, {3.910266831259099*^9, 
  3.9102668580334115`*^9}, {3.9102669926483927`*^9, 3.910266995036968*^9}},
 TextAlignment->Center,ExpressionUUID->"8312e22e-5f3c-48eb-b253-630d9b664b26"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"0e208f4b-6ac4-44fe-b130-978d80b79168"],

Cell[TextData[{
 "So ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "=", 
    SuperscriptBox["D", "*"]}], TraditionalForm]],ExpressionUUID->
  "86155a7a-e7c3-4c8e-9a10-d04ce5a769a4"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "=", 
    SuperscriptBox["T", "*"]}], TraditionalForm]],ExpressionUUID->
  "0f86f1e6-1b90-4ed5-9339-288a1818da71"],
 "."
}], "Text",
