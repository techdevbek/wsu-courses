 FontFamily->
  "Times New Roman",ExpressionUUID->"b5afe521-c2f9-4d4b-af28-bd1fdf7b2c4b"],

Cell[TextData[{
 "A linear transformation is said to be s",
 StyleBox["ymmetric",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Beta]"], "T"], "=", 
     SubscriptBox[
      RowBox[{"[", "T", "]"}], "\[Beta]"]}], ",", " ", 
    RowBox[{"for", " ", "some", " ", "basis", " ", 
     RowBox[{"\[Beta]", ".", " "}]}]}], TraditionalForm]],ExpressionUUID->
  "6b3f31b2-4d48-47c4-b6e7-08ba66ab34da"]
}], "Text",
