   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209084275255`*^9}, {3.6241937616904435`*^9, 
   3.624193771581601*^9}, {3.6246266823378897`*^9, 3.624626829673931*^9}, {
   3.6246271674150486`*^9, 3.6246271674150486`*^9}, {3.62523082748895*^9, 
   3.6252309485913424`*^9}, {3.625231137598692*^9, 3.625231137598692*^9}, {
   3.6252337547153473`*^9, 3.625233769172261*^9}, {3.6252338400134635`*^9, 
   3.6252338523266163`*^9}, {3.6255767100473633`*^9, 3.62557675602606*^9}, {
   3.626612911171327*^9, 3.6266130735683517`*^9}, {3.626785683556218*^9, 
   3.6267856946349325`*^9}, 3.8473614480345335`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"ee2b8a2a-c7a7-4f09-ac5a-50f77846c8bd"],

Cell[TextData[{
 " Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", " "}], TraditionalForm]],ExpressionUUID->
  "b0b0a5bb-e65d-4ad0-b14d-562b7fe1d868"],
 "be a linear operator on a finite dimensional inner product space.  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"||", 
     RowBox[{"T", "(", "x", ")"}], "||"}], "=", 
    RowBox[{"||", "x", "||"}]}], TraditionalForm]],ExpressionUUID->
  "e4ae36ea-38f6-4d9b-851a-cee78f086602"],
 ", \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "45c55ecf-22c7-4525-a8a1-466312367924"],
 ", then we say ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "389ce465-a3cb-4407-a1df-967f826fe3a2"],
 " is ",
 StyleBox["unitary",
  FontWeight->"Bold"],
 " (over \[DoubleStruckCapitalC]) or ",
 StyleBox["orthogonal",
  FontWeight->"Bold"],
 " (over \[DoubleStruckCapitalR]). "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, {
   3.622549545655701*^9, 3.6225497572401175`*^9}, {3.622553144281087*^9, 
   3.6225531848188205`*^9}, {3.6235851050020804`*^9, 3.623585196428582*^9}, {
   3.624020691472356*^9, 3.6240209084275255`*^9}, {3.6241937616904435`*^9, 
   3.624193771581601*^9}, {3.6246266823378897`*^9, 3.624626829673931*^9}, {
