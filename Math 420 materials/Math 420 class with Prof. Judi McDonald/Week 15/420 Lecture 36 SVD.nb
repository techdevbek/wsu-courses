Cell[CellGroupData[{

Cell[TextData[StyleBox["Singular Value Decomposition",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
   3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.6207349095107193`*^9, 
   3.6207349400432186`*^9}, {3.6209940980164237`*^9, 
   3.6209941257916193`*^9}, {3.621166706928668*^9, 3.621166722976368*^9}, {
   3.62159916232817*^9, 3.621599196108389*^9}, 3.62159984976527*^9, {
   3.6223749799468083`*^9, 3.6223749960257387`*^9}, {3.6225494720298038`*^9, 
   3.622549507234743*^9}, {3.6235856366612887`*^9, 3.623585653224654*^9}, {
   3.6240206450382576`*^9, 3.6240206470696516`*^9}, {3.6240206789248157`*^9, 
   3.6240206887691174`*^9}, 3.624626589860346*^9, {3.62462665353562*^9, 
   3.6246266752906113`*^9}, {3.6252307815053463`*^9, 
   3.6252308090068398`*^9}, {3.62557668924995*^9, 3.6255767052976656`*^9}, 
   3.625580291723336*^9, {3.847744995198949*^9, 3.8477450026645045`*^9}, {
   3.8789917826007743`*^9, 
   3.8789917837213736`*^9}},ExpressionUUID->"fc567c68-6f47-4829-8b6e-\
1ca694cdd668"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Question: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.625576018846874*^9, 3.625576024206529*^9}, {
   3.6255760570961037`*^9, 3.6255760575180025`*^9}, {3.6255773136897373`*^9, 
   3.625577379824893*^9}, {3.6264406202550693`*^9, 3.6264406386935463`*^9}, {
   3.6264407017124095`*^9, 3.6264407159319067`*^9}, 3.8471859637356715`*^9, {
   3.878944887244769*^9, 3.8789448887119503`*^9}, {3.878944985001936*^9, 
   3.878944985929305*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"1b1f7dc7-4e9e-456c-99cb-0a9c71c4e9bf"],

Cell[TextData[{
 "Even if ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b5b3980a-2c7c-4474-9446-1c7e8e26afd6"],
 " is not a square matrix, notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "a607e8b1-2a41-4cc1-a887-a0cbf032f0f9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[VeryThinSpace]", 
    SuperscriptBox["A", "*"]}], TraditionalForm]],ExpressionUUID->
  "0285743e-1433-4f7c-ad12-2cdc03bdd795"],
 " are both self-adjoint.  Can we take advantage of this when we are working \
with ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "c8dfcf25-69e5-496e-80c3-8d37778f1fce"],
 " itself?  "
}], "Text",
 CellChangeTimes->{{3.8477450513160353`*^9, 3.8477453298957777`*^9}, {
  3.8477454668765097`*^9, 3.8477455221683245`*^9}, {3.8477456132233877`*^9, 
  3.8477456255492487`*^9}, {3.847745659944312*^9, 3.847745703806911*^9}, {
  3.8477457355658703`*^9, 3.847745872742693*^9}, {3.847746587018421*^9, 
  3.8477465973424687`*^9}, {3.8792474237168064`*^9, 3.8792474858587317`*^9}, {
  3.9101278779582677`*^9, 3.910127897576971*^9}, {3.910267551383748*^9, 
  3.910267551796833*^9}},ExpressionUUID->"ec2b053f-59e3-4142-aeac-\
94e75a7a452d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.8477458749606*^9, 
  3.8477458749606*^9}},ExpressionUUID->"561e16f8-7396-4408-9f98-a483ac242034"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", " ", 
    SubscriptBox["\[Lambda]", "2"], ",", "...", ",", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],ExpressionUUID->
  "d775b156-d777-46a3-9ed1-58fa33b4c2b8"],
 " be the eigenvalues of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "2fcabe06-8c36-42a3-a1a8-ebc1d2f4ce73"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "fdcb82d3-1318-4ae3-89a9-078513094ac1"],
 " is self-adjoint, the eigenvalues are real, so we can also order the \
eigenvalues so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]", "\[TripleDot]", 
    "\[GreaterEqual]", " ", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],ExpressionUUID->
  "c79b60ec-7b8b-4656-ab7d-c1c2a224c29d"],
 ".  In the next proof, we will see that these eigenvales are in fact \
nonnegative."
}], "Text",
 CellChangeTimes->{{3.8477450513160353`*^9, 3.8477453298957777`*^9}, {
  3.8477454668765097`*^9, 3.8477455221683245`*^9}, {3.8477456132233877`*^9, 
  3.8477456255492487`*^9}, {3.847745659944312*^9, 3.847745703806911*^9}, {
  3.8477457355658703`*^9, 3.847745862952191*^9}, {3.8477458971649537`*^9, 
  3.8477459052637815`*^9}, {3.8792475029927425`*^9, 3.8792475207297993`*^9}, {
  3.9102676234332194`*^9, 3.9102676298483763`*^9}, {3.9102681588697033`*^9, 
  3.910268183159712*^9}},ExpressionUUID->"0bd6f959-bfa9-4e3e-8f28-\
6a451c555019"],

Cell[TextData[{
 "Similarly let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Mu]", "1"], ",", " ", 
    SubscriptBox["\[Mu]", "2"], ",", "...", ",", 
    SubscriptBox["\[Mu]", "m"]}], TraditionalForm]],ExpressionUUID->
  "b6298679-6161-415e-8006-0ffb43896f1c"],
 " be the eigenvalues of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[VeryThinSpace]", 
    SuperscriptBox["A", "*"]}], TraditionalForm]],ExpressionUUID->
  "28844543-05d7-41fb-bc99-75e12a314c68"],
 " ordered so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Mu]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Mu]", "2"], "\[GreaterEqual]", "\[TripleDot]", 
    "\[GreaterEqual]", " ", 
    SubscriptBox["\[Mu]", "m"]}], TraditionalForm]],ExpressionUUID->
  "f36aec1a-028f-4e65-bdf5-4a9d1f0d7a48"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8477450513160353`*^9, 3.8477453298957777`*^9}, {
  3.8477454668765097`*^9, 3.8477455221683245`*^9}, {3.8477456132233877`*^9, 
  3.8477456255492487`*^9}, {3.847745659944312*^9, 3.847745703806911*^9}, {
  3.8477457355658703`*^9, 3.847745862952191*^9}, {3.8477458971649537`*^9, 
  3.8477459052637815`*^9}, {3.8792475029927425`*^9, 3.8792475207297993`*^9}, {
  3.9102676234332194`*^9, 3.9102677177802987`*^9}, {3.9102681914157295`*^9, 
  3.910268198183834*^9}},ExpressionUUID->"7ce02613-717c-4145-9750-\
8fc81dede632"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.8477450513160353`*^9, 3.8477453298957777`*^9}, {
  3.8477454668765097`*^9, 3.8477455221683245`*^9}, {3.8477456132233877`*^9, 
  3.8477456255492487`*^9}, {3.847745659944312*^9, 3.847745703806911*^9}, {
  3.8477457355658703`*^9, 3.847745862952191*^9}, {3.8477458971649537`*^9, 
  3.847745906594884*^9}},ExpressionUUID->"78c8daa0-ac26-439c-9350-\
63979d42aedb"],

Cell[TextData[{
 "Thus there is a matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ce71d2e9-c5c2-4881-aec5-be50d63d4e53"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "e216eb41-9c3e-412f-9b2f-97857eacb2dc"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["A", "*"], "A"}], "=", 
    RowBox[{"V", "\[VeryThinSpace]", "D", "\[VeryThinSpace]", 
     SuperscriptBox["V", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "85bf05bc-3575-4f32-9633-2ef09b6bfd31"],
 ",  and there exists a matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "d1aa5baa-c54c-4789-8330-0ab2767c9b72"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", 
     SuperscriptBox["A", "*"]}], ",", " "}], TraditionalForm]],ExpressionUUID->
  "2133c0f9-1c20-417c-a137-fbb2270ed227"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", 
     SuperscriptBox["A", "*"]}], "=", 
    RowBox[{"U", "\[VeryThinSpace]", "G", "\[VeryThinSpace]", 
     SuperscriptBox["U", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "b90a0aa3-43d7-450a-9026-d251a4c129b9"],
 "where ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "305fcc02-a50b-4242-83e0-dbd5a499d4aa"],
 " is a unitary matrix and ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "28a9f610-cc92-49a3-89f0-896ae089293f"],
 " and ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "75e12e38-ba6c-4395-8161-eff77473b368"],
 " are diagonal matrices with the diagonal elements written in descending \
order. "
}], "Text",
 CellChangeTimes->{{3.8477450513160353`*^9, 3.8477453298957777`*^9}, {
  3.8477454668765097`*^9, 3.8477455221683245`*^9}, {3.8477456132233877`*^9, 
  3.8477456255492487`*^9}, {3.847745659944312*^9, 3.847745703806911*^9}, {
  3.8477457355658703`*^9, 3.847745862952191*^9}, {3.8477458971649537`*^9, 
  3.8477458991220536`*^9}, {3.84774603730408*^9, 3.8477460406022215`*^9}, {
  3.879247539851574*^9, 3.8792475517538557`*^9}, {3.87924776389054*^9, 
  3.8792478553491077`*^9}, {3.9102675882027645`*^9, 
  3.910267600015462*^9}},ExpressionUUID->"1720d3e7-c3b0-43e6-a63c-\
3bedb941b304"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["THEOREM:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8477461698427405`*^9, 
  3.84774617167415*^9}},ExpressionUUID->"a0cff03e-1412-4444-bdc5-\
12930c5e2eb6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "66d656e4-fa77-45ed-9a6f-5e827756a2be"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "35b46676-496d-4a8f-9045-b705423ad503"],
 " matrix with entries from ",
 Cell[BoxData[
  FormBox["\[DoubleStruckCapitalC]", TraditionalForm]],ExpressionUUID->
  "06b78d70-19ab-4578-9875-ef3e90472a93"],
 ".  Then there exists and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "m"}], TraditionalForm]],ExpressionUUID->
  "06d89247-dbde-4021-b54d-28d154127aa7"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "65a16f1a-59a8-47e6-9ef5-e36fc6c622e3"],
 ", an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "6dfb6265-c971-4194-a5a8-5e16191dcf0e"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c5b84016-9f44-4010-bb5d-077ea197acfd"],
 ", and an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "79d62b52-88f9-4fe2-978e-cdec3f409e53"],
 " diagonal matrix ",
 Cell[BoxData[
  FormBox["\[CapitalSigma]", TraditionalForm]],ExpressionUUID->
  "6755d4aa-b567-4de4-8d9a-8b62a8a349ea"],
 " with nonnegative diagonal elements,  such that"
}], "Text",
 CellChangeTimes->{{3.847746188845224*^9, 3.8477461899973693`*^9}, {
   3.8477463060411005`*^9, 3.847746339857624*^9}, {3.8477463724067*^9, 
   3.847746433710762*^9}, 
   3.910267747362363*^9},ExpressionUUID->"43e15ad2-3f47-4fcd-bc4f-\
b2e60499a712"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
     SuperscriptBox["V", "*"]}]}], TraditionalForm]],ExpressionUUID->
  "b8af214b-4e05-43c5-ab7c-965c987ef539"]
}], "Text",
 CellChangeTimes->{{3.847746188845224*^9, 3.8477461899973693`*^9}, {
  3.8477463060411005`*^9, 3.847746339857624*^9}, {3.8477463724067*^9, 
  3.847746428232994*^9}},
 TextAlignment->Center,ExpressionUUID->"7edac4d9-f0a1-4197-8c49-d60f1d432f30"],

Cell[TextData[{
 "The elements on the diagonal of ",
 Cell[BoxData[
  FormBox["\[CapitalSigma]", TraditionalForm]],ExpressionUUID->
  "9f6a41fb-cfea-4282-855c-6e3c8770530b"],
 " are referred to as the singular values of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "ba330482-c0af-4d60-8e22-e7d83dd2f351"],
 "."
}], "Text",
 CellChangeTimes->{{3.8477525010144005`*^9, 
  3.847752527662341*^9}},ExpressionUUID->"b4c3c8df-754b-4547-8d0d-\
8d42a4f7ce2a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:", "Subsubsubsection",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.8477464505661774`*^9, 
  3.847746458083578*^9}},ExpressionUUID->"abcef2c6-183a-4811-ba05-\
bde0fc70dfe2"],

Cell[TextData[{
 "There exists  an orthonormal basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["v", "1"], ",", "...", ",", 
     SubscriptBox["v", "n"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "50b88647-af2f-4879-a0af-1db6401dc7f5"],
 " for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalC]", "n"], TraditionalForm]],
  ExpressionUUID->"36d91d89-8d77-4b95-997d-fc9d0308a7e7"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "edda3799-058f-4525-82e9-ad56ed0b5d11"],
 ", with corresponding ",
 StyleBox["eigenvalues",
  FontColor->GrayLevel[0]],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", 
    SubscriptBox["\[Lambda]", "2"], ",", "...", ",", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],ExpressionUUID->
  "f044f50c-47a6-4453-b8fe-fa56dbebb7b6"],
 "."
}], "Text",
 CellChangeTimes->{{3.847747309917947*^9, 3.847747316217287*^9}, {
   3.8478110526250525`*^9, 3.8478110531770477`*^9}, 
   3.879247881273328*^9},ExpressionUUID->"75fc6915-d573-4ab8-90fa-\
0fe631b8c708"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.847747309917947*^9, 
  3.8477473234263844`*^9}},ExpressionUUID->"f5dd154f-76e0-42a0-82fe-\
72fd317ec2cc"],

Cell[TextData[{
 "Some of the eigenvalues may be zero.  Let\[CloseCurlyQuote]s assume there \
are ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "5cfdad5a-ca51-4a57-a006-97f1a4862b65"],
 " nonzero ",
 StyleBox["eigenvalues",
  FontColor->GrayLevel[0]],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "r"}], TraditionalForm]],ExpressionUUID->
  "6469099e-78dc-4add-9cfd-2a203ea5a9be"],
 " zero eigenvalues.  Without loss of generality, we can order the vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["v", "1"], ",", "...", ",", 
     SubscriptBox["v", "r"], ",", 
     SubscriptBox["v", 
      RowBox[{"r", "+", "1"}]], ",", "...", ",", 
     SubscriptBox["v", "n"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "99026fc1-dadc-452c-9267-7e9b2355195b"],
 " so that the first ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "0026c362-7bec-4e15-abbb-8e2067edc05b"],
 " vectors correspond to nonzero eigenvalues."
}], "Text",
 CellChangeTimes->{{3.847747309917947*^9, 3.8477475381542187`*^9}, {
  3.847810999153982*^9, 
  3.8478109998957143`*^9}},ExpressionUUID->"f0241d79-8309-45ce-92bc-\
0243736c8011"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"491a7b0e-022f-4bdd-a339-2f5ad96754b4"],

Cell[TextData[{
 "Consider the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"A", "\[VeryThinSpace]", 
      SubscriptBox["v", "1"]}], ",", "...", ",", 
     RowBox[{"A", "\[VeryThinSpace]", 
      SubscriptBox["v", "r"]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "33023e31-6fcb-4a8c-8e41-e53ed6840a29"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalC]", "m"], TraditionalForm]],
  ExpressionUUID->"f3d5c373-eb9c-4032-a8fa-f099172e499e"],
 ".   Notice"
}], "Text",
 InitializationCell->True,
 CellChangeTimes->{{3.8477464505661774`*^9, 3.8477464520338163`*^9}, {
   3.8477464907304153`*^9, 3.847746952442075*^9}, {3.8477470071412015`*^9, 
   3.847747039919286*^9}, {3.847747543243785*^9, 3.847747544587201*^9}, 
   3.910127957608023*^9},ExpressionUUID->"bc25c620-dd66-41e3-966c-\
af7e9d50afc1"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"<", 
     RowBox[{"A", "\[VeryThinSpace]", 
      SubscriptBox["v", "i"]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"A", "\[VeryThinSpace]", 
       SubscriptBox["v", "j"]}], ">"}], " ", "=", 
     RowBox[{"<", 
      RowBox[{
       SuperscriptBox["A", "*"], "A", "\[VeryThinSpace]", 
       SubscriptBox["v", "i"]}]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], " ", "=", " ", 
     RowBox[{"<", " ", 
      RowBox[{
       SubscriptBox["\[Lambda]", "i"], 
       SubscriptBox["v", "i"]}]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], " ", "=", 
     RowBox[{
      SubscriptBox["\[Lambda]", "i"], "<", " ", 
      SubscriptBox["v", "i"]}]}], ",", 
    RowBox[{
     RowBox[{
      SubscriptBox["v", "j"], ">"}], " ", "=", 
     TagBox[GridBox[{
        {"\[Piecewise]", GridBox[{
           {
            SubscriptBox["\[Lambda]", "i"], 
