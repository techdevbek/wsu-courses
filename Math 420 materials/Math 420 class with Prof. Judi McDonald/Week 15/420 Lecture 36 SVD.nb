Cell[TextData[{
 "Notice",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         FormBox[
          RowBox[{
           RowBox[{"A", "\[VeryThinSpace]", "V"}], "=", 
           RowBox[{
            RowBox[{"[", 
