Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"83596eae-b4f9-4497-bdf4-9daf83bb2bee"],

Cell[TextData[{
 "Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["v", "1"], "\[CenterEllipsis]", 
      SubscriptBox[Cell[TextData[StyleBox["v",
        FontSlant->"Italic"]],ExpressionUUID->
        "64b900f4-c993-4d99-8777-2f1873fcdfbe"], "n"]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"3e821137-e4fe-4877-a8c1-5ddbfdab7616"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["u", "1"], "\[CenterEllipsis]", " ", 
      SubscriptBox["u", "m"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "acf648a9-0b4f-43f4-9960-d9b3f73398d7"],
 ". These are both unitary matrices."
}], "Text",
 CellChangeTimes->{{3.8477485374879704`*^9, 3.84774860122748*^9}, {
  3.8477526916445627`*^9, 3.8477526925546026`*^9}, {3.847752723142254*^9, 
