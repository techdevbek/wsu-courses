     SubscriptBox["u", "1"], ",", 
     SubscriptBox["u", "2"], ",", "...", ",", 
     SubscriptBox["u", "r"], ",", " ", 
     SubscriptBox["u", 
      RowBox[{"r", "+", "1"}]], ",", "...", ",", 
     SubscriptBox["u", "m"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "73716663-7e4b-436f-8342-bc0303c95bc4"]
}], "Text",
