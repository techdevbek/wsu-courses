Cell[CellGroupData[{

Cell[TextData[StyleBox["Interesting Observation:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8477524007804255`*^9, 3.8477524092818146`*^9}, {
  3.8477525760793843`*^9, 
  3.847752591942619*^9}},ExpressionUUID->"51bbbe99-16f3-4f38-8d30-\
efd12056983c"],

Cell[TextData[{
 "Factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", " "}], TraditionalForm]],ExpressionUUID->
  "720cc579-e76c-45bc-acfa-c676d55e855a"],
 "into its Singular Value Decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]"}]}], TraditionalForm]],
  ExpressionUUID->"f8e39716-82fc-477d-8e1c-2c2322518e21"],
 "\[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "*"], TraditionalForm]],ExpressionUUID->
  "a391d77d-d017-4dfc-8865-6e04535c2ecb"]
}], "Text",
 CellChangeTimes->{{3.8477524345319242`*^9, 3.847752461151219*^9}, {
  3.847752538847472*^9, 3.8477525635883727`*^9}, {3.84775260001145*^9, 
  3.847752638212327*^9}},ExpressionUUID->"9d6606ea-9bcc-4e3d-9bd3-\
a76fab86c2cd"],

Cell[TextData[{
 "View ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["u", "1"], "     ", 
      SubscriptBox["u", "m"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "422582b7-a53c-4dcb-9153-e043be8dfe56"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalSigma]", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox["\[Sigma]", "1"], "0", "\[CenterEllipsis]", "0", "0", 
        "0", "0"},
       {"0", "\[DescendingEllipsis]", "\[DescendingEllipsis]", 
        "\[VerticalEllipsis]", "0", "0", "0"},
       {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        SubscriptBox["\[Sigma]", 
         RowBox[{"r", "-", "1"}]], "0", "0", "0", "0"},
       {"0", "\[CenterEllipsis]", "0", 
        SubscriptBox["\[Sigma]", "r"], "0", "0", "0"},
       {"0", "\[CenterEllipsis]", "\[CenterEllipsis]", "0", "0", 
        "\[CenterEllipsis]", "0"},
       {"\[VerticalEllipsis]", " ", " ", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
       {"0", "\[CenterEllipsis]", "\[CenterEllipsis]", "0", "0", 
        "\[CenterEllipsis]", "0"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "23637133-c398-46f2-8a01-95de2a05e608"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", "*"], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
       {
        SuperscriptBox[
         SubscriptBox["v", "1"], "*"]},
       {"\[VerticalEllipsis]"},
       {
        SuperscriptBox[
         SubscriptBox["v", "n"], "*"]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], " "}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "91b68ab3-ed5f-45ea-956f-663f4362c743"]
}], "Text",
 CellChangeTimes->{{3.847752653686981*^9, 3.8477526745894003`*^9}, {
  3.847752732874351*^9, 3.8477527622524195`*^9}, {3.8477529097134085`*^9, 
  3.8477529934379606`*^9}},ExpressionUUID->"52d6b254-886d-4954-a910-\
3f8aec1e482b"],

Cell[TextData[{
 "Then \[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
         SuperscriptBox["V", "*"]}], "=", 
        RowBox[{
         FormBox[
          RowBox[{"[", 
           RowBox[{
            SubscriptBox["\[Sigma]", "1"], 
            SubscriptBox["u", "1"], "     ", 
            SubscriptBox["\[Sigma]", "2"], 
            SubscriptBox["u", "2"]}]}],
          TraditionalForm], " ", 
         FormBox[
          RowBox[{" ", 
           RowBox[{"\[CenterEllipsis]", " ", 
            SubscriptBox["\[Sigma]", "r"], 
            SubscriptBox["u", "r"]}]}],
          TraditionalForm], "0", " ", "\[CenterEllipsis]0"}]}], "]"}], 
      GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
        {
         SuperscriptBox[
          SubscriptBox["v", "1"], "*"]},
        {"\[VerticalEllipsis]"},
        {
         SuperscriptBox[
          SubscriptBox["v", "n"], "*"]}
       }], "\[NoBreak]", 
      GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 50}]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Sigma]", "1"], 
       SubscriptBox["u", "1"], 
       SuperscriptBox[
        SubscriptBox["v", "1"], "*"]}], "+", 
      RowBox[{
       SubscriptBox["\[Sigma]", "2"], 
       SubscriptBox["u", "2"], 
       SuperscriptBox[
        SubscriptBox["v", "2"], "*"]}], "+", 
      RowBox[{"\[CenterEllipsis]", 
       SubscriptBox["\[Sigma]", "r"], 
       SubscriptBox["u", "r"], 
       SuperscriptBox[
        SubscriptBox["v", "r"], "*"]}]}]}], "\[IndentingNewLine]"}], 
   TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "b12c51d3-4cbb-4c16-835c-5b1b0a95da81"]
}], "Text",
 CellChangeTimes->{{3.8477530068432302`*^9, 3.8477532072782803`*^9}, {
  3.8477532500878663`*^9, 3.8477532500878663`*^9}, {3.847753337362463*^9, 
  3.847753494479675*^9}, {3.8477535566069736`*^9, 
  3.8477535757000537`*^9}},ExpressionUUID->"cc51ab7e-ceb1-4311-8426-\
448b425ba3e9"],

Cell["Notice:", "Text",
 CellChangeTimes->{{3.8477536393993626`*^9, 
  3.8477536484942055`*^9}},ExpressionUUID->"57ac20e2-6db0-4599-ae98-\
986f86459700"],

Cell[TextData[{
 "1. We can express ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "59d22fc8-7aaf-4cea-9c57-9b87011bf92c"],
 " as a linear combination of ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "2a4421ba-7c42-473d-8672-b29097c0b372"],
 " rank 1 matrices."
}], "Text",
 CellChangeTimes->{{3.8477536393993626`*^9, 
  3.8477536746899977`*^9}},ExpressionUUID->"13846f96-9793-4943-bc46-\
7c7270e049e6"],

Cell[TextData[{
 "2. If several of the singular values of ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "726d3684-2aa9-4978-a105-abd4c27e0a82"],
 " are small, we can get a very good estimate for ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2c55f8c2-5093-4c33-894c-b4177d070d1b"],
 " even after throwing away several of the terms at the end of the sequence."
}], "Text",
 CellChangeTimes->{{3.8477536393993626`*^9, 3.847753735587364*^9}, {
  3.8477537880729084`*^9, 
  3.847753788074398*^9}},ExpressionUUID->"ae1a4089-7e82-4945-b47f-\
042002b98bd7"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
