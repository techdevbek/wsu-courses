Cell[CellGroupData[{

Cell[TextData[StyleBox["Interesting Facts:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.847749488082573*^9, 
  3.8477495047105494`*^9}},ExpressionUUID->"0674da8a-8ccf-465c-a84a-\
bd3eef19fdb6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["A", "*"], "A"}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
        "U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
         SuperscriptBox["V", "*"]}], ")"}], "*"], "U", "\[VeryThinSpace]", 
      "\[CapitalSigma]", "\[VeryThinSpace]", 
      SuperscriptBox["V", "*"]}], "=", 
     RowBox[{
      RowBox[{"V", "\[VeryThinSpace]", 
       SuperscriptBox["\[CapitalSigma]", "*"], "\[VeryThinSpace]", 
       SuperscriptBox["U", "*"], "U", "\[VeryThinSpace]", "\[CapitalSigma]", 
       "\[VeryThinSpace]", 
       SuperscriptBox["V", "*"]}], "=", 
      RowBox[{"V", "\[VeryThinSpace]", 
       SuperscriptBox["\[CapitalSigma]", "*"], "\[VeryThinSpace]", 
       "\[CapitalSigma]", "\[VeryThinSpace]", 
       SuperscriptBox["V", "*"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6d5e7a2f-9462-40da-a41b-201f5fa3a2eb"],
 ", so ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c8c8e96b-c739-42fd-b325-c22a7b876909"],
 " consists if the eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["A", "*"], "A"}], TraditionalForm]],ExpressionUUID->
  "54b4131d-02b4-4dbf-9935-87779ccd1224"],
 " and the eigenvalues are on the diagonal of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalSigma]", "*"], "\[VeryThinSpace]", 
    RowBox[{"\[CapitalSigma]", "\[VeryThinSpace]", "."}]}], TraditionalForm]],
  ExpressionUUID->"e529e7ce-f600-4da1-b91d-4d3c18b7e0db"]
}], "Text",
 CellChangeTimes->{{3.8477495199456763`*^9, 
  3.84774966931136*^9}},ExpressionUUID->"6f71f72d-66f7-49af-b434-\
0ff99bb75b1d"],

Cell["", "Text",ExpressionUUID->"d4b529aa-6af9-4e1b-b914-affa519d5818"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", 
     SuperscriptBox["A", "*"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
        SuperscriptBox["V", "*"]}], ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
        "U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
         SuperscriptBox["V", "*"]}], ")"}], "*"]}], "=", 
     RowBox[{
      RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
       SuperscriptBox["V", "*"], "V", "\[VeryThinSpace]", 
       SuperscriptBox["\[CapitalSigma]", "*"], "\[VeryThinSpace]", 
       SuperscriptBox["U", "*"]}], "=", 
      RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
       SuperscriptBox["\[CapitalSigma]", "*"], "\[VeryThinSpace]", 
       SuperscriptBox["U", "*"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "cd7b3f36-a437-4faa-8eaf-d8008bd1cd94"],
 ", so ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "486e528c-b96e-4e71-b6bc-b8e5b1860d24"],
 " consists of the eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[VeryThinSpace]", 
    SuperscriptBox["A", "*"]}], TraditionalForm]],ExpressionUUID->
  "8b35be6f-c52d-4bb8-b397-d7fa02839ada"],
 " and the eigenvalues are on the diagonal of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalSigma]", "\[VeryThinSpace]", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[CapitalSigma]", "\[VeryThinSpace]"}], "*"], "."}]}], 
   TraditionalForm]],ExpressionUUID->"099c0120-2254-4f81-a2bf-3c4a19f9b64d"]
}], "Text",
 CellChangeTimes->{{3.8477496761927686`*^9, 3.8477497933389516`*^9}, {
  3.847812147616292*^9, 3.847812151608184*^9}, {3.8792480867424555`*^9, 
  3.879248088393997*^9}},ExpressionUUID->"1ad4460d-5266-4752-885b-\
e61bd4630da7"]
}, Open  ]],

