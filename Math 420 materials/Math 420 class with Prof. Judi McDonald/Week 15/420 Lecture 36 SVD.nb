Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"30615dfc-90e7-4f45-bcaf-451f5b21b12b"],

Cell[TextData[{
 "But then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", "V"}], "=", 
    RowBox[{
    "U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]"}]}], 
   TraditionalForm]],ExpressionUUID->"82308709-297b-4ad6-8c91-ee559ff63408"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]", "\[VeryThinSpace]", 
