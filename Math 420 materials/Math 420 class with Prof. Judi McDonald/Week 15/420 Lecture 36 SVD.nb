Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"458aa041-76c6-4777-b797-c0ddbaf96cb7"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "<=", "r"}], TraditionalForm]],ExpressionUUID->
  "86910117-0a33-4542-9fb2-e8cfc90644b1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"||", 
      RowBox[{"A", "\[VeryThinSpace]", 
       SubscriptBox["v", "i"]}], 
      SuperscriptBox["||", "2"]}], " ", "=", " ", 
     RowBox[{"<", 
      RowBox[{"A", " ", 
       SubscriptBox["v", "i"]}]}]}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"A", "\[VeryThinSpace]", 
       SubscriptBox["v", "i"]}], ">"}], "=", 
     SubscriptBox["\[Lambda]", "i"]}]}], TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "d311b65b-7318-477a-841b-055de12f1840"],
 ", and thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "i"], ">", "0"}], TraditionalForm]],
  ExpressionUUID->"6be65e9e-19ca-4f7c-8939-e523c990032f"],
 ". Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "i"], "=", 
    FractionBox[
     RowBox[{"A", "\[VeryThinSpace]", 
      SubscriptBox["v", "i"]}], 
     SqrtBox[
      SubscriptBox["\[Lambda]", "i"]]]}], TraditionalForm]],ExpressionUUID->
  "547a35ea-b1ae-46a8-bbf5-a9d672746a2a"],
 ",  and order the vectors so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
      SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]"}], "..."}], 
    "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "r"], ">", "0"}], TraditionalForm]],
  ExpressionUUID->"a882bce4-7419-4f02-9e32-14e60bbcaf55"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["u", "1"], ",", 
     SubscriptBox["u", "2"], ",", "...", ",", 
     SubscriptBox["u", "r"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "bd1e3f0d-e518-484e-930b-cf2a81659570"],
 " is an orthonormal set, and hence can be extended to an orthonormal basis \
for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalC]", "m"], TraditionalForm]],
  ExpressionUUID->"baf4221d-c214-4e56-ac88-75165360d18c"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.847747228441588*^9, 3.8477472548680544`*^9}, {
   3.847747556798356*^9, 3.847747721309102*^9}, {3.847747877490212*^9, 
