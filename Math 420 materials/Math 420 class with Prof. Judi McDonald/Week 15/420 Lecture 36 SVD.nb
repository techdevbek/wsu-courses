  3.8477488694594355`*^9}},ExpressionUUID->"1ce16110-d3c8-4058-97e0-\
380468588d81"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"\[IndentingNewLine]", 
   RowBox[{"=", 
    RowBox[{
     RowBox[{
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["u", 
            RowBox[{"1", "  "}]], "..."}], "   ", 
          SubscriptBox["u", "r"], "   ", 
          SubscriptBox["u", 
           RowBox[{"r", "+", "1"}]]}], "  ", "..."}], "  ", 
        SubscriptBox["u", "m"]}], "]"}], 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {
          SqrtBox[
           SubscriptBox["\[Lambda]", "1"]], "0", "\[CenterEllipsis]", "0", 
          "0", "\[CenterEllipsis]", "0"},
         {"0", "\[DescendingEllipsis]", "\[DescendingEllipsis]", 
          "\[VerticalEllipsis]", "0", "\[CenterEllipsis]", "0"},
         {"\[VerticalEllipsis]", "\[DescendingEllipsis]", 
          SqrtBox[
           SubscriptBox["\[Lambda]", 
            RowBox[{"r", "-", "1"}]]], "0", "\[VerticalEllipsis]", " ", 
          "\[VerticalEllipsis]"},
         {"0", "\[CenterEllipsis]", "0", 
          SqrtBox[
           SubscriptBox["\[Lambda]", "r"]], "0", "\[CenterEllipsis]", "0"},
         {"0", "\[CenterEllipsis]", "\[CenterEllipsis]", "0", "0", 
          "\[CenterEllipsis]", "0"},
         {"\[VerticalEllipsis]", " ", " ", "\[VerticalEllipsis]", 
          "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
          "\[VerticalEllipsis]"},
         {"0", "\[CenterEllipsis]", "\[CenterEllipsis]", "0", "0", 
          "\[CenterEllipsis]", "0"}
        }], "\[NoBreak]", ")"}]}], "=", 
     RowBox[{"U", "\[VeryThinSpace]", "\[CapitalSigma]"}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"41502b05-4ca2-4125-8a5d-036a4cdeb525"]], \
