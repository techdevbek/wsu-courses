  FormBox["a", TraditionalForm]],ExpressionUUID->
  "c8325e21-c1e5-4344-ac17-d2a6f2ebcd79"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"-", "x"}], ")"}], TraditionalForm]],ExpressionUUID->
  "192e497a-be9a-4c96-8981-e59749e29ddb"],
