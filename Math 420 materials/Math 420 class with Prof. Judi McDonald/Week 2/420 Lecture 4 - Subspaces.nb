 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.8390588899588737`*^9, 
  3.8390588986880302`*^9}},ExpressionUUID->"762ea79f-d7a4-4524-a6ab-\
bdd5a3a18921"],

Cell[TextData[{
 "A ",
 StyleBox["subspace",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" of a vector space over a field \[DoubleStruckCapitalF]",
  FontColor->RGBColor[0, 0, 0]],
 " is a ",
 StyleBox["nonempty",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " ",
 StyleBox["subset ",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[0., 0., 1.]],
 "of the vector space that is also a vector space over \
\[DoubleStruckCapitalF]."
}], "Text",
 CellChangeTimes->{{3.618318874449812*^9, 3.618318876238*^9}, {
   3.618319052797199*^9, 3.618319423577367*^9}, {3.61831948651137*^9, 
   3.6183195214016323`*^9}, {3.6183195726039686`*^9, 
   3.6183195728361235`*^9}, {3.618319625717631*^9, 3.6183200218144016`*^9}, {
   3.618320144037789*^9, 3.618320482387991*^9}, {3.6187461535373335`*^9, 
   3.618746240894226*^9}, {3.6187462818638244`*^9, 3.618746288825466*^9}, {
   3.6187464822279673`*^9, 3.61874648512677*^9}, {3.6187465364215775`*^9, 
   3.6187465384719563`*^9}, {3.6187466419208326`*^9, 
   3.6187466433453236`*^9}, {3.839059105038147*^9, 3.839059107414914*^9}, {
   3.839059150219308*^9, 3.83905917630087*^9}, {3.8390593130644517`*^9, 
   3.8390593165694675`*^9}, 
   3.902228582791381*^9},ExpressionUUID->"e0d68ea6-dbdf-46e9-b353-\
575a71a97798"],

Cell[TextData[{
 "Notice VS 1,2,5,6,7,8 hold for any subset of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3750827f-2b9b-4d55-a29b-a8d2dca11465"]
}], "Text",
 CellChangeTimes->{{3.902332296423093*^9, 
  3.9023323384372325`*^9}},ExpressionUUID->"79174348-a229-4cee-89c4-\
7d94301f97de"],

Cell[TextData[{
 "But the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[Element]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "df6bd2f5-5689-43c6-bf68-f64b0cf40806"],
 " might not be in the subset, nor the additive inverse.  Moreover, a subset \
might not be closed under addition and scalar multiplication. "
}], "Text",
 CellChangeTimes->{{3.902332296423093*^9, 
  3.9023323989030404`*^9}},ExpressionUUID->"a76b423d-030d-4b83-8c5a-\
89aca73f2cba"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Lemma:", "Subsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsection",
 CellChangeTimes->{{3.618318874449812*^9, 3.618318876238*^9}, {
   3.618319052797199*^9, 3.618319423577367*^9}, {3.61831948651137*^9, 
   3.6183195214016323`*^9}, {3.6183195726039686`*^9, 
   3.6183195728361235`*^9}, {3.618319625717631*^9, 3.6183200218144016`*^9}, {
   3.618320144037789*^9, 3.618320482387991*^9}, {3.6187461535373335`*^9, 
   3.618746240894226*^9}, {3.6187462818638244`*^9, 3.618746288825466*^9}, {
   3.6187464822279673`*^9, 3.61874648512677*^9}, {3.6187465364215775`*^9, 
   3.6187465384719563`*^9}, {3.6187466419208326`*^9, 
   3.6187466433453236`*^9}, {3.839059105038147*^9, 3.839059107414914*^9}, {
   3.839059150219308*^9, 3.8390591793618345`*^9}, 3.8390592977170086`*^9},
 TextAlignment->Left,ExpressionUUID->"d17fa28f-c994-4273-90a0-487b38fe705e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "84a9f9b8-12b0-409c-bc46-b650ecef9149"],
 " be a vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "19686a76-c1e6-4c0a-b59b-fac39e6ab132"],
 " be a subset of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "9e795092-375a-4609-a90c-ebce18bd966d"],
 "  Then ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "0d1625ce-588a-4839-819c-551716b44974"],
 " is a subspace of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b0496310-0008-4d83-bfd6-cdaaf8723ab5"],
 " if and only if the following properties hold: "
}], "Text",
 CellChangeTimes->{{3.618318874449812*^9, 3.618318876238*^9}, {
  3.618319052797199*^9, 3.618319423577367*^9}, {3.61831948651137*^9, 
  3.6183195214016323`*^9}, {3.6183195726039686`*^9, 3.6183195728361235`*^9}, {
  3.618319625717631*^9, 3.6183200218144016`*^9}, {3.618320144037789*^9, 
  3.618320482387991*^9}, {3.6187461535373335`*^9, 3.618746240894226*^9}, {
  3.6187462818638244`*^9, 3.618746288825466*^9}, {3.6187464822279673`*^9, 
  3.61874648512677*^9}, {3.6187465364215775`*^9, 3.6187465384719563`*^9}, {
  3.6187466419208326`*^9, 3.6187466433453236`*^9}, {3.839059105038147*^9, 
  3.839059107414914*^9}},ExpressionUUID->"576b2d66-60fd-4362-be99-\
097db99a8064"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     StyleBox["(",
      FontSlant->"Italic"], 
     StyleBox["i",
      FontSlant->"Plain"], 
     StyleBox[")",
      FontSlant->"Italic"]}], 
    StyleBox["   ",
     FontSlant->"Italic"], "0"}], "\[Element]", 
   RowBox[{"W", "  ", 
    RowBox[{"(", 
     RowBox[{
     "the", " ", "zero", " ", "vector", " ", "is", " ", "in", " ", "W"}], 
     ")"}]}]}], TraditionalForm], "\n", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", "ii", ")"}], 
    StyleBox[
     RowBox[{"  ", 
      StyleBox[" ",
       FontSlant->"Italic"]}]], 
    RowBox[{"\[ForAll]", "x"}]}], ",", 
   RowBox[{"y", " ", "\[Element]", " ", "W"}], ",", " ", 
   FormBox[
    RowBox[{
     RowBox[{"x", "+", "y"}], "\[Element]", " ", "W"}],
    TraditionalForm]}], TraditionalForm], "\n", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"(", "iii", ")"}], "  ", 
    RowBox[{"\[ForAll]", 
     RowBox[{"x", "\[Element]", "W"}]}]}], ",", " ", 
   RowBox[{"\[ForAll]", 
    RowBox[{"a", " ", "\[Element]", " ", "\[DoubleStruckCapitalF]"}]}], ",", 
   " ", 
   RowBox[{
    RowBox[{"a", " ", "x"}], "\[Element]", "W", "                   "}]}], 
  TraditionalForm]}], "DisplayFormula",
 CellChangeTimes->{{3.618318874449812*^9, 3.618318876238*^9}, {
   3.618319052797199*^9, 3.618319423577367*^9}, {3.61831948651137*^9, 
   3.6183195214016323`*^9}, {3.6183195726039686`*^9, 
   3.6183195728361235`*^9}, {3.618319625717631*^9, 3.6183200218144016`*^9}, {
   3.618320144037789*^9, 3.618320482387991*^9}, {3.6187461535373335`*^9, 
   3.618746400413719*^9}, {3.618746620607704*^9, 3.618746622930253*^9}, 
   3.6187471294997225`*^9, {3.618749518032251*^9, 3.6187495196302834`*^9}, {
   3.870521790953738*^9, 3.870521805312195*^9}, {3.8705219126324425`*^9, 
   3.870521915168939*^9}},ExpressionUUID->"ae54946f-59d8-4a3d-8908-\
81539f671a15"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{
  3.8383083505487647`*^9, {3.8383084483120995`*^9, 
   3.838308456647626*^9}},ExpressionUUID->"9d9c6499-2906-48e1-bbe5-\
ddca628ca557"],

Cell["\[DoubleLongRightArrow]", "Text",
 CellChangeTimes->{{3.9022406367082744`*^9, 
  3.9022407735182967`*^9}},ExpressionUUID->"f6cae762-e592-483e-999e-\
3898320fe869"],

Cell[TextData[{
 "Assume ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9fbbc6ac-f4c1-4d12-bbe3-ee0b8b4799b5"],
 " is a subspace. Because a subspace is itself a vector space, by VS3, there \
is an additive identity, and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "de8f4564-c6cf-440c-b4ce-52b36a659fe9"],
 " must be closed under addition and multiplication."
}], "Text",
 CellChangeTimes->{{3.9022406367082744`*^9, 
  3.902240775343408*^9}},ExpressionUUID->"08e48a28-301b-47c2-aea4-\
05b23334000a"],

Cell["\[DoubleLongLeftArrow]", "Text",
 CellChangeTimes->{{3.9022405963194804`*^9, 
  3.902240607816302*^9}},ExpressionUUID->"e7ac5dc7-f599-40df-80d2-\
592ca57ade66"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "f848732b-3bf6-4bfc-80b1-d062e9649c52"],
 " be the addtive inverse of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"add6f323-2e1a-4990-8b3a-b7d65935521f"],
 ". By property (iii) we know that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], "x"}], "\[Element]", "W"}], 
   TraditionalForm]],ExpressionUUID->"82849bcc-ae7d-4788-81b2-b8b30c94b5af"],
 ".  Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "x"}], "+", "x"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "x"}], "+", 
      RowBox[{
       RowBox[{"(", "1", ")"}], "x"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "1"}], ")"}], "x"}], "=", 
      RowBox[{
       RowBox[{"0", "x"}], "=", "0"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "e6cd640f-4250-4e0a-8118-bd1599864fbc"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}], "x"}], TraditionalForm]],ExpressionUUID->
  "71ddb284-c10d-4175-b036-dbb4f667c06e"],
 " is the additive inverse of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "9e5760e5-7266-4cc6-b87b-109a159d1d40"],
 ".  We used VS 5, 8, and the lemma.  Thus VS4 is true for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "367c4b8e-fc64-4cc1-8b8f-6c467a354642"],
 ". As observed above, to establish that ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f514e457-929a-445e-ae78-c44d42598e3f"],
 " is itself a vector space, we need closure under addtion and scalar \
multiplication, as well as VS3 and VS4, since VS 1, 2, 5,6,7,8 hold for any \
subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "558cd8f7-be15-407a-9979-c4f3cf823e24"],
 "."
}], "Text",
 CellChangeTimes->{{3.9022404875871577`*^9, 3.9022405876702585`*^9}, {
   3.9022409449359674`*^9, 3.902241054133421*^9}, {3.9022411305809665`*^9, 
   3.9022412667220488`*^9}, 3.9022413199764504`*^9, {3.9022413503955607`*^9, 
   3.9022413735260267`*^9}},ExpressionUUID->"04046bd6-5f68-4546-8dea-\
d25d0b938863"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
