Cell["\<\
THINK:  If I multiply the additive identity of the field by a vector, I get \
the additive identity if the vector space.\
\>", "Text",
 CellChangeTimes->{{3.902238851733161*^9, 
  3.9022388832451262`*^9}},ExpressionUUID->"1d3b70ee-a1f7-4646-9ecd-\
50d7130b7ba4"],

Cell[TextData[{
 "(i) Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "x"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"0", "+", "0"}], ")"}], "x"}], "=", 
     RowBox[{
      RowBox[{"0", "x"}], "+", 
      RowBox[{"0", "x", " ", "by"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fe2f2e08-87dc-4603-8de7-26998a057fce"],
 " VS8 properties of the additive inverse. By VS4, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "x"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7c0c36fc-6ff1-442c-8a9c-6b37e471fdbf"],
 " has an additive inverse ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    RowBox[{"(", 
     RowBox[{"0", "x"}], ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7e9270ad-ca3f-4b04-aa71-2498cdac194d"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"0", "x"}], "+", 
     RowBox[{"(", 
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"0", "x"}], ")"}]}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"0", "x"}], "+", 
       RowBox[{"0", "x"}]}], ")"}], "+", 
     RowBox[{"(", 
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"0", "x"}], ")"}]}], ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b782d65c-1b7b-41d1-9767-fbdaa81ec9ae"],
 ".  So"
}], "Text",
 CellChangeTimes->{{3.90222816529904*^9, 3.9022281949426064`*^9}, {
  3.90223910910418*^9, 3.902239110173194*^9}, {3.902239161950799*^9, 
