6ebfb6bd1645"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"0", "x"}], "+", 
     RowBox[{"(", 
      RowBox[{"-", 
       RowBox[{"(", 
        RowBox[{"0", "x"}], ")"}]}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"0", "x"}], "+", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"0", "x"}], "+", 
       RowBox[{"(", 
        RowBox[{"-", 
