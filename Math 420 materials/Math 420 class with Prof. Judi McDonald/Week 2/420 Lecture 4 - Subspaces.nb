Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e0162cf6-47aa-44b2-80a1-27d426b0167d"],
 " be a vector space over a field \[DoubleStruckCapitalF]. Then\n(i)  For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"42394ec0-0a7c-4fb0-aa84-c5db0634dd9f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ForAll]", 
     RowBox[{"x", "\[Element]", " ", "V"}]}], ","}], TraditionalForm]],
  ExpressionUUID->"c657c3ff-ea02-476c-9210-67a96f7b7a97"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[VeryThinSpace]", "x"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"8968d013-a804-43ef-a969-d83ab32297cc"],
 ".\n(ii) \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"b06262fa-7ab5-4b55-9fcf-d3e8ba12ac47"],
 " and \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[Element]", " ", "V"}], ","}], TraditionalForm]],
  ExpressionUUID->"db3fa96c-84da-4ab4-958d-2703864597b0"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "a"}], ")"}], " ", "x"}], "=", 
    RowBox[{
     RowBox[{"a", "(", 
      RowBox[{"-", "x"}], ")"}], "=", 
     RowBox[{"-", 
      RowBox[{
       StyleBox[
        RowBox[{"(", 
         RowBox[{"a", " ", "x"}], ")"}],
        FontFamily->"Times New Roman",
        FontWeight->"Normal",
        FontColor->RGBColor[0., 0., 0.]], "."}]}]}]}], TraditionalForm]],
  ExpressionUUID->"0c268c8e-8292-47a4-90e7-f9e3273763bb"],
 "\n(iii) \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "\[Element]", "\[DoubleStruckCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"cd63de23-d19d-449c-a064-3e00d09c1fc9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[Element]", " ", "V"}], ","}], TraditionalForm]],
  ExpressionUUID->"9b6594fd-198e-4950-b299-cedb38af4502"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", "\[VeryThinSpace]", "0"}], "=", "0."}], TraditionalForm]],
  ExpressionUUID->"bc9aab71-34a4-4b01-a14d-c9d7532e18f0"]
}], "Text",
