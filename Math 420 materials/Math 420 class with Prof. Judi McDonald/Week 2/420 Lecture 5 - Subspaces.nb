}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"27c20efe-0d61-4820-9175-fb255ec7958c"],

Cell[TextData[{
 "Fix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "\[Element]", "\[DoubleStruckCapitalR]"}], TraditionalForm]],
  ExpressionUUID->"7404ca80-eede-4986-962e-06ffb56bea53"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"{", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"a"},
        {"b"},
        {"q"}
       }], "\[NoBreak]", ")"}], " "}]}], TraditionalForm]],ExpressionUUID->
  "c144b9fc-b5a9-4ee6-80c8-4d9801633a33"],
 "| ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"a", ",", " ", 
     RowBox[{"b", " ", "\[Element]", "\[DoubleStruckCapitalR]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"bd35ecff-8c9d-431d-a011-280c9a342be0"],
 ".  Is ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f34849c3-c840-4c47-9b14-2463352b784c"],
 " a subspace of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"6e8b3cba-9ead-4fa7-b6d3-136aab8069dd"],
 "?"
}], "Text",
 CellChangeTimes->{{3.8393423701947136`*^9, 3.8393424296703787`*^9}, {
   3.8393424917813597`*^9, 3.8393425211058197`*^9}, 3.8393426316918945`*^9, {
   3.83934911224159*^9, 3.8393491131062555`*^9}, {3.8707763240882907`*^9, 
   3.8707763252985225`*^9}, {3.8707810120808907`*^9, 
   3.8707810131383305`*^9}, {3.9024030481082554`*^9, 
   3.902403049008192*^9}},ExpressionUUID->"7df50e57-5669-45b5-8638-\
fea88cb89592"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "941ac5ca-8a87-4c07-8c9d-3654d0d6c1eb"],
 ", then ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5a1060ef-f8da-4bad-9b00-35c1c45c3768"],
 " is not a subspace since ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox[
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0"},
         {"0"},
         {"q"}
        }], "\[NoBreak]", ")"}], "\[NotEqual]", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0"},
         {"0"},
         {"0"}
        }], "\[NoBreak]"}]}],
     FontFamily->"Times New Roman",
     FontWeight->"Normal"], ")"}], " "}]],ExpressionUUID->
  "d3b35d28-043f-41a4-85cc-722d62e97d2b"],
 " ."
}], "Text",
 CellChangeTimes->{{3.902412433094425*^9, 
  3.902412527022435*^9}},ExpressionUUID->"5e4da346-56fa-4a98-bd12-\
eca1c570c0da"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "900dc4b5-7bde-4fa2-a39b-db72c6d17d22"],
 ", then ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7c79fbda-7c1b-4675-9b92-3eabd68c28c6"],
 " is a subspace."
}], "Text",
 CellChangeTimes->{{3.9024125389500823`*^9, 
  3.9024125743223696`*^9}},ExpressionUUID->"e26669fc-e543-4267-9fea-\
