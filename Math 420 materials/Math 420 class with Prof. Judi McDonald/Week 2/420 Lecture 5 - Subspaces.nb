  "32ee3d5a-d04c-46bd-8a24-3bcb4e0440f4"],
 " is two dimensional subspace of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3268f60b-1d0c-4767-8878-1d683c06f7ac"],
 ".  It is not ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f143b45f-8768-464b-974d-544bd65becac"],
 "."
}], "Text",
 CellChangeTimes->{{3.902412082731487*^9, 3.9024122050846925`*^9}, {
  3.9024122361906333`*^9, 3.9024122855397973`*^9}, {3.902412590196424*^9, 
  3.902412594860494*^9}},ExpressionUUID->"dbeb9eb4-ae2d-4c8c-ac7a-\
