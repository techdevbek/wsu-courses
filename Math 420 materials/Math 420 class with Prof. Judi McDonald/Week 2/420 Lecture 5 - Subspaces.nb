Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{
  3.8383083505487647`*^9, {3.8383084483120995`*^9, 
   3.838308456647626*^9}},ExpressionUUID->"7eeb246f-345e-4674-8c9d-\
5b3c3045152b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "i"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "04b02df8-9914-4334-ab8b-2c85dc9740d9"],
 " be a collection of subspaces where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[Element]", " ", "\[ScriptCapitalJ]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1054d929-d2cd-4725-a515-72b869e366fc"],
 " for some index set \[ScriptCapitalJ]."
}], "Text",
 CellChangeTimes->{{3.9024129115107555`*^9, 3.9024129539994*^9}, {
  3.9024130392144804`*^9, 3.902413064834589*^9}, {3.902413124769924*^9, 
  3.902413143290306*^9}},ExpressionUUID->"34777df9-51b7-40d4-b61e-\
cffaec219262"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"W", "=", 
   RowBox[{
    UnderscriptBox["\[Intersection]", 
     RowBox[{" ", 
      RowBox[{"i", "\[Element]", "\[ScriptCapitalJ]"}]}]], 
    SubscriptBox["V", "i"]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"e56777fd-79c1-4e9c-b3ff-ebcfdc27ed20"]], \
"Text",
 CellChangeTimes->{{3.9024129115107555`*^9, 3.9024129539994*^9}, {
  3.9024130392144804`*^9, 3.9024130397124505`*^9}, {3.9024131884209538`*^9, 
  3.902413272072316*^9}},ExpressionUUID->"9206aef0-ca23-4283-9163-\
a0db762aa2e0"],

Cell["", "Text",ExpressionUUID->"1b825104-c4ef-445c-a1b7-f3c82c881ded"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      StyleBox["(",
       FontSlant->"Italic"], 
      StyleBox["i",
       FontSlant->"Plain"], 
      StyleBox[")",
       FontSlant->"Italic"]}], 
     StyleBox["   ",
      FontSlant->"Italic"], "0"}], "\[Element]", 
    RowBox[{
    "W", "  ", "because", " ", "0", " ", "must", " ", "be", " ", "in", " ", 
     "every", " ", 
     RowBox[{"subspace", ".", "\n", 
      RowBox[{"(", "ii", ")"}]}], 
     StyleBox[
      RowBox[{"  ", 
       StyleBox[" ",
        FontSlant->"Italic"]}]], "Let", " ", "x"}]}], ",", 
   RowBox[{"y", " ", "\[Element]", " ", "W"}], ",", " ", 
   RowBox[{"then", "  ", 
    FormBox[
     RowBox[{
      RowBox[{"x", "+", "y"}], "\[Element]", " ", "W"}],
     TraditionalForm], " ", "because", " ", Cell[TextData[{
     Cell[BoxData[
      FormBox["x", TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "e88639c5-3a22-4502-b4ed-6387f787e6fc"],
     " and ",
     Cell[BoxData[
      FormBox["y", TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "a738a686-239b-47b8-b28d-703604bfe05d"]
    }],ExpressionUUID->"6a88c73f-d73e-4e13-bc6c-ed5f1c58fc01"], " ", "are", 
    " ", "in", " ", "every", " ", 
    SubscriptBox["V", "i"]}], ",", " ", 
   RowBox[{"and", " ", "the", " ", Cell[TextData[Cell[BoxData[
     FormBox[
      SubscriptBox["V", "i"], TraditionalForm]],
     FormatType->TraditionalForm,ExpressionUUID->
     "e1782b46-1c1f-4efa-a57c-f32deadcc339"]],ExpressionUUID->
     "767ecc09-96b6-43ef-8d80-d7d48436aa4c"], " ", "are", " ", "closed", " ", 
    "under", " ", "addition"}], ",", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"so", " ", "x"}], "+", "y"}], "\[Element]", 
    SubscriptBox["V", "i"]}], ",", " ", 
   RowBox[{"and", " ", "hence", " ", "in", " ", Cell[TextData[{
     Cell[BoxData[
      FormBox["W", TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "817e6194-c23e-4afa-882e-b685bda26be5"],
     "."
    }],ExpressionUUID->"41d36967-bbbc-41b2-8e65-226f9eece103"]}]}], 
  TraditionalForm], "\n", 
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"(", "iii", ")"}], "  ", "Let", " ", "x"}], "\[Element]", 
    RowBox[{"W", " ", "and", " ", "let", " ", "a"}], " ", "\[Element]", " ", 
    "\[DoubleStruckCapitalF]"}], ",", " ", 
   RowBox[{
    RowBox[{"then", " ", "a", " ", "x"}], "\[Element]", 
    RowBox[{"W", " ", "because", "  ", Cell[TextData[{
      Cell[BoxData[
       FormBox["x", TraditionalForm]],
       FormatType->TraditionalForm,ExpressionUUID->
       "7d0bc196-75c7-4d00-85f8-cfb1cdf97559"],
      "  ",
      Cell[BoxData[
       FormBox["is", TraditionalForm]],
       FormatType->TraditionalForm,ExpressionUUID->
       "93e504a9-faea-4f17-812a-37b819d61287"]
     }],ExpressionUUID->"c806ff1a-beda-4946-ae84-234c498ebce9"], " ", "in", 
     " ", "every", " ", 
     SubscriptBox["V", "i"]}]}], ",", " ", 
   RowBox[{"and", " ", "the", " ", Cell[TextData[Cell[BoxData[
     FormBox[
      SubscriptBox["V", "i"], TraditionalForm]],
     FormatType->TraditionalForm,ExpressionUUID->
     "218e3901-09c7-4b9f-8cad-70f0ebf9a047"]],ExpressionUUID->
     "a7027faf-e629-4055-bd4b-4259563c00fb"], " ", "are", " ", "closed", " ", 
    "scalar", " ", "multiplication"}], ",", " ", 
   RowBox[{
    RowBox[{"so", " ", "a", "\[VeryThinSpace]", "x"}], "\[Element]", 
    SubscriptBox["V", "i"]}], ",", " ", 
   RowBox[{"and", " ", "hence", " ", "in", " ", Cell[TextData[{
     Cell[BoxData[
      FormBox["W", TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "dab7deca-ab46-40ef-b475-8b2e4f9f36db"],
     "."
    }],ExpressionUUID->"c3c0418f-c433-43e9-a279-d56f3c27cd25"], 
    "                 "}]}], TraditionalForm]}], "DisplayFormula",
 CellChangeTimes->{{3.618318874449812*^9, 3.618318876238*^9}, {
   3.618319052797199*^9, 3.618319423577367*^9}, {3.61831948651137*^9, 
   3.6183195214016323`*^9}, {3.6183195726039686`*^9, 
   3.6183195728361235`*^9}, {3.618319625717631*^9, 3.6183200218144016`*^9}, {
   3.618320144037789*^9, 3.618320482387991*^9}, {3.6187461535373335`*^9, 
   3.618746400413719*^9}, {3.618746620607704*^9, 3.618746622930253*^9}, 
   3.6187471294997225`*^9, {3.618749518032251*^9, 3.6187495196302834`*^9}, {
   3.870521790953738*^9, 3.870521805312195*^9}, {3.8705219126324425`*^9, 
   3.870521915168939*^9}, {3.902402760700243*^9, 3.9024028451769333`*^9}, {
   3.9024134276206255`*^9, 
   3.9024136309090023`*^9}},ExpressionUUID->"d61b34f0-d544-497d-a690-\
1b94040192e2"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["SECTION 1.4 - LINEAR COMBINATIONS AND SPAN",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.618747318516198*^9, 3.6187473223377485`*^9}, {
   3.8392831181488247`*^9, 3.839283122013604*^9}, {3.8392831624429073`*^9, 
   3.839283194444538*^9}, {3.8392839780638075`*^9, 3.839283980757876*^9}, 
   3.8392840476653414`*^9, {3.8709522372706957`*^9, 
   3.8709522388791585`*^9}},ExpressionUUID->"3ac012d0-f42f-4dd9-b6db-\
c0f43c5cc77c"],

Cell["", "Text",ExpressionUUID->"d35eb6f3-1bae-46d3-8726-9daf7ff99e48"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontSlant->"Plain",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
   3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
   3.6187478943151035`*^9}, {3.618921935437778*^9, 3.6189219580218277`*^9}, {
   3.618922635866583*^9, 3.618922635870586*^9}, {3.6189227041517787`*^9, 
   3.6189227050498595`*^9}, {3.6191781587456026`*^9, 3.6191781619557343`*^9}, 
   3.839283225483884*^9},ExpressionUUID->"636584e6-220c-471a-b77a-\
fed1d88f2a2a"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "4fa3302f-7f2f-4ded-b692-9ed04eb4cb08"],
 " be a vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[SubsetEqual]", "V"}], TraditionalForm]],ExpressionUUID->
  "f219ae1a-79cc-44f4-8c7b-f061cd1658ee"],
 " be nonempty.  A vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "f273dcf5-0a64-4ac4-af3f-20c83cda1b2e"],
 " is called a ",
 StyleBox["linear combination",
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 " of the vectors of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "1c0ccd52-5113-456d-a6cc-e0c687799729"],
 " if there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "1"], ",", " ", 
    SubscriptBox["u", "2"], ",", " ", 
    RowBox[{
     RowBox[{"...", " ", 
      SubscriptBox["u", "m"]}], "\[Element]", "S"}]}], TraditionalForm]],
  ExpressionUUID->"41b551a4-12d6-4efa-82a9-0864f7072fa7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", " ", 
    SubscriptBox["a", "2"], ",", " ", 
    RowBox[{
     RowBox[{"...", " ", 
      SubscriptBox["a", "m"]}], "\[Element]", "\[DoubleStruckCapitalF]"}]}], 
   TraditionalForm]],ExpressionUUID->"d0141631-b169-4cb9-8479-b37e205c60f1"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"1", " \[VeryThinSpace]"}]], 
        SubscriptBox["u", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SubscriptBox["u", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "m"], 
      RowBox[{
       SubscriptBox["u", "m"], "."}]}]}]}], TraditionalForm]],ExpressionUUID->
  "86d35986-d84f-4de5-8daf-10e50802137e"],
 "  Note: ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "28059b2f-18b7-42f3-aeff-4e58436696e9"],
 " is a finite postive integer."
}], "Text",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
   3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
   3.6187478943151035`*^9}, {3.618921935437778*^9, 3.6189219580218277`*^9}, {
   3.618922635866583*^9, 3.618922635870586*^9}, {3.6189227041517787`*^9, 
   3.6189227050498595`*^9}, {3.6191781587456026`*^9, 3.6191781619557343`*^9}, 
   3.839283236310096*^9, {3.839283268744117*^9, 3.8392832720068054`*^9}, {
   3.9024140729352503`*^9, 
   3.902414092793078*^9}},ExpressionUUID->"64ef77b3-f7c6-4225-8bb5-\
0b06dd752e26"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
  3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
  3.618747953613637*^9}, {3.61892192004155*^9, 3.6189219204758406`*^9}, {
  3.618922802663266*^9, 3.6189228026712713`*^9}, {3.6191781784467087`*^9, 
  3.6191781784507103`*^9}},ExpressionUUID->"83c444b4-8bc8-4087-9c6b-\
f9ea61e0a885"],

Cell[TextData[{
 "Given a set ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "bf02d585-9567-4004-b57f-f96134bc030b"],
 " of actual vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"c2f2d0ff-e23a-46b9-b86f-23b4b39360e6"],
 ", you should be able to tell if a given vector is a linear combination of \
the vectors in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "."}], TraditionalForm]],ExpressionUUID->
  "e2ac3566-629d-4b11-bc8c-45a3f09da572"],
 "  (Hint: put them in a matrix and row reduce)"
}], "Text",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
   3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
   3.618747953613637*^9}, {3.61892192004155*^9, 3.6189219204758406`*^9}, {
   3.618922802663266*^9, 3.6189228026712713`*^9}, 3.6191781784467087`*^9, {
   3.8392832823204603`*^9, 3.8392833514778576`*^9}, {3.839283390351641*^9, 
   3.839283398203475*^9}, {3.840115194370251*^9, 3.840115195409478*^9}, {
   3.8709487824558125`*^9, 3.8709488134529023`*^9}, {3.902414324065012*^9, 
   3.9024143420191936`*^9}},ExpressionUUID->"469ea306-25ee-408d-9086-\
a5c5252107a5"],

Cell[TextData[{
 "Remark:  Notice that in linear algebra we only take ",
 StyleBox["finite ",
  FontSlant->"Italic"],
 "sums. We don\[CloseCurlyQuote]t allow infinite series."
}], "Text",
 CellChangeTimes->{{3.8401152313951445`*^9, 3.84011526727284*^9}, {
  3.840118656917151*^9, 
  3.8401186602791405`*^9}},ExpressionUUID->"588eb0d1-0f32-407d-a229-\
fc0d015a2852"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontSlant->"Plain",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontFamily->"Times New Roman",
  FontSlant->"Plain"]
}], "Subsubsubsection",
 CellChangeTimes->{
  3.6187478917113695`*^9, {3.618747961940199*^9, 3.618748043749483*^9}, {
   3.6189230649889717`*^9, 3.618923075201786*^9}, 
   3.8392834091489997`*^9},ExpressionUUID->"9d58f57c-9631-437b-a615-\
f32abd747caf"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a2971560-4493-45e1-bea5-e852d977f905"],
 " be a vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[SubsetEqual]", "V"}], TraditionalForm]],ExpressionUUID->
  "5c8b2ce4-75ea-46b1-ad7f-33b158fd7b66"],
 " be nonempty. The ",
 StyleBox["span",
  FontColor->GrayLevel[0]],
 " of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "3ea3abe3-07a6-4f9f-bf86-31546a989d8b"],
 ", denoted ",
 StyleBox["span(",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "41d8ea14-20aa-4525-983e-d26e8e7617c8"],
 StyleBox[")",
  FontColor->GrayLevel[0]],
 ", is the set of all (finite) linear combinations of vectors in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "."}], TraditionalForm]],ExpressionUUID->
  "1121ef1d-50a7-4320-a5a7-4b83e01c9eff"],
 "  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", "\[Phi]"}], TraditionalForm]],ExpressionUUID->
  "f1b3f7ed-d6a1-45de-9900-eca27ad5dfe9"],
 ", by convention, we say ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", 
     RowBox[{"(", "S", ")"}]}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],ExpressionUUID->
  "bb96be83-698c-4fc5-be38-3c14a56d38f3"],
 "."
}], "Text",
 CellChangeTimes->{
  3.6187478917113695`*^9, {3.618747961940199*^9, 3.618748043749483*^9}, {
