Cell[TextData[{
 "The last row of the reduced echelon form of our matrix indicates that there \
is no solution for this system of equations.  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[NotElement]", 
    RowBox[{"span", "(", "S", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7151f18b-4bb9-4024-a600-806835dcdd43"],
 "."
}], "Text",
