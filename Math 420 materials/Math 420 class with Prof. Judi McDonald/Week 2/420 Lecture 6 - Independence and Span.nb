  3.902586914155924*^9}},ExpressionUUID->"82297ba8-2b22-4af6-89b7-\
333f605c3099"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox["  ",
  FontFamily->"Times New Roman"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.618921152717435*^9, 3.618921166929902*^9}, 
   3.618921254806816*^9, {3.618921757408559*^9, 3.6189217980436563`*^9}, {
   3.6189218566714697`*^9, 3.6189218823645515`*^9}, 3.6189249677181115`*^9, 
   3.8392830242712517`*^9},ExpressionUUID->"df36d739-6bd4-4e42-9a6e-\
c21e011bf3f9"],

Cell[TextData[{
 "A subset ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "d3f7aba7-1268-41b4-a112-e3c001b8a310"],
 " of a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "1db2d93c-c89d-4bd4-9473-047854ad6842"],
 " generates (or spans) ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "0df4d235-61ee-46d3-b007-91f7460e226d"],
 " provided Span(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", ")"}], "=", Cell[TextData[Cell[BoxData[
     FormBox[
      RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
     "0fe29ecd-4576-4609-84c5-43e6131cc4f8"]],ExpressionUUID->
     "bbf2dae8-d31d-4cc2-855d-4ecf55a8965e"]}], TraditionalForm]],
  ExpressionUUID->"5ffcf743-58be-4c3d-8eca-efaa0c1b9705"],
 " We might also phrase this as the set",
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 Cell[BoxData[
  FormBox[
   StyleBox["S",
    FontColor->GrayLevel[0]], TraditionalForm]],
  FontColor->RGBColor[0, 0, 1],ExpressionUUID->
  "52d05599-a60f-4bc6-9d93-09fca19c6048"],
 " ",
 StyleBox["spans ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "f256178c-ace0-4d4e-9e10-2f22ff465a2b"],
 "."
}], "Text",
 CellChangeTimes->{{3.618921152717435*^9, 3.618921166929902*^9}, 
   3.618921254806816*^9, {3.618921757408559*^9, 3.6189217980436563`*^9}, {
   3.6189218566714697`*^9, 3.6189218823645515`*^9}, 3.6189249677181115`*^9, {
   3.8392830305728827`*^9, 3.839283037873643*^9}, {3.839330708998873*^9, 
   3.839330790238006*^9}, {3.8402920193197603`*^9, 3.8402920198070717`*^9}, 
   3.840292312591776*^9},ExpressionUUID->"ccd59938-98c3-4f4b-b4cf-\
dd60c9784685"]
