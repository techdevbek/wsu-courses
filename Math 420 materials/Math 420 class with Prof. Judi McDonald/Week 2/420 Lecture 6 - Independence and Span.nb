Cell[CellGroupData[{

Cell[TextData[StyleBox["Example", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8393308042688427`*^9, 
  3.839330808442788*^9}},ExpressionUUID->"e1834ad8-b010-418d-b444-\
f3538514eb0c"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "+", "x"}], ",", " ", 
      RowBox[{"x", "+", 
       SuperscriptBox["x", "2"]}], ",", " ", 
      RowBox[{"1", "+", 
       SuperscriptBox["x", "2"]}], ",", 
      RowBox[{"1", "+", "x", "+", 
       SuperscriptBox["x", "2"]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"004f886f-512e-45aa-8f8b-075c9eca791f"],
 ".  Does ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "c5a80264-aa1e-44ac-a6c1-df9c00bcd5da"],
 " span ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "1"], TraditionalForm]],
  ExpressionUUID->"0484cc45-3ed8-4b48-8c24-e6be533310ff"],
 "? Does ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "eac18a4f-0d25-409a-9f6c-e8a5f1f99f5d"],
 " span ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "2"], TraditionalForm]],
  ExpressionUUID->"475756de-f6d4-4d6a-b261-bf78f4d1bb4f"],
 "?  Does ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "4899227e-6037-442d-b3ea-76ff3b266ccc"],
 " span ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "3"], TraditionalForm]],
  ExpressionUUID->"a739e389-7c99-47bf-96a4-c65feab89f7a"],
 "?"
}], "Text",
 CellChangeTimes->{{3.8393308317218657`*^9, 
  3.8393309772673626`*^9}},ExpressionUUID->"50cb8023-2f03-477e-b0d0-\
c26c9cb188eb"],

Cell[TextData[{
 "No.  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", "(", "S", ")"}], "\[NotEqual]", 
    SubscriptBox["\[DoubleStruckCapitalP]", "1"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6deeac6c-8384-454f-9eb8-2ec9e4cb2f98"],
 " since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "+", 
     SuperscriptBox["x", "2"]}], "\[NotElement]", 
    RowBox[{
     SubscriptBox["\[DoubleStruckCapitalP]", "1"], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9145ce32-6034-4a38-a4c8-517ecd95f352"]
}], "Text",
 CellChangeTimes->{{3.902587052803403*^9, 
  3.902587099839841*^9}},ExpressionUUID->"40b2535b-2952-4037-b56b-\
175bcb799e2f"],

Cell[TextData[{
 "Yes.  With a little work you can show every vector in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1cea1e9d-728e-4901-9a46-3cec779bd2a4"],
 " can be written as a linear combination of things in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "506cc9e2-c7b8-4c91-81eb-1014d1b29686"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[SubsetEqual]", 
    RowBox[{
     SubscriptBox["\[DoubleStruckCapitalP]", "2"], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "635e7987-80c6-4985-a31e-049887bdb683"]
}], "Text",
 CellChangeTimes->{{3.9025871308651795`*^9, 
  3.9025871823618155`*^9}},ExpressionUUID->"f3000ab8-d9ad-415e-9f40-\
159b80b81f92"],

Cell[TextData[{
 "No.  There is no way to get ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "3"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e062393-2752-4304-b613-2f9c96107d57"],
 " by taking linear combination of vectors in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "745c094b-ae73-45c7-b284-5ae4142c829e"],
 "."
}], "Text",
 CellChangeTimes->{{3.9025871874070272`*^9, 
  3.902587217852008*^9}},ExpressionUUID->"89408183-bce9-4154-8f1a-\
13c701328051"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
