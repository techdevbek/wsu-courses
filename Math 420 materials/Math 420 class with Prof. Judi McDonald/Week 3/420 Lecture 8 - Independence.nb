Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
   3.6193646809340987`*^9}, 
   3.840712932918723*^9},ExpressionUUID->"9f76a5ef-1e35-4967-8426-\
d7a788721636"],

Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a7ea091b-c053-4788-91a9-e7957b801e17"],
 " be a vector space over a field \[DoubleStruckCapitalF]. A subset \[Beta] \
of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b9d57532-60b2-471a-b44d-793257c77369"],
 " is a ",
 StyleBox["basis",
  FontWeight->"Bold",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 StyleBox["for ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a2f5690d-73b6-4de6-a3b8-35b405ff8629"],
 " provided \[Beta] is linearly independent and spans ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "46aaa228-26ab-4c10-97d7-2bdcf2b03764"]
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
  3.6193646809340987`*^9}},ExpressionUUID->"5e5c903b-6dcc-48bd-9152-\
7124b3b7eca1"],

Cell[TextData[{
 "We say \[Beta] spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "74cc4dbf-45f6-45d4-8e34-94a7a1bc74c8"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", 
     RowBox[{"(", "\[Beta]", ")"}]}], "=", "V"}], TraditionalForm]],
  ExpressionUUID->"3afd4e39-8e45-4fb6-889f-4cec86423f35"],
 "."
}], "Text",
 CellChangeTimes->{{3.8719894966209164`*^9, 
  3.8719895400977774`*^9}},ExpressionUUID->"d4831a1f-76b4-45ee-acf3-\
8ff8a92ef195"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"5455f35a-2023-4235-b99c-b81ccfa7e3e9"],

Cell[TextData[{
 StyleBox["MORAL:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " A spanning set can be too big.  A linearly independent set could be too \
small.  ",
 StyleBox["A basis is just right",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8408961720557137`*^9, 
  3.840896218303209*^9}},ExpressionUUID->"fe34275c-e4d6-4dae-bcc4-\
72aa27a97872"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.619351805243565*^9, 3.6193518185101566`*^9}, {
   3.6193519210581617`*^9, 3.6193519276975975`*^9}, {3.6193561565435925`*^9, 
   3.6193562226016865`*^9}, 
   3.840712981336104*^9},ExpressionUUID->"c26cab19-58b3-4855-8572-\
26bac67f008c"],

Cell[TextData[{
 StyleBox["Let ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FontWeight->"Plain",
  FontColor->RGBColor[0, 0, 0],ExpressionUUID->
  "a2e8004c-832a-4d1d-85f8-2c347d9e4624"],
 StyleBox[" be a vector space over a field \[DoubleStruckCapitalF].  Let \
\[Beta]\[SubsetEqual]",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ce77e72a-9a3d-4b66-b8ca-6f135f6bd592"],
 ".  Then \[Beta] is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "937f2c14-39b9-4b5f-9c4b-0344d86e6c6f"],
 " if and only if every vector in ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b34a1cf3-4c3b-460a-b24e-e4d1a90bd903"],
 " can be expressed ",
 StyleBox["uniquely",
  FontColor->RGBColor[0, 0, 1]],
 " as a linear combination of the vectors in \[Beta]."
}], "Text",
 CellChangeTimes->{{3.619351805243565*^9, 3.6193518185101566`*^9}, {
   3.6193519210581617`*^9, 3.6193519276975975`*^9}, {3.6193561565435925`*^9, 
   3.6193562226016865`*^9}, 
   3.8407129859496355`*^9},ExpressionUUID->"f62a4b2d-b59e-4b3c-ab48-\
aa2e479745c6"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
