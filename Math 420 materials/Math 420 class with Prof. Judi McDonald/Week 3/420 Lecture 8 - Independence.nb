Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "4b78e457-84e5-4572-a102-6db522a84873"],
 " be a subset of a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "41d441d8-8600-4505-a3c9-22dcfb34c261"],
 " over a field \[DoubleStruckCapitalF]. The set ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "7ff4d43f-1e5d-4ee3-82f9-88c8a7e864d6"],
 " is ",
 StyleBox["linearly independent",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[" ",
  FontColor->GrayLevel[0]],
 StyleBox["if it is ",
  FontColor->RGBColor[0, 0, 0]],
 StyleBox["not",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[1., 0., 0.]],
 StyleBox[" linearly dependent",
  FontColor->RGBColor[0, 0, 0]],
