 " be a vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "1a242235-d050-49c6-937c-8e1d7d5a17d8"],
 " be a linearly independent subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "068d48b2-db15-47b3-a8ad-ac99b46ee35a"],
 "and let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "eabb0f7b-6ada-4253-8033-6376a514d724"],
 "  The subset ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Union]", 
    RowBox[{"{", "v", "}"}]}], TraditionalForm]],ExpressionUUID->
  "67226112-4a5b-4fe6-8be1-b7ce6451ebd2"],
 " is linearly dependent if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", 
    RowBox[{"Span", "(", "S", ")"}]}], TraditionalForm]],ExpressionUUID->
  "7a350531-3b16-4b03-8406-6d4930c8c616"],
 "."
}], "Text",
 CellChangeTimes->{{3.6191782467652006`*^9, 3.6191782971633806`*^9}, {
   3.6191783612981877`*^9, 3.61917836545696*^9}, {3.619178407222246*^9, 
   3.619178430641836*^9}, {3.6191796823227034`*^9, 3.619179725082162*^9}, 
   3.6191798035617995`*^9, 3.8405407804765515`*^9, {3.840724507386862*^9, 
   3.840724507386862*^9}, 
   3.903011162100176*^9},ExpressionUUID->"124c6c94-fc6c-44fb-ac1d-\
4847704b0c28"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.619184190753389*^9, 3.6191841919922123`*^9}, {
  3.619184252192725*^9, 3.61918425250686*^9}, {3.619184325042267*^9, 
  3.619184328378024*^9}, {3.619184459097686*^9, 
  3.6191844616070714`*^9}},ExpressionUUID->"4a4c966a-1f83-4a8e-8bb7-\
2bccf8ab2647"],

Cell[TextData[{
 "(\[DoubleLongRightArrow]) Assume the subset ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Union]", 
    RowBox[{"{", "v", "}"}]}], TraditionalForm]],ExpressionUUID->
  "01f22354-5cb5-41d3-874c-1e0c01daedb7"],
 " is linearly dependent.  There exist vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", 
    SubscriptBox["v", "2"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["v", "n"], "\[Element]", 
     RowBox[{"S", "\[Union]", 
      RowBox[{"{", "v", "}"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "265e3d24-9799-4457-b9dd-94e9af5e24a4"],
 " and nonzero scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    SubscriptBox["a", "2"], ",", "...", ",", 
    SubscriptBox["a", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8de02972-1cf1-4a14-b960-db717ad895e8"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1a7a7f41-b3fc-4370-aae2-3ef0e30ec96d"],
 ".  Since ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8a96a33b-a2c1-4786-be9b-2fac65d8c193"],
 " is linearly independent, at least one ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", 
    SubscriptBox["v", "2"], ",", "...", ",", 
    SubscriptBox["v", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ae7abf10-5f4e-4619-b693-e62f2a2c3ff3"],
 " is not in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "74df5b76-4a12-4362-bc84-a6ec102eede1"],
 ".  WLOG ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "2"], "=", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "66d043ef-a968-49c2-969e-dab812bdf55d"],
 ", thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "2"], "=", "-"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1593f141-8eb2-4cc3-a895-788212c38548"],
 "(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", "1"], 
         SubscriptBox["v", "1"]}], "+", 
        RowBox[{
         SubscriptBox["a", "3"], 
         SubscriptBox["v", "3"]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", "n"], 
       SubscriptBox["v", "n"]}]}], ")"}], "/", 
    SubscriptBox["a", "2"]}], TraditionalForm]],ExpressionUUID->
  "dca92a71-1785-4413-9d9a-d625179b4edc"],
 ", making ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dda7d4ac-9a58-416a-ae12-fd9b83b4ee80"],
 " a linear combination of vectors in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a8f2715-3a2c-4d42-bae0-3f4a31612265"],
 ", and hence ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ffe20218-063f-4fb8-a5f1-a05c42681ef6"],
 " is in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Span", " ", "S"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "36c0c6aa-103d-4dfa-87ed-2ee6573b4a01"],
 "."
}], "Text",
 CellChangeTimes->{{3.619184190753389*^9, 3.6191841919922123`*^9}, {
   3.619184252192725*^9, 3.6191842529611607`*^9}, {3.8407247853365064`*^9, 
   3.840724791250661*^9}, {3.840724830667646*^9, 3.840724874054703*^9}, 
   3.8717254284433208`*^9, {3.9031906508430414`*^9, 3.9031906573122396`*^9}, {
   3.9031907175107145`*^9, 3.9031907606978273`*^9}, {3.9031908237125716`*^9, 
   3.903191001095626*^9}},ExpressionUUID->"d251dd8c-e2cf-427f-b8e6-\
95bc46675fe2"],

Cell[TextData[{
 "(\[DoubleLongLeftArrow]) Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", 
    RowBox[{"Span", "(", "S", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d796cb7e-1745-431b-8df2-23dfea0b231b"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6b1edb5f-e674-44ee-ae38-f4f10586b7f9"],
 " for scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["a", "1"], "..."}], " ", 
    SubscriptBox["a", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3eed3352-a98f-406b-935c-d31d83f6412e"],
 " and vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", 
    SubscriptBox["v", "2"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["v", "n"], "\[Element]", "S"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f3eb732f-0511-47c5-a55c-bc30b4ab76a3"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"-", "v"}], "+", 
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2af725d4-e3fc-4dd3-8637-f7666360e8c3"],
 ", establishing that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Union]", 
    RowBox[{"{", "v", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "28a591e1-4fc3-4ad3-8373-64424fc8cd0d"],
 " is linearly dependent. "
}], "Text",
 CellChangeTimes->{{3.619184190753389*^9, 3.6191841919922123`*^9}, {
   3.619184252192725*^9, 3.619184253899787*^9}, {3.840724458659778*^9, 
   3.840724518588873*^9}, 3.8717254348429136`*^9, {3.9031906770332255`*^9, 
   3.903190687242428*^9}, {3.903191091281019*^9, 
   3.9031912274679766`*^9}},ExpressionUUID->"627237e8-d55f-4f76-abd8-\
bd0d21f310c4"],

Cell["", "Text",
 CellChangeTimes->{{3.840724527112562*^9, 
  3.8407245271165504`*^9}},ExpressionUUID->"ab99fb9f-15aa-431f-8047-\
dff6d542c73c"],

Cell[TextData[{
 "Statement 1\[DoubleLongLeftRightArrow]statement 2...\
\[DoubleLongLeftRightArrow]Statement ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47c4a33c-3e57-4a71-bd87-aa716cc99a86"]
}], "Text",
 CellChangeTimes->{{3.9031913011844664`*^9, 
  3.9031913392999954`*^9}},ExpressionUUID->"2307713c-b1d6-44a5-88f8-\
daeb832e3f7e"]
}, Open  ]]
}, Open  ]],

