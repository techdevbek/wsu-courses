7d89503f52da"],

Cell[TextData[{
 StyleBox["Let ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "14638742-6541-4c38-b685-68247d9272a1"],
 " be a vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "1"], "\[SubsetEqual]", 
    SubscriptBox["S", "2"], "\[SubsetEqual]"}], TraditionalForm]],
  ExpressionUUID->"d6bec801-b47a-49de-a1a3-80f68db65d13"],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "039114cf-bef1-47e6-9bb0-6c09ab7df192"],
 ".  If ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],ExpressionUUID->
  "38ccc62b-f5e3-4ff2-9e61-2779079c5db9"],
 " is a linearly dependent subset, then ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "2"], TraditionalForm]],ExpressionUUID->
  "1936f200-0b9e-4f49-a3f0-cea7a8e08aa3"],
 " is a linearly dependent subset."
}], "Text",
 CellChangeTimes->{{3.6191782467652006`*^9, 3.6191782971633806`*^9}, {
   3.6191783612981877`*^9, 3.61917836545696*^9}, {3.619178407222246*^9, 
   3.6191784226265097`*^9}, {3.619178682026099*^9, 3.619178682539447*^9}, {
   3.6191794161212826`*^9, 3.6191795170246525`*^9}, 
   3.6191796304792185`*^9},ExpressionUUID->"8751d18a-0a03-4cf6-b528-\
1858e59a7745"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6191782467652006`*^9, 3.6191782971633806`*^9}, {
  3.6191783612981877`*^9, 3.61917836545696*^9}, {3.619178407222246*^9, 
  3.6191784284874043`*^9}, {3.619179530435589*^9, 3.61917961125041*^9}, {
  3.6191836364203625`*^9, 
  3.6191836496620445`*^9}},ExpressionUUID->"ea2e1a26-5d92-4d5b-b02d-\
7e13b3f5044b"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "54867877-0861-46a2-bb9c-166989941b34"],
 " is linearly dependent, there exist vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", 
    SubscriptBox["v", "2"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["v", "n"], "\[Element]", 
     SubscriptBox["S", "1"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fd418a96-3651-4e31-8492-1ff7b053a395"],
 " and nonzero scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    SubscriptBox["a", "2"], ",", "...", ",", 
    SubscriptBox["a", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8cb27a43-38eb-4d4a-b667-75637a6b2e71"],
 " so that "
}], "Text",
 CellChangeTimes->{{3.8717314778272657`*^9, 3.8717315429011793`*^9}, 
   3.903011132927976*^9, {3.9031895359319572`*^9, 3.9031896016117945`*^9}, {
   3.9031896448556614`*^9, 
   3.903189692198253*^9}},ExpressionUUID->"e79ca177-0dbc-4024-941d-\
e9e53a1d7716"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+", 
       RowBox[{
        SubscriptBox["a", "2"], 
        SubscriptBox["v", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "af5d70c5-5ba6-440c-8ad4-d497c1516c6f"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "1"], "\[SubsetEqual]", 
    SubscriptBox["S", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "164bdedd-3fc8-47b4-a025-8ab1d1294182"],
 ", we see that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", 
    SubscriptBox["v", "2"], ",", "...", ",", 
    RowBox[{
     SubscriptBox["v", "n"], "\[Element]", 
     SubscriptBox["S", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e3bc31f7-0abe-4612-a05a-761371924933"],
 ", and hence we have a nontrivial linear combination of vectors in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "31c9b724-ea6a-4c34-80d3-8b7c7ec38e3f"],
 " that adds to zero, so ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "831f2adb-aa9d-4057-a349-a0eab355a48f"],
 " is linearly dependent as well."
}], "Text",
 CellChangeTimes->{{3.8717314778272657`*^9, 3.8717315429011793`*^9}, 
   3.903011132927976*^9, {3.9031895359319572`*^9, 3.9031896016117945`*^9}, {
   3.9031896448556614`*^9, 3.9031897552137394`*^9}, {3.9031897861127768`*^9, 
   3.9031897902243752`*^9}, {3.903189876975272*^9, 3.9031898775645256`*^9}, {
   3.903189967502692*^9, 3.9031900061362295`*^9}, {3.9031900532097883`*^9, 
   3.9031900980343647`*^9}, {3.903190196874999*^9, 
   3.903190208201013*^9}},ExpressionUUID->"6106cdfb-9595-47dd-a831-\
2d8637d782c4"]
}, Open  ]],

