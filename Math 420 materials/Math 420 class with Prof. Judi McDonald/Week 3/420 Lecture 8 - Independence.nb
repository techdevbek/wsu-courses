 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "1"], TraditionalForm]],ExpressionUUID->
  "f088aa82-312c-459d-954f-25d7af2ea6c8"],
 " is also a linearly independent subset."
}], "Text",
