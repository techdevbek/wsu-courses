  3.903188780300192*^9}},ExpressionUUID->"aee4e877-5269-4c9d-8b54-\
46b5f962a66a"],

Cell[TextData[{
 "OBSERVATION:  If ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69ae7ded-5d50-48ee-9d11-7f13d6fec40d"],
 " is a nonempty subset then"
}], "Text",
 CellChangeTimes->{{3.9031887871537905`*^9, 
  3.903188830828988*^9}},ExpressionUUID->"e123efde-ec55-4863-bacf-\
61ccfc61e564"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", " ", 
     RowBox[{"(", "S", ")"}]}], "=", 
    RowBox[{
     RowBox[{
     "set", " ", "of", " ", "all", " ", "finite", " ", "linear", " ", 
      "combinations", " ", "of", " ", "vectors", " ", "in", " ", "S"}], "=", 
     " ", 
     RowBox[{
     "the", " ", "smallest", " ", "subspace", " ", "that", " ", "contains", 
      " ", "S"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bd9dedc2-1371-4451-8901-23fb5bef4cd0"]
}], "Text",
 CellChangeTimes->{{3.9031887871537905`*^9, 3.9031888555346885`*^9}, {
  3.903189232338115*^9, 
  3.903189232955343*^9}},ExpressionUUID->"753abbbd-b83c-4bb9-826b-\
987c00b205bd"],

Cell[TextData[{
 "Two choices seem to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"Span", " ", "\[Phi]"}], "=", 
     RowBox[{"{", "}"}]}], ",", " ", 
    RowBox[{
    "because", " ", "there", " ", "are", " ", "not", " ", "any", " ", 
     "linear", " ", "combinations", " ", "or", "  "}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5b6fdb22-deda-4121-b9e7-770f998f91d6"]
}], "Text",
 CellChangeTimes->{{3.9031892433314734`*^9, 
  3.9031893209836063`*^9}},ExpressionUUID->"850978ed-96a4-412d-9d08-\
e837d08444d2"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", " ", "\[Phi]"}], "=", 
    RowBox[{
     RowBox[{"{", "0", "}"}], " ", "because", " ", 
     RowBox[{"{", "0", "}"}], " ", "is", " ", "the", " ", "smallest", " ", 
     "subspace", " ", "that", " ", "contains", " ", "the", " ", "empty", " ", 
     "set"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "50320422-ffe1-4954-9baf-b8cbfed96a4e"],
 "."
}], "Text",
