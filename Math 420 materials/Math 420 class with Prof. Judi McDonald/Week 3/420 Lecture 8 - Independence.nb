Cell[TextData[{
 "QUESTION:  What is the motivation to define ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Span", " ", "\[Phi]"}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c768cd61-3f65-491d-ad9d-96fd0aff9bcc"],
 "?"
