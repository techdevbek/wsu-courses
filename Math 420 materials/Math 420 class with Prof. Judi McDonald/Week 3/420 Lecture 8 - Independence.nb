   3.9031893279004755`*^9}},ExpressionUUID->"e98e66a4-8a08-4680-9b8e-\
dbb4dc0fd399"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "bded6546-dc64-4d2b-a241-128fdcf5c6c7"],
 " be a subset of a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "6193d2f5-2906-4403-8474-59daa656ab39"],
 " over a field \[DoubleStruckCapitalF]. The set ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "8a02dae2-2541-44ef-83f0-09c4a736f491"],
 " is ",
 StyleBox["linearly dependent",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["provided there are vectors ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "1"], ","}], TraditionalForm]],ExpressionUUID->
  "581f8cad-3645-4b9c-8916-0bb057b75b00"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "2"], ",", " ", "...", ",", " ", 
    SubscriptBox["x", "n"]}], TraditionalForm]],ExpressionUUID->
  "14b6319d-b0d3-4f5b-b84f-3bb81a27cb2f"],
 " \[Element]",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", "S"}], TraditionalForm]],ExpressionUUID->
  "67de6f21-0e41-41b0-a856-eb3bc250400c"],
 " and ",
 StyleBox["nonzero",
  FontColor->RGBColor[1, 0, 0]],
 " ",
 StyleBox["coefficients ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "1"], TraditionalForm]],ExpressionUUID->
  "01360c7f-f8ed-4d59-87d8-46fa842cd606"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "2"], TraditionalForm]],ExpressionUUID->
  "1e92863a-070a-4b10-bb4f-29b81478c633"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"...", ",", 
    SubscriptBox["c", "n"]}], TraditionalForm]],ExpressionUUID->
  "fc701dd1-0f68-4d27-a013-b11302c1572c"],
 " \[Element] \[DoubleStruckCapitalF], such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["c", "1"], 
        SubscriptBox["x", "1"]}], "+", 
       RowBox[{
        SubscriptBox["c", "2"], 
        SubscriptBox["x", "2"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["c", "n"], 
      SubscriptBox["x", "n"]}]}], "=", "0."}], TraditionalForm]],
  ExpressionUUID->"a4224ecb-28d9-4f90-8b1e-e9d43a73fbc8"]
}], "Text",
 CellChangeTimes->{{3.6191782467652006`*^9, 3.619178296989267*^9}, {
   3.619181552873315*^9, 3.619181608161667*^9}, {3.6191816573524094`*^9, 
   3.6191817891991816`*^9}, 3.8402291153917847`*^9, 
   3.8402297541335597`*^9},ExpressionUUID->"2965fc27-a747-439e-867a-\
22b2e4c3f38c"]
}, Open  ]],

