Notebook[{

Cell[CellGroupData[{
Cell[TextData[StyleBox["MATH 420-01",
 FontSize->24,
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Title",
 CellChangeTimes->{{3.6179684285727897`*^9, 3.6179684375948114`*^9}, 
   3.617971980867153*^9, 3.8383066845018682`*^9, {3.8387365145039787`*^9, 
   3.8387365163000507`*^9}},
 TextAlignment->Center,ExpressionUUID->"28ef0196-bf89-4053-9813-6dc8f407d461"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["1.6 Bases and Dimension",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 
  3.619351702367731*^9}},ExpressionUUID->"8b512edb-b6d2-4adf-a640-\
39a5ebb646c2"],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"5455f35a-2023-4235-b99c-b81ccfa7e3e9"],

Cell[TextData[{
 StyleBox["MORAL:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " A spanning set can be too big.  A linearly independent set could be too \
small.  ",
 StyleBox["A basis is just right",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8408961720557137`*^9, 
  3.840896218303209*^9}},ExpressionUUID->"fe34275c-e4d6-4dae-bcc4-\
72aa27a97872"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem: ", "Subsubsubsection",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ", "Subsubsubsection",
  FontFamily->"Times New Roman"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.619351805243565*^9, 3.619351818509158*^9}, {
   3.6193518500202003`*^9, 3.6193519046526947`*^9}, {3.619351992935667*^9, 
   3.619352187471823*^9}, {3.6193522761893177`*^9, 3.619352279087253*^9}, {
   3.6195272031918573`*^9, 3.61952720580861*^9}, 
   3.8411522250429525`*^9},ExpressionUUID->"871ae7d0-5705-4dd7-8d48-\
ba54f9c8d21d"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "51c1ac19-e219-4aba-87d3-c5774cd6d6a2"],
 " be a vector space over a field \[DoubleStruckCapitalF].  Suppose ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "6f175a00-eddb-4c80-b964-7e45819c9b22"],
 " is a subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "92786497-79ad-4fd0-a28e-73bba512681c"],
 " with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "506d6bc0-8dcb-491d-80f9-bb5298289d13"],
 " vectors such that ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "acff5001-0de7-49dd-9404-eaf83a8e569d"],
 " spans ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "d93476d2-af03-4c75-80df-d3071fdf22ad"],
 "  Let ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "52185b92-5d1b-41b7-b5de-cfaf1887db29"],
 " be a linearly independent subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "062b7829-88c0-4f77-b009-8024cdb51233"],
 " containing ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "cc957fd4-e138-453a-9046-931a84bd1736"],
 " vectors.  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[LessEqual]", "n"}], TraditionalForm]],
  FontColor->RGBColor[1, 0, 0],ExpressionUUID->
  "ae03e10b-a06a-48bb-b631-077c7937691e"],
 StyleBox[" and",
  FontColor->RGBColor[1, 0, 0]],
 " there is a subset ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "7c8d2d4a-7df4-4142-8cae-12638eaac067"],
 " of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "05d22856-de82-4b01-b7c8-c1c329323094"],
 " containing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "m"}], TraditionalForm]],ExpressionUUID->
  "ab6f0ad4-f2d4-4b90-912f-2668101816c6"],
 " vectors such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[Union]", "R"}], TraditionalForm]],ExpressionUUID->
  "e9980afb-42b1-4e2e-961f-31c6d8b99c5c"],
 " spans ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "2295619f-927a-4176-8f4a-522c1f79698f"],
 " "
}], "Text",
 CellChangeTimes->{{3.619351805243565*^9, 3.619351818509158*^9}, {
  3.6193518500202003`*^9, 3.6193519046526947`*^9}, {3.619351992935667*^9, 
  3.619352187471823*^9}, {3.6193522761893177`*^9, 3.619352279087253*^9}, {
  3.6195272031918573`*^9, 
  3.61952720580861*^9}},ExpressionUUID->"54ba1976-4181-4054-913f-\
9a6e3cb9728e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.619784453524646*^9, 3.619784453525646*^9}, {
  3.6197850130123434`*^9, 
  3.6197850173522406`*^9}},ExpressionUUID->"9b2bb280-e1ba-4c5a-97c7-\
1bbb2264b234"],

Cell[TextData[{
 "We will induct on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", 
    RowBox[{"number", " ", "of", " ", "vectors", " ", "in", " ", "L"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bdea01ab-b0c8-4306-b1ab-1a3f418e732d"],
 "."
}], "Text",
 CellChangeTimes->{{3.903793921596616*^9, 
  3.9037939418542905`*^9}},ExpressionUUID->"683946ee-9383-487b-8412-\
92832a1df01f"],

Cell[TextData[{
 "Inductive hypothesis: For any linearly independent set with ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "662f27df-c515-4e42-b7df-9fa74e95fbc6"],
 " elements contained in a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "db094466-5c9f-4f3a-a542-e561bc2a0396"],
 " for which there is a finite spanning set ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e629aa81-7b19-4541-8fc2-8db7a0833b82"],
 ", we see that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[LessEqual]", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "edc3fda3-3d4d-4a0a-9170-710a4aef6850"],
 " and there is a subset ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5a5fa90a-df3d-4a3d-95f3-e1f30757c583"],
 " of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d0754436-9b13-4621-bd5e-dc9087f292c8"],
 " containing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "m", " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "86dcb7da-89bb-4678-a980-e280fb317640"],
 " elements such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[Union]", "R"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0266b4c0-e327-4bd7-8f93-fcb3ff95a163"],
 " is a spanning set for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ae40fb30-7ea5-4cb3-9388-ee66c7e6bd8e"],
 "."
}], "Text",
 CellChangeTimes->{{3.903794030412886*^9, 3.903794136954704*^9}, {
  3.9037941683267746`*^9, 
  3.9037941702900763`*^9}},ExpressionUUID->"d7cb3219-1363-48db-96ea-\
adf218a77ce8"],

Cell[TextData[{
 "Base case: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "63131bef-fad7-4837-8c74-584c2c27cd4b"]
}], "Text",
 CellChangeTimes->{{3.903793971585765*^9, 3.903793971587764*^9}, {
  3.9037940030370646`*^9, 3.903794004900378*^9}, {3.9037942097816343`*^9, 
  3.903794233165236*^9}},ExpressionUUID->"025063d6-9c29-4c98-a344-\
3fdad75a868d"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "=", 
    RowBox[{
     RowBox[{"{", "}"}], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bd652a5e-9a0b-473d-9516-a262183e9a40"],
 "  The result follows trivially by setting ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"S", "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fbf7fd6b-6d85-4c6a-825b-0a3436fee215"]
}], "Text",
 CellChangeTimes->{{3.903793971585765*^9, 3.903793971587764*^9}, {
  3.9037940030370646`*^9, 3.903794004900378*^9}, {3.9037942097816343`*^9, 
  3.903794256005102*^9}},ExpressionUUID->"3d27f71c-3fdc-4c54-9f28-\
8acea92c3e8d"],

Cell[TextData[{
 "For a little more certainty, lets also establish the case ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b09dd19a-f849-423e-8298-d5693ba873a7"],
 ".  Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "=", 
    RowBox[{"{", 
     SubscriptBox["x", "1"], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f981f86-38bf-44fe-b318-2c0a22fafc3f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["u", "1"], ",", "...", ",", 
      SubscriptBox["u", "n"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c5e12163-8d65-4a97-8e5d-f9598352d3ab"]
}], "Text",
 CellChangeTimes->{{3.9037939717661753`*^9, 3.903793971768178*^9}, {
  3.9037944050544944`*^9, 3.9037944306318283`*^9}, {3.9037944662048283`*^9, 
  3.9037944969475746`*^9}},ExpressionUUID->"f7a81b64-94fa-4bba-9b8a-\
2ff33276453a"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0438f2f7-0b6c-4187-b27b-d8e8f7c11fb3"],
 " spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "563169e0-bda2-4245-8d98-a4ebb053bac2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[SubsetEqual]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "def9482c-7b38-4304-8ae6-d703c4f18b41"],
 " with one element, we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", 
    RowBox[{"1", "<=", "n"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c837847e-21d8-42a4-854f-5e2eb3181b0d"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.903794530835307*^9, 
  3.9037945711770363`*^9}},ExpressionUUID->"01730d06-779b-4053-8242-\
434981c938c5"],

Cell[TextData[{
 "Moveover, since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", " ", "spans", " ", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cb157a95-bf57-4871-b231-d157228e379a"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "1"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["u", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["u", "n"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "86b1d0bb-e20e-4f08-90a5-23a5b1691093"],
 " where at least one ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "j"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "acf72f73-b7ff-40b7-988a-9126f208b29b"],
 " is nonzero (since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "1"], "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cc326fad-9049-4833-abc8-da65347f5ffe"],
 " as it is part of a linearly independent set).   WLOG ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "514e7f2c-890c-4e03-ad09-5d775c90f4e2"],
 " is nonozero, hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "1"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["x", "1"], "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["a", "2"], 
           SubscriptBox["u", "2"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "n"], 
         SubscriptBox["u", "n"]}]}], ")"}]}], 
     SubscriptBox["a", "1"]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ddb89633-169e-4e97-967f-5b4cdbac58b5"],
 ".  Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["u", "2"], ",", "...", ",", 
      SubscriptBox["u", "n"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ee1cfa0f-2f70-4101-92d8-066ff15c6d0c"],
 ", a set with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ca2004be-5e37-4e57-af64-6e2f5d8e0e42"],
 " elements and notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[Union]", "R"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3ab93093-501c-448b-ab59-9d8665ccca66"],
 "  spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4494de6e-2d70-420e-8961-4438f6077464"],
 " since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "1"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b87479f2-31e3-4dc6-8ffe-2d03748e299e"],
 " is a linear combination of elements in this set and it also contains ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["u", "2"], ",", "...", ",", 
     SubscriptBox["u", "n"]}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1daae9eb-946b-4797-be67-03a5d3640eb1"],
 "."
}], "Text",
 CellChangeTimes->{{3.9037946328641167`*^9, 3.903794720760322*^9}, {
   3.903794754268114*^9, 3.903794928265006*^9}, 3.903794960925044*^9, 
   3.9037950191792173`*^9},ExpressionUUID->"2fd7807d-3206-4a24-b454-\
019e16dacea3"],

Cell["Inductive Step:", "Text",
 CellChangeTimes->{{3.9037939719622593`*^9, 3.903793971965407*^9}, {
   3.9037940113908362`*^9, 3.9037940204442863`*^9}, 
   3.903794951283064*^9},ExpressionUUID->"15e442e2-57ab-43df-88cd-\
8210c4bd040f"],

Cell[TextData[{
 "Assume IH is true for ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c6b3e70c-f4b1-460f-b864-7586946038ba"],
 ".  Let ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6f0f4a3d-128f-45bf-8ffb-d0adf5b501d4"],
 " be linearly independent set with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "+", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ef2da948-b300-435b-9286-5d14b7ef1f80"],
 " elements in a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3ce5cadd-525a-4701-b899-bc2f34c0ada0"],
 " with a finite spanning set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", ".", " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dc370c5c-c912-4d2d-a1b1-ff76e48cb068"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["x", "1"], ",", "...", ",", 
       SubscriptBox["x", "m"], ",", 
       SubscriptBox["x", 
        RowBox[{"m", "+", "1"}]]}], "}"}], ".", " "}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69b86f7d-cf2e-44d8-97ba-e4351e1d1e39"],
 "  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      RowBox[{"...", "."}], ",", " ", 
      SubscriptBox["x", "m"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "49f4266f-95e6-4486-a3d9-b8df4dcabfa6"],
 ".  The result is true for ",
 Cell[BoxData[
  FormBox["K", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5b923835-f2df-4d5d-8730-e36f897b2286"],
 ".  Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "<=", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cf04a575-ee69-4bf7-826b-2efe27c40828"],
 " and there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "\[SubsetEqual]", "S"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "14219332-59aa-4c5b-8b1d-6bcb4205d9a5"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "\[Union]", "Q"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "39e6af9e-7f11-44c8-83ac-2811fddaffd7"],
 " spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b7e0c282-4376-460b-96d3-fc3216aa9007"],
 "."
}], "Text",
 CellChangeTimes->{{3.9037955306391892`*^9, 
  3.90379576817715*^9}},ExpressionUUID->"24e4ecc2-9e60-45df-b772-\
d9ab240fea14"],

Cell[TextData[{
 "Notice:  We need ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"m", "+", "1"}], "\[LessEqual]", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b6c6e0fa-6ba9-44be-97f7-244e7374212e"],
 " and to put ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", 
    RowBox[{"m", "+", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2df558e0-283e-462a-91db-25734ed7037c"],
 " back into the  mix  ammending ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "\[Union]", 
    RowBox[{"Q", " ", "to", " ", "become", " ", "L"}], "\[Union]", "R"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a8d1c394-770b-4c8d-baf5-acf872252b8b"],
 ". "
}], "Text",
 CellChangeTimes->{{3.9037955306391892`*^9, 
  3.903795918368345*^9}},ExpressionUUID->"cdc459dd-2c75-4ce0-8347-\
d5e6881d94f7"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"K", "\[Union]", "Q"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "44916eb4-f0d5-4880-b739-84d59d29fef6"],
 " is a spanning set, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", 
     RowBox[{"m", "+", "1"}]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["a", "1"], 
          SubscriptBox["x", "1"]}], "+"}], "..."}], "+", 
       RowBox[{
        SubscriptBox["a", "m"], 
        SubscriptBox["x", "m"]}], "+", 
       RowBox[{
        SubscriptBox["b", "1"], 
        SubscriptBox["q", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["b", "k"], 
      SubscriptBox["q", "k"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f2c4bcc2-0659-4c2a-a0e8-67b5387029dd"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["q", "1"], ",", 
    RowBox[{
     RowBox[{"...", 
      SubscriptBox["q", "k"]}], "\[Element]", "Q", "\[SubsetEqual]", "S"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "41b04d4d-b9e7-458b-84c0-2dd6a478ac59"]
}], "Text",
 CellChangeTimes->{{3.9037959869859753`*^9, 
  3.9037960715831194`*^9}},ExpressionUUID->"bf26508f-82f4-4b88-aefa-\
8c02ffc646ad"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "04f3ed08-ad8a-4a83-872d-c0662d80c83c"],
 " is linearly independent, we know that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", 
    RowBox[{"m", "+", "1"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f799fdae-e0aa-4bb6-859c-e381ec1e327f"],
 " is NOT a linear combination of the other ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "j"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ac88fabe-9ed7-4e14-b015-04a41310600b"],
 "\[CloseCurlyQuote]s, so at least one of the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["b", "l"], "'"}], "s"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5369f390-4d89-47f0-bc8a-374166334b63"],
 " is nonzero.  First this tells us that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Q", "\[NotEqual]", 
     RowBox[{"{", "}"}]}], ","}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3698e94e-dd73-4d67-ba10-a71a07f09452"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "<", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1c5d6350-5904-448f-a7d1-1ab43b897615"],
 ". WLOG ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "1"], "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0258a92d-c5a1-4659-b95f-6a6b845e7fd6"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["q", "1"], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["x", 
       RowBox[{"m", "+", "1"}]], "-", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             SubscriptBox["a", "1"], 
             SubscriptBox["x", "1"]}], "+"}], "..."}], "+", 
          RowBox[{
           SubscriptBox["a", "m"], 
           SubscriptBox["x", "m"]}], "+", 
          RowBox[{
           SubscriptBox["b", "2"], 
           SubscriptBox["q", "2"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["b", "k"], 
         SubscriptBox["q", "k"]}]}], ")"}]}], 
     SubscriptBox["b", "1"]]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aab75130-b134-4f8f-9034-9abffb93aeb9"]
}], "Text",
 CellChangeTimes->{{3.903796114665052*^9, 
  3.9037963306153297`*^9}},ExpressionUUID->"cbd90d3e-88f8-48e0-ad72-\
d7393fd85ced"],

Cell[TextData[{
 "Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"Q", "-", 
     RowBox[{"{", 
      SubscriptBox["q", "1"], "}"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a301ceee-eba9-435f-859c-84014214115b"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[Union]", "R"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "60390c29-a3be-4f85-bf83-3738a321d060"],
 " is a spanning set for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9cfd7241-1827-49c3-9094-552cb2d7a34a"]
}], "Text",
 CellChangeTimes->{{3.9037963355274673`*^9, 3.903796350773965*^9}, {
  3.903796416882534*^9, 
  3.903796434476239*^9}},ExpressionUUID->"398e2929-f0b1-428c-a016-\
1cd35e450664"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Corollary: ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6193522937456126`*^9, 3.6193523484664035`*^9}, 
   3.6193529268926077`*^9, {3.619958746191124*^9, 3.619958746194127*^9}, 
   3.841152509511204*^9},ExpressionUUID->"6d73d8d3-56d6-4adb-a6d2-\
a0e08555e0d4"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f6d6fe02-f453-4880-8f76-9362860844de"],
 " be a vector space with a finite basis over a field \
\[DoubleStruckCapitalF].  Then every basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "14c72e91-5fdb-47a5-9668-7bb90e58862a"],
 " has the same number of elements."
}], "Text",
 CellChangeTimes->{{3.6193522937456126`*^9, 3.6193523484664035`*^9}, 
   3.6193529268926077`*^9, {3.619958746191124*^9, 
   3.619958746194127*^9}},ExpressionUUID->"01d2f75e-9f7c-4646-98f8-\
dee2daea0c14"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontFamily->"Times New Roman",
  FontWeight->"Plain",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6193522937456126`*^9, 3.6193523484664035`*^9}, 
   3.6193529268926077`*^9, {3.619958746191124*^9, 3.6199587463768897`*^9}, {
   3.619959106742134*^9, 3.6199592338839717`*^9}, 
   3.8411525119759855`*^9},ExpressionUUID->"f9a10b00-66e0-441b-ba85-\
3ac1c3ffc0ff"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f067cc4f-c91e-414d-be11-19ca73cfab32"],
 " and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4c87f47a-2e7c-43f3-88bd-300748683ffd"],
 " are two bases for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c7eaf7df-beef-4f68-8736-a595c191d428"],
 "."
}], "Text",
 CellChangeTimes->{{3.9037965785373807`*^9, 
  3.9037966038035183`*^9}},ExpressionUUID->"d28e0ca3-cec7-4b2c-a2a4-\
39d8b0d50b4f"],

Cell["\<\
Since \[Beta] is linearly independent and \[Gamma] is a spanning set, \[Beta] \
cannot have more elements than \[Gamma].\
\>", "Text",
 CellChangeTimes->{{3.9037965721385555`*^9, 3.9037965755939913`*^9}, {
  3.9037966273003173`*^9, 3.903796660944578*^9}, {3.903796692000662*^9, 
  3.9037966953098927`*^9}},ExpressionUUID->"6d8bc254-7bf1-4b6b-b278-\
9b197388dad3"],

Cell["\<\
Since \[Gamma] is linearly independent and \[Beta] is a spanning set, \
\[Gamma] cannot have more elements than \[Beta].\
\>", "Text",
 CellChangeTimes->{{3.9037966699371853`*^9, 
  3.9037966987919493`*^9}},ExpressionUUID->"ff9c8a7b-c705-4e26-a67e-\
a474c2ed43e1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition: ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6193523410374355`*^9, 3.6193525226062894`*^9}, {
   3.6199593681437626`*^9, 3.6199593681497717`*^9}, 
   3.841152869034235*^9},ExpressionUUID->"f77d482c-f449-492a-99fe-\
a9290b25da4e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "86435bf7-ecf7-49d6-86e7-672c5725f674"],
 " be a vector space over a field \[DoubleStruckCapitalF].  The vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "04f75e3d-6e9f-4efc-8baf-c5aab33b299a"],
 " is said to be ",
 StyleBox["finite dimensional",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " if it has a basis consisting of a finite number of vectors.  The unique \
number of vectors in a basis is called the ",
 StyleBox["dimension",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "021a2aec-773b-4493-8088-1513c57f815d"],
 " and is denoted by dim(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", ")"}], ".", " "}], TraditionalForm]],ExpressionUUID->
  "b7680f86-5cc3-4266-b840-a475fbbc01b0"],
 "  A  vector space that is not finite dimensional is called \
infinite-dimensional.  "
}], "Text",
 CellChangeTimes->{{3.6193523410374355`*^9, 3.6193525226062894`*^9}, {
  3.6199593681437626`*^9, 
  3.6199593681497717`*^9}},ExpressionUUID->"1cde73bb-7b40-4049-b6ad-\
7d43783bd8a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Two out of three ain\[CloseCurlyQuote]t Bad",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193523410374355`*^9, 3.6193525226062894`*^9}, {
  3.6199593681437626`*^9, 3.6199593681497717`*^9}, {3.841489893348731*^9, 
  3.8414899025044985`*^9}},ExpressionUUID->"95478262-15a7-425e-891a-\
b9fadf4b5394"],

Cell[TextData[ButtonBox["https://www.youtube.com/watch?v=k5hWWe-ts2s",
 BaseStyle->"Hyperlink",
 ButtonData->{
   URL["https://www.youtube.com/watch?v=k5hWWe-ts2s"], None},
 ButtonNote->"https://www.youtube.com/watch?v=k5hWWe-ts2s"]], "Text",
 CellChangeTimes->{{3.841317359657486*^9, 
  3.841317403909354*^9}},ExpressionUUID->"31627ef0-c3d3-4a75-a659-\
0db94356e002"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem (two out of three ain\[CloseCurlyQuote]t \
bad): ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
   3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
   3.6199597468419385`*^9}, 3.8411528716322393`*^9, {3.841417891911512*^9, 
   3.84141790139275*^9}, {3.8414896734387274`*^9, 3.8414896742727222`*^9}, {
   3.8721595021666107`*^9, 
   3.8721595207183075`*^9}},ExpressionUUID->"173a5a5a-95ad-4dc4-a179-\
0620b5a23aa2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "011c9680-b465-4a26-8159-f4424aa70684"],
 " be an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b8363107-adec-4590-9a5a-ec87c00203fc"],
 " dimensional vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "0970684f-6ad3-4af1-86e8-cd51ebc81488"],
 " be a subset of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "18caeb19-ebe8-4bdf-aa2e-52fa2c13311f"],
 "  Any ",
 StyleBox["two",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " of the following properties implies the third:"
}], "Text",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
   3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
   3.6199597468419385`*^9}, 
   3.8414178802431984`*^9},ExpressionUUID->"759e50b6-7c95-4e96-b7dd-\
c2f8bfbf9a3d"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "529e24ff-f819-4360-a07e-2caa5721bc01"],
 " spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7b47c1fe-e7ed-421e-b91c-e437dac01e70"],
 "."
}], "Text",
 CellChangeTimes->{{3.619959754321927*^9, 3.619959769886304*^9}, {
   3.6199598022829213`*^9, 3.6199598050888023`*^9}, 
   3.8414899390379877`*^9},ExpressionUUID->"31185318-3af0-4542-b7cb-\
44950ce11f3e"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "014bc618-053a-4333-9578-01729f44bef0"],
 " is linearly independent."
}], "Text",
 CellChangeTimes->{{3.619959754321927*^9, 3.619959780120134*^9}, 
   3.8414899427114024`*^9},ExpressionUUID->"53cf2b64-c460-45eb-9557-\
c9409775104d"],

Cell[TextData[{
 "(iii)  ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "beb18840-ebda-4709-bf40-954e99be5850"],
 " has ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "c7737095-79b8-45f3-9ebe-e18665a86f03"],
 " elements."
}], "Text",
 CellChangeTimes->{{3.619959786500396*^9, 3.619959799744236*^9}, 
   3.8414899478577757`*^9},ExpressionUUID->"1c578a36-e538-4c29-b268-\
896dbaa32017"]
}, Open  ]],

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
  3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
