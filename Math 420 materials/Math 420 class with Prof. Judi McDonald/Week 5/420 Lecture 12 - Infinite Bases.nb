  3.841490551801755*^9}},ExpressionUUID->"0252d39d-c4b8-4bc9-bdc5-\
2700b7d01e25"],

Cell[TextData[{
 "A collection of elements (subset of) in \[ScriptCapitalF] is called a ",
 StyleBox["chain",
  FontSlant->"Italic",
  FontColor->RGBColor[0, 0, 1]],
 " \[ScriptCapitalC], if for each ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ",", 
    RowBox[{"B", " ", "\[Element]", "\[ScriptCapitalC]"}], ","}], 
   TraditionalForm]],ExpressionUUID->"bdc7559d-8db8-4f37-8a4a-93281aa91ffd"],
 " either ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[SubsetEqual]", "B"}], TraditionalForm]],ExpressionUUID->
  "122aba44-de12-4884-8168-35a65a6cfb21"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "\[SubsetEqual]", 
    RowBox[{"A", "."}]}], TraditionalForm]],ExpressionUUID->
  "6dcfe59e-24f2-429b-b782-bfc0b5c9202e"]
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
  3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
  3.6195248999749575`*^9}, {3.6195250154712567`*^9, 3.6195250154792614`*^9}, {
