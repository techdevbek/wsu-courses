63d8a07072ae"],

Cell[TextData[{
 "Let \[ScriptCapitalC] be a chain in a poset \[ScriptCapitalF] .  An element \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", " ", "\[ScriptCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"0b603231-aeb1-4855-9f63-069de341ad14"],
 " is an ",
 StyleBox["upper bound",
  FontSlant->"Italic"],
 " for \[ScriptCapitalC] provided \[ForAll]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[Element]", "\[ScriptCapitalC]"}], ",", " "}], 
   TraditionalForm]],ExpressionUUID->"3d378da6-a402-4f06-9769-b95ef08634a5"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[SubsetEqual]", 
    RowBox[{"U", ".", "  "}]}], TraditionalForm]],ExpressionUUID->
  "55876a1a-8508-4bff-8ca3-31ce9756fc5a"]
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
  3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
  3.6195248999749575`*^9}, {3.6195250154712567`*^9, 3.619525190527417*^9}, {
  3.6195254297958403`*^9, 3.61952543525447*^9}, {3.6195255036058583`*^9, 
  3.619525534526002*^9}, {3.6195258757961097`*^9, 3.6195258795636225`*^9}, {
  3.620132273449484*^9, 3.620132274234129*^9}, {3.620132775239579*^9, 
  3.620132797149106*^9}, {3.8414906263351555`*^9, 
  3.8414906505863256`*^9}},ExpressionUUID->"a9cde122-f69c-4cd5-bac8-\
b49a791b5691"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE:  ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6195252352460885`*^9, 3.619525323610387*^9}, 
   3.6195253739536314`*^9, {3.6195254099917107`*^9, 3.6195254168492584`*^9}, {
   3.62012987681186*^9, 3.6201298768128605`*^9}, {3.6201301730174627`*^9, 
   3.6201302329253993`*^9}, {3.620132657842806*^9, 3.6201326596586685`*^9}, 
   3.841490673582374*^9},ExpressionUUID->"510e0aed-cbfb-4f5c-83eb-\
4de42a64ed04"],

Cell[TextData[{
 "The set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}], TraditionalForm]],
  ExpressionUUID->"875d1379-6eb7-4a7c-a164-13ab04d70870"],
 " is an upper bound for the chain ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", "b"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}]}], "}"}], "."}]}], 
   TraditionalForm]],ExpressionUUID->"4e76e578-d010-4bf4-a5da-71c6c5a6954a"]
}], "Text",
 CellChangeTimes->{{3.6195252352460885`*^9, 3.619525323610387*^9}, 
   3.6195253739536314`*^9, {3.6195254099917107`*^9, 3.6195254168492584`*^9}, {
   3.62012987681186*^9, 3.6201298768128605`*^9}, {3.6201301730174627`*^9, 
   3.6201302329253993`*^9}, {3.620132657842806*^9, 3.6201326596586685`*^9}, {
   3.841759998290733*^9, 
   3.8417600278855295`*^9}},ExpressionUUID->"4ebc8b36-9630-407f-9a89-\
024bcadb50f9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Zorn's Lemma (Also attributed to Hausdorff): ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.6195252352460885`*^9, 3.619525323610387*^9}, 
   3.6195253739536314`*^9, {3.6195254099917107`*^9, 3.6195254168492584`*^9}, {
   3.62012987681186*^9, 3.620129877202118*^9}, {3.6201326184826784`*^9, 
   3.6201326197255077`*^9}, 3.6201329840509777`*^9, 3.841749425891381*^9, {
   3.8417600722864437`*^9, 
   3.8417600837155685`*^9}},ExpressionUUID->"d1707266-4d06-432c-aea7-\
e8738750b812"],

Cell["\<\
 Let \[ScriptCapitalF] be a partially order set.  If every chain in \
\[ScriptCapitalF] has an upper bound, then \[ScriptCapitalF] contains a \
maximal element.  \
\>", "Text",
 CellChangeTimes->{{3.6195252352460885`*^9, 3.619525323610387*^9}, 
   3.6195253739536314`*^9, {3.6195254099917107`*^9, 3.6195254168492584`*^9}, {
   3.62012987681186*^9, 3.620129877202118*^9}, {3.6201326184826784`*^9, 
   3.6201326197255077`*^9}, 
   3.6201329840509777`*^9},ExpressionUUID->"3da1c041-8938-40dd-b134-\
80cd7ecc3e20"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"b548d8a3-906f-4459-857d-40b60dec02c2"],

Cell[TextData[{
 "In the linear algebra context,  \[ScriptCapitalF] will be sets of linearly \
independent subsets of a vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ","}], TraditionalForm]],ExpressionUUID->
  "ba6a09a9-a42c-4976-b91c-16637bd924fd"],
 " and the relation \[SubsetEqual] will be actually be the subset relation.  \
Zorn\[CloseCurlyQuote]s lemma is equivalent to the Axiom of Choice."
}], "Text",
 CellChangeTimes->{{3.6201302769454994`*^9, 3.620130324415145*^9}, {
   3.620130649840949*^9, 3.6201307002695684`*^9}, {3.6201329260034695`*^9, 
   3.62013293229066*^9}, 3.841684873095475*^9, {3.8416849309282813`*^9, 
   3.8416849337137833`*^9}, {3.8417601332144485`*^9, 
   3.841760145538286*^9}},ExpressionUUID->"0db70170-ca9e-43cb-9f05-\
063a224bccaa"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.620130598374591*^9}, {
   3.6201331067776365`*^9, 3.6201331067796383`*^9}, 
   3.8416849426508675`*^9},ExpressionUUID->"13029ea5-6035-41b4-a8f1-\
0decddaebec6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "25408365-ff83-417b-b13c-a40b645632fa"],
 " be a vector space over a field \[DoubleStruckCapitalF].  If \[Beta] is a \
maximal linearly independent subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "29eacf70-5ae0-4d1e-a70f-510c71b1c498"],
 ", then \[Beta] is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "e1a8aa07-a5f7-41e1-bf53-0b7f76700bce"]
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.620130598374591*^9}, {
   3.6201331067776365`*^9, 3.6201331067796383`*^9}, 
   3.841684950118368*^9},ExpressionUUID->"0b3ba16f-4245-4907-9b79-\
55ffa619c51e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF: ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.620130598374591*^9}, {
  3.6201331067776365`*^9, 3.620133106965768*^9}, {3.620133147921833*^9, 
  3.6201331534485188`*^9}},ExpressionUUID->"55106e47-3c78-427e-919c-\
57ce202a6eeb"],

Cell[TextData[{
 "Assume \[Beta] is a maximal linearly independent subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bb9d9b77-7da5-4930-a1c9-1c6b13a8edeb"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ca13ce1c-5774-4f2e-8078-3dadc91167ba"],
 ".  If ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "63197272-d8bb-4fee-8fad-013e823464be"],
 " cannot be written as a finite linear combination of elements in \[Beta], \
then we could take ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "\[Union]", 
    RowBox[{"{", "v", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d9d1ac7c-fa9e-4bef-bd39-c8bea7eb6043"],
 " and get a linearly independent set that properly contains \[Beta] and \
hence show that \[Beta] is not a maximal linearly independent set, \
contradicting our assumptions.  "
}], "Text",
 CellChangeTimes->{{3.904055936690283*^9, 
  3.90405605794133*^9}},ExpressionUUID->"812169a5-4c87-48bd-85df-\
31744ebe8c0d"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
