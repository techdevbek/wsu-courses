374b1abe0574"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"e8372a43-b3a3-4008-8f72-5e199132fc02"],
 " is an example of a chain from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "."}], TraditionalForm]],ExpressionUUID->
  "25c75b88-5f30-479c-81fd-174768c9188d"]
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
