 BaseStyle->"Hyperlink",
 ButtonData->{
   URL["https://www.youtube.com/watch?v=k5hWWe-ts2s"], None},
 ButtonNote->"https://www.youtube.com/watch?v=k5hWWe-ts2s"]], "Text",
 CellChangeTimes->{{3.841317359657486*^9, 
  3.841317403909354*^9}},ExpressionUUID->"31627ef0-c3d3-4a75-a659-\
0db94356e002"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem (two out of three ain\[CloseCurlyQuote]t \
bad): ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
   3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
   3.6199597468419385`*^9}, 3.8411528716322393`*^9, {3.841417891911512*^9, 
   3.84141790139275*^9}, {3.8414896734387274`*^9, 3.8414896742727222`*^9}, {
   3.8721595021666107`*^9, 
   3.8721595207183075`*^9}},ExpressionUUID->"173a5a5a-95ad-4dc4-a179-\
0620b5a23aa2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "011c9680-b465-4a26-8159-f4424aa70684"],
 " be an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b8363107-adec-4590-9a5a-ec87c00203fc"],
 " dimensional vector space over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "0970684f-6ad3-4af1-86e8-cd51ebc81488"],
 " be a subset of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "18caeb19-ebe8-4bdf-aa2e-52fa2c13311f"],
 "  Any ",
 StyleBox["two",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " of the following properties implies the third:"
}], "Text",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
   3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
   3.6199597468419385`*^9}, 
   3.8414178802431984`*^9},ExpressionUUID->"759e50b6-7c95-4e96-b7dd-\
c2f8bfbf9a3d"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "529e24ff-f819-4360-a07e-2caa5721bc01"],
 " spans ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7b47c1fe-e7ed-421e-b91c-e437dac01e70"],
 "."
}], "Text",
 CellChangeTimes->{{3.619959754321927*^9, 3.619959769886304*^9}, {
   3.6199598022829213`*^9, 3.6199598050888023`*^9}, 
   3.8414899390379877`*^9},ExpressionUUID->"31185318-3af0-4542-b7cb-\
44950ce11f3e"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "014bc618-053a-4333-9578-01729f44bef0"],
 " is linearly independent."
}], "Text",
 CellChangeTimes->{{3.619959754321927*^9, 3.619959780120134*^9}, 
   3.8414899427114024`*^9},ExpressionUUID->"53cf2b64-c460-45eb-9557-\
c9409775104d"],

Cell[TextData[{
 "(iii)  ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "beb18840-ebda-4709-bf40-954e99be5850"],
 " has ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "c7737095-79b8-45f3-9ebe-e18665a86f03"],
 " elements."
}], "Text",
 CellChangeTimes->{{3.619959786500396*^9, 3.619959799744236*^9}, 
   3.8414899478577757`*^9},ExpressionUUID->"1c578a36-e538-4c29-b268-\
896dbaa32017"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193529461794896`*^9, 3.6193529886308546`*^9}, {
  3.6197853875235667`*^9, 3.6197854135940065`*^9}, {3.6199596913223906`*^9, 
  3.6199596915825667`*^9}, {3.61995980847906*^9, 
  3.619959809888005*^9}},ExpressionUUID->"644a49ef-8df7-4e50-8497-\
240cea35345f"],

Cell[TextData[{
 "(i) and (ii) \[DoubleLongRightArrow](iii): A linearly independent spanning \
set is a basis, and all bases have the same number elements denoted as the \
dimension, so there must be ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "89e41334-1ff0-484d-a6f5-609784b49546"],
 " elements in the set.  "
}], "Text",
 CellChangeTimes->{{3.904053125725254*^9, 3.904053137848563*^9}, {
  3.904053199122489*^9, 
  3.9040532672875175`*^9}},ExpressionUUID->"3ce2e662-a3d6-4e2a-9af8-\
45870efee378"],

Cell[TextData[{
 "(i) and (iii) \[DoubleLongRightArrow](ii): If ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aaa162e8-0600-4b15-ae65-7fc1ca38eca2"],
 " is a spanning set with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6dca353f-792f-4cd2-901b-8fbef0c194f8"],
 " elements, we know that ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "19c6aa67-b162-4f87-825f-244a928c236f"],
 " contains a basis.  However, if we need to remove 1 or more vectors, our \
set will be too small to basis, thus it is already linearly independent."
}], "Text",
 CellChangeTimes->{{3.9040531451348667`*^9, 3.904053161877474*^9}, {
  3.904053384357254*^9, 
  3.9040535579824405`*^9}},ExpressionUUID->"4d517f00-2c82-4ffd-9888-\
5fa56f1df63a"],

Cell[TextData[{
 "(ii) and (iii) \[DoubleLongRightArrow](i): If ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7a5fd18e-93ad-4773-bbcd-2c3a739deb45"],
 " is a linearly independent set with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "70e15f1b-48a8-47fd-9de5-f3fd089cdff7"],
 " elements, we know we can extend ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a258a955-f22c-4116-9c6f-d81180166ee2"],
 " to a basis, possibly by adding elements.  If need to add elements to get a \
basis, we\[CloseCurlyQuote]ll have too many elements, thus ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "67b45825-84c7-4faa-a5f6-b9f778c98353"],
 " must already have been a basis and hence a spanning set for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "603fa057-8848-4677-90e6-4584c9a92e29"],
 "."
}], "Text",
 CellChangeTimes->{{3.9040531451348667`*^9, 3.90405317456497*^9}, {
  3.9040534726896625`*^9, 
  3.904053483425838*^9}},ExpressionUUID->"f2263cdb-90cc-4f59-8764-\
567ec947e8a0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem: ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.619957653632929*^9, 3.6199577466234455`*^9}, {
   3.6199577911267204`*^9, 3.619957795772828*^9}, {3.619960332613911*^9, 
   3.6199603745073714`*^9}, 
   3.8411528974494915`*^9},ExpressionUUID->"92dae0e9-aefd-4c5a-82f5-\
c992ee7ff97e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "653b53ac-2cc4-423f-bd8c-7ac73c13dce8"],
 " be a finite dimensional vector space over a field \[DoubleStruckCapitalF]. \
If ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "73acc0a4-abaa-494e-a2fe-a7ab4039bcda"],
 " is a subspace of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ","}], TraditionalForm]],ExpressionUUID->
  "907fcb23-d36a-4b98-8b49-28e9bf5a1066"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "W", ")"}]}], "<=", 
    RowBox[{"dim", 
     RowBox[{"(", "V", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1d4f2eb8-01c1-4501-9cab-e793b8a53460"],
 ".  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "W", ")"}]}], " ", "=", " ", 
    RowBox[{"dim", " ", 
     RowBox[{"(", "V", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8bd2ee66-3828-44f3-90e2-5c6f5e7c6197"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"V", "."}]}], TraditionalForm]],ExpressionUUID->
  "dd826fd8-6fa6-4a0c-8fa6-5c46523c3513"]
}], "Text",
 CellChangeTimes->{{3.619957653632929*^9, 3.6199577466234455`*^9}, {
   3.6199577911267204`*^9, 3.619957795772828*^9}, {3.619960332613911*^9, 
   3.6199603745073714`*^9}, {3.8721595626389637`*^9, 3.8721595764497795`*^9}, 
   3.872593675569706*^9},ExpressionUUID->"d1384f94-5251-486e-aadf-\
d1d160bc1e0a"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.619957653632929*^9, 3.6199577466234455`*^9}, {
  3.6199577911267204`*^9, 3.619957795772828*^9}, {3.619960332613911*^9, 
  3.619960332789604*^9}, {3.619960670922925*^9, 
  3.6199606768098464`*^9}},ExpressionUUID->"e850763f-9684-4d1b-abc0-\
e5acb492eb71"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "68cb4a36-66c2-4e5e-9bff-dea8ed4078ec"],
 " be a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a02e127e-c2cc-4cdc-a86a-77ad766c59c3"],
 ".  Then \[Beta] is a linearly independent subset of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "722b8cba-13e3-4fa2-a3f2-fae075bc8996"],
 ", so it can be extended to a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "29787067-f1d0-4aac-820b-d0c10ffd8b2e"],
 ".  Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "W", ")"}]}], "<=", 
    RowBox[{"dim", 
     RowBox[{"(", "V", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8f474c69-6244-4dad-80e3-0b2e274c746a"],
 ".  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "W", ")"}]}], " ", "=", " ", 
    RowBox[{"dim", " ", 
     RowBox[{"(", "V", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b2e6e86c-5358-4948-acf3-4c6ab1e105a4"],
 ", then \[Beta] is a linearly independent set with the right number of \
elements to be a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d96587bb-6c02-4c05-bf06-739db3dbecd0"],
 ", and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", " ", "\[Beta]"}], "=", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "035e1d29-451e-4587-b382-2829f3e7382b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"span", " ", "\[Beta]"}], "=", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e4c8de52-0ce3-4925-8a08-bfd53c87c23d"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"V", "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7cd3fabd-fc3c-4ef0-95ed-c0864824c970"]
}], "Text",
 CellChangeTimes->{{3.9040539209317427`*^9, 
  3.9040540567559595`*^9}},ExpressionUUID->"4c45bb8e-9e94-4fc8-9b57-\
959a62b2f63d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.619957653632929*^9, 3.6199577466234455`*^9}, {
  3.6199577911267204`*^9, 3.619957795772828*^9}, {3.619960332613911*^9, 
  3.619960332789604*^9}, {3.619960670922925*^9, 3.6199606768098464`*^9}, {
  3.8725894019834757`*^9, 
  3.87258941272692*^9}},ExpressionUUID->"f839f333-94ae-4dba-a661-\
764436d4e9ec"],

Cell[TextData[{
 "Consider ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "\[NoBreak]", GridBox[{
          {"a"},
          {"b"},
          {"a"}
         }], "\[NoBreak]", ")"}], "|", "a"}], ",", 
      RowBox[{"b", " ", "\[Element]", " ", "\[DoubleStruckCapitalR]"}]}], 
     "}"}]}], TraditionalForm]],ExpressionUUID->
  "25eba092-d91f-4eb3-b213-116d1dd347ff"],
 ", a subspace of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"93da27a3-cbb6-4f03-be9a-5306b552b48a"],
 ". A basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "a1f40eba-7d83-4bd5-ace5-ae054b52d399"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"0"},
         {"1"}
        }], "\[NoBreak]", ")"}], ",", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", ")"}]}], "}"}], "  "}], TraditionalForm]],
  ExpressionUUID->"0ce05207-529f-43e2-b699-72603510a646"]
}], "Text",
 CellChangeTimes->{{3.619960735445861*^9, 3.619960865765691*^9}, 
   3.8413174446492934`*^9, {3.8415011348638115`*^9, 
   3.8415012653392515`*^9}},ExpressionUUID->"59aed21b-8603-4859-8dbf-\
3b2ac7ce228b"],

Cell[TextData[{
 "The standard basis for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"10c44e01-9d59-4c6e-a1f7-c43dbbac0187"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"1"},
        {"0"},
        {"0"}
       }], "\[NoBreak]", ")"}], ",", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"0"},
        {"1"},
        {"0"}
       }], "\[NoBreak]", ")"}], " ", ",", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"0"},
        {"0"},
        {"1"}
       }], "\[NoBreak]", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "05db9c25-a6a9-4e5f-8c42-10ee632103b4"],
 "."
}], "Text",
 CellChangeTimes->{{3.841501271087533*^9, 
  3.84150133082419*^9}},ExpressionUUID->"0267d3e8-3620-4b8a-b250-\
19a36a36bacc"],

Cell[TextData[{
 "Can we remove a vector from the basis for ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"60c7f647-b3a7-4745-8c80-873cb7e15787"],
 " to get a basis for ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "dbb9d8c5-959f-4772-a554-460e9ac823a8"],
 "?  No.  Any two will leave us with a row that is always zero when we take \
the span of these two vectors.  "
}], "Text",
 CellChangeTimes->{{3.841501980079479*^9, 3.841502046757718*^9}, {
  3.872589431051401*^9, 3.872589461921596*^9}, {3.8725941751142387`*^9, 
  3.872594176162037*^9}, {3.904054239894844*^9, 
  3.9040542658901405`*^9}},ExpressionUUID->"5615c863-b9f2-4c5a-9082-\
11eb70f3c698"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Corollary: ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 " "
}], "Subsubsubsection",
 CellChangeTimes->{{3.619957824341483*^9, 3.6199578708204994`*^9}, 
   3.841152908788699*^9, {3.841502123518928*^9, 
   3.8415021282758875`*^9}},ExpressionUUID->"330219a0-7b1d-4c2f-a0b2-\
f5a57ec762b0"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "bda1700e-2c90-4e4c-81b6-eadae47c3ee2"],
 " be a finite dimensional vector space over a field \[DoubleStruckCapitalF]. \
If \[Beta] is a basis for a subspace ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "360822d3-cd78-45ef-9ee5-a5e435cddff0"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ","}], TraditionalForm]],ExpressionUUID->
  "edd217a5-a66e-48c3-aada-616be110ba02"],
 " then \[Beta] can be extended to a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "2ea47034-ac30-4145-9016-1eb91df54e0f"],
 " "
}], "Text",
 CellChangeTimes->{{3.619957824341483*^9, 
  3.6199578708204994`*^9}},ExpressionUUID->"546c2c63-acac-4968-b983-\
e696856ac707"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["1.7 Maximal Linearly Independent Sets",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
  3.841490200807414*^9, 
  3.8414902175646925`*^9}},ExpressionUUID->"79a50019-a637-4685-a147-\
1178362d6139"],

Cell[TextData[{
 "Today\[CloseCurlyQuote]s lecture relies the ",
 StyleBox["Axiom of Choice",
  FontSlant->"Italic"],
 ":"
}], "Text",
 CellChangeTimes->{{3.872589599705939*^9, 
  3.8725896052126837`*^9}},ExpressionUUID->"9fb41373-59d3-48e2-9cb7-\
9175d702798d"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["The Axiom of Choice:", "Subsubsubsection",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0.5, 0.5]],
 StyleBox[" ", "Subsubsubsection"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, {3.619525571118126*^9, 3.61952557112213*^9}, 
   3.8417492456856976`*^9, 3.841749471707713*^9, {3.841749505908329*^9, 
   3.8417495122597103`*^9}},ExpressionUUID->"a96c0483-d178-4b4e-a65d-\
e2f2aec15d4f"],

Cell["\<\
Given a (possibly infinite) collection of sets, you can choose one element \
from each set, and make a new set.  \
\>", "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, {3.619525571118126*^9, 3.61952557112213*^9}, 
   3.8417492456856976`*^9, 3.841749473386135*^9, {3.8725895765158677`*^9, 
   3.8725895805069885`*^9}, {3.8725945664629507`*^9, 
   3.8725945696782284`*^9}},ExpressionUUID->"13322e39-d7c7-46c0-b979-\
af5c2668f9cd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"af36af45-8480-4938-b975-5a678a11b7c7"],

Cell["\<\
It tends to be very useful a in Abstract Algebra, but is somewhat \
controversial for analytical techniques because you can use it to create sets \
with no measure and duplicate a sphere (the Banach-Tarski Paradox).  \
\>", "Text",
 CellChangeTimes->{{3.6195252352460885`*^9, 3.6195252578741064`*^9}, {
  3.619525335394207*^9, 3.61952535492317*^9}, {3.619525890773802*^9, 
  3.6195258925799956`*^9}, {3.8416848291595573`*^9, 3.8416849148086104`*^9}, {
  3.841748995427766*^9, 
  3.841749200146013*^9}},ExpressionUUID->"a6d454b7-b2e6-4e8f-88d1-\
a768d0b86e40"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 "  "
}], "Subsubsubsection",
 CellChangeTimes->{{3.61952558912508*^9, 3.6195256201006365`*^9}, {
   3.619525656836276*^9, 3.61952566765946*^9}, {3.619525728225751*^9, 
   3.619525824353547*^9}, 
   3.8414903133637795`*^9},ExpressionUUID->"3d985c5f-8d21-42eb-b1f2-\
9a985a203bfd"],

Cell[TextData[{
 "A ",
 StyleBox["partially ordered set (poset)",
  FontColor->GrayLevel[0]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 "is a set \[ScriptCapitalF] together with a relation ",
 Cell[BoxData[
  FormBox["\[SubsetEqual]", TraditionalForm]],ExpressionUUID->
  "999e839a-62ef-4486-95f7-96446f702a07"],
 " that is reflexive, antisymmetric, and transitive.   "
}], "Text",
 CellChangeTimes->{{3.61952558912508*^9, 3.6195256201006365`*^9}, {
  3.619525656836276*^9, 3.61952566765946*^9}, {3.619525728225751*^9, 
  3.619525824353547*^9}},ExpressionUUID->"3eb52f38-c4a4-45d6-95e7-\
3097d33636a8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE: ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, 3.619525571118126*^9, {3.619525805924304*^9, 
   3.619525812224489*^9}, {3.619961874516096*^9, 3.6199618745651317`*^9}, {
   3.6199619838465347`*^9, 3.619962086174114*^9}, {3.6201300030882535`*^9, 
   3.6201300235068693`*^9}, 3.620132035048529*^9, 
   3.841490344177127*^9},ExpressionUUID->"33dcfd85-3ea9-4ebb-984c-\
1d9f21c8755a"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "b"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "d"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"a", ",", "b", ",", "d", ",", "e"}], "}"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"dd27b3a1-a873-4aa7-95b4-4726e64b6cc8"],
 ".   Let the relation on ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "dfc2ec0c-f436-484a-a226-812228d4ea9d"],
 " be the usual subset relation.  "
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, 3.619525571118126*^9, {3.619525805924304*^9, 
   3.619525812224489*^9}, {3.619961874516096*^9, 3.6199618745651317`*^9}, {
   3.6199619838465347`*^9, 3.619962086174114*^9}, {3.6201300030882535`*^9, 
   3.6201300235068693`*^9}, 3.620132035048529*^9, {3.8414903745007915`*^9, 
   3.841490382189866*^9}, {3.8416851133319397`*^9, 3.8416852268969803`*^9}, {
   3.8416853699957366`*^9, 3.841685515592769*^9}, {3.8416855632643003`*^9, 
   3.841685567306389*^9}, {3.8416856394338083`*^9, 3.8416857546259856`*^9}, 
   3.841685850581268*^9},ExpressionUUID->"a2fc61db-1393-457a-be24-\
ad8ad8aa5a6a"],

Cell[TextData[{
 "So, for example ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}], "\[SubsetEqual]", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"e099f7e1-6b99-4e5a-bf93-1f8230b977f3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}], "\[SubsetEqual]", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "d"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"002d8fb8-4983-4846-9359-4bcaeac5489e"],
 ", but ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "c"}], "}"}], TraditionalForm]],
  ExpressionUUID->"eac7accf-a4ab-4b2a-8937-c22c6a6d5991"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "d"}], "}"}], TraditionalForm]],
  ExpressionUUID->"2700683a-3c2a-4ed5-9797-58838bb19447"],
 " are not comparable.   "
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, 3.619525571118126*^9, {3.619525805924304*^9, 
   3.619525812224489*^9}, {3.619961874516096*^9, 3.6199618745651317`*^9}, {
   3.6199619838465347`*^9, 3.619962086174114*^9}, {3.6201300030882535`*^9, 
   3.6201300235068693`*^9}, 3.620132035048529*^9, {3.841490386022275*^9, 
   3.8414903876895704`*^9}, {3.8416852319346952`*^9, 3.84168526229166*^9}, {
   3.84168547108424*^9, 3.84168548425422*^9}, {3.84168551952944*^9, 
   3.8416855264117675`*^9}, {3.841685771895541*^9, 
   3.841685839389602*^9}},ExpressionUUID->"4394cfc3-d247-440d-be64-\
b0a4811ad89b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition:", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, 3.619525571118126*^9, {3.619525805924304*^9, 
   3.619525812224489*^9}, {3.619961874516096*^9, 3.619961876023101*^9}, {
   3.6201294629727354`*^9, 3.6201294629797373`*^9}, {3.6201320519147687`*^9, 
   3.6201320527734685`*^9}, 
   3.841490397302782*^9},ExpressionUUID->"d5896c8c-385b-4333-a8b8-\
ad5bc3e5ca63"],

Cell[TextData[{
 "Let \[ScriptCapitalF] be a poset.  An element ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[Element]", "\[ScriptCapitalF]"}], TraditionalForm]],
  ExpressionUUID->"abf4197e-a88b-4119-b6db-df62c5d95e7a"],
 " is said to be ",
 StyleBox["maximal",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 "in \[ScriptCapitalF] if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[SubsetEqual]", "N", "\[Element]", "\[ScriptCapitalF]"}], 
   TraditionalForm]],ExpressionUUID->"65954a81-3de5-443e-895f-6db74d298250"],
 "implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", "N"}], TraditionalForm]],ExpressionUUID->
  "c337f43f-2acb-4afe-8e6e-c12f15f2ec27"],
 "."
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, 3.619525571118126*^9, {3.619525805924304*^9, 
   3.619525812224489*^9}, {3.619961874516096*^9, 3.619961876023101*^9}, {
   3.6201294629727354`*^9, 3.6201294629797373`*^9}, {3.6201320519147687`*^9, 
   3.6201320527734685`*^9}, {3.841490398985371*^9, 
   3.8414904384004707`*^9}},ExpressionUUID->"d6e8bbe4-1158-4158-8ac0-\
aea9ac3bb26d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248999749575`*^9}, {3.6195250154712567`*^9, 
   3.6195250154792614`*^9}, {3.6201292423916826`*^9, 
   3.6201292423936844`*^9}, {3.6201293971105785`*^9, 
   3.6201294548493185`*^9}, {3.6201294949950824`*^9, 
   3.6201295612139287`*^9}, {3.6201297677165623`*^9, 3.620129840329999*^9}, {
   3.6201298870697083`*^9, 3.620129918539632*^9}, {3.6201300517086744`*^9, 
   3.620130072765705*^9}, {3.620130102952752*^9, 3.6201301194247336`*^9}, 
   3.84149044379768*^9},ExpressionUUID->"ae27e7ea-94c2-46d7-99af-\
a1d8ea11c9c6"],

Cell[TextData[{
 "Working with the example above, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b"}], "}"}], TraditionalForm]],ExpressionUUID->
  "13ef49d5-27bd-4f2e-8692-fc948846b5ca"],
 " is not maximal since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b"}], "}"}], "\[SubsetEqual]", 
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"2e4321e5-9caa-4831-942d-e92b830f841d"],
 ", however ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "c", ",", "d"}], "}"}], TraditionalForm]],
  ExpressionUUID->"9b5191aa-f19d-49e4-9ef4-363140cf8038"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"a", ",", "b", ",", "d", ",", "e"}], "}"}], TraditionalForm]],
  ExpressionUUID->"7743cc6d-3cf7-4a8c-b584-29b41162bf35"],
 " are both maximal in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "."}], TraditionalForm]],ExpressionUUID->
  "6106a56d-ea65-43cb-a107-9f415309e771"]
}], "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248999749575`*^9}, {3.6195250154712567`*^9, 
   3.6195250154792614`*^9}, {3.6201292423916826`*^9, 
   3.6201292423936844`*^9}, {3.6201293971105785`*^9, 
   3.6201294548493185`*^9}, {3.6201294949950824`*^9, 
   3.6201295612139287`*^9}, {3.6201297677165623`*^9, 3.620129840329999*^9}, {
   3.6201298870697083`*^9, 3.620129918539632*^9}, {3.6201300517086744`*^9, 
   3.620130072765705*^9}, {3.620130102952752*^9, 3.6201301194247336`*^9}, {
   3.841490473525424*^9, 3.8414905045775347`*^9}, 3.841685362946772*^9, {
   3.8417596428996105`*^9, 
   3.841759721046008*^9}},ExpressionUUID->"cea691cf-73d9-4a29-a6d4-\
dc0d15116079"]
}, Closed]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.9040550379957595`*^9, 
  3.9040550541685157`*^9}},ExpressionUUID->"d60c35fb-a444-4351-980d-\
95cbfbede472"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "=", 
    RowBox[{"S", "\[Union]", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"c", ",", "e"}], "}"}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"2d923cfd-d31d-413b-be80-154ca6d1bab0"],
 ".  Is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"c", ",", "e"}], "}"}], " "}], TraditionalForm]],ExpressionUUID->
  "89758206-8486-478f-a452-92c08af8cb85"],
 "maximal in ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "04fd079b-86a4-4b8a-80b2-e7c998948f71"],
 "? Yes. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"c", ",", "e"}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "253886ef-2d38-4858-aaf0-b75ef3b49c69"],
 " is not contained in any of the sets listed in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a5ab7b5a-c921-4159-a596-001b6fb69974"],
 "."
}], "Text",
 CellChangeTimes->{{3.8417597789460993`*^9, 3.8417598256403894`*^9}, 
   3.904055133974599*^9, {3.9040551723240213`*^9, 
   3.904055203116469*^9}},ExpressionUUID->"ca6b2f4e-4bac-456c-8064-\
e97f219dd2d4"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition :  ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
