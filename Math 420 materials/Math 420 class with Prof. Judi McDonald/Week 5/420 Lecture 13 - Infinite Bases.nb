Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, 3.872589995169072*^9, {
   3.8725900938365297`*^9, 
   3.872590136206272*^9}},ExpressionUUID->"6407f8b6-8904-4cc1-99ab-\
cd39e78983eb"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalC]", TraditionalForm]],ExpressionUUID->
  "f263bf15-83ad-491d-8b33-34b406bfa8b9"],
 " be a chain of linearly independent subsets, where each subset contains ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "."}], TraditionalForm]],ExpressionUUID->
  "9c4e917e-e2bd-4084-b896-c814b576120b"],
 "  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", "U"}], TraditionalForm]],ExpressionUUID->
  "cd17b4dd-4f46-4632-97e7-6e9f17971fff"],
 " be the union of the sets in the chain ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "."}], TraditionalForm]],ExpressionUUID->
  "c3c27ab8-9939-487f-a003-4eaafacff105"],
 "  So ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "f6133c43-9801-484b-a57c-a24dfbfd9869"],
 " is an upper bound with respect to subset inclusion, however we need to \
show it is linearly independent. "
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, 3.872589995169072*^9, {
   3.8725900938365297`*^9, 
   3.87259013805851*^9}},ExpressionUUID->"b796cb51-8b25-4300-8069-\
853a4da421f6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"0f0b70bf-baee-4627-ad54-0274a7c023b5"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "0e00c6b0-705d-48d2-b7ff-63306f15e8a8"],
 " is linearly dependent.  Then there are vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", " ", "...", ",", 
    RowBox[{
     SubscriptBox["v", "n"], "\[Element]", "U"}]}], TraditionalForm]],
  ExpressionUUID->"5f579e7d-04f9-4687-82a2-7355e77ba3df"],
 " and nonzero scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    RowBox[{"...", 
     SubscriptBox["a", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "f1639831-a1d2-40fe-bef6-60fffe78855d"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"a4e5c8fe-0c44-425d-83b3-e64f2cdcc212"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, {3.872590010411272*^9, 
   3.8725900139074125`*^9}, 
   3.872590153622569*^9},ExpressionUUID->"7e47697e-ecc2-4ca5-a523-\
f1b7ef43d293"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, {3.872590010411272*^9, 
   3.8725900139074125`*^9}},ExpressionUUID->"8b4a55b4-5cb7-4951-836a-\
9563d44443a4"],

Cell[TextData[{
 "Since the chain is ordered by inclusion and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["v", "1"], ",", " ", "...", ",", 
    SubscriptBox["v", "n"]}], TraditionalForm]],ExpressionUUID->
  "045a6566-17a0-4218-b65f-966063a9e22a"],
 " are in the union, there must be a set in the chain that contains all the \
vectors.  But this contradicts that the chain consisted of linearly \
independent sets. "
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, {3.872590010411272*^9, 
   3.872590029192872*^9}, 
   3.8725901722402153`*^9},ExpressionUUID->"c8d2a189-3bc1-4fe3-8627-\
404067186265"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, {3.872590010411272*^9, 
   3.872590029192872*^9}},ExpressionUUID->"d6711d8f-c941-465d-9a43-\
16e9a4df9c97"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "497e9356-012b-40dd-9b1e-e765c669fcf8"],
 " itself must be linearly independent and hence every chain of linearly \
independent vectors has an upper bound. "
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133595951491*^9}, {3.6201337695998726`*^9, 3.620133803751588*^9}, {
   3.6201338648375635`*^9, 3.620134354437785*^9}, {3.62013438863483*^9, 
   3.620134623920813*^9}, 3.841749356258629*^9, {3.8417607778108625`*^9, 
   3.8417608205719047`*^9}, {3.841760856041541*^9, 3.8417609466506343`*^9}, {
   3.841761038673031*^9, 3.841761137562314*^9}, {3.841761184099036*^9, 
   3.841761269455508*^9}, {3.841761307087992*^9, 3.841761353766424*^9}, {
   3.841761423740202*^9, 3.8417614246521387`*^9}, {3.872590010411272*^9, 
   3.872590012053918*^9}},ExpressionUUID->"2490886f-2a61-4247-81fd-\
49e09b876f1d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"deb3175d-4746-41f7-9b30-82ba8d8404f1"],

Cell[TextData[{
 "By Zorn\[CloseCurlyQuote]s Lemma, there is a maximal linearly independent \
subset \[Beta]. By the previous theorem,",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", "\[Beta]"}], TraditionalForm]],ExpressionUUID->
  "5ebb30c0-a4ab-46f2-91d5-a249fdc46163"],
 " is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "9a5e3c7b-57ab-4a5f-9353-a09c9afaac64"],
 "."
}], "Text",
 CellChangeTimes->{{3.6201346450869684`*^9, 3.620134645087969*^9}, {
  3.841761379059901*^9, 3.8417614092400475`*^9}, {3.872590034470524*^9, 
  3.872590083841568*^9}, {3.8725902048248696`*^9, 
  3.872590205966479*^9}},ExpressionUUID->"fc67d016-0b90-47ef-a5f4-\
68078842408b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
   3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
   3.620133603841753*^9}, 
   3.8417493623991375`*^9},ExpressionUUID->"6f5cc107-c844-44c6-86f8-\
fdbc3287471c"],

Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "Every vector space has a basis."
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
  3.620130760211604*^9, 3.6201307778403573`*^9}, {3.6201335957163253`*^9, 
  3.620133603841753*^9}},ExpressionUUID->"97ced246-767c-4084-9466-\
f048c419f39b"],

Cell["Example:", "Text",
 CellChangeTimes->{{3.90422729100595*^9, 
  3.9042272937568607`*^9}},ExpressionUUID->"4257ba2f-0f46-4563-a6ab-\
cc5b3c9d6704"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"{", "1", "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "x"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "x", ",", 
     SuperscriptBox["x", "2"]}], "}"}], ",", "..."}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"528cf7d4-b2b8-445b-9b7c-f48eb855e5bc"]], \
"Text",
 CellChangeTimes->{{3.90422729100595*^9, 
  3.904227309934822*^9}},ExpressionUUID->"a38503bb-c52b-4cf9-a08d-\
7d76ba816d74"],

Cell[TextData[{
 "{1},",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", " ", 
     RowBox[{"1", "+", "x"}]}], "}"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6d63823c-6ff9-4408-bf6f-397b738291f9"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"1", "+", "x"}], ",", 
     RowBox[{
      SuperscriptBox["x", "2"], "+", "x"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b042101d-7e3f-4d01-a98f-432d7b875266"],
 "}"
}], "Text",
 CellChangeTimes->{{3.9042273174806223`*^9, 3.9042273292363253`*^9}, {
  3.904227464269515*^9, 
  3.9042274894695377`*^9}},ExpressionUUID->"efc430df-57eb-40da-a7ab-\
56fa02396e1d"],

Cell[TextData[{
 "When we take the union of sets, it is important that they are order by \
inclusion in order to maintain linear independence for the union.   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["A", "1"], "\[SubsetEqual]", 
     SubscriptBox["A", "2"], "\[SubsetEqual]"}], "..."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e04bc891-1559-4d90-8fdb-68b17370a50e"]
}], "Text",
 CellChangeTimes->{{3.90422735832364*^9, 
  3.904227420771558*^9}},ExpressionUUID->"6b6cfbaa-6ce3-4b28-9349-\
04474a614640"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["2.1 Linear Transformations, Null Spaces, and Ranges",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Section",
 CellChangeTimes->{{3.6193516890568523`*^9, 3.619351702367731*^9}, {
  3.6203876739853225`*^9, 3.6203876922623634`*^9}, {3.620735019367158*^9, 
  3.6207350298364553`*^9}},ExpressionUUID->"a9e267bb-264a-403c-9a24-\
93a752d1dce8"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition:",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
   3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387836092571*^9}, {
   3.620387883284501*^9, 3.6203879041984644`*^9}, {3.620561937073022*^9, 
   3.6205619886225605`*^9}, 3.620735053543985*^9, {3.6207350886322956`*^9, 
   3.620735247439514*^9}, 3.841914970263242*^9},
 TextAlignment->Center,ExpressionUUID->"58130677-bd28-4b3a-9cbf-7d61e1627f0e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "df333dd5-7a04-40c6-9405-22c326a55802"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "ad40b956-d6f7-47bc-901f-3359570f071e"],
 " be vector spaces over a field \[DoubleStruckCapitalF]. A function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"5c75d0bc-a35d-424f-aa72-ee4e656bbe3c"],
 " is a linear transformation provided ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ForAll]", "x"}], ",", 
    RowBox[{"y", "\[Element]", "V"}], ",", " ", 
    RowBox[{"\[ForAll]", 
     RowBox[{"a", "\[Element]", "\[DoubleStruckCapitalF]"}]}], ","}], 
   TraditionalForm]],ExpressionUUID->"87011c19-7d41-41bb-b5cb-852b394f0dfa"]
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
   3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387836092571*^9}, {
   3.620387883284501*^9, 3.6203879041984644`*^9}, {3.620561937073022*^9, 
   3.6205619886225605`*^9}, 3.620735053543985*^9, {3.6207350886322956`*^9, 
   3.620735247439514*^9}, {3.841914972347023*^9, 
   3.841914972736253*^9}},ExpressionUUID->"9042581f-0ed6-4637-b2a7-\
0729fc1f9af3"],

Cell[TextData[{
 "\t(a)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"x", "+", "y"}], ")"}], "=", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], "+", 
     RowBox[{"T", "(", "y", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c8fe11e4-58e1-4928-8000-6e7041af43f1"]
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
  3.6193646809340987`*^9}, {3.620387707475087*^9, 
  3.6203878676577663`*^9}},ExpressionUUID->"ff3ffec1-63d6-4cd4-9d38-\
abd73eeb6391"],

Cell[TextData[{
 "\t(b)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"a", " ", "x"}], ")"}], "=", 
    RowBox[{"a", " ", 
     RowBox[{"T", "(", "x", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "379b178e-77cf-47d7-98eb-14d8af610959"],
 "."
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
   3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387873321865*^9}, {
   3.6203879141911373`*^9, 3.6203879460685773`*^9}, 3.6207363324456387`*^9, 
   3.841931790120735*^9, {3.8419318345007305`*^9, 
   3.841931837145603*^9}},ExpressionUUID->"cd5880eb-5de8-450f-be62-\
97d428d62a21"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLES:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
  3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387873321865*^9}, {
  3.6203879141911373`*^9, 3.62038794606557*^9}, {3.620388121941948*^9, 
  3.620388127244492*^9}},ExpressionUUID->"ca31a8a4-f4fd-43b2-8e77-\
4cc685d57867"],

Cell[CellGroupData[{

Cell["", "Subsubsubsubsection",
 CellGroupingRules->{"SectionGrouping", Inherited},
 CellChangeTimes->{{3.872767563554373*^9, 3.8727675822568693`*^9}, 
   3.904147924870886*^9},ExpressionUUID->"f4b47f95-9c01-4998-a551-\
519f698fd032"],

Cell[TextData[{
 "When is the line: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], "=", 
     RowBox[{
      RowBox[{"m", " ", "x"}], "+", "b"}]}], ","}], TraditionalForm]],
  ExpressionUUID->"adf57a98-28e9-444d-b655-046f1ab2976c"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ",", " ", 
    RowBox[{"b", "\[Element]", "\[DoubleStruckCapitalF]"}]}], 
   TraditionalForm]],ExpressionUUID->"9dbce13d-2444-4c09-9e68-8f374a7921e4"],
 ", a linear transformation?"
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
  3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387873321865*^9}, {
  3.6203879141911373`*^9, 3.62038794606557*^9}, {3.620388121941948*^9, 
  3.6203881318255453`*^9}, {3.6203912198022547`*^9, 3.620391275119166*^9}, {
  3.8419150287943335`*^9, 3.8419150604488993`*^9}, {3.8727675877074842`*^9, 
  3.872767593886799*^9}},ExpressionUUID->"ee5a2ca2-1131-4c40-b3a2-\
fcf162bba5a7"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", 
    RowBox[{
     SubscriptBox["x", "1"], "+", 
     SubscriptBox["x", "2"]}], ")"}], "=", 
   RowBox[{
    RowBox[{"m", "(", 
     RowBox[{
      SubscriptBox["x", "1"], "+", 
      SubscriptBox["x", "2"]}], ")"}], "+", "b"}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"3a231d75-a016-4ed6-9e2d-58b5eed9d255"]], \
"Text",
 CellChangeTimes->{{3.9042277982536187`*^9, 
  3.9042278237221174`*^9}},ExpressionUUID->"64d9b502-ee50-4085-b7d2-\
8fbb76344565"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["x", "1"], ")"}], "+", 
    RowBox[{"T", Cell[TextData[Cell[BoxData[
      FormBox[
       RowBox[{"(", 
        SubscriptBox["x", "2"], ")"}], TraditionalForm]],
      FormatType->TraditionalForm,ExpressionUUID->
      "51f049c0-23fe-45cf-8864-4e7c88c53ffe"]],ExpressionUUID->
      "a7270146-b93f-48c8-8008-e9f02c146bc5"]}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"m", " ", 
      SubscriptBox["x", "1"]}], "+", "b", "+", 
     RowBox[{"m", "\[VeryThinSpace]", 
      SubscriptBox["x", "2"]}], "+", "b"}], "=", 
    RowBox[{
     RowBox[{"m", "(", 
      RowBox[{
       SubscriptBox["x", "1"], "+", 
       SubscriptBox["x", "2"]}], ")"}], "+", 
     RowBox[{"2", "b"}]}]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"9b1063f0-57e2-4fbd-ac45-638b108e4db7"]], \
"Text",
 CellChangeTimes->{{3.904227828831913*^9, 
  3.904227909183795*^9}},ExpressionUUID->"2bf192d8-6282-4275-957f-\
73587ffc6edf"],

Cell[TextData[{
 "When are they equal? Precisely when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cee00f1c-03cc-4815-9070-3537fc75911f"],
 "."
}], "Text",
 CellChangeTimes->{{3.9042278818005285`*^9, 3.9042278872870555`*^9}, {
  3.9042279240250964`*^9, 
  3.9042279313582973`*^9}},ExpressionUUID->"fc484696-8204-485d-99de-\
45df37df3457"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6ea458d9-f7d5-4046-b94d-491327f7157e"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"c", "\[VeryThinSpace]", "x"}], ")"}], "=", 
    RowBox[{
     RowBox[{"m", "(", 
      RowBox[{"c", "\[VeryThinSpace]", "x"}], ")"}], "=", 
     RowBox[{
      RowBox[{"c", "(", 
       RowBox[{"m", "\[VeryThinSpace]", "x"}], ")"}], "=", 
      RowBox[{"c", "\[VeryThinSpace]", 
       RowBox[{"T", "(", "x", ")"}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dc5348de-1662-4086-ac38-20ebc7932b61"]
}], "Text",
 CellChangeTimes->{{3.904227943356818*^9, 
  3.9042279943085003`*^9}},ExpressionUUID->"63c27dc1-9233-4d6e-b59f-\
99283118b492"],

Cell[TextData[{
 "Thus ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"m", " ", "x"}], "+", "b"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "50c226f1-18d1-48dc-9660-3d7f86540618"],
 " is a linear transformation if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"b", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0394f9fb-cfdb-4979-abbb-1e20bf1dc509"],
 "."
}], "Text",
 CellChangeTimes->{{3.904228001303794*^9, 
  3.904228027580267*^9}},ExpressionUUID->"35abed2b-c878-4d3b-8b74-\
f7163ccc4a6e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsubsection",
 CellGroupingRules->{
  "SectionGrouping", 
   Inherited},ExpressionUUID->"a85718fa-5e80-44b3-b976-7fc6ea1ff3af"],

Cell[TextData[{
 "What about the quadratic: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"a", " ", 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{"b", " ", "x"}], "+", "c"}]}], TraditionalForm]],ExpressionUUID->
  "ce5e80c1-4917-4583-946e-47a09dbe26f2"]
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
  3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387873321865*^9}, {
  3.6203879141911373`*^9, 3.62038794606557*^9}, {3.620388121941948*^9, 
  3.6203881362264814`*^9}, {3.620391753254873*^9, 3.6203917807432146`*^9}, {
  3.8419150906545696`*^9, 
  3.8419150925849543`*^9}},ExpressionUUID->"77da7d1d-c549-4106-af5f-\
64d222feb712"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0b2e9350-f7a6-4687-9238-35d2a09897dc"],
 " is a linear transformation if and only if both ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f48c7255-38f8-4e1d-a3a6-0a734588902d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3d4f56a8-a8ce-4498-99c5-6f474063365d"],
 "."
}], "Text",
 CellChangeTimes->{{3.904228504161613*^9, 3.9042285192501783`*^9}, {
  3.9042285572695365`*^9, 
  3.904228577174514*^9}},ExpressionUUID->"ca3e1bc9-0d31-4a30-9e78-\
4daffabfeb29"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsubsection",
 CellGroupingRules->{
  "SectionGrouping", 
   Inherited},ExpressionUUID->"01f66475-2592-4212-aca8-38737bb1023a"],

Cell[TextData[{
 "Is the differential operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", ":", 
    RowBox[{
    "\[DoubleStruckCapitalP]", "\[LongRightArrow]", 
     "\[DoubleStruckCapitalP]"}]}], TraditionalForm]],ExpressionUUID->
  "3e784bf3-0bd2-4d2f-9506-4d4e3e865e8e"],
 " a linear transformation?"
}], "Text",
 CellChangeTimes->{{3.872763806334653*^9, 
  3.8727638774339256`*^9}},ExpressionUUID->"25e6abd5-ca25-4728-bd1c-\
247f4007bd09"],

Cell["Yes. ", "Text",
 CellChangeTimes->{{3.9042286422046804`*^9, 
  3.9042286435299892`*^9}},ExpressionUUID->"47421d45-051a-442a-bc97-\
612a8abab925"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsubsection",
 CellGroupingRules->{
  "SectionGrouping", 
   Inherited},ExpressionUUID->"13446406-fd70-4da1-803b-a3ed7346c6b5"],

Cell[TextData[{
 "How about integration on polynomials:  i.e. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "f", ")"}], "=", 
    RowBox[{"\[Integral]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "d", "\[VeryThinSpace]", "x"}]}]}], 
   TraditionalForm]],ExpressionUUID->"648d946b-9dd5-4bac-8d8c-1d02e6e96aa1"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"F", "(", "x", ")"}], "+", "C"}], " ", ","}], TraditionalForm]],
  ExpressionUUID->"b2a8a007-a6e6-4bb2-9391-f60919174eb3"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "'"}], "=", "f", " "}], TraditionalForm]],ExpressionUUID->
  "1e3bbd6c-be53-4715-8293-0b6321f9d872"],
 "and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "9be2d1c3-e251-42b3-8edc-9636dcaec1ec"],
 " is an arbitrary constant? "
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
