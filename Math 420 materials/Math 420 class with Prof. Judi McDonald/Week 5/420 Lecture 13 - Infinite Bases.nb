  3.620133609637334*^9}},ExpressionUUID->"a2732ddf-2456-451f-beec-\
e0283cebff16"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "cd22f550-be59-4bac-b810-1f19f2730321"],
 " be a linearly independent subset in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "938cd396-127d-4d50-93b6-ab7a0a2c2a04"],
 "  Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "bb7bd6c7-2602-413b-865f-908d8b38ba07"],
 " be the set of all sets of linearly independent vectors that contain ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "9ca363d4-a0dd-4bba-bd29-8f18cfb4283a"],
 "."
}], "Text",
 CellChangeTimes->{{3.6201303906140337`*^9, 3.6201306435927916`*^9}, {
