e2f2aec15d4f"],

Cell["\<\
Given a (possibly infinite) collection of sets, you can choose one element \
from each set, and make a new set.  \
\>", "Text",
 CellChangeTimes->{{3.6195245162495155`*^9, 3.619524556332207*^9}, {
   3.619524595680655*^9, 3.6195247716334076`*^9}, {3.6195248085331306`*^9, 
   3.6195248085381327`*^9}, {3.619525571118126*^9, 3.61952557112213*^9}, 
   3.8417492456856976`*^9, 3.841749473386135*^9, {3.8725895765158677`*^9, 
   3.8725895805069885`*^9}, {3.8725945664629507`*^9, 
   3.8725945696782284`*^9}},ExpressionUUID->"13322e39-d7c7-46c0-b979-\
af5c2668f9cd"]
}, Open  ]],

