Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"5455f35a-2023-4235-b99c-b81ccfa7e3e9"],

Cell[TextData[{
 StyleBox["MORAL:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " A spanning set can be too big.  A linearly independent set could be too \
small.  ",
 StyleBox["A basis is just right",
  FontSlant->"Italic"],
 ". "
}], "Text",
 CellChangeTimes->{{3.8408961720557137`*^9, 
  3.840896218303209*^9}},ExpressionUUID->"fe34275c-e4d6-4dae-bcc4-\
72aa27a97872"],

Cell[TextData[{
 StyleBox["REMARK:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 " Throughout the course, we will develop valuable ideas for both finite and \
infinite dimensional vector spaces.  Infinite dimensional vector spaces, such \
as the polynomials, continuous functions, and signals, are important \
mathematical structures, so it is worthwhile to establish that even infinite \
dimensional vector spaces have bases. "
}], "Text",
 CellChangeTimes->{{3.8408961720557137`*^9, 3.840896218303209*^9}, {
  3.9041473881884766`*^9, 3.9041474406517057`*^9}, {3.904147576454213*^9, 
  3.904147715375847*^9}},ExpressionUUID->"8b82256b-4a3e-44f2-850e-\
d26a7dce8a69"]
}, Open  ]],

