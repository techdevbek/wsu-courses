Cell[TextData[{
 "How about integration on polynomials:  i.e. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "f", ")"}], "=", 
    RowBox[{"\[Integral]", 
     RowBox[{
      RowBox[{"f", "(", "x", ")"}], "d", "\[VeryThinSpace]", "x"}]}]}], 
   TraditionalForm]],ExpressionUUID->"648d946b-9dd5-4bac-8d8c-1d02e6e96aa1"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"F", "(", "x", ")"}], "+", "C"}], " ", ","}], TraditionalForm]],
  ExpressionUUID->"b2a8a007-a6e6-4bb2-9391-f60919174eb3"],
 " where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "'"}], "=", "f", " "}], TraditionalForm]],ExpressionUUID->
  "1e3bbd6c-be53-4715-8293-0b6321f9d872"],
 "and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "9be2d1c3-e251-42b3-8edc-9636dcaec1ec"],
 " is an arbitrary constant? "
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
   3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
   3.6193646809340987`*^9}, {3.620387707475087*^9, 3.620387873321865*^9}, {
   3.6203879141911373`*^9, 3.62038794606557*^9}, {3.620388121941948*^9, 
   3.6203881407244806`*^9}, {3.62038855172571*^9, 3.620388556245718*^9}, {
   3.6203922254713364`*^9, 3.6203923563843355`*^9}, {3.6203924530774803`*^9, 
   3.620392461360001*^9}, {3.6203924991599836`*^9, 3.620392559754016*^9}, {
   3.620392603403019*^9, 3.6203926368044324`*^9}, {3.620392677925232*^9, 
   3.6203927060840454`*^9}, {3.6203927361974497`*^9, 
   3.6203927824005265`*^9}, {3.841915108095297*^9, 3.841915140617234*^9}, {
   3.841932662659015*^9, 3.8419326632893496`*^9}, {3.841932722772339*^9, 
   3.841932763369189*^9}, {3.841932874525076*^9, 3.841932875671623*^9}, 
   3.872763760016192*^9, {3.8727638885385275`*^9, 3.872763890777912*^9}, {
   3.872847394281292*^9, 
   3.8728473942971916`*^9}},ExpressionUUID->"dd54ea62-6113-4780-afea-\
94e83ba10875"],

Cell[TextData[{
 "The indefinite integral is not unique - it depends on the choice of ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "581c190f-4baa-4847-8141-4a21eb4319dd"],
 ", thus this ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "eab3ba20-00bf-4eea-a50a-542edc8bb1c8"],
 " is not even a function."
}], "Text",
 CellChangeTimes->{{3.9043989525691833`*^9, 3.904398985427575*^9}, {
  3.9043990986950684`*^9, 
  3.9043990989916615`*^9}},ExpressionUUID->"c7ddfc6a-220d-4c2f-8405-\
a9f530949ebc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"c2a05d92-d3b1-4058-8fa8-7a1b9005596e"],

Cell[TextData[{
 "The identity transformation is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", "x"}], TraditionalForm]],
  ExpressionUUID->"c92cd96f-7fcb-4ab1-be4b-5750848cc0f8"],
 ", and it is a linear transformation from  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", " ", "to", " ", "V"}], TraditionalForm]],ExpressionUUID->
  "761fc1da-ef41-4e40-9eb9-6851e69b857f"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.6193517457577114`*^9, 3.6193517796814995`*^9}, {
  3.619351911663891*^9, 3.6193519161268754`*^9}, {3.6193645941331277`*^9, 
