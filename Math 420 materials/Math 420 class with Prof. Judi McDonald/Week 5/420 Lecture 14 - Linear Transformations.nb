  FormBox[
   RowBox[{"y", "\[Element]", "W"}], TraditionalForm]],ExpressionUUID->
  "1fc0e349-0339-4001-950f-7824283924dc"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Exists]", 
     RowBox[{"x", "\[Element]", "V"}]}], ",", " ", 
    RowBox[{"so", " ", "that", " "}]}], TraditionalForm]],ExpressionUUID->
  "973080fc-ab66-4d96-a215-f24e63d289af"],
