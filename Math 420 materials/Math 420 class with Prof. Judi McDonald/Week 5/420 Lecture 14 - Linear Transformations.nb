Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ce6492fc-88dc-4091-adb3-b76ebe6b6539"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f1dea5e7-911d-4557-9391-b38ebfa3871c"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"13a7a4c0-ca39-4f49-a418-7b6139ea19da"],
 " a linear transformation.  The null space and range of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "8388c2b4-d26b-4364-ac61-69a1f1e89ed8"],
 " are subspaces of ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox["V", TraditionalForm]],ExpressionUUID->
    "8a6d31c3-769f-4f34-8fcf-d49aeda02017"]],ExpressionUUID->
    "023d0363-cdd3-408a-ba37-96427e5a749d"], TraditionalForm]],ExpressionUUID->
  "a58ed5ad-5a74-4703-a864-d8398c0ca84c"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "e4f1feb7-19da-4106-b261-a5dc6179de8b"],
 " respectively.  "
}], "Text",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
  3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
  3.6203893004250755`*^9}, {3.6203936325359077`*^9, 3.620393633134288*^9}, {
  3.62039387205732*^9, 3.6203938720638356`*^9}},
 TextAlignment->Left,ExpressionUUID->"e8aefc8b-f939-49c5-a958-42d3ebd6a912"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.841933352046378*^9, 
  3.8419333539840913`*^9}},ExpressionUUID->"399dc840-bd31-434b-bcbd-\
cea2ac1f9dac"],

Cell[TextData[{
 "In each case we need to show (i) 0\[Element]set (ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", 
    RowBox[{"y", " ", "\[Element]", " ", 
     RowBox[{
      RowBox[{"set", " ", "implies", " ", "x"}], "+", "y"}], " ", 
     "\[Element]", 
     RowBox[{"set", " ", "and", " ", 
      RowBox[{"(", "iii", ")"}], "x"}], " ", "\[Element]", "set"}], ",", " ", 
    RowBox[{"a", "\[Element]", 
     RowBox[{
     "\[DoubleStruckCapitalF]", " ", "implies", " ", "a", "\[VeryThinSpace]", 
      "x"}], "\[Element]", 
     RowBox[{"set", "."}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fda3afc1-1615-4e0a-95be-212f527631c2"],
 "  Details left to reader."
}], "Text",
 CellChangeTimes->{{3.904399838481264*^9, 3.904399921082265*^9}, {
  3.9043999806077414`*^9, 
  3.9043999859318542`*^9}},ExpressionUUID->"acb0b74a-7441-4fee-add2-\
d58635e91878"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition: ", "Subsubsubsection",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
   3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
   3.6203893939779353`*^9}, 3.841915507369938*^9},
 TextAlignment->Left,ExpressionUUID->"eb4232a9-1ddf-493c-9fd1-956e8d6887cc"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "0bbd4161-1c3a-47c4-a9b4-0d0db73b89ec"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "98ed7dc8-4903-4c4f-b990-b1b71110a7f6"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"b90618cf-e17c-4d55-864f-eb1d65c1b25b"],
 " a linear transformation.  The  ",
 StyleBox["nullity",
  FontWeight->"Bold",
  FontColor->GrayLevel[0]],
 StyleBox[" of ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "df504723-c6cb-4d27-9859-ff59feee4ea6"],
 StyleBox[" is the dimension of the nullspace of ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "970a44ca-0f7f-49d6-953a-5814e398d7f0"],
 StyleBox[" and the ",
  FontColor->GrayLevel[0]],
 StyleBox["rank",
  FontWeight->"Bold",
  FontColor->GrayLevel[0]],
 StyleBox[" of ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "c2696f8e-11b2-4143-ad89-3999961e6754"],
 StyleBox[" is the dimension of the range of ",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ".", "  "}], TraditionalForm]],
  FontColor->GrayLevel[0],ExpressionUUID->
  "4bb6aa8c-f871-4b6a-9abd-cd7cd91e5799"]
}], "Text",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
  3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
  3.6203893939779353`*^9}, {3.8419155532198997`*^9, 3.8419155532198997`*^9}},
 TextAlignment->Left,ExpressionUUID->"3d9f233b-a534-4281-bc0e-6fa3751fe931"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
   3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
   3.6203894720450616`*^9}, 3.841915562460141*^9},
 TextAlignment->Left,ExpressionUUID->"47be4622-9aee-40af-bc41-5fb378603917"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b35a46d8-f12a-4f46-a9d6-3e96d4beb9f7"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f4baf7f5-648d-414e-b5a5-756d7364568d"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"a76fa0da-c7be-45c4-bdb9-dfb2f04aff9a"],
 " a linear transformation. If \[Beta] is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "acdbc196-f4c6-46d9-91d9-acf9a606450e"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "\[Beta]", ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"d9c45774-3a96-4d0c-8a91-54986b2d4d28"],
 "spans the range of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "0d5c5dde-6aa9-4d84-8110-d00d531572f6"]
}], "Text",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
  3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
  3.6203894720450616`*^9}},
 TextAlignment->Left,ExpressionUUID->"4624feb8-802c-45b4-9164-2efb43947be1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["PROOF:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.841933352046378*^9, 
  3.8419333539840913`*^9}},ExpressionUUID->"2ce21fbf-8b09-4737-9a9a-\
7f6a1c8c7cc0"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", 
    RowBox[{
     RowBox[{"R", "(", "T", ")"}], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "497adec5-bc40-419c-87b8-78e013e69deb"],
 " Then there is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "33cef59f-8e7d-412a-b799-e6e1cadbdb89"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "=", 
    RowBox[{"T", "(", "v", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "08a8ed11-007b-4edd-934d-a7f05110df97"],
 ". Since \[Beta] is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7bf4095d-ffb9-4480-8267-98b5fbdf58f7"],
 ", there exists ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "1"], ",", " ", "...", ",", 
    RowBox[{
     SubscriptBox["u", "k"], "\[Element]", "\[Beta]"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "019b0554-c313-4477-ab4b-7645f23a24d9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", 
    RowBox[{
     RowBox[{"...", 
      SubscriptBox["a", "k"]}], "\[Element]", "\[DoubleStruckCapitalF]"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "985bf305-3a62-4f55-95f6-5fc1d593e84d"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", "1"], 
        SubscriptBox["u", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "k"], 
      SubscriptBox["u", "k"]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "351b76e7-79a9-41cd-b506-e0552ffa6df6"],
 ".  Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "=", 
    RowBox[{
     RowBox[{"T", "(", "v", ")"}], "=", 
     RowBox[{
      RowBox[{"T", "(", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["a", "1"], 
           SubscriptBox["u", "1"]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "k"], 
         SubscriptBox["u", "k"]}]}], ")"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"T", "(", 
           RowBox[{
            SubscriptBox["a", "1"], 
            SubscriptBox["u", "1"]}], ")"}], "+"}], "..."}], "+", 
        RowBox[{"T", "(", 
         RowBox[{
          SubscriptBox["a", "k"], 
          SubscriptBox["u", "k"]}], ")"}]}], "=", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["a", "1"], 
           RowBox[{"T", "(", 
            SubscriptBox["u", "1"], ")"}]}], "+"}], "..."}], "+", 
        RowBox[{
         SubscriptBox["a", "k"], 
         RowBox[{"T", "(", 
          SubscriptBox["u", "k"], ")"}]}]}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "42069519-59f7-4377-b7da-2a613b725278"],
 ", so ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4a5d0064-bef3-4319-86bc-4458913fbbf6"],
 " is a linear combination of elements from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "31c8ccaa-a38e-4ce4-813f-13b771b9a3f2"],
 ", establishing the result. "
}], "Text",
 CellChangeTimes->{{3.904400226033579*^9, 3.9044003797156296`*^9}, {
  3.9044005844316597`*^9, 3.904400646409017*^9}, {3.9044006928102307`*^9, 
  3.904400724440782*^9}},ExpressionUUID->"63162e24-4571-4047-92db-\
e3d724420fa2"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE: ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203889300024424`*^9, 3.620388931563486*^9}, {
   3.6203890191940064`*^9, 3.620389063811781*^9}, {3.6203891575263095`*^9, 
   3.6203895080280814`*^9}, {3.620734253587384*^9, 3.620734441229158*^9}, 
   3.8419156105525355`*^9},
 TextAlignment->Left,ExpressionUUID->"003891ff-55cd-43de-aeb4-a83abe4119f5"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "3"]}], "->", 
    SuperscriptBox["\[DoubleStruckCapitalR]", "4"]}], TraditionalForm]],
  ExpressionUUID->"5ea063f7-395b-4d47-a063-6adbee9c51f6"],
 ", be defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", " ", 
     GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}], GridBox[{
       {"a"},
       {"b"},
       {"c"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}]}], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}], GridBox[{
       {"a"},
       {"0"},
       {"c"},
       {"0"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}], "  "}]}], TraditionalForm]],ExpressionUUID->
  "a528fff5-7334-4122-b8de-d914ac50753f"]
}], "Text",
 CellChangeTimes->{{3.87294002797547*^9, 3.872940126306926*^9}, {
  3.9041483315143623`*^9, 
  3.904148333234123*^9}},ExpressionUUID->"05bb971e-cd04-4fa2-a9ba-\
00e380f35c1c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], " ", ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"0"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"0"},
         {"0"},
         {"1"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}]}], " ", "}"}]}], TraditionalForm]],
  ExpressionUUID->"5b5514c8-57ef-4278-b540-c6006b756a21"],
 "     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "\[Beta]", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"1"},
         {"0"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"0"},
         {"0"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"0"},
         {"0"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "49039ee5-d4ee-421d-887c-ccc60b012463"]
}], "Text",
 CellChangeTimes->{{3.8729401492946978`*^9, 
  3.8729402482562003`*^9}},ExpressionUUID->"83447f80-3c9b-475b-bd21-\
02a232d464f9"],

Cell[TextData[{
 "Notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "df3522c7-2db5-44f3-b60a-eee1246afabb"],
 " is linearly dependent. "
}], "Text",
 CellChangeTimes->{{3.904392843127881*^9, 
  3.9043928673290825`*^9}},ExpressionUUID->"44134393-f8a4-495e-a00f-\
9640bba1d3bc"],

Cell[TextData[{
 "Aside:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"0"},
         {"b"},
         {"0"}
        }], "\[NoBreak]", ")"}], " ", "|", 
      RowBox[{"b", "\[Element]", "\[DoubleStruckCapitalR]"}]}], "}"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8f3fe553-7a68-44e6-aa26-98d3cf53aa9e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "\[NoBreak]", GridBox[{
          {"a"},
          {"0"},
          {"c"},
          {"0"}
         }], "\[NoBreak]", ")"}], " ", "|", "a"}], ",", 
      RowBox[{"c", " ", "\[Element]", "\[DoubleStruckCapitalR]"}]}], "}"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4d23a66a-0b13-401e-8d2b-0988bcc48253"]
}], "Text",
 CellChangeTimes->{{3.9044008322551374`*^9, 
  3.9044008946243258`*^9}},ExpressionUUID->"16f826c3-c2b1-4965-a1fd-\
1ccc524c2c40"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
   3.6207364387148905`*^9, 3.620736439121175*^9}, 
   3.841915752666336*^9},ExpressionUUID->"80862fce-f6ba-43cd-bd52-\
39ae874b98ba"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "053c7ec1-f161-4ca7-a7ca-ef381a5f5968"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "9ded2e82-4eff-4e04-93b2-9a744a176645"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"e38b91dc-034d-4a60-adc2-d1ca33f1a70d"],
 " a linear transformation.  If ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "5b2e4425-2171-4112-b02a-918b1ac6687b"],
 " is finite dimensional, then "
}], "Text",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
  3.6207364387148905`*^9, 
  3.620736439121175*^9}},ExpressionUUID->"fcc80963-9675-4f16-ac48-\
8f2d66317c68"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "+", 
    RowBox[{"nullity", "(", "T", ")"}]}], "=", 
   RowBox[{"dim", "(", "V", ")"}]}], TraditionalForm]], "Equation",
 CellChangeTimes->{{3.620389531221552*^9, 3.620389562540455*^9}},
 TextAlignment->Center,ExpressionUUID->"7a30359c-06c7-4fdf-aab7-08f1d5d0de27"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Plain"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.620736443558888*^9, 3.620736445715252*^9}, {
  3.620736973050677*^9, 
  3.6207369730663033`*^9}},ExpressionUUID->"9229e693-439a-4be7-be25-\
ea1550acecf6"],

Cell[TextData[{
 "Let \[Alpha] be a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", "T", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d219b94f-d98f-4ded-b5de-fd7277cb5dea"],
 ".  So the number elements in \[Alpha] is equal to the nullity of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b17cc064-c1fd-4343-a505-263129bce3b3"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "p"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a6017910-f60d-4b84-8772-f133c34c0490"],
 ". Extend \[Alpha] to a basis \[Beta] for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "48c8aa41-081c-411e-abe2-2a390dc04fc3"],
 ".  Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "p"], ",", 
      SubscriptBox["v", 
       RowBox[{"p", "+", "1"}]], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7b26ae1f-c8f6-4fbf-b7bc-3d26d6c5d9a1"],
 ".  Here ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"nullity", "(", "T", ")"}], " ", "and", " ", "n"}], "=", 
     RowBox[{
      RowBox[{"dim", "(", "V", ")"}], "."}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "52d59e40-f73b-45f2-97e2-f07bd36e6642"],
 "  What happens if we apply ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9c68468c-99be-40b2-8e81-3058e544f733"],
 " to the elements of \[Beta]?  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "1"], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a352e69a-f3ec-4fec-829d-752d94e40250"],
 ",...,",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "p"], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d5fe5777-f6fa-4881-aec4-c60af5b0d6e2"],
 " since we are applying ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "de27ce86-be9f-414b-aace-96d74da10d28"],
 " to vectors in the null space of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1de7c3bb-568f-4531-b3e5-9167f91c1bda"],
 ". Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{"T", "(", 
      RowBox[{
       SubscriptBox["v", 
        RowBox[{"p", "+", "1"}]], ",", "...", ",", 
       RowBox[{"T", "(", 
        SubscriptBox["v", "n"], ")"}]}], ")"}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d8134bb-337f-4c47-8f19-3266ef2c0a1a"],
 ".  We will show that \[Gamma] is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "."}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2c4113cc-9d78-4e34-830e-cd19b056e5b5"]
}], "Text",
 CellChangeTimes->{{3.904401312343648*^9, 3.904401377797246*^9}, {
  3.904401416465118*^9, 3.9044015079881096`*^9}, {3.9044015475461025`*^9, 
  3.9044016649236107`*^9}},ExpressionUUID->"feff069a-7f98-4210-b188-\
764880da2283"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
