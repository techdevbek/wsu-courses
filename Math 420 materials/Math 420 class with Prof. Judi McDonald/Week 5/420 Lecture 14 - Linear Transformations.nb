cecda102c7a2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"N", "(", "T", ")"}], "=", 
   RowBox[{"{", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"x", "\[Element]", "V"}], "|", 
      RowBox[{"T", "(", "x", ")"}]}], "=", "0"}], "}"}]}], 
  TraditionalForm]], "Equation",
