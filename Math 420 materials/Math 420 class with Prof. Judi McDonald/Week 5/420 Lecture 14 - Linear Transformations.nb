Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c450a8fc-19da-479d-9312-719140ac9e6d"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "de0ec967-8f66-4933-9782-a9a7e141e266"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"406e6d11-50b8-4e57-8cf3-21b486777a55"],
 " a linear transformation.  The  ",
 StyleBox["null space (or kernel)",
  FontWeight->"Bold",
  FontColor->GrayLevel[0]],
 StyleBox[" of ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ","}], TraditionalForm]],ExpressionUUID->
  "937a16f7-2369-413f-acbe-86ef552af118"],
 " denoted ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], ",", " "}], TraditionalForm]],
  ExpressionUUID->"b28f2047-4a6f-4e9f-a909-137a3301eefb"],
 "is the set of all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "c2ba1213-cc10-4fa2-9f2e-0506982797c6"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", "0."}], TraditionalForm]],
  ExpressionUUID->"c70f9ec4-d9b1-4c19-acac-32bb97b096fe"]
}], "Text",
 CellChangeTimes->{{3.6203886088000836`*^9, 3.620388801442622*^9}, 
   3.6203891207237635`*^9, {3.6205617066601405`*^9, 3.6205617066601405`*^9}, 
