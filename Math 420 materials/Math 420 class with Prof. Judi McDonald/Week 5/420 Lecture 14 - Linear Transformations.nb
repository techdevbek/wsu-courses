    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"5a7a6e14-0581-45cd-ac08-5d18b436bb4a"],
 " a linear transformation.  The  ",
 StyleBox["range",
  FontWeight->"Bold",
  FontColor->GrayLevel[0]],
 StyleBox[" of ",
  FontColor->RGBColor[0, 0, 0]],
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ","}], TraditionalForm]],ExpressionUUID->
  "91433efd-db5f-41e8-9cea-a4c4c9f702d6"],
 " denoted ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], ",", " "}], TraditionalForm]],
  ExpressionUUID->"250e7f25-a070-483c-90b8-88c0021b5118"],
 "is the set of all ",
