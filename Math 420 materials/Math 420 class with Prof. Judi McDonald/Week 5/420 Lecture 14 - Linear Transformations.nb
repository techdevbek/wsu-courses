Cell[TextData[{
 "The zero transformation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "0"], "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"8d176c8f-a62d-43f1-a240-cb84f93d3654"],
