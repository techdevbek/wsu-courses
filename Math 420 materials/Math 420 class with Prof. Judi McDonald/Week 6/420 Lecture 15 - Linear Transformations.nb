 "     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "\[Beta]", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"1"},
         {"0"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"0"},
         {"0"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}], GridBox[{
         {"0"},
         {"0"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]},
        ImageSize->{7, 65}]}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "49039ee5-d4ee-421d-887c-ccc60b012463"]
}], "Text",
 CellChangeTimes->{{3.8729401492946978`*^9, 
  3.8729402482562003`*^9}},ExpressionUUID->"83447f80-3c9b-475b-bd21-\
02a232d464f9"],

Cell[TextData[{
 "Notice that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", "\[Beta]", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "df3522c7-2db5-44f3-b60a-eee1246afabb"],
 " is linearly dependent. "
}], "Text",
 CellChangeTimes->{{3.904392843127881*^9, 
  3.9043928673290825`*^9}},ExpressionUUID->"44134393-f8a4-495e-a00f-\
9640bba1d3bc"]
}, Closed]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
   3.6207364387148905`*^9, 3.620736439121175*^9}, 
   3.841915752666336*^9},ExpressionUUID->"80862fce-f6ba-43cd-bd52-\
39ae874b98ba"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "053c7ec1-f161-4ca7-a7ca-ef381a5f5968"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "9ded2e82-4eff-4e04-93b2-9a744a176645"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"e38b91dc-034d-4a60-adc2-d1ca33f1a70d"],
 " a linear transformation.  If ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "5b2e4425-2171-4112-b02a-918b1ac6687b"],
 " is finite dimensional, then "
}], "Text",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
  3.6207364387148905`*^9, 
  3.620736439121175*^9}},ExpressionUUID->"fcc80963-9675-4f16-ac48-\
8f2d66317c68"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "+", 
    RowBox[{"nullity", "(", "T", ")"}]}], "=", 
   RowBox[{"dim", "(", "V", ")"}]}], TraditionalForm]], "Equation",
 CellChangeTimes->{{3.620389531221552*^9, 3.620389562540455*^9}},
 TextAlignment->Center,ExpressionUUID->"7a30359c-06c7-4fdf-aab7-08f1d5d0de27"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Plain"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.620736443558888*^9, 3.620736445715252*^9}, {
  3.620736973050677*^9, 
  3.6207369730663033`*^9}},ExpressionUUID->"9229e693-439a-4be7-be25-\
ea1550acecf6"],

Cell[TextData[{
 "Let \[Alpha] be a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", "T", ")"}], TraditionalForm]],ExpressionUUID->
  "318c2856-449a-43bf-b770-ed8cfb2c4105"],
 ".  So the number elements in \[Alpha] is equal to the nullity of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "20e9b57d-9d94-4b8f-b845-e4b0b850e55b"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "p"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "4189db67-e6eb-4538-b596-26a6aeb039ce"],
 ". Extend \[Alpha] to a basis \[Beta] for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c7d59426-0718-443c-a364-83def0a140a1"],
 ".  Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "p"], ",", 
      SubscriptBox["v", 
       RowBox[{"p", "+", "1"}]], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "f6d4565b-ecc3-4fad-8abf-81643402512d"],
 ".  Here ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"nullity", "(", "T", ")"}], " ", "and", " ", "n"}], "=", 
     RowBox[{
      RowBox[{"dim", "(", "V", ")"}], "."}]}]}], TraditionalForm]],
  ExpressionUUID->"c2ad114c-6c71-465e-9a38-f714731317f9"],
 "  What happens if we apply ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "0884addd-d081-4a23-b26f-c08f20307126"],
 " to the elements of \[Beta]?  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "1"], ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"ca8400de-a8c1-4318-9a45-0454335f587a"],
 ",...,",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "p"], ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"6b984a28-d4f4-4a4e-8ebe-e99f6c76b1fd"],
 " since we are applying ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "4e5e1449-4ba4-4a95-8ee6-4da9245e7ac1"],
 " to vectors in the null space of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "78db8204-b514-4c31-9c2d-55766a3c4728"],
 ". Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"T", "(", 
       SubscriptBox["v", 
        RowBox[{"p", "+", "1"}]], ")"}], ",", "...", ",", 
      RowBox[{"T", "(", 
       SubscriptBox["v", "n"], ")"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"dd16d42e-bca1-461d-b9f9-cb26fd91ecd1"],
 ".  We will show that \[Gamma] is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "."}], TraditionalForm]],ExpressionUUID->
  "0b6129e9-da99-4822-a12b-650148925f63"],
 "  Since span ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"span", " ", 
     RowBox[{"T", "(", "\[Beta]", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cd7377b4-5f21-44cd-b4e3-513154e47389"],
 ", we know \[Gamma] spans ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "(", "T", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c69df312-5616-4a45-9381-8f81c52eb15e"],
 ". Suppose ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9f81fd88-52c8-4f3c-af33-624c67ccc64a"],
 " is linearly dependent.  Then there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", 
     RowBox[{"p", "+", "1"}]], ",", " ", "...", ",", " ", 
    SubscriptBox["a", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6555cdac-0850-4c1d-af1c-ede3ef050863"],
 ", not all zero, so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"p", "+", "1"}]], 
        RowBox[{"T", "(", 
         SubscriptBox["v", 
          RowBox[{"p", "+", "1"}]], ")"}]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      RowBox[{"T", "(", 
       SubscriptBox["v", "n"], ")"}]}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "53529ad4-fc55-4cda-b709-f17439ecfa95"],
 ".  Since ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47f85d45-4f9d-45f5-a320-421e264171b0"],
 " is linear, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["a", 
          RowBox[{"p", "+", "1"}]], 
         SubscriptBox["v", 
          RowBox[{"p", "+", "1"}]]}], "+"}], "..."}], "+", 
      RowBox[{
       SubscriptBox["a", "n"], 
       SubscriptBox["v", "n"]}]}], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "227e5231-4349-4209-9ec7-442bd753d6f7"],
 ".  But then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"p", "+", "1"}]], 
        SubscriptBox["v", 
         RowBox[{"p", "+", "1"}]]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "\[Element]", 
    RowBox[{"N", "(", "T", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8b2b9983-0a82-4913-883d-a19a19c27202"],
 ".  Since \[Alpha] is a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", 
    RowBox[{"(", "T", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5b0c9d17-760b-4339-b8e5-06d1aee45a45"],
 ", we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"p", "+", "1"}]], 
        SubscriptBox["v", 
         RowBox[{"p", "+", "1"}]]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["b", "1"], 
        SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
     RowBox[{
      SubscriptBox["b", "p"], 
      SubscriptBox["v", 
       RowBox[{"p", ",", " "}]]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69aacc51-dca3-4ccb-8df6-7a9a13e73e8e"],
 " but then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["b", "1"], 
       SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
    RowBox[{
     SubscriptBox["b", "p"], 
     SubscriptBox["v", 
      RowBox[{"p", " "}]]}], "-"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "13bcffd4-e1e9-4bb3-806f-d35a162e6ef6"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["a", 
         RowBox[{"p", "+", "1"}]], 
        SubscriptBox["v", 
         RowBox[{"p", "+", "1"}]]}], "-"}], "..."}], "-", 
     RowBox[{
      SubscriptBox["a", "n"], 
      SubscriptBox["v", "n"]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"cbb817da-3c0b-4938-8ebf-2c9dc10be0be"],
 ". But this is a linear combination of the elements in the basis \[Beta], \
hence all the coefficients are zero, contradicting our earlier assumption \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "16b3de94-bc0b-46d1-8d32-32c14cecd51d"],
 " was linearly dependent.  Thus \[Gamma] is a linearly independent spanning \
set for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "(", "T", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bc34e134-021a-41f6-b50f-818b0714419a"],
 " and hence the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"n", "-", "p"}], "=", 
     RowBox[{
      RowBox[{"dim", "(", "V", ")"}], "-", 
      RowBox[{"nullity", " ", 
       RowBox[{"(", "T", ")"}]}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1a3e1794-37f9-47d1-8aa5-55a04aaa2156"],
 " completing the proof."
}], "Text",
 CellChangeTimes->{{3.9046579139927607`*^9, 3.904657946888296*^9}, 
   3.904657978402003*^9, {3.9046580341526394`*^9, 3.904658181938569*^9}, {
   3.9046582349518876`*^9, 3.904658261092553*^9}, {3.9046583086578345`*^9, 
   3.904658322324397*^9}, {3.904658360533622*^9, 3.9046584009443445`*^9}, {
   3.904658432163811*^9, 
   3.904658626139331*^9}},ExpressionUUID->"feff069a-7f98-4210-b188-\
764880da2283"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
   3.6207364387148905`*^9, 3.620736439121175*^9}, 
   3.841915752666336*^9},ExpressionUUID->"2f0d19cf-1567-4210-b1a5-\
096ce2bdd1fa"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "09230594-498d-4bbc-a68b-fa4641c02c9b"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "4317bc74-6083-4233-aed8-7bd7759abc4c"],
 " be vector spaces over a field \[DoubleStruckCapitalF] and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"e5a80c5d-843f-4ee8-a032-87eeb7e6783b"],
 " a linear transformation.  The transformation  ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "886422b7-5a38-432d-b9c6-339b0359d796"],
 " is one-to-one if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"{", "0", "}"}], "."}]}], TraditionalForm]],ExpressionUUID->
  "d487381c-6a3c-4252-b311-10cecbeb828f"]
}], "Text",
 CellChangeTimes->{{3.620389628387791*^9, 3.6203896687777395`*^9}, {
  3.6207348846154976`*^9, 
  3.6207348867093554`*^9}},ExpressionUUID->"1a7bd738-a69a-48a5-852e-\
34df1cbf15b9"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Plain"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.620736443558888*^9, 3.620736445715252*^9}, {
  3.620736973050677*^9, 
  3.6207369730663033`*^9}},ExpressionUUID->"6b63d229-4f2d-4f98-9eb2-\
cb3792f16863"],

Cell[TextData[{
 "Instead we could try to prove ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "627ac6f1-fa23-43c2-ae4d-efe2d51c9cc7"],
 " is not one-to-one if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "\[NotEqual]", 
    RowBox[{
     RowBox[{"{", "0", "}"}], "."}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a8905e6a-f818-4a0c-a274-0c86194b28da"],
 " "
}], "Text",
 CellChangeTimes->{{3.9046589550421495`*^9, 
  3.9046590068785567`*^9}},ExpressionUUID->"68d9e0e4-2313-4de0-a000-\
3c4a0bd63290"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ede7fd2a-e554-4933-8f0e-8436f8a75d4c"],
 " is not one-to-one if and only if there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", ",", 
    RowBox[{"v", "\[Element]", "V"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "37338a30-9e81-4503-b9a3-508409c249e0"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[NotEqual]", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6e844cf3-b3cc-4f36-8fbc-2aae46bc90a0"],
 " yet ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "u", ")"}], "=", 
    RowBox[{"T", "(", "v", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5834e82c-4ee6-4dc3-b650-7cf4beb54b79"]
}], "Text",
 CellChangeTimes->{{3.904659031413983*^9, 
  3.9046591196535263`*^9}},ExpressionUUID->"c8462ca6-ca30-45a1-afdc-\
1e36b3c41a85"],

Cell[TextData[{
 " if and only if there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", ",", 
    RowBox[{"v", "\[Element]", "V"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "69571bde-2b15-438b-a068-38d61317ecf3"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[NotEqual]", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d40027d2-3af1-48ec-b02c-1762d4a21c97"],
 " yet ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"T", "(", "u", ")"}], "-", 
     RowBox[{"T", "(", "v", ")"}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d26aaaac-a972-4bad-8db6-05d63d01bb6f"]
}], "Text",
 CellChangeTimes->{{3.904659031413983*^9, 
  3.9046591611963463`*^9}},ExpressionUUID->"661fd0a2-360b-4c52-b9a2-\
2d6c19e0dd3d"],

Cell[TextData[{
 "if and only if there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", ",", 
    RowBox[{"v", "\[Element]", "V"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6717ae13-ac56-4d00-aed8-6b0da2b04a78"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[NotEqual]", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "643904b1-6537-4c17-904f-cf09740f9df1"],
 " yet ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"u", "-", "v"}], ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e79db5d6-03a9-4a8e-b452-bf59a64f850d"]
}], "Text",
 CellChangeTimes->{{3.904659031413983*^9, 
  3.904659166953692*^9}},ExpressionUUID->"3ac1b46b-8042-41d8-9983-\
ddb130a217db"],

Cell[TextData[{
 "if and only if there exist ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", ",", 
    RowBox[{"v", "\[Element]", "V"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a5aa6e6e-d413-4db7-bccf-e99821dab8b0"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[NotEqual]", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b4baf3af-d348-4381-8f81-3e85d62e3457"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"u", "-", "v"}], ")"}], "\[Element]", 
    RowBox[{"N", "(", "T", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c0745bc2-342a-44c3-a80c-daaacb339ea8"]
}], "Text",
 CellChangeTimes->{{3.9046591899439864`*^9, 3.904659212593541*^9}, {
  3.90465928534832*^9, 3.9046592853503203`*^9}, {3.9046593264894753`*^9, 
  3.90465932897818*^9}},ExpressionUUID->"8533da44-970c-4179-b802-\
f8f94356b0c2"],

Cell[TextData[{
 "if and only if there exists ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", ",", 
    RowBox[{"v", "\[Element]", "V"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f541cbb9-b8f2-4a06-b92d-252d37d64f29"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "\[NotEqual]", "v"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "327de676-0c7f-4ce1-9569-ceb94630101c"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "=", 
    RowBox[{
     RowBox[{"u", "-", "v"}], "\[NotEqual]", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "785b3e7e-e2a8-4f7d-9efb-a4eaf1b9979d"],
 " but ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "w", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "01bf446e-de7d-45d0-8142-30a11e8054c8"],
 "  (for example, to work up, we can write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "=", 
    RowBox[{
     RowBox[{"3", "w"}], "-", 
     RowBox[{"2", "w"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fb5d4839-797a-4c93-a827-dc3bfd791cbf"],
 ")"
}], "Text",
 CellChangeTimes->{{3.9046591899439864`*^9, 3.904659212593541*^9}, {
   3.90465928534832*^9, 3.9046592853503203`*^9}, {3.9046593264894753`*^9, 
   3.9046593293462057`*^9}, {3.9046594279795995`*^9, 
   3.9046594718760705`*^9}, {3.9046595187005897`*^9, 3.904659576549445*^9}, 
   3.904659622009486*^9},ExpressionUUID->"ff2cef7a-4010-45f2-a19b-\
c8f7debcc594"],

Cell[TextData[{
 "if and only if there exists ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", "V"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f30d4d9b-de98-413a-b505-04c57dcecea0"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[NotEqual]", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e44cc2c2-36ff-4e35-9069-b0a061fb2f60"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "w", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0ef5b770-6a94-4d6b-89c4-8643837f961c"]
}], "Text",
 CellChangeTimes->{{3.9046591899439864`*^9, 3.904659212593541*^9}, {
  3.90465928534832*^9, 3.9046592853503203`*^9}, {3.9046593264894753`*^9, 
  3.9046593684733377`*^9}},ExpressionUUID->"dbda39db-9e7e-4b63-a686-\
9a2e244252f2"],

Cell[TextData[{
 "if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "\[NotEqual]", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f74c4f9c-e8dc-47bb-85b7-2f1358bb2942"]
}], "Text",
 CellChangeTimes->{{3.9046591899439864`*^9, 3.904659212593541*^9}, {
  3.9046592880576897`*^9, 
  3.904659300694513*^9}},ExpressionUUID->"e7349cbb-c3ff-4fe6-91ea-\
b939c1879596"],

Cell[TextData[{
 "REMARK:  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    FormBox[
     RowBox[{
      RowBox[{"T", ":", "V"}], "\[Rule]", "W"}],
     TraditionalForm]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "077a1d06-0d18-4fb1-a8ea-a6998294ad47"],
 ", then ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c6a14c70-2809-4e77-9ac8-02e57f1b8aa0"],
 " is onto if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "=", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "adbe2357-3bdd-4414-950f-42a9f5a69cd7"],
 "."
}], "Text",
 CellChangeTimes->{{3.9046598343432055`*^9, 
  3.9046598562899647`*^9}},ExpressionUUID->"28cd1a81-8122-4bcb-b68e-\
974f1b6093f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203891011306877`*^9, 3.6203891497961516`*^9}, {
   3.6207364387148905`*^9, 3.620736439121175*^9}, 
   3.841915752666336*^9},ExpressionUUID->"5f3516de-3d64-4c86-b0f8-\
d112c9170386"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e73471d0-fb69-4a00-a04e-411ffdd763ff"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "047aa54d-13f4-401d-b1f7-d1473d0fd252"],
 " be finite dimensional vector spaces over a field \[DoubleStruckCapitalF] \
and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
  ExpressionUUID->"1edbde66-0590-466e-8cc4-e7033e811f77"],
 " a linear transformation.  If ",
 StyleBox["dim",
  FontColor->RGBColor[0.7, 0, 0.3]],
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", "V", ")"}], "=", 
     RowBox[{"dim", "(", "W", ")"}]}], ",", " "}], TraditionalForm]],
  FontColor->RGBColor[0.7, 0, 0.3],ExpressionUUID->
  "33441e24-f3a2-4d15-8067-9651b2ff3ff3"],
 "then the following are equivalent."
}], "Text",
 CellChangeTimes->{{3.6203897026748533`*^9, 3.6203897899054823`*^9}, {
   3.6207348923262796`*^9, 3.620734893572381*^9}, {3.620738328564801*^9, 
   3.6207383290335784`*^9}, {3.6207393523162284`*^9, 3.620739356988346*^9}, 
   3.872941704609948*^9, {3.8729418269801884`*^9, 
   3.8729418293974133`*^9}},ExpressionUUID->"703718c5-de77-4ecb-b292-\
ba87e29b5acb"],

Cell[TextData[{
 "\t(a)  ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "10393b88-2b67-4189-a35b-5785b9f541a2"],
 " is one-to-one."
}], "Text",
 CellChangeTimes->{{3.6203897026748533`*^9, 
  3.6203898238865585`*^9}},ExpressionUUID->"316986bf-ead2-4914-8e0d-\
a7ed13360389"],

Cell[TextData[{
 "\t(b) ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "d9c2a250-2907-4f15-9a72-f4a2c42a3373"],
 " is onto."
}], "Text",
 CellChangeTimes->{{3.6203897026748533`*^9, 
  3.6203898506614285`*^9}},ExpressionUUID->"e24352b6-d8c9-4555-b898-\
c116888b4e1b"],

Cell[TextData[{
 "\t(c) rank(",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "d7e8ae92-84cf-49f1-91b0-d6835407d3bf"],
 ") = dim",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", "V", ")"}], "=", 
    RowBox[{"dim", "(", "W", ")"}]}], TraditionalForm]],ExpressionUUID->
  "31e68e6d-f454-4343-972b-dd5bbc82ec24"],
 "."
}], "Text",
 CellChangeTimes->{{3.6203897026748533`*^9, 3.6203898751277637`*^9}, {
  3.872941745091501*^9, 
  3.872941750693801*^9}},ExpressionUUID->"3cb56e12-c759-4d5c-9384-\
cb094920ca69"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["PROOF: ",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Plain"]
}], "Subsubsubsection",
 CellChangeTimes->{{3.620736443558888*^9, 3.620736445715252*^9}, {
  3.620736973050677*^9, 
  3.6207369730663033`*^9}},ExpressionUUID->"92c0968a-3325-487f-9690-\
fc3ae5c74148"],

Cell[TextData[{
 "Throughout the proof we assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", 
     RowBox[{"(", "V", ")"}]}], "=", 
    RowBox[{"dim", 
     RowBox[{"(", "W", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c7dfd5f5-76c9-42a5-a2a1-fd18551b925f"],
 ".  The result is NOT true otherwise.  "
}], "Text",
 CellChangeTimes->{{3.6203897026748533`*^9, 3.6203898136997724`*^9}, {
  3.620739413244997*^9, 3.620739414600899*^9}, {3.8731979704098406`*^9, 
  3.87319799319217*^9}, {3.9043929283399763`*^9, 3.90439293044141*^9}, {
  3.904650373137502*^9, 
  3.904650384468565*^9}},ExpressionUUID->"51f06bcc-2364-410f-a511-\
e466e98b7500"],

Cell[TextData[{
 "We will employ the proof strategy of showing ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", "a", ")"}], "\[Implies]", 
    RowBox[{
     RowBox[{"(", "c", ")"}], "\[Implies]", 
     RowBox[{
      RowBox[{"(", "b", ")"}], "\[Implies]", 
      RowBox[{"(", "a", ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "51ff3c99-e012-41fb-876e-070f2da54533"],
 "."
}], "Text",
 CellChangeTimes->{{3.904660098500197*^9, 3.904660147031167*^9}, {
  3.9046603523099847`*^9, 
  3.9046603546181974`*^9}},ExpressionUUID->"4918e518-c84e-4afa-a71c-\
b0c838cac4ee"],

Cell[TextData[{
 "(a)\[Implies](c):  Assume ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fb1450d5-b626-49f7-a98a-96fc0a05cc74"],
 " is one-to-one. Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "22882997-eb04-4484-9126-51ffd30fee60"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"nullity", "(", "T", ")"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1601d33e-a6d8-41f2-8017-e5f82043efa0"],
 " and we know ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"rank", "(", "T", ")"}], "+", 
     RowBox[{"nullity", "(", "T", ")"}]}], "=", 
    RowBox[{
     RowBox[{"dim", "(", "V", ")"}], "=", 
     RowBox[{"dim", "(", "W", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "0c560753-6d52-4469-aa59-53981335c8a0"],
 ", and thus",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"rank", "(", "T", ")"}], "=", 
     RowBox[{
      RowBox[{"dim", "(", "V", ")"}], "=", 
      RowBox[{
       RowBox[{"dim", "(", "W", ")"}], "."}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1b61e4f6-d746-49c0-b131-084a527a40ba"]
}], "Text",
 CellChangeTimes->{{3.9046601807909365`*^9, 
  3.9046603491765857`*^9}},ExpressionUUID->"646bd51a-defe-4faa-ba2a-\
c4401bff6e75"],

Cell[TextData[{
 "(c)\[Implies](b): Assume ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", 
     FormBox["T",
      TraditionalForm], ")"}], "=", 
    RowBox[{"dim", 
     FormBox[
      RowBox[{
       RowBox[{"(", "V", ")"}], "=", 
       RowBox[{"dim", "(", "W", ")"}]}],
      TraditionalForm]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3b6dc288-6807-4a43-bb76-9c8bcc6ea26b"],
 ".  Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "\[SubsetEqual]", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7cc5d49b-2415-4191-9bd1-6dfea5f9909a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "=", 
    RowBox[{"dim", "(", "W", ")"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4aa4131a-8fb7-4bb2-bbdb-979ba8cb8e11"],
 ", we can conclude that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "T", ")"}], "=", "W"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "04d157aa-8d29-4be1-85e5-e2503068fcae"],
 " establishing that ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3de3f723-ce9d-4584-83c0-169b6d990c6d"],
 " is onto."
}], "Text",
 CellChangeTimes->{{3.90466037023251*^9, 
  3.9046604898582115`*^9}},ExpressionUUID->"6485bec7-8b8e-4dff-bb20-\
6d8ef703bf1e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", "b", ")"}], "\[Implies]", 
     RowBox[{"(", "a", ")"}]}], ":", " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "48fd3e7a-2786-4b1b-beb5-629957efa0e5"],
 "Assume ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d9fa14c3-f3ef-401b-be7a-a567dd73d6d6"],
 " is onto.  Then  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"rank", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{"dim", "(", "W", ")"}], "=", 
     RowBox[{"dim", "(", "V", ")"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8165fc46-df2d-407a-a9d7-79c9e1928dd6"],
 ", and hence since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"nullity", "(", "T", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"dim", "(", "V", ")"}], "-", 
      RowBox[{"rank", "(", "T", ")"}]}], "=", "0"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "224e75fe-ee34-4161-8bbd-3a709a5a3c65"],
 ", we can conclude that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", "T", ")"}], "=", 
    RowBox[{"{", "0", "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9072c26d-e504-451e-8c01-62d976da1685"],
 " and hence ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "95278a95-7540-4998-8ccf-3ab0756742d4"],
 " is one-to one. "
}], "Text",
 CellChangeTimes->{{3.904660520363082*^9, 
  3.9046606451251535`*^9}},ExpressionUUID->"9f6dce54-be3b-48ce-a7fc-\
eb8c21c15887"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
