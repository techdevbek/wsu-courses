Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338864794811*^9}, {3.6213389834840994`*^9, 
   3.621338987328038*^9}, {3.621339178981964*^9, 3.62133917973199*^9}, 
   3.8425220328218484`*^9},
 FontSize->16,ExpressionUUID->"a29b44e5-b6f6-4008-bf55-f3c36a856e1b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "3ac63277-81c2-4b11-baef-1fe8a0cefadd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", " "}], TraditionalForm]],ExpressionUUID->
  "3a73c652-a0b4-4b42-b455-be577e03ded6"],
 "be vector spaces over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
    ExpressionUUID->"216f7190-4345-47d6-bdee-c640d1bee243"]],ExpressionUUID->
    "51d6de62-28f4-49ba-a8fd-98d8b437b4b1"], TraditionalForm]],ExpressionUUID->
  "91127a82-4874-48a5-b20d-dfe738b8057a"],
 " be an invertible linear transformation.  Then"
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
  3.621338848168948*^9, 3.621338864794811*^9}, {3.6213389834840994`*^9, 
  3.621338987328038*^9}, {3.621339178981964*^9, 3.62133917973199*^9}},
 FontSize->16,ExpressionUUID->"cb6cece1-2350-4ec6-aaac-abd8f292fe91"],

Cell[TextData[{
 "(i)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"-", "1"}]], ":", "W"}], "\[Rule]", "V"}], TraditionalForm]],
  ExpressionUUID->"ce6d15aa-7e29-4bce-8cba-abd1eab0d0c6"],
 " is a linear transformation."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
  3.621338848168948*^9, 3.6213389095312443`*^9}},
 FontSize->16,ExpressionUUID->"e8435a3e-bfe9-48f9-bb1d-16db607dd310"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      SuperscriptBox["T", 
       RowBox[{"-", "1"}]], ")"}], 
     RowBox[{"-", "1"}]], "=", "T"}], TraditionalForm]],ExpressionUUID->
  "c2799a91-8601-45e7-bc2d-d27dee0b0282"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, {3.6213389798589115`*^9, 
   3.6213390132356577`*^9}, {3.621339215901774*^9, 3.621339215901774*^9}, 
   3.6213402829417396`*^9},
 FontSize->16,ExpressionUUID->"0f800d4d-6252-4c99-8882-cd812b0d1daf"],

Cell[TextData[{
 "(iii) If ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7aaf93cd-d878-4187-a1ae-8bce6bb7afa4"],
 " is finite dimensional, then dim(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", ")"}], "=", " ", 
    RowBox[{"dim", "(", "V", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b5ae42fa-a4d8-4ced-aea6-ac27fa772a33"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, {3.6213389798589115`*^9, 
   3.6213390132356577`*^9}, {3.621339215901774*^9, 3.6213392879867105`*^9}, {
   3.6213396418756475`*^9, 3.6213396418756475`*^9}, 3.8425220822477226`*^9},
 FontSize->16,ExpressionUUID->"655675f5-47f5-41ba-9525-68c0a2459f1b"],

Cell[TextData[{
 "(iv)  If ",
 Cell[BoxData[
  FormBox[
   RowBox[{Cell[TextData[Cell[BoxData[
     FormBox[
      RowBox[{
       RowBox[{"S", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
     ExpressionUUID->"e0473195-cbe4-4d20-8db0-3d193afe7278"]],ExpressionUUID->
     "d6892f46-e694-47df-aaef-cf3f109234da"], " "}], TraditionalForm]],
  ExpressionUUID->"1b513149-5cec-41a4-ba49-ff76a06fe5ab"],
 "is an invertible linear transformation, then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"S", " ", "T"}], ")"}], 
     RowBox[{"-", "1"}]], "=", Cell[TextData[{
     Cell[BoxData[
      FormBox[
       RowBox[{
        SuperscriptBox["T", 
         RowBox[{"-", "1"}]], 
        SuperscriptBox["S", 
         RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
      "2c27abdd-8f42-4f27-909b-5ec6eff32198"],
     "."
    }],ExpressionUUID->"270f4a88-e166-4e77-8535-7ac8c433d90e"]}], 
   TraditionalForm]],ExpressionUUID->"1fd818c1-616f-4dd7-9ff9-9ffde7030527"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
  3.621338848168948*^9, 3.621338932751212*^9}, {3.6213389798589115`*^9, 
  3.6213390132356577`*^9}, {3.621339215901774*^9, 3.6213392879867105`*^9}, {
  3.6213396418756475`*^9, 3.621339699112985*^9}, {3.6213427912316895`*^9, 
  3.6213427912316895`*^9}, {3.9054381984009356`*^9, 3.905438200048586*^9}},
 FontSize->16,ExpressionUUID->"3cee30b3-dd9b-4368-8065-225f1d74ccfe"],

Cell[TextData[{
 "(v)  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", " "}], TraditionalForm]],ExpressionUUID->
  "5e70a58f-d9f6-4e5d-b0bf-f565b255ede2"],
 "is one-to-one and onto.  "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
  3.621338848168948*^9, 3.621338932751212*^9}, {3.6213389798589115`*^9, 
  3.6213390132356577`*^9}, {3.621339215901774*^9, 3.6213392879867105`*^9}, {
  3.6213396418756475`*^9, 3.621339699112985*^9}, {3.6213427912316895`*^9, 
  3.6213428085606995`*^9}, {3.621343064522817*^9, 3.6213430684761715`*^9}},
 FontSize->16,ExpressionUUID->"54391058-90d1-43c2-a56a-2326913248d8"],

Cell["PROOF: ", "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
  3.621338848168948*^9, 3.621338932751212*^9}, {3.6213389798589115`*^9, 
  3.621339025720663*^9}, {3.6213392907837257`*^9, 3.621339294080775*^9}, {
  3.621339393554385*^9, 3.621339393554385*^9}},
 FontSize->14,ExpressionUUID->"04d9004c-9f1e-4f24-9818-a54a853ba442"],

Cell["", "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
