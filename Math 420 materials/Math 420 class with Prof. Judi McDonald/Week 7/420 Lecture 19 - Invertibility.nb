   3.8387365163000507`*^9}},
 TextAlignment->Center,ExpressionUUID->"28ef0196-bf89-4053-9813-6dc8f407d461"],

Cell[TextData[{
 "QUESTION 2 on this weeks homework:  When you are trying to show two sets \
are equal, say ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", "S"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d1674ccf-f4cc-4ef5-9eae-d154f5ec7ebb"],
 ", sometimes it works to show ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[SubsetEqual]", "S"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "54935dc3-1e1c-4f84-a040-04ed39a967bd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[SubsetEqual]", "R"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c145ee02-9d1a-424b-bb2b-c5db0348b91f"],
 "."
}], "Text",
 CellChangeTimes->{{3.9054351919466166`*^9, 3.9054352386920586`*^9}, {
  3.90543547267636*^9, 
  3.9054354995623846`*^9}},ExpressionUUID->"3c953b67-9a59-40b8-9977-\
0276d7e11fd8"],

Cell[TextData[{
 "QUESTION 4: Examples of vector spaces: ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "973845ab-9b49-4c91-a83c-4f40cd4b9f0d"],
 ", \[DoubleStruckCapitalR], \[DoubleStruckCapitalC], {0}, Matrices,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalP]", "n"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8b2497eb-f566-4f49-bd40-c1be5ed1e5a4"]
}], "Text",
 CellChangeTimes->{{3.9054355259540796`*^9, 
  3.9054356243800497`*^9}},ExpressionUUID->"70dfabcc-fa47-40bc-a5b9-\
616a11dbe113"],

