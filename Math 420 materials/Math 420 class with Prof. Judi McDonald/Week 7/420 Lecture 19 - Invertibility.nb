Cell[TextData[{
 "Find ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", 
     SubscriptBox["I", "V"], "]"}], "\[Alpha]", "\[Beta]"], TraditionalForm]],
  ExpressionUUID->"be6215fd-a758-4cf7-a303-b4e2a7ca5d6c"],
 " when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {
          RowBox[{"-", "1"}]},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], " ", ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {"1"},
         {"1"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}]}], " ", "}"}], " "}], TraditionalForm]],
  ExpressionUUID->"0f443614-2211-41a8-bda7-6410bb9b3d51"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {"2"},
         {"1"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"1"},
         {"0"},
         {"0"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}], " ", ",", 
      RowBox[{
       GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
         {"0"},
         {"1"},
         {"1"}
        }], "\[NoBreak]", 
       GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
         LineBox[{{0, 0}, {1, 0}}]},
        ImageSize->{5, 50}]}]}], " ", "}"}]}], TraditionalForm]],
  ExpressionUUID->"b8552231-91ad-49a0-877a-f77baf0ad4e2"]
}], "Text",
