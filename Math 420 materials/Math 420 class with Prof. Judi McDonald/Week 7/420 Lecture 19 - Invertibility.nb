Cell[TextData[StyleBox["Recall: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6213400833689947`*^9, 3.6213401627977257`*^9}, 
   3.8425220002562456`*^9, {3.8733597204210443`*^9, 3.8733597455633483`*^9}},
 FontSize->16,ExpressionUUID->"f2f96026-827d-427b-b0a9-bf6bbdf79237"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["I", "V"], ":", "V"}], "\[Rule]", "V"}], TraditionalForm]],
  ExpressionUUID->"845fd8bb-b38d-4a53-85ca-71cd7ac652fd"],
 " is the linear transformation such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["I", "V"], "(", "v", ")"}], "=", "v"}], ",", " ", 
    RowBox[{"\[ForAll]", 
     RowBox[{"v", "\[Element]", 
      RowBox[{"V", "."}]}]}]}], TraditionalForm]],ExpressionUUID->
  "ccdb5747-dced-4f75-a7ca-09eb1b079f41"]
}], "Text",
 CellChangeTimes->{{3.6213400833689947`*^9, 3.6213401627977257`*^9}},
 FontSize->16,ExpressionUUID->"0e4a0dea-d099-4487-9313-db1ef96fb168"]
}, Open  ]],

