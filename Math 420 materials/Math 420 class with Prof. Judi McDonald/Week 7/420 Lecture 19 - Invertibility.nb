Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.6203886088000836`*^9, 3.620388801442622*^9}, 
   3.6203891207237635`*^9, {3.6205617066601405`*^9, 3.6205617066601405`*^9}, {
   3.620736073812117*^9, 3.62073614726906*^9}, {3.6207361899626207`*^9, 
   3.6207361937127953`*^9}, {3.62099235466839*^9, 3.620992462186183*^9}, {
   3.6209925324669895`*^9, 3.620992536435944*^9}, {3.620992708448018*^9, 
   3.620992822657107*^9}, {3.620993883295639*^9, 3.6209940795154953`*^9}, 
   3.6209941308075027`*^9, {3.6209977161927443`*^9, 3.6209977184841127`*^9}, {
   3.620997874799956*^9, 3.6209978783157496`*^9}, {3.620997952332549*^9, 
   3.6209979714035807`*^9}, {3.621165272553954*^9, 3.6211652937269073`*^9}, 
   3.6211659216592555`*^9, {3.621166746977624*^9, 3.621166958257507*^9}, {
   3.6213388088544016`*^9, 3.6213388324025044`*^9}, {3.621339814751517*^9, 
   3.621339816439105*^9}, {3.6213422707396784`*^9, 3.6213422756305614`*^9}, 
   3.842522028414048*^9},
 FontSize->16,ExpressionUUID->"db71fa7a-ee99-4d57-950f-85a989625df8"],

Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ecebf2d3-7ae9-4239-85de-36ebcb7904f4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", " "}], TraditionalForm]],ExpressionUUID->
  "ebae4882-cf0b-45fa-8e68-228492dabb63"],
 "be vector spaces over a field \[DoubleStruckCapitalF].  Let ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      RowBox[{"T", ":", "V"}], "\[Rule]", "W"}], TraditionalForm]],
    ExpressionUUID->"e97da60c-884f-4138-9896-135396d492ba"]],ExpressionUUID->
    "c15aed10-1c6a-45f0-a490-a8e28f4c2c2c"], TraditionalForm]],ExpressionUUID->
  "a393ef5f-ce95-4a85-9c5c-128368a67e24"],
 " be a linear transformation.  A transformation ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      RowBox[{"S", ":", "W"}], "\[Rule]", "V"}], TraditionalForm]],
    ExpressionUUID->"3ddc4098-ede0-4867-b61f-7e96713cfb40"]],ExpressionUUID->
    "5d38a56d-ff84-48fa-97d2-dc134f2d5c9c"], TraditionalForm]],ExpressionUUID->
  "52252d12-ec74-48fc-b72d-db97dc1ff845"],
 " is called the ",
 StyleBox["inverse",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 " of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "5ee9a6d8-4964-4026-b31d-cb4bcc296348"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", " ", "T"}], "=", 
    SubscriptBox["I", "V"]}], TraditionalForm]],ExpressionUUID->
  "0829c258-2087-461e-a2e5-5d72ae111495"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", " ", "S"}], "=", 
    SubscriptBox["I", "W"]}], TraditionalForm]],ExpressionUUID->
  "73425140-0bab-4ee9-ae1c-2659b562f668"],
 ".  If ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "7c2c946b-c621-402a-a460-913ff588c3c5"],
 " has an inverse, it is said to be ",
 StyleBox["invertible",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox[",",
  FontColor->RGBColor[0, 0, 0]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 StyleBox["and the inverse is denoted by",
  FontColor->RGBColor[0, 0, 0]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 Cell[BoxData[
  FormBox[
   StyleBox[
    SuperscriptBox["T", 
     RowBox[{"-", "1"}]],
    FontColor->GrayLevel[0]], TraditionalForm]],
  FontColor->RGBColor[0, 0, 1],ExpressionUUID->
  "96890b56-a2e7-40b8-a4d4-8239b7088717"],
 "."
}], "Text",
 CellChangeTimes->{{3.6203886088000836`*^9, 3.620388801442622*^9}, 
   3.6203891207237635`*^9, {3.6205617066601405`*^9, 3.6205617066601405`*^9}, {
   3.620736073812117*^9, 3.62073614726906*^9}, {3.6207361899626207`*^9, 
   3.6207361937127953`*^9}, {3.62099235466839*^9, 3.620992462186183*^9}, {
   3.6209925324669895`*^9, 3.620992536435944*^9}, {3.620992708448018*^9, 
   3.620992822657107*^9}, {3.620993883295639*^9, 3.6209940795154953`*^9}, 
   3.6209941308075027`*^9, {3.6209977161927443`*^9, 3.6209977184841127`*^9}, {
   3.620997874799956*^9, 3.6209978783157496`*^9}, {3.620997952332549*^9, 
   3.6209979714035807`*^9}, {3.621165272553954*^9, 3.6211652937269073`*^9}, 
   3.6211659216592555`*^9, {3.621166746977624*^9, 3.621166958257507*^9}, {
   3.6213388088544016`*^9, 3.6213388324025044`*^9}, {3.621339814751517*^9, 
   3.621339816439105*^9}, {3.6213422707396784`*^9, 3.6213422756305614`*^9}, {
   3.90543781049557*^9, 3.905437810521082*^9}},
 FontSize->16,ExpressionUUID->"0629c866-b0db-4dd2-b5bb-e9a606f2d6b9"],

Cell["Invertible and nonsingular are synonyms ", "Text",
 CellChangeTimes->{{3.6203886088000836`*^9, 3.620388801442622*^9}, 
   3.6203891207237635`*^9, {3.6205617066601405`*^9, 3.6205617066601405`*^9}, {
   3.620736073812117*^9, 3.62073614726906*^9}, {3.6207361899626207`*^9, 
   3.6207361937127953`*^9}, {3.62099235466839*^9, 3.620992462186183*^9}, {
   3.6209925324669895`*^9, 3.620992536435944*^9}, {3.620992708448018*^9, 
   3.620992822657107*^9}, {3.620993883295639*^9, 3.6209940795154953`*^9}, 
   3.6209941308075027`*^9, {3.6209977161927443`*^9, 3.6209977184841127`*^9}, {
   3.620997874799956*^9, 3.6209978783157496`*^9}, {3.620997952332549*^9, 
   3.6209979714035807`*^9}, {3.621165272553954*^9, 3.6211652937269073`*^9}, 
   3.6211659216592555`*^9, {3.621166746977624*^9, 3.621166958257507*^9}, {
   3.6213388088544016`*^9, 3.6213388324025044`*^9}, {3.621339814751517*^9, 
   3.621339816439105*^9}, {3.6213422707396784`*^9, 3.6213422756305614`*^9}, {
   3.9054378115895023`*^9, 3.905437856563717*^9}, {3.905437891529688*^9, 
