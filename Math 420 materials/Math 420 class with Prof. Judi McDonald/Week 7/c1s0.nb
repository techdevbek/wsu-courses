Cell[TextData[{
 StyleBox["2.  ",
  FontWeight->"Bold"],
 "Using the table from Example 1, create a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[Cross]", "4"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d45ee4cb-42d5-4529-b852-6b3b0e72aec9"],
