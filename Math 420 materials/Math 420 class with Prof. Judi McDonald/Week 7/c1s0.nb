Cell["Is a diagonal matrix upper triangular or lower triangular?", "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498234954825*^9}, {3.5505784270087*^9, 
   3.5505784506857*^9}, 3.5506718684487*^9, 3.626177550553909*^9, 
   3.8945319499898877`*^9, {3.8945424380150285`*^9, 3.8945424427754345`*^9}, {
   3.894637913792821*^9, 3.8946379316126227`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"b35a1119-9e26-43a1-8d0a-63e50c7dd781"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["SOLUTION", "SolutionFont"]], "Subsubsubsubsection",
 FontFamily->
  "Times New Roman",ExpressionUUID->"2b2236e3-07cc-459f-ae4c-0630ef033852"],

Cell["\<\
Since the entries below the main diagonal of a diagnonal matrix are zero, it \
is upper triangular.  Since the entries above the main diagonal are also \
zero, it is a lower triangular matrix as well.  \
\>", "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498237499185*^9}, {3.5498237846597*^9, 
   3.5498238682757*^9}, {3.5498239937621*^9, 3.5498240071469*^9}, {
   3.5505785302255*^9, 3.5505785464059*^9}, {3.6267044756322765`*^9, 
   3.626704477507373*^9}, {3.8945431697735286`*^9, 3.8945433379593153`*^9}, {
   3.8945433689777355`*^9, 3.894543486935153*^9}, {3.8946308270587053`*^9, 
   3.894630967641828*^9}, {3.8946314747983866`*^9, 3.894631485884124*^9}, 
   3.894631833147395*^9, {3.894633559930974*^9, 3.894633577289428*^9}, {
   3.8946379509622936`*^9, 3.8946380777556033`*^9}, {3.9005030964552546`*^9, 
   3.90050309836915*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e62c27a8-ef72-4438-95cd-9e95d66c730b"],

