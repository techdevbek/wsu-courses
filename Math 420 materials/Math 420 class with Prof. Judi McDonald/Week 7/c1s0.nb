 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "31"], TraditionalForm]],ExpressionUUID->
  "e1f2cbde-d75a-43ef-bcf2-0950e732885b"],
 "."
}], "Text",
 CellChangeTimes->{{3.8945426603681912`*^9, 3.8945429118129582`*^9}, {
   3.8945433514031982`*^9, 3.8945433530669527`*^9}, 
   3.894631872640521*^9},ExpressionUUID->"c10260c9-23f5-4906-8539-\
0708228499bc"],

Cell[TextData[{
 "(c) Describe the positions of the numbers ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "9"}], TraditionalForm]],ExpressionUUID->
  "6ae9797b-663b-4e96-aff9-c2108cc4a068"],
 " and ",
 Cell[BoxData[
  FormBox["5", TraditionalForm]],ExpressionUUID->
  "4bbe87f4-ad17-4056-9466-d78c34961a7c"],
 " using letters with numerical subscripts.  "
}], "Text",
 CellChangeTimes->{{3.8945426603681912`*^9, 3.8945429118129582`*^9}, {
  3.8945433514031982`*^9, 
  3.8945433530669527`*^9}},ExpressionUUID->"1d1490ed-68e9-4c73-9ae6-\
2c1175792760"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["SOLUTION", "SolutionFont"]], "Subsubsubsubsection",
 FontFamily->
  "Times New Roman",ExpressionUUID->"925d287b-758c-4ffd-93de-69ffb709c307"],

Cell[TextData[{
 "(a) Matrix ",
 StyleBox["A ",
  FontSlant->"Italic"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Cross]", "3"}], TraditionalForm]],ExpressionUUID->
  "7e90092e-058e-47e9-9ff1-7684e5290395"],
 ", while matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "39d3b113-ccbd-47c2-bf9c-cd7f902fbd1d"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "\[Cross]", "2.", " "}], TraditionalForm]],ExpressionUUID->
  "cf3a4008-b9ca-40d9-875a-e5b880b084c6"]
}], "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498237499185*^9}, {3.5498237846597*^9, 
   3.5498238682757*^9}, {3.5498239937621*^9, 3.5498240071469*^9}, {
   3.5505785302255*^9, 3.5505785464059*^9}, {3.6267044756322765`*^9, 
   3.626704477507373*^9}, {3.8945431697735286`*^9, 3.8945433379593153`*^9}, {
   3.8945433689777355`*^9, 3.894543486935153*^9}, 3.894631877009885*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e6ba316d-c94b-426b-9984-91e3abbf07b8"],

Cell[TextData[{
 "(b) Since  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "23"], TraditionalForm]],ExpressionUUID->
  "9d0d6f5d-af8a-4e59-98fc-e1d06540912f"],
 " refers to the entry in row two and column three of the matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "538c9279-0d1a-448f-bc3f-6658a57c8cf5"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "23"], "=", "3"}], TraditionalForm]],ExpressionUUID->
  "9e3b74a2-21f1-40a3-8965-df3ea006c1c9"],
 ". Similarly, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "31"], TraditionalForm]],ExpressionUUID->
  "c621ed9b-9d07-4fd2-afa3-126189376daf"],
 " refers to the entry in row three and column one of the matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "e606d0ac-7143-4e1d-945b-5857555dcd19"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "31"], "=", "3"}], TraditionalForm]],ExpressionUUID->
  "c13f2302-e9db-4ff6-b003-175602c9aeed"],
 "."
}], "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498237499185*^9}, {3.5498237846597*^9, 
   3.5498238682757*^9}, {3.5498239937621*^9, 3.5498240071469*^9}, {
   3.5505785302255*^9, 3.5505785464059*^9}, {3.6267044756322765`*^9, 
   3.626704477507373*^9}, {3.8945431697735286`*^9, 3.8945433379593153`*^9}, {
   3.8945433689777355`*^9, 3.894543486935153*^9}, 3.8946318811607485`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e4d691da-d2e0-411f-b4dc-e16651170070"],

Cell[TextData[{
 "(c) Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "9"}], TraditionalForm]],ExpressionUUID->
  "bcbf3d79-694b-4612-84f4-54988bbad198"],
 " occurs in the second row and third column of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "9fa469f8-8976-4da3-9830-07e9bac8810c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "9"}], "=", 
    RowBox[{
     SubscriptBox["a", "22"], "."}]}], TraditionalForm]],ExpressionUUID->
  "750c8028-9d02-4ce3-b181-0bc871864e76"],
 " Similarly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"5", "=", 
    SubscriptBox["m", "12"]}], TraditionalForm]],ExpressionUUID->
  "479ec935-45ac-46f6-a56f-c744e603dba8"],
 ".  "
}], "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498237499185*^9}, {3.5498237846597*^9, 
   3.5498238682757*^9}, {3.5498239937621*^9, 3.5498240071469*^9}, {
   3.5505785302255*^9, 3.5505785464059*^9}, {3.6267044756322765`*^9, 
   3.626704477507373*^9}, {3.8945431697735286`*^9, 3.8945433379593153`*^9}, {
   3.8945433689777355`*^9, 3.894543486935153*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"67cfa6cf-710f-4274-91ef-05a6e5ab1cbe"],

Cell[TextData[StyleBox["\[FilledSquare]", "SolutionEndFont"]], "Text",
 TextAlignment->Right,
 FontFamily->
  "Times New Roman",ExpressionUUID->"67677535-4b93-4e1a-a2ce-05058a2552ac"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 "\tIt is often convenient to work with a ",
 StyleBox["generic",
  FontSlant->"Italic"],
 " matrix, one were the numbers are not actually known or represented.  In \
this case, only letters with subscripts are used, but you can imagine the \
entries as numbers."
}], "Text",
 CellChangeTimes->{3.8946311759886675`*^9, 
  3.89463124666706*^9},ExpressionUUID->"cf00a5fe-60d9-442f-9c2c-52ad00225a98"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["EXAMPLE 3", "ExampleFont"]], "Subsubsubsection",
 CellChangeTimes->{
  3.626704328978153*^9, {3.8945436128987184`*^9, 3.894543613434141*^9}, {
   3.9010236782113657`*^9, 3.9010236803437977`*^9}},
 FontFamily->"Times New Roman",
 CellTags->"EXAMPLE 3",ExpressionUUID->"44eb29a6-ad47-4b43-9992-730cd68ac3f8"],

Cell[TextData[{
 "Write out a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", "\[Cross]", "2"}], TraditionalForm]],ExpressionUUID->
  "cacab8e3-2f91-4b12-8ab8-232ff2aabc62"],
 " matrix ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "9591db4a-6fac-4870-b13f-8b7ae390231f"],
 " using letters with subscripts as its entries. "
}], "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498234954825*^9}, {3.5505784270087*^9, 
   3.5505784506857*^9}, 3.5506718684487*^9, 3.626177550553909*^9, 
   3.8945319499898877`*^9, {3.8945436402921104`*^9, 3.894543718808219*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"018dc1e4-0db2-48fd-a097-f99220251c1c"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["SOLUTION", "SolutionFont"]], "Subsubsubsubsection",
 FontFamily->
  "Times New Roman",ExpressionUUID->"a151ec95-db18-43f0-aee8-2c613bb7be83"],

Cell[TextData[{
 "The matrix ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "33e5861f-684b-41e6-bbdc-09b949f62884"],
 " needs to have four rows and two columns.  Each entry can be described \
using a lower case ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "9c39eaa2-5a21-46fc-8217-66311661046b"],
 " with the row and colunm numbers identified in the subscripts:"
}], "Text",
 CellChangeTimes->{
  3.5491129444842*^9, {3.5498229270653*^9, 3.5498229684053*^9}, {
   3.5498230024913*^9, 3.5498230125376997`*^9}, {3.5498230638461*^9, 
   3.5498231119565*^9}, {3.5498231586161003`*^9, 3.5498234013989*^9}, {
   3.5498234791649*^9, 3.5498237499185*^9}, {3.5498237846597*^9, 
   3.5498238682757*^9}, {3.5498239937621*^9, 3.5498240071469*^9}, {
   3.5505785302255*^9, 3.5505785464059*^9}, {3.6267044756322765`*^9, 
   3.626704477507373*^9}, {3.894543725769537*^9, 3.8945438262246957`*^9}, 
   3.8945438856868815`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ff5ec859-7740-4e3f-8c14-20b26a9e2489"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{
      StyleBox["B",
       FontWeight->"Plain"], "=", 
      TemplateBox[{
        GraphicsBox[{
          LineBox[{{0, 0}, {0, 40}}], 
          LineBox[{{0, 40}, {2, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
        TagBox[
         GridBox[{{
            RowBox[{"\[NoBreak]", 
              GridBox[{{
                 SubscriptBox["b", "11"], 
                 SubscriptBox["b", "12"]}, {
                 SubscriptBox["b", "21"], 
                 SubscriptBox["b", "22"]}, {
                 SubscriptBox["b", "31"], 
                 SubscriptBox["b", "32"]}, {
                 SubscriptBox["b", "41"], 
                 SubscriptBox["b", "42"]}}, 
               GridBoxAlignment -> {"Columns" -> {{"Right"}}}]}]}}, 
          AutoDelete -> False, GridBoxAlignment -> {"Columns" -> {{Right}}}, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
        GraphicsBox[{
          LineBox[{{2, 0}, {2, 40}}], 
          LineBox[{{0, 40}, {2, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
       "RowDefault"]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"25246a21-fcaa-4687-93bc-935dd6960725"]], \
"Text",
 CellChangeTimes->{{3.8945438321394334`*^9, 3.8945439213607817`*^9}, {
  3.8945441902883177`*^9, 
  3.894544190556221*^9}},ExpressionUUID->"e7e67011-4d87-4a76-b4f5-\
4a47837b98a8"],

Cell[TextData[StyleBox["\[FilledSquare]", "SolutionEndFont"]], "Text",
 TextAlignment->Right,
 FontFamily->
  "Times New Roman",ExpressionUUID->"a9fe5ec7-b6a1-4d74-a124-810868075506"]
}, Open  ]]
}, Open  ]],

Cell[TextData[{
 "\tWhen the number of rows and columns of a matrix is not known, triple dots \
are used to indicate the missing entries in the description.  For example, \
the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "59f04ece-072e-4b8f-8810-0eeb92167a62"],
 " matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "544d98fe-f9be-4928-ad57-67784a0b6f37"],
 " can be visualized as"
}], "Text",
 CellChangeTimes->{{3.894543960300053*^9, 3.8945440543710823`*^9}, {
  3.8946280767487946`*^9, 3.8946280776935863`*^9}, {3.894628867446419*^9, 
  3.894628869306032*^9}, {3.894631005966132*^9, 
  3.8946310189258738`*^9}},ExpressionUUID->"2bd8a004-0d56-4020-b405-\
c31e57a3bde8"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{"A", "=", 
      TemplateBox[{
        GraphicsBox[{
          LineBox[{{0, 0}, {0, 40}}], 
          LineBox[{{0, 40}, {2, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
        TagBox[
         GridBox[{{
            RowBox[{"\[NoBreak]", 
              GridBox[{{
                 SubscriptBox["a", "11"], 
                 SubscriptBox["a", "12"], "\[CenterEllipsis]", 
                 SubscriptBox["a", 
                  RowBox[{"1", "\[VeryThinSpace]", "n"}]]}, {
                 SubscriptBox["a", "21"], 
                 SubscriptBox["a", "22"], "\[CenterEllipsis]", 
                 SubscriptBox["a", 
                  RowBox[{"2", "\[VeryThinSpace]", "n"}]]}, {
                "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
                 "\[DescendingEllipsis]", "\[VerticalEllipsis]"}, {
                 SubscriptBox["a", 
                  RowBox[{"m", "\[VeryThinSpace]", "1"}]], 
                 SubscriptBox["a", 
                  RowBox[{"m", "\[InvisibleComma]", "2"}]], 
                 "\[CenterEllipsis]", 
                 SubscriptBox["a", 
                  RowBox[{"m", "\[VeryThinSpace]", "n"}]]}}, 
               GridBoxAlignment -> {"Columns" -> {{"Center"}}}]}]}}, 
          AutoDelete -> False, 
          GridBoxAlignment -> {"Columns" -> {{"Center"}}}, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
        GraphicsBox[{
          LineBox[{{2, 0}, {2, 40}}], 
          LineBox[{{0, 40}, {2, 40}}], 
          LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
       "RowDefault"]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], TraditionalForm]],
 TextAlignment->
  Center,ExpressionUUID->"aa6d4f2b-52d9-46bb-9715-eeb2352558b9"]], "Text",
 CellChangeTimes->{{3.8945438321394334`*^9, 3.8945439213607817`*^9}, {
  3.8945441176422033`*^9, 3.8945442851867046`*^9}, {3.8946268827392235`*^9, 
  3.8946268859630413`*^9}},ExpressionUUID->"72b34410-f800-488e-9073-\
bc436ba508f6"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "Vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"e92d48a7-2e4a-4d6f-9cfb-80cca766582c"]
}], "Subsection",
 CellChangeTimes->{{3.5570838687674*^9, 3.5570838705614*^9}, {
  3.8946289053211193`*^9, 3.894628916230135*^9}},
 FontFamily->"Times New Roman",
 CellTags->
  "Vectors in Rn",ExpressionUUID->"c7c18ef6-1284-4911-9db2-eb3b801d522b"],

Cell[TextData[{
 "A ",
 StyleBox["vector ",
  FontWeight->"Bold"],
 "in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "n"], TraditionalForm]],
  ExpressionUUID->"251a2924-6cd3-4203-9d5e-850404c9112c"],
 " is an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "1"}], TraditionalForm]],ExpressionUUID->
  "2c4af906-a7f3-4ae8-bbb3-1bf4d53495d1"],
 " matrix whose entries are chosen from the real numbers.  Since vectors only \
have one column, the second subscript is not needed when denoting specific \
entries.  Because vectors often play a special role in linear algebra, \
vectors in this textbook will be denoted using a boldface non-italic font.  \
For example, a vector ",
 Cell[BoxData[
  FormBox[
   StyleBox["x",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "c2482137-c871-4931-a497-32e904bed08d"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "2"], TraditionalForm]],
  ExpressionUUID->"51c19bed-13ba-445a-a4d4-e6f9e9cc9a60"],
 " would be denoted as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FormBox[
     StyleBox["x",
      FontWeight->"Bold",
      FontSlant->"Plain"],
     TraditionalForm], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {
        SubscriptBox["x", "1"]},
       {
        SubscriptBox["x", "2"]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], " "}]}], TraditionalForm]],ExpressionUUID->
  "e8ab88ea-1801-4696-a454-8418205d0b79"],
 ", whereas the vector ",
 Cell[BoxData[
  FormBox[
   StyleBox["y",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "f702c675-25eb-4059-82b6-aa445828f4ca"],
 " in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "4"], TraditionalForm]],
  ExpressionUUID->"07a9d95f-5d56-4b68-a001-084bbb8f47b7"],
 " would be illustrated as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FormBox[
     StyleBox["y",
      FontWeight->"Bold",
      FontSlant->"Plain"],
     TraditionalForm], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}], GridBox[{
       {
        SubscriptBox["y", "1"]},
       {
        SubscriptBox["y", "2"]},
       {
        SubscriptBox["y", "3"]},
       {
        SubscriptBox["y", "4"]}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]},
      ImageSize->{7, 65}], " "}]}], TraditionalForm]],ExpressionUUID->
  "fcd3f464-1545-4fc9-8ffa-f02602c6359b"],
 ".  In linear algebra, it is always important to pay attention to the \
context and what role each letter letter is playing in a description.   "
}], "Text",
 CellChangeTimes->{{3.894626987867606*^9, 3.894627097996495*^9}, {
  3.8946273464845953`*^9, 3.8946275307265244`*^9}, {3.8946290047866*^9, 
  3.894629089429294*^9}, {3.8946291584446173`*^9, 3.894629161930358*^9}, {
  3.894629274711063*^9, 3.894629295060742*^9}, {3.894629476093897*^9, 
  3.8946295864320726`*^9}, {3.894630393450449*^9, 3.8946304083447213`*^9}, {
  3.8946304832538705`*^9, 3.8946305485641923`*^9}, {3.8946314003413644`*^9, 
  3.894631425376545*^9}, {3.900502785788274*^9, 
  3.9005027863271627`*^9}},ExpressionUUID->"7766350d-8f8f-43a2-a168-\
d5c59e7997d5"],

Cell[TextData[{
 "\tOne of the important ways to view a matrix is to see it as a collection \
of vectors.  For example, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    TemplateBox[{
      GraphicsBox[{
        LineBox[{{0, 0}, {0, 40}}], 
        LineBox[{{0, 40}, {2, 40}}], 
        LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
      TagBox[
       GridBox[{{
          RowBox[{"\[NoBreak]", 
            GridBox[{{
               SubscriptBox["a", "11"], 
               SubscriptBox["a", "12"], "\[CenterEllipsis]", 
               SubscriptBox["a", 
                RowBox[{"1", "\[VeryThinSpace]", "n"}]]}, {
               SubscriptBox["a", "21"], 
               SubscriptBox["a", "22"], "\[CenterEllipsis]", 
               SubscriptBox["a", 
                RowBox[{"2", "\[VeryThinSpace]", "n"}]]}, {
              "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
               "\[DescendingEllipsis]", "\[VerticalEllipsis]"}, {
               SubscriptBox["a", 
                RowBox[{"m", "\[VeryThinSpace]", "1"}]], 
               SubscriptBox["a", 
                RowBox[{"m", "\[InvisibleComma]", "2"}]], "\[CenterEllipsis]", 
               SubscriptBox["a", 
                RowBox[{"m", "\[VeryThinSpace]", "n"}]]}}, 
             GridBoxAlignment -> {"Columns" -> {{"Center"}}}]}]}}, AutoDelete -> 
        False, GridBoxAlignment -> {"Columns" -> {{"Center"}}}, 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      GraphicsBox[{
        LineBox[{{2, 0}, {2, 40}}], 
        LineBox[{{0, 40}, {2, 40}}], 
        LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
     "RowDefault"]}], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->
  "a17dd4b0-a8e9-4409-aef2-071f0d5bde81"],
 ", then the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f22ebfb4-0cc2-4242-a94a-103a9aaf8277"],
 " columns of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "0655855e-0be5-4e75-a95c-f764a2e23963"],
 " can be viewed ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cadd54cb-2109-4ad7-8ce6-458b4e34dead"],
 " vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "m"], TraditionalForm]],
  ExpressionUUID->"370bc33d-46a7-4038-a099-975c78019a6a"],
 ":  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["a",
      FontWeight->"Bold",
      FontSlant->"Plain"], "1"], "=", 
    TemplateBox[{
      GraphicsBox[{
        LineBox[{{0, 0}, {0, 40}}], 
        LineBox[{{0, 40}, {2, 40}}], 
        LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}], 
      TagBox[
       GridBox[{{
          RowBox[{"\[NoBreak]", 
            GridBox[{{
               SubscriptBox["a", "11"]}, {
               SubscriptBox["a", "21"]}, {"\[VerticalEllipsis]"}, {
               SubscriptBox["a", 
                RowBox[{"m", "\[VeryThinSpace]", "1"}]]}}, 
             GridBoxAlignment -> {"Columns" -> {{"Center"}}}]}]}}, AutoDelete -> 
        False, GridBoxAlignment -> {"Columns" -> {{"Center"}}}, 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      GraphicsBox[{
        LineBox[{{2, 0}, {2, 40}}], 
        LineBox[{{0, 40}, {2, 40}}], 
        LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
     "RowDefault"]}], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->
  "1504dd82-971d-4e51-bdb5-20d3decfaad5"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox[
        StyleBox["a", FontWeight -> "Bold", FontSlant -> "Plain"], "2"], "=", 
       GraphicsBox[{
         LineBox[{{0, 0}, {0, 40}}], 
         LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]}], 
     TagBox[
      GridBox[{{
         RowBox[{"\[NoBreak]", 
           GridBox[{{
              SubscriptBox["a", "12"]}, {
              SubscriptBox["a", "22"]}, {"\[VerticalEllipsis]"}, {
              SubscriptBox["a", 
               RowBox[{"m", "\[InvisibleComma]", "2"}]]}}, 
            GridBoxAlignment -> {"Columns" -> {{"Center"}}}]}]}}, AutoDelete -> 
       False, GridBoxAlignment -> {"Columns" -> {{"Center"}}}, 
       GridBoxItemSize -> {
        "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
     GraphicsBox[{
       LineBox[{{2, 0}, {2, 40}}], 
       LineBox[{{0, 40}, {2, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
    "RowDefault"], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->
  "60c2fd23-04e9-4a79-af8d-ce1d6746b125"],
 ", ... , ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox[
        StyleBox["a", FontWeight -> "Bold", FontSlant -> "Plain"], "n"], "=", 
       GraphicsBox[{
         LineBox[{{0, 0}, {0, 40}}], 
         LineBox[{{0, 40}, {2, 40}}], 
         LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]}], 
     TagBox[
      GridBox[{{
         RowBox[{"\[NoBreak]", 
           GridBox[{{
              SubscriptBox["a", 
               RowBox[{"1", "\[VeryThinSpace]", "n"}]]}, {
              SubscriptBox["a", 
               RowBox[{"2", "\[VeryThinSpace]", "n"}]]}, {
             "\[VerticalEllipsis]"}, {
              SubscriptBox["a", 
               RowBox[{"m", "\[VeryThinSpace]", "n"}]]}}, 
            GridBoxAlignment -> {"Columns" -> {{"Center"}}}]}]}}, AutoDelete -> 
       False, GridBoxAlignment -> {"Columns" -> {{"Center"}}}, 
       GridBoxItemSize -> {
        "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
     GraphicsBox[{
       LineBox[{{2, 0}, {2, 40}}], 
       LineBox[{{0, 40}, {2, 40}}], 
       LineBox[{{0, 0}, {2, 0}}]}, ImageSize -> {10, 75}]},
    "RowDefault"], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->
  "eb45c32c-6c28-4819-9eee-03945e0076ef"],
 ", in which case ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "8d8d784e-a830-4cdd-8dac-4ac977c79174"],
 " can be also represented as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"[", GridBox[{
       {
        SubscriptBox[
         StyleBox["a",
          FontWeight->"Bold",
          FontSlant->"Plain"], "1"], 
        SubscriptBox[
         StyleBox["a",
          FontWeight->"Bold",
          FontSlant->"Plain"], "2"], "\[CenterEllipsis]", 
        SubscriptBox[
         StyleBox["a",
          FontWeight->"Bold",
          FontSlant->"Plain"], "n"]}
      }], "]"}]}], TraditionalForm]],ExpressionUUID->
  "8259ecf1-dc06-47f0-8ad8-a9700000c6a8"],
 ".  Notice that in this instance the subscript on the ",
 Cell[BoxData[
  FormBox[
   StyleBox["a",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]],ExpressionUUID->
  "d745343a-5100-4f0a-9f36-87e79d94672a"],
 "\[CloseCurlyQuote]s represents the column number, rather than an entry in a \
matrix or vector.  "
}], "Text",
