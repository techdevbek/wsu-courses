Cell[TextData[{
 "Create a matrix ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "2e218888-f570-4a5c-8c10-e8de5672cf0b"],
 " whose columns are the vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     FormBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Plain"],
      TraditionalForm], "1"], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
       {"1"},
       {
        RowBox[{"-", "2"}]},
       {"3"}
      }], 
     GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak] "}]}], TraditionalForm]],
  ExpressionUUID->"e898509e-a7cb-4d3a-a40e-2f59453a763d"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     FormBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Plain"],
      TraditionalForm], "2"], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
       {"2"},
       {
        RowBox[{"-", "2"}]},
       {"2"}
      }], 
     GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak] "}]}], TraditionalForm]],
  ExpressionUUID->"b8d7568b-fcf0-45f9-b178-a7faba40f908"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     FormBox[
      StyleBox["x",
       FontWeight->"Bold",
       FontSlant->"Plain"],
      TraditionalForm], "3"], "=", 
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak]", GridBox[{
       {"3"},
       {
        RowBox[{"-", "2"}]},
       {
        RowBox[{"-", "3"}]}
      }], 
     GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 50}], "\[NoBreak] "}]}], TraditionalForm]],
  ExpressionUUID->"d0b9fd64-944e-49c4-996b-badcbe7b994b"],
 "."
}], "Text",
