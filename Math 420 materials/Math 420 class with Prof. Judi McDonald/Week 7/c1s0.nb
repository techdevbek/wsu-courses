  3.894638424253958*^9}},ExpressionUUID->"a9fd0b80-ba0c-4c4b-9881-\
eaa150ba74ae"],

Cell[TextData[{
 "Notice that ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "242cf229-7833-4423-a490-fb47aba9d724"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "\[Cross]", "5"}], TraditionalForm]],ExpressionUUID->
  "0bec377b-1915-451c-a7bc-da3d2e80129a"],
 " upper triangular matrix and ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "53b01d94-3d8a-4b8c-9a0b-78c6fd23b0ac"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", "\[Cross]", "3"}], TraditionalForm]],ExpressionUUID->
  "b25ccbec-bad2-4816-bbcf-6b475041c4a2"],
 " lower triagular matrix.  "
}], "Text",
 CellChangeTimes->{{3.8946378039348073`*^9, 
  3.8946378748538833`*^9}},ExpressionUUID->"8f60786c-6580-4eec-a7a9-\
87a6532f4c68"],

