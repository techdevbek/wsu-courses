Cell["\<\
Identifying patterns in matrices is an important component of analysing the \
systems or data they represent.  \
\>", "Text",
 CellChangeTimes->{{3.8946297394150324`*^9, 3.894629817804164*^9}, {
   3.894630250081592*^9, 3.8946302756364326`*^9}, {3.894630318875556*^9, 
