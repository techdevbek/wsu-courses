Cell[TextData[{
 "An additional way view a matrix and process the data it contains is to work \
with the rows of the matrix.  For example, it may be helpful to visualize ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "aa44575a-2387-436e-a0c4-4043d8fd6d0d"],
 " as being organized into stripes of data:  "
}], "Text",
 CellChangeTimes->{{3.8946297394150324`*^9, 3.894629817804164*^9}, {
   3.894630250081592*^9, 3.8946302756364326`*^9}, {3.894630318875556*^9, 
   3.894630387885614*^9}, {3.894630554999176*^9, 3.89463060932784*^9}, 
