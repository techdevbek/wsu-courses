Cell["\<\
This calculation can be thought of as multiplying each column by the cost of \
shipping from that location, and then adding up the corresponding information \
across each row:  \
\>", "Text",
 CellChangeTimes->{{3.8946275656753483`*^9, 3.8946277710374794`*^9}, {
  3.9005013478634768`*^9, 3.9005018389860783`*^9}, {3.9005034532428126`*^9, 
  3.9005034757807612`*^9}, {3.901021939401552*^9, 
  3.901022050543643*^9}},ExpressionUUID->"f653ae08-28bb-400c-a659-\
726c7abfdafd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{GridBox[{
      {
       StyleBox[
        RowBox[{"Color", "/", "Location"}], "Text",
        FontWeight->"Plain"]},
      {"Black"},
      {"Grey"},
      {"Blue"},
      {"Crimson"},
      {"White"},
      {"Green"}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}], "      ", 
    "0", GridBox[{
      {"Seattle"},
      {"14"},
      {"15"},
      {"7"},
      {"12"},
      {"7"},
      {"9"}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]}], "+", 
   RowBox[{"1", GridBox[{
      {"Portland"},
      {"12"},
      {"10"},
      {"6"},
      {"8"},
      {"8"},
      {"2"}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]}], "+", 
   RowBox[{"2", GridBox[{
      {
       RowBox[{"San", " ", "Franciso"}]},
      {"15"},
      {"12"},
      {"9"},
      {"10"},
      {"3"},
      {"7"}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]}], "+", 
   RowBox[{"3", GridBox[{
      {
       RowBox[{"Los", " ", "Angeles"}]},
      {"17"},
      {"16"},
      {"20"},
      {"12"},
      {"6"},
      {"12"}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]}]}], " ", 
  "=", " ", GridBox[{
    {
     RowBox[{"Total", " ", "Shipping", " ", "Cost"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "12", "+", "30", "+", "51"}], "=", "93"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "10", "+", "24", "+", "48"}], "=", "82"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "6", "+", "18", "+", "60"}], "=", "84"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "8", "+", "20", "+", "36"}], "=", "64"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "8", "+", "6", "+", "18"}], "=", "32"}]},
    {
     RowBox[{
      RowBox[{"0", "+", "4", "+", "14", "+", "36"}], "=", "52"}]}
   },
   GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}]}]], "Text",
 CellChangeTimes->{{3.9005011059497604`*^9, 3.9005013323094025`*^9}, {
