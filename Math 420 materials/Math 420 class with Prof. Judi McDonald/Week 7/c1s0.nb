341753a5a1e0"],

Cell[TextData[{
 "\tThe ",
 StyleBox["diagonal entries",
  FontWeight->"Bold"],
 " in an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "2846d32f-f78f-40d7-a7d0-981572f17984"],
 " matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "95bd46a7-1646-457e-bd46-7c4cb6b7747c"],
 " are the entries where the two subscripts are match: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "11"], ",", 
    SubscriptBox["a", "22"], ",", 
    SubscriptBox["a", "33"], ",", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"290caf5d-635a-4ed2-909b-cf4f9d06ce06"],
 ". They form the ",
 StyleBox["main diagonal",
  FontWeight->"Bold"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "a2630f94-34cb-48bf-9915-083fce7c23e4"],
 ". The main diagonal is highlighted for the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "283ecb9a-c9e9-4211-9409-42eedd0b2fd8"],
 " matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b59303e8-e158-4410-abe2-bc5948a5b9cc"],
 " below."
}], "Text",
 CellChangeTimes->{
