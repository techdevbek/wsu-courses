Cell[TextData[{
 StyleBox["1.",
  FontWeight->"Bold"],
 "  Write out an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "c16a21eb-eb02-4317-b43a-40db09c7b82d"],
 " lower triangluar matrix ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "d7ec285e-dd0e-4a80-89af-0c2492b0a03a"],
 ", representing any nonzero entries with appropriate letters and subscripts, \
and listing zeros where appropriate. "
}], "Text",
