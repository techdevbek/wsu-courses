                  RowBox[{"1", " ", "2"}]}]], "\[CenterEllipsis]", 
               SubscriptBox["t", 
                RowBox[{"n", "-", 
                  RowBox[{"1", " ", "n"}], "-", "1"}]], "0"}, {
               SubscriptBox["t", 
                RowBox[{"n", "\[VeryThinSpace]", "1"}]], 
               SubscriptBox["t", 
                RowBox[{"n", "\[InvisibleComma]", "2"}]], "\[CenterEllipsis]", 
               SubscriptBox["t", 
                RowBox[{"n", "-", 
                  RowBox[{"1", " ", "n"}]}]], 
