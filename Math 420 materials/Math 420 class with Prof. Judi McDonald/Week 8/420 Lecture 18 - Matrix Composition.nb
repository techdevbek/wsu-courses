Cell[TextData[{
 "FUNCTION NOTATION: ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{"g", 
     RowBox[{"(", 
      RowBox[{"f", 
       RowBox[{"(", "x", ")"}]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5ad233e6-c2ce-413e-8863-f9a0dc399de0"],
 " means apply ",
 StyleBox["f",
  FontSlant->"Italic"],
 " to ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "801b08b0-8722-42fb-a50a-3c07ee55306b"],
 ", then apply ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "5cab8b5e-2445-4500-827e-f177bb609027"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "5cbc7caf-d246-45af-988b-0e58db9b67f6"],
 "."
}], "Text",
 CellChangeTimes->{{3.9050063702296686`*^9, 3.905006412792731*^9}, 
