   3.8734669500707865`*^9}},ExpressionUUID->"6b9e63cb-26f8-4b33-9fad-\
aa79a42e6d7e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "U"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "30f9dc0a-f658-42d2-9ce5-fd8ccbef7144"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", ":", "V"}], "->", "W", " "}], TraditionalForm]],
  ExpressionUUID->"42d627cc-65e5-43f4-9d86-a46103a14ac6"],
 " be linear transformations on finite dimensional vector spaces, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", 
    RowBox[{"and", " ", "W"}]}], TraditionalForm]],ExpressionUUID->
  "34be8f58-0ef1-4ea5-87f6-9e07e5a58eff"],
 ", over the same field \[DoubleStruckCapitalF].  Let \[Alpha], \[Beta], and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "fa24928c-4296-4a0c-bdf4-51e23c4bacf4"],
 " be bases of each vector space respectively. "
}], "Text",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
   3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
   3.6187478943151035`*^9}, {3.618921935437778*^9, 3.6189219580218277`*^9}, {
   3.618922635866583*^9, 3.618922635870586*^9}, {3.6189227041517787`*^9, 
   3.6189227050498595`*^9}, {3.6191781587456026`*^9, 3.6191781619557343`*^9}, 
   3.839283236310096*^9, {3.839283268744117*^9, 3.8392832720068054`*^9}, {
   3.8734643917876186`*^9, 3.8734644806441946`*^9}, {3.873464515474539*^9, 
   3.873464580558587*^9}, {3.873467034929221*^9, 3.873467035604673*^9}, {
   3.87346920648635*^9, 
   3.8734692268262997`*^9}},ExpressionUUID->"b424aa31-0509-4f20-8147-\
efdf0b91f5ad"],

Cell[TextData[{
 "Set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    SubsuperscriptBox[
     RowBox[{"[", "T", "]"}], "\[Alpha]", "\[Beta]"]}], TraditionalForm]],
  ExpressionUUID->"74074731-fbc5-4774-b3c9-176da63fdb10"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    SubsuperscriptBox[
     RowBox[{"[", "S", "]"}], "\[Beta]", "\[Gamma]"]}], TraditionalForm]],
  ExpressionUUID->"47e596f6-69c9-4fde-8b9c-86fc538a0931"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{"[", 
      RowBox[{"S", "\[VeryThinSpace]", "T"}], "]"}], "\[Alpha]", "\[Gamma]"], 
    "=", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]}], TraditionalForm]],
  ExpressionUUID->"759ac9ca-8140-441e-b392-bb3df2ba291a"],
 "."
}], "Text",
 CellChangeTimes->{{3.618747377613885*^9, 3.618747430114893*^9}, {
   3.618747556047266*^9, 3.6187478036821966`*^9}, {3.6187478943131027`*^9, 
   3.6187478943151035`*^9}, {3.618921935437778*^9, 3.6189219580218277`*^9}, {
   3.618922635866583*^9, 3.618922635870586*^9}, {3.6189227041517787`*^9, 
   3.6189227050498595`*^9}, {3.6191781587456026`*^9, 3.6191781619557343`*^9}, 
   3.839283236310096*^9, {3.839283268744117*^9, 3.8392832720068054`*^9}, {
