48f386df5f40"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"S", "(", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"a", "b"},
       {"c", "d"}
      }], "\[NoBreak]", ")"}], ")"}], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"a"},
      {"c"},
      {
       RowBox[{"b", "+", "d"}]}
     }], "\[NoBreak]", ")"}]}], 
