Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"835d8945-13f8-460f-a56f-1b5f64a1b79c"],

Cell[TextData[{
 "To get the ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "974c9c2c-9f44-4b24-bda4-ebe8cccf9e88"],
 "-th column of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", 
     RowBox[{"S", "\[VeryThinSpace]", "T"}], "]"}], "\[Alpha]", "\[Gamma]"], 
   TraditionalForm]],ExpressionUUID->"25367540-4d6d-4508-8e23-c746001130de"],
 ", we write the vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[VeryThinSpace]", 
    RowBox[{"T", "(", 
     SubscriptBox["u", "j"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "05f247f0-ee59-420b-9a4b-dce509a3d7c8"],
 " in terms of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "1"], ",", "...", ",", 
    SubscriptBox["w", "s"]}], TraditionalForm]],ExpressionUUID->
  "f21c8365-6237-4e5f-9faf-fc694d2cb2d3"],
 ". We can compute ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[VeryThinSpace]", 
    RowBox[{"T", "(", 
     SubscriptBox["u", "j"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b04af175-0de3-442f-980d-dfc3d779e43b"],
 " by applying ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "caece96d-7557-44e7-811b-32ca02fbb6e9"],
 " to the vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", 
    SubscriptBox["u", "j"], ")"}], TraditionalForm]],ExpressionUUID->
  "8ef30b61-6f25-45d9-a35f-d19319d62395"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", 
    SubscriptBox["u", "j"], ")"}], TraditionalForm]],ExpressionUUID->
