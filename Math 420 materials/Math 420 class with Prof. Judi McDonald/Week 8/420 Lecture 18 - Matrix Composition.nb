Cell[TextData[{
 "To find ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]", "\[Gamma]"], TraditionalForm]],
  ExpressionUUID->"b248653a-7c9c-4962-8055-9ac62d65d57c"],
 ", we should get a 4x4 matrix",
 StyleBox[" ",
  FontFamily->"Times New Roman",
  FontWeight->"Normal"],
 Cell[BoxData[
  RowBox[{
   GraphicsBox[{LineBox[{{0, 0}, {0, 40}}], LineBox[{{0, 40}, {1, 40}}], 
     LineBox[{{0, 0}, {2, 0}}]},
    ImageSize->{7, 65}], GridBox[{
     {"1", 
      StyleBox["1",
       FontColor->RGBColor[1, 0.5, 0]], 
      StyleBox["1",
       FontColor->RGBColor[0.5, 0, 0.5]], 
      StyleBox["1",
       FontColor->RGBColor[0, 1, 0]]},
     {"0", 
      StyleBox["1",
       FontColor->RGBColor[1, 0.5, 0]], 
      StyleBox["0",
       FontColor->RGBColor[0.5, 0, 0.5]], 
      StyleBox["0",
       FontColor->RGBColor[0, 1, 0]]},
     {"0", 
      StyleBox["0",
       FontColor->RGBColor[1, 0.5, 0]], 
      StyleBox["0",
       FontColor->RGBColor[0.5, 0, 0.5]], 
      StyleBox["0",
       FontColor->RGBColor[0, 1, 0]]},
     {"1", 
      StyleBox["1",
       FontColor->RGBColor[1, 0.5, 0]], 
      StyleBox["3",
       FontColor->RGBColor[0.5, 0, 0.5]], 
      StyleBox["7",
       FontColor->RGBColor[0, 1, 0]]}
    }], "\[NoBreak]", 
   GraphicsBox[{LineBox[{{2, 0}, {2, 40}}], LineBox[{{0, 40}, {2, 40}}], 
     LineBox[{{0, 0}, {2, 0}}]},
    ImageSize->{7, 65}]}]],
  FontFamily->"Times New Roman",
  FontWeight->"Normal",ExpressionUUID->"f4a0489d-ec6c-4ec0-b99a-f559d70aac13"],
 StyleBox[" ",
  FontFamily->"Times New Roman",
  FontWeight->"Normal"]
}], "Text",
 CellChangeTimes->{{3.8733714775946093`*^9, 3.87337148156141*^9}, {
  3.873371581568681*^9, 3.873371667492832*^9}, {3.8733719055010777`*^9, 
