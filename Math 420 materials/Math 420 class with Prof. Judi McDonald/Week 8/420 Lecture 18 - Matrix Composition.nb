          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"k", "=", "1"}], "n"], 
           RowBox[{
            SubscriptBox["a", 
             RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
            SubscriptBox["b", 
