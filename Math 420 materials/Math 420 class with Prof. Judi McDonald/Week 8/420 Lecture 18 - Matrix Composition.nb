Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"a0dc1fee-140e-46db-bca6-29b2c13bbeb1"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{"1", ",", "x", ",", 
      SuperscriptBox["x", "2"], ",", 
      SuperscriptBox["x", "3"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "ec3ad91e-1d22-4b90-92b2-851ca9e4ac38"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["E", 
        StyleBox["ij",
         FontSlant->"Italic"]], "|", "i"}], ",", 
      RowBox[{"j", " ", "\[Element]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}]}]}], " ", "}"}]}], TraditionalForm]],
  ExpressionUUID->"6429acf9-f924-4397-83f7-950bdd6c8424"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Eta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["e", "i"], "|", 
      RowBox[{"i", "\[Element]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"13800d59-cc08-4445-8ab7-956b3c41874a"],
 " be bases for the respective vector spaces above.  "
}], "Text",
 CellChangeTimes->{{3.620388950699255*^9, 3.6203889564891157`*^9}, 
   3.6203891179248977`*^9, {3.620393553950329*^9, 3.6203935565810804`*^9}, {
   3.620993000190227*^9, 3.620993247508776*^9}, {3.620993288722335*^9, 
   3.6209932995666714`*^9}, {3.6209934241430845`*^9, 
   3.6209934956661296`*^9}, {3.621165342500039*^9, 
   3.6211655471944933`*^9}},ExpressionUUID->"57392872-1f36-42c3-b3bc-\
13cdf8fa9cd5"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SuperscriptBox["E", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "502921cd-2a5d-4415-9c0a-54a1c2914833"],
 " is the matrix with a 1 in row ",
 StyleBox["i ",
  FontSlant->"Italic"],
 "and column ",
 StyleBox["j",
  FontSlant->"Italic"],
 " and zeros elsewhere. "
}], "Text",
 CellChangeTimes->{{3.8733713704208593`*^9, 
  3.873371422116871*^9}},ExpressionUUID->"2b3bc24a-e462-4efa-a08d-\
052484803c39"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["e", "i"], TraditionalForm]],ExpressionUUID->
  "12061db0-cc40-4066-a000-2a654d704fef"],
 " is the vector with a 1 in row ",
 StyleBox["i ",
  FontSlant->"Italic"],
 " and zeros elsewhere. "
}], "Text",
 CellChangeTimes->{{3.8733714326294537`*^9, 
  3.873371450975763*^9}},ExpressionUUID->"925f50ff-00f0-48e1-bcfb-\
6f8a0e8c63ab"]
}, Open  ]],

