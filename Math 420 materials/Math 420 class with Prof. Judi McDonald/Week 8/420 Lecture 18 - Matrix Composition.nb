Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", "f", ")"}], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"f", "(", "1", ")"}], 
       RowBox[{
        RowBox[{"f", "'"}], 
        RowBox[{"(", "0", ")"}]}]},
      {"0", 
       RowBox[{
        RowBox[{"f", "(", "1", ")"}], "+", 
        RowBox[{"f", "\"\<(1)\>"}]}]}
     }], "\[NoBreak]", ")"}]}], 
  TraditionalForm]],ExpressionUUID->"4b3a0c08-ad8f-4e36-81ba-efec85eda4c0"]], \
"Text",
