       StyleBox["1",
        FontColor->RGBColor[0, 1, 0]]}
     }], "\[NoBreak]", 
    GraphicsBox[{LineBox[{{1, 0}, {1, 25}}], LineBox[{{0, 25}, {1, 25}}], 
      LineBox[{{0, 0}, {1, 0}}]},
