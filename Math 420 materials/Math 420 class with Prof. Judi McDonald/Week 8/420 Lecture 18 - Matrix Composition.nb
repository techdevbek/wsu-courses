Cell[TextData[{
 "The columns of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[VeryThinSpace]", "B"}], TraditionalForm]],ExpressionUUID->
  "da640bb7-99d4-4d84-8a6e-9a287593061c"],
 " consist of linear combinations of the columns of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "f0dbdecd-06e4-44c2-a659-faf18e29a274"],
 " using the weights from each column from ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
