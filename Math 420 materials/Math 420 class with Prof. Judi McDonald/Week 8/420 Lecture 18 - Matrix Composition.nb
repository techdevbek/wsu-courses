Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", "1", ")"}], "=", 
   RowBox[{
    RowBox[{
     GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
       {"1", "0"},
       {"0", "1"}
      }], "\[NoBreak]", 
     GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
       LineBox[{{0, 0}, {1, 0}}]},
      ImageSize->{5, 30}]}], "=", 
    RowBox[{
     RowBox[{"1", 
      GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
        {"1", "0"},
        {"0", "0"}
       }], "\[NoBreak]", 
      GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}]}], " ", "+", 
     RowBox[{"0", 
      GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
        {"0", "1"},
        {"0", "0"}
       }], "\[NoBreak]", 
      GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}]}], " ", "+", 
     RowBox[{"0", 
      GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}], "\[NoBreak]", GridBox[{
        {"0", "0"},
        {"1", "0"}
       }], "\[NoBreak]", 
      GraphicsBox[{LineBox[{{1, 0}, {1, 10}}], LineBox[{{0, 10}, {1, 10}}], 
        LineBox[{{0, 0}, {1, 0}}]},
       ImageSize->{5, 30}]}], "+", 
     RowBox[{"1", " ", 
      GraphicsBox[{LineBox[{{0, 0}, {0, 10}}], LineBox[{{0, 10}, {1, 10}}], 
