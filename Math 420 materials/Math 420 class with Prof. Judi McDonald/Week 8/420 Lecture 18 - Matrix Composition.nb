Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["u", "1"], ",", "...", ",", 
     SubscriptBox["u", "q"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "7695b961-c4d8-4273-bf55-cb2fd47cf5ac"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["v", "1"], ",", 
     RowBox[{"...", 
      SubscriptBox["v", "r"]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "eea7276f-e74b-4407-b36c-8cad4d7bc93c"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
