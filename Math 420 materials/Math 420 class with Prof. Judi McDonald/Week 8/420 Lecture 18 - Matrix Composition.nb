1c4d78756ed4"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "af3b1259-0e27-4576-bacc-67233556469e"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "b8810e32-687e-40b9-9fa1-410120e5ba43"],
 " matrix, let ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "f75e3c16-8cdd-4faa-8134-ee980f722de1"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "1"}], TraditionalForm]],ExpressionUUID->
  "cbd1fcbf-d240-490d-bdb0-20c7f9724faf"],
 " vector, and let ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "6f31f0b4-053e-4a80-a1de-54b31e814083"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "p"}], TraditionalForm]],ExpressionUUID->
  "1d2faab5-d455-48d2-842f-29768a24b14b"],
 " matrix, all with entries from the field \[DoubleStruckCapitalF]. We define "
}], "Text",
 CellChangeTimes->{{3.87346582239075*^9, 
  3.873465878150283*^9}},ExpressionUUID->"b16bf73d-e7b3-4e49-aea8-\
ddb0a999243c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"A", "\[VeryThinSpace]", "x"}], "=", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"k", "=", "1"}], "n"], 
      RowBox[{
       SubscriptBox["x", "k"], 
       SubscriptBox["a", "k"]}]}]}], ",", " "}], TraditionalForm]],
  ExpressionUUID->"585729fa-e1d9-478f-8399-8015c58f58d4"],
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "5b11a8e4-d123-4800-81d9-13137b1937a9"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "-", "th"}], TraditionalForm]],ExpressionUUID->
  "20ab93cc-bd10-43e6-a9fc-98ac88100de9"],
 " entry in ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "ae77fcc1-4dcd-4c74-a86a-f6a1c8c1d206"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "0f841585-abf1-4115-83ad-1676a4d092ce"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "-", "th"}], TraditionalForm]],ExpressionUUID->
  "1acea7b9-fb44-4323-ad4b-e49075778476"],
 " column of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "42e17186-9365-43ca-95ca-bbaaa6e9cbf2"],
 "."
}], "Text",
 CellChangeTimes->{{3.8734658949143457`*^9, 3.8734660343984137`*^9}},
 TextAlignment->Center,ExpressionUUID->"cf13ace2-4586-4780-818f-6c35db9f1302"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "2", "3"},
       {"4", "5", "6"},
       {"7", "8", "9"}
      }], "\[NoBreak]", ")"}], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"3"},
       {"2"},
       {"1"}
      }], "\[NoBreak]", ")"}]}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"3", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1"},
         {"4"},
         {"7"}
        }], "\[NoBreak]", ")"}]}], "+", 
     RowBox[{"2", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"2"},
         {"5"},
         {"8"}
        }], "\[NoBreak]", ")"}]}], "+", 
     RowBox[{"1", 
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"3"},
         {"6"},
         {"9"}
        }], "\[NoBreak]", ")"}]}]}], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"10"},
       {"28"},
       {"46"}
      }], "\[NoBreak]", ")"}], "  "}]}]],ExpressionUUID->
  "748a8410-5ada-4813-b64e-a4bdd1a330fa"],
 " "
}], "Text",
 CellChangeTimes->{{3.9050056794222283`*^9, 
  3.905005799042617*^9}},ExpressionUUID->"6c636fc2-001b-40c7-a096-\
e2cb137fca00"],

Cell["We define", "Text",
 CellChangeTimes->{{3.873466046337187*^9, 3.8734660468396664`*^9}, {
  3.8734662120991354`*^9, 
  3.873466213728012*^9}},ExpressionUUID->"935e5563-abde-4159-8e52-\
c4bd36b8c4a0"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"A", "\[VeryThinSpace]", "B"}], "=", 
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      RowBox[{"A", "\[VeryThinSpace]", 
       SubscriptBox["b", "1"], "  ", "A", "\[VeryThinSpace]", 
       SubscriptBox["b", "2"]}], " ", "..."}], " ", "A", "\[VeryThinSpace]", 
     SubscriptBox["b", "p"]}], "]"}]}], 
  TraditionalForm]],ExpressionUUID->"db547ab6-651d-4486-81df-90b179749ad1"]], \
"Text",
 CellChangeTimes->{{3.904995762991146*^9, 
  3.904995771533957*^9}},ExpressionUUID->"f46deb57-2669-4306-95ad-\
6f15212e23cd"],

Cell[TextData[Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"1", "2", "3"},
      {"4", "5", "6"},
      {"7", "8", "9"}
     }], "\[NoBreak]", ")"}], 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"3", 
       RowBox[{"-", "1"}]},
      {"2", "1"},
      {"1", "1"}
     }], "\[NoBreak]", ")"}]}], "=", 
  RowBox[{
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{"(", "\[NoBreak]", GridBox[{
           {"1", "2", "3"},
           {"4", "5", "6"},
           {"7", "8", "9"}
          }], "\[NoBreak]", ")"}], 
        RowBox[{"(", "\[NoBreak]", GridBox[{
           {"3"},
           {"2"},
           {"1"}
          }], "\[NoBreak]", ")"}], "     "}], 
       RowBox[{
        RowBox[{"(", "\[NoBreak]", GridBox[{
           {"1", "2", "3"},
           {"4", "5", "6"},
           {"7", "8", "9"}
          }], "\[NoBreak]", ")"}], 
        RowBox[{"(", "\[NoBreak]", GridBox[{
           {
            RowBox[{"-", "1"}]},
           {"1"},
           {"1"}
          }], "\[NoBreak]", ")"}]}]}
     }], "\[NoBreak]", ")"}], " ", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"10", "4"},
      {"28", "7"},
      {"46", "10"}
     }], "\[NoBreak]", ")"}], 
   " "}]}]],ExpressionUUID->"b74351cb-f757-43b2-a753-37f6c414b217"]], "Text",
 CellChangeTimes->{{3.905005843793369*^9, 
  3.9050060015161233`*^9}},ExpressionUUID->"311471e9-defa-49cb-9713-\
