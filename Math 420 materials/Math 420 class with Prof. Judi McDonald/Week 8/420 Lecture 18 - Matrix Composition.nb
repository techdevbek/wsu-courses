Cell["\<\
What does your answer translate to in terms of linear transformations? \
\>", "Text",
 CellChangeTimes->{{3.8734711983116865`*^9, 3.8734712193002815`*^9}, {
   3.873544695045935*^9, 3.8735447277018566`*^9}, 
   3.9049960074892783`*^9},ExpressionUUID->"1b347922-1713-484c-a918-\
1cda88efbc14"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"R", "(", 
    RowBox[{"S", "\[VeryThinSpace]", "T"}], ")"}], "\[SubsetEqual]", 
   RowBox[{"R", "(", "S", ")"}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"a5c687dd-7561-4194-9419-9391a9677b5d"]], \
"Text",
 CellChangeTimes->{{3.905264749942129*^9, 
  3.9052647848194227`*^9}},ExpressionUUID->"9a4b3d07-b217-41f5-8058-\
20c2e58bd857"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Observation:",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontFamily->"Times New Roman"]
}], "Subsubsubsection",
 CellChangeTimes->{
  3.6187478917113695`*^9, {3.618747961940199*^9, 3.618748043749483*^9}, {
   3.6189230649889717`*^9, 3.618923075201786*^9}, 3.8392834091489997`*^9, {
   3.8734661482144084`*^9, 
   3.873466153901842*^9}},ExpressionUUID->"f14e9390-13ee-4dee-b42c-\
b732bb4f5265"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "7e886937-ba7f-4584-9ca2-7f8e4002f67a"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "99fe1e68-cb5a-4a5c-9deb-635788cacce7"],
 " matrix and let ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "dac51ab2-cb04-4e35-b842-15b1465796de"],
 " be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "p"}], TraditionalForm]],ExpressionUUID->
  "edf15139-912a-4cc1-86fd-480f6fe20446"],
 " matrix with entries from the field \[DoubleStruckCapitalF].  Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{"C", "=", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]}], TraditionalForm]],
  ExpressionUUID->"9f6e0380-1c08-4b05-b6bc-68d56f61919e"],
 ", where "
}], "Text",
 CellChangeTimes->{{3.873464687262715*^9, 3.873464769652665*^9}, {
  3.8734648701659174`*^9, 3.8734648849121127`*^9}, {3.8734661618255987`*^9, 
  3.8734661732372985`*^9}},ExpressionUUID->"8f2c7165-bef2-47fe-a78d-\
33c973e69f1f"],

Cell[TextData[Cell[BoxData[
 FormBox[GridBox[{
    {
     RowBox[{GridBox[{
        {
         RowBox[{
          SubscriptBox["c", 
           RowBox[{"i", "\[VeryThinSpace]", "j"}]], "=", 
          RowBox[{
           UnderoverscriptBox["\[Sum]", 
            RowBox[{"k", "=", "1"}], "n"], 
           RowBox[{
            SubscriptBox["a", 
             RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
            SubscriptBox["b", 
             RowBox[{"k", "\[VeryThinSpace]", "j"}]]}]}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{"Center"}}}], "=", 
      RowBox[{
       RowBox[{"[", 
        RowBox[{
         SubscriptBox["Row", "i"], "A"}], "]"}], "[", 
       RowBox[{
        SubscriptBox["Col", "j"], "B"}], "]"}]}]}
   },
   GridBoxItemSize->{"Columns" -> {{
        Scaled[0.96]}}}], 
  TraditionalForm]],ExpressionUUID->"1dd0fb8b-8d72-4cfa-8c44-6f2c1dc9db00"]], \
"Text",
 CellChangeTimes->{{3.8734665601005793`*^9, 
  3.87346656538468*^9}},ExpressionUUID->"c472eb50-e41c-4c36-a718-\
b113797f3b83"],

Cell[TextData[StyleBox["viz. - it is the product of row i of A with column j \
of B. ",
 FontSlant->"Italic"]], "Text",
 CellChangeTimes->{{3.873541010139632*^9, 3.873541058308008*^9}, {
  3.9049960456161203`*^9, 
  3.9049960469088955`*^9}},ExpressionUUID->"20f06d88-ad30-4e51-9b0d-\
e7a32653adfc"],

Cell[BoxData[
 FormBox[
  TagBox[
   FormBox[
    StyleBox[
     DynamicModuleBox[{$CellContext`col$$ = 1, $CellContext`row$$ = 1, 
      Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
      Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ =
       1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{{
         Hold[$CellContext`row$$], 1, 
         Style["entry in row", {FontFamily -> "Times", 14, Italic}]}, 1, 3, 
        1}, {{
         Hold[$CellContext`col$$], 1, 
         Style["entry in column", {FontFamily -> "Times", 14, Italic}]}, 1, 3,
         1}}, Typeset`size$$ = {
      645., {123.02432626994326`, 135.05567373005672`}}, Typeset`update$$ = 0,
       Typeset`initDone$$, Typeset`skipInitDone$$ = 
      False, $CellContext`row$16012$$ = 0, $CellContext`col$16013$$ = 0}, 
      DynamicBox[Manipulate`ManipulateBoxes[
       1, TraditionalForm, 
        "Variables" :> {$CellContext`col$$ = 1, $CellContext`row$$ = 1}, 
        "ControllerVariables" :> {
          Hold[$CellContext`row$$, $CellContext`row$16012$$, 0], 
          Hold[$CellContext`col$$, $CellContext`col$16013$$, 0]}, 
        "OtherVariables" :> {
         Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
          Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
          Typeset`specs$$, Typeset`size$$, Typeset`update$$, 
          Typeset`initDone$$, Typeset`skipInitDone$$}, "Body" :> 
        Module[{$CellContext`clr1$, $CellContext`clr2$, $CellContext`clr3$, \
$CellContext`rr$, $CellContext`cc$, $CellContext`matB$, $CellContext`matA$, \
$CellContext`A$}, $CellContext`matA$ = {{3, 5, -1, 2}, {-2, 1, -4, 1}, {0, 3, 
            0, -4}}; $CellContext`matB$ = {{2, 0, 1}, {0, -2, 2}, {4, 1, 3}, {
            2, 0, 6}}; $CellContext`clr1$ = $CellContext`jcyandk; \
$CellContext`clr2$ = $CellContext`jcrimson; $CellContext`clr3$ = \
$CellContext`jblue; RGBColor[0, 0.7, 0.9]; Grid[{{
              Grid[{{
                 Grid[{{
                    Style["AB", Italic], "=", $CellContext`jlbr3, 
                    Style[
                    
                    Grid[$CellContext`matA$, Alignment -> {Right, Bottom}, 
                    Spacings -> {1, 0.5}, 
                    ItemStyle -> {
                    None, {$CellContext`row$$ -> $CellContext`clr2$}, Null}, 
                    Frame -> {
                    None, {$CellContext`row$$ -> $CellContext`clr2$}, 
                    Null}]], $CellContext`jrbr3, $CellContext`jlbr4, 
                    Style[
                    
