     SubscriptBox["w", "1"], ",", " ", "...", ",", " ", 
     SubscriptBox["w", "s"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "349ca20e-d4a8-455f-a8d0-a4574bc9e83b"],
 " be basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", 
    RowBox[{"and", " ", "W"}]}], TraditionalForm]],ExpressionUUID->
  "7df79972-76b9-47db-993c-c6449461aa3d"],
 " respectively.  "
}], "Text",
