           SubscriptBox["Col", "k"], "(", "A", ")"}], " ", "]"}], 
         RowBox[{
          SubscriptBox["Col", "j"], "[", 
          RowBox[{
           SubscriptBox["Row", "k"], "B"}], "]"}]}]}], "=", 
       RowBox[{
        SubscriptBox["Row", "i"], 
        RowBox[{
         SubscriptBox["Col", "j"], "[", 
         RowBox[{
          UnderoverscriptBox["\[Sum]", 
           RowBox[{"k", "=", "1"}], "n"], 
          RowBox[{
           RowBox[{
            SubscriptBox["Col", "k"], "(", "A", ")"}], 
