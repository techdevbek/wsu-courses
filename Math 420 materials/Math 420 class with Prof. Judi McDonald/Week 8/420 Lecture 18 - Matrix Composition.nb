Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", 
     SubscriptBox["\[DoubleStruckCapitalP]", "3"]}], "\[Rule]", 
    SubscriptBox["M", 
     RowBox[{"2", "x2"}]]}], TraditionalForm]],ExpressionUUID->
  "f0b76c12-9c9c-4341-9108-138bfff921f4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", ":", 
     SubscriptBox["M", 
      RowBox[{"2", "x2"}]]}], "\[Rule]"}], TraditionalForm]],ExpressionUUID->
  "5bbeb9a9-a924-49d1-a6bf-d8714c9a875f"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"4266116e-5c2b-4a4e-8d4d-0613f3537249"],
 " so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "\[VeryThinSpace]", 
     RowBox[{"T", ":", 
      SubscriptBox["\[DoubleStruckCapitalP]", "3"]}]}], "->", 
    SuperscriptBox["\[DoubleStruckCapitalR]", "3"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d6a3936f-42bf-4670-9d71-450e00711322"]
}], "Text",
