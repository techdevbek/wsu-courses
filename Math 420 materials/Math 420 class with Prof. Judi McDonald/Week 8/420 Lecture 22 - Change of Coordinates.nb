Cell[TextData[{
 "Observe that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Cross]", "n"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fecff2c1-6e43-4bf7-aafe-6b09a9e09e57"],
 " matrices ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["E", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b36fd8cc-e221-4e77-b72c-71fa0f3a3902"],
 " form a basis for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{"m", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}], 
   TraditionalForm]],ExpressionUUID->"81a4b025-8017-4c9d-9e6d-ec77c5b50e93"],
 ", which is isomorphic to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", 
    FormBox[
     RowBox[{"V", ",", "W"}],
     TraditionalForm], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
