What is the relationship between these matrices?"
}], "Text",
 CellChangeTimes->{{3.8741458231142063`*^9, 3.8741458880096865`*^9}, {
  3.9062021424471855`*^9, 3.906202143045616*^9}},
 FontFamily->"Times New Roman",
 FontSize->14,
 FontWeight->"Normal",ExpressionUUID->"222438cd-91e0-4814-912e-8e861380a02b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem: ",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6215981009575243`*^9, 3.62159821730051*^9}, 
   3.621598356761585*^9, {3.6216111387533464`*^9, 3.6216111400346584`*^9}, 
   3.8425223116722083`*^9, 3.8425223602552567`*^9},
 FontSize->16,ExpressionUUID->"c53e5bca-7eb1-4834-b81d-6af138a94cbe"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "3ac9f53f-4bd6-40ce-ad2b-3c895bb6a3d2"],
 " be a finite dimensional vector space over a field \[DoubleStruckCapitalF] \
with ordered bases  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "9aa53b4b-ea49-4934-901b-0f11bc932d5b"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["w", "1"], ",", " ", 
      SubscriptBox["w", "2"], ",", "...", ",", 
      SubscriptBox["w", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "b6f4ea2b-a15a-4b1d-b109-c6c8b0fe8e0f"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "=", 
    SubsuperscriptBox[
     RowBox[{"[", 
      SubscriptBox["I", "V"], "]"}], "\[Beta]", "\[Gamma]"]}], 
   TraditionalForm]],ExpressionUUID->"32651a58-2ba4-4278-9038-d69decb9936c"],
 ". Then "
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, 3.621599458231881*^9, 
   3.8435806031376653`*^9},
 FontSize->16,ExpressionUUID->"cd013aa9-d60d-4ff5-b478-e20885696ec2"],

Cell[TextData[{
 "(i) ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "4ae2621c-e536-4e3f-866c-c7a6b192e65a"],
 " is invertible."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.6213395330644956`*^9}, {3.6215993159889507`*^9, 
   3.6215993228600216`*^9}, {3.874145308302221*^9, 3.874145308302221*^9}},
 FontSize->16,ExpressionUUID->"20142a1c-a84f-42ac-baed-f5d7323c024e"],

Cell[TextData[{
 "(ii) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"for", " ", "any", " ", "v"}], "\[Element]", "V"}], ",", " ", 
    RowBox[{
     SubscriptBox[
      RowBox[{"[", "v", "]"}], "\[Gamma]"], "=", 
     SubscriptBox[
      RowBox[{"Q", " ", "[", "v", "]"}], "\[Beta]"]}]}], TraditionalForm]],
  ExpressionUUID->"c7cd4be7-f087-4239-8475-bf52af9e4d16"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339597661574*^9}, {3.621340300692667*^9, 
   3.621340300692667*^9}, {3.621599332546517*^9, 3.6215993852746563`*^9}, {
   3.6215996342152843`*^9, 3.621599635470467*^9}},
 FontSize->16,ExpressionUUID->"ea93147b-9b2e-4f81-baed-c2f00d8cddd6"],

Cell[TextData[{
 "NOTE:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["I", "V"], ":", "V"}], "->", "V"}], TraditionalForm]],
  ExpressionUUID->"16370e7b-4a31-487b-9edd-9a286ee08cb0"],
 ", so the  bases have the same number of elements. "
}], "Text",
 CellChangeTimes->{{3.8741503827807274`*^9, 
  3.8741504028984804`*^9}},ExpressionUUID->"269662d2-e160-48af-b78d-\
52fbf9250ce7"]
}, Open  ]],

