Cell[TextData[{
 "Consider the bases ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"1"},
        {"0"},
        {"1"}
       }], "\[NoBreak]", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e56d063c-9819-444b-abbc-e4305bc03079"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"0"},
      {"1"},
      {"1"}
     }], "\[NoBreak]", ")"}], TraditionalForm]],ExpressionUUID->
  "409df5ba-5367-4057-a86a-3ccaf508f589"],
 Cell[BoxData[
  FormBox[
   RowBox[{",", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1"},
       {"1"},
       {"1"}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a6f8bc80-e584-477f-bbb4-8422c7fcd844"],
 "} and \[Gamma] ={",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"1"},
      {
       RowBox[{"-", "1"}]},
      {"0"}
     }], "\[NoBreak]", ")"}], TraditionalForm]],ExpressionUUID->
  "1f7310ec-c174-467b-b521-a8810b0b0a49"],
 Cell[BoxData[
  FormBox[
   RowBox[{",", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0"},
       {"1"},
       {
        RowBox[{"-", "1"}]}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a57727b4-def5-4e9e-a34d-64b3e0014c02"],
 Cell[BoxData[
  FormBox[
   RowBox[{",", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1"},
       {"1"},
       {
        RowBox[{"-", "1"}]}
      }], "\[NoBreak]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "23642399-d5c0-40b0-a317-775cdb3f33df"],
 "}. Find ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", 
     SubscriptBox["I", "V"], "]"}], "\[Beta]", "\[Gamma]"], TraditionalForm]],
  ExpressionUUID->"e800b7f0-80c0-41fb-80e7-4631f034c9c1"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
