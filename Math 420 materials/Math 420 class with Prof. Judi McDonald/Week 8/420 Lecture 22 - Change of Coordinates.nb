   3.906031633793873*^9}},
 FontSize->14,ExpressionUUID->"eaf05716-8ccb-491e-9e82-a376ee67a9a8"],

Cell[TextData[{
 "NOTATION: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["I", "V"], ":", "V"}], "->", "V"}], TraditionalForm]],
  ExpressionUUID->"c6d4c819-5a22-45e4-8d45-9c8a6a9c2b93"],
 " is a linear transformation.  ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "a65cafa0-d233-4164-b0ec-8a311e29d182"],
 ", all by itself, is the matrix from 220. "
}], "Text",
