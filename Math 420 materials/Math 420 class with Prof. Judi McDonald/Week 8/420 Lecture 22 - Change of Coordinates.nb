Cell[TextData[StyleBox["Theorem: ",
 FontFamily->"Times New Roman",
 FontWeight->"Bold",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6213403095368614`*^9, 3.621340310865079*^9}, {
   3.621597771133131*^9, 3.621597951992612*^9}, 3.8425222996815133`*^9, 
   3.8425224546893625`*^9},
 FontSize->16,ExpressionUUID->"907f2478-096e-4536-a9ba-a2ea1df2174d"],

Cell[TextData[{
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]],
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c9b7f5e2-eb1e-4b85-a174-5f8d1918abcf"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "e62307a6-2b8e-43f8-86fe-a5a59ffa38b1"],
 " be finite dimensional vector spaces over a field \[DoubleStruckCapitalF] \
with ordered bases  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "e8b94a56-fde7-4c8d-abc4-3cbcaf164e2f"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["w", "1"], ",", " ", 
      SubscriptBox["w", "2"], ",", "...", ",", 
      SubscriptBox["w", "m"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "d7db573c-def3-4f42-94ef-1241356b0da2"],
 " respectively.  The function \[CapitalPhi]:\[ScriptCapitalL](",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ",", "W"}], TraditionalForm]],ExpressionUUID->
  "fe86cd88-7fe7-43b5-b9ea-d4183dfee86d"],
 ") \[Rule]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["M", 
      RowBox[{"m", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}], 
    ","}], TraditionalForm]],ExpressionUUID->
  "2d342f0d-8e99-41e1-a279-8ab42adf7f20"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPhi]", 
     RowBox[{"(", "T", ")"}]}], " ", "=", " ", 
    SubsuperscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]", "\[Gamma]"]}], TraditionalForm]],
  ExpressionUUID->"f5e5f07f-0266-4cd2-94db-cb43eecfcc98"],
 " is an isomorphism.  "
}], "Text",
 CellChangeTimes->{{3.6213403095368614`*^9, 3.621340310865079*^9}, {
   3.621597771133131*^9, 3.621597951992612*^9}, 3.873482684380145*^9, {
   3.906041717448934*^9, 3.906041718042429*^9}},
 FontSize->16,ExpressionUUID->"a7325223-e447-4606-92eb-06f2b16ed467"]
}, Open  ]],

