Cell["", "Subsubsubsection",ExpressionUUID->"e8d38bbf-3c69-43cd-b983-13eade5d1a21"],

Cell[TextData[{
 "Observe that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"Q", " ", "[", "v", "]"}], "\[Beta]"], "="}], TraditionalForm]],
  ExpressionUUID->"a530a65a-cb8b-4d02-a590-3478cf66c15a"],
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", 
     SubscriptBox["I", "V"], "]"}], "\[Beta]", "\[Gamma]"], TraditionalForm]],
  ExpressionUUID->"646bf6e9-b9f6-42bf-92a7-60356ab56f03"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "v", "]"}], "\[Beta]"], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"[", 
       RowBox[{
        SubscriptBox["I", "V"], "(", "v", ")"}], "]"}], "\[Gamma]"], "=", 
     SubscriptBox[
      RowBox[{"[", "v", "]"}], "\[Gamma]"]}]}], TraditionalForm]],
  ExpressionUUID->"450a3119-589f-44f1-8351-e81a7eef9297"],
 "."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
