  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6215981009575243`*^9, 3.62159821730051*^9}, 
   3.621598356761585*^9, {3.6216111387533464`*^9, 3.6216111400346584`*^9}, 
   3.8425223116722083`*^9, 3.8425223602552567`*^9},
 FontSize->16,ExpressionUUID->"6cec1f65-73fb-4b16-ad4b-181ce575a7b3"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "d5cb99af-92e2-4d7a-b883-d71d1aefe215"],
 " be a finite dimensional vector space over a field \[DoubleStruckCapitalF] \
with ordered bases  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "bbfdd8e1-58ef-4f91-b202-08f3cb49b609"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["w", "1"], ",", " ", 
      SubscriptBox["w", "2"], ",", "...", ",", 
      SubscriptBox["w", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "9a4546f8-d665-46c4-a986-890a1310570a"],
 ".  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "=", 
    SubsuperscriptBox[
     RowBox[{"[", 
      SubscriptBox["I", "V"], "]"}], "\[Beta]", "\[Gamma]"]}], 
   TraditionalForm]],ExpressionUUID->"9dcb506d-dd3d-48a2-9129-92a443ca23d1"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2ea3840b-c17d-45e3-a48f-fdec7157635a"],
 ":",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e2838228-b441-4eab-a5cc-9d351ee174a5"],
 "\[Rule] ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "881e8564-b55d-4074-bcbf-c05d7c585ff4"],
 " a linear transformation.    Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]", "\[Beta]"], "=", 
    SuperscriptBox["Q", 
     RowBox[{"-", "1"}]], " "}], TraditionalForm]],ExpressionUUID->
  "2a48849c-41e5-40bd-8e57-e9fbb2ab1213"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{"[", "T", "]"}], "\[Gamma]", "\[Gamma]"], "Q"}], 
   TraditionalForm]],ExpressionUUID->"7af51dc0-8e5a-43b5-82cc-706b86faf5b8"],
 "."
}], "Text",
 CellChangeTimes->{{3.6213403095368614`*^9, 3.621340310865079*^9}, {
   3.621597771133131*^9, 3.621597951992612*^9}, {3.6215994833957386`*^9, 
   3.6215996529281735`*^9}, {3.6217710159922876`*^9, 3.621771030925764*^9}, 
   3.843580617745408*^9, {3.874409079636688*^9, 3.8744091125237365`*^9}, {
   3.87440915662136*^9, 3.8744091882437053`*^9}},
 FontSize->16,ExpressionUUID->"1d7c38b6-9a4b-4ab9-82d0-0e75b4e96799"],

Cell["PROOF:", "Text",
 CellChangeTimes->{{3.874409048869833*^9, 
  3.8744090503291764`*^9}},ExpressionUUID->"9808880c-eece-4b83-b928-\
bca14f696372"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox[
     RowBox[{
      SuperscriptBox["Q", 
       RowBox[{"-", "1"}]], " ", "[", "T", "]"}], "\[Gamma]", "\[Gamma]"], 
    "Q"}], "=", 
   RowBox[{
    SubsuperscriptBox[
     RowBox[{
      SubsuperscriptBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          SubsuperscriptBox[
           RowBox[{"[", 
            SubscriptBox["I", "V"], "]"}], "\[Beta]", "\[Gamma]"], ")"}], 
         RowBox[{"-", "1"}]], " ", "[", "T", "]"}], 
       StyleBox["\[Gamma]",
        FontColor->RGBColor[0, 1, 0]], 
       StyleBox["\[Gamma]",
        FontColor->RGBColor[0, 0, 1]]], "[", 
      SubscriptBox["I", "V"], "]"}], 
     StyleBox["\[Beta]",
      FontColor->RGBColor[1, 0, 1]], 
     StyleBox["\[Gamma]",
      FontColor->RGBColor[0, 1, 0]]], "=", 
    RowBox[{
     SubsuperscriptBox[
      RowBox[{
       SubsuperscriptBox[
        RowBox[{"[", 
         SubsuperscriptBox["I", "V", 
          RowBox[{"-", "1"}]], "]"}], 
        StyleBox["\[Gamma]",
         FontColor->RGBColor[0, 0, 1]], 
        StyleBox["\[Beta]",
         FontColor->RGBColor[1, 0.5, 0.5]]], " ", "[", 
       RowBox[{"T", "\[VeryThinSpace]", 
        SubscriptBox["I", "V"]}], "]"}], 
      StyleBox["\[Beta]",
       FontColor->RGBColor[1, 0, 1]], 
      StyleBox["\[Gamma]",
       FontColor->RGBColor[0, 0, 1]]], "=", 
     RowBox[{
      SubsuperscriptBox[
       RowBox[{"[", 
        RowBox[{
         SubsuperscriptBox["I", "V", 
          RowBox[{"-", "1"}]], "T", "\[VeryThinSpace]", 
         SubscriptBox["I", "V"]}], "]"}], 
       StyleBox["\[Beta]",
        FontColor->RGBColor[1, 0, 1]], 
       StyleBox["\[Beta]",
        FontColor->GrayLevel[0]]], "=", 
      SubsuperscriptBox[
       RowBox[{"[", "T", "]"}], 
       StyleBox["\[Beta]",
        FontColor->RGBColor[1, 0, 1]], 
       StyleBox["\[Beta]",
        FontColor->GrayLevel[0]]]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"292f2079-eae8-447b-ac2e-03a4d16ca7ea"]], \
"Text",
 CellChangeTimes->{{3.874409205988289*^9, 3.874409270078431*^9}, {
  3.8744093005022755`*^9, 3.8744093094195786`*^9}, {3.8744094348615465`*^9, 
  3.8744094883580875`*^9}, {3.874409527364222*^9, 3.874409538621498*^9}, {
  3.874409597824089*^9, 3.874409597824089*^9}},
 FontFamily->"Times New Roman",
 FontSize->16,
 FontWeight->"Normal",ExpressionUUID->"7a2eb2ff-19ba-4b65-b224-056f881bf60c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Definition: ",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6215981009575243`*^9, 3.62159821730051*^9}, 
   3.621598356761585*^9, {3.6216111387533464`*^9, 3.6216111400346584`*^9}, 
   3.8425223116722083`*^9, 3.8425223602552567`*^9, {3.874145780941457*^9, 
   3.8741457864861207`*^9}},
 FontSize->16,ExpressionUUID->"a74207ad-e0a5-4716-b0d7-ed2dea66c1e1"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ",", 
    RowBox[{"B", " ", "\[Element]", 
     RowBox[{
      RowBox[{
       SubscriptBox["M", 
        RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", 
       ")"}], "."}]}]}], TraditionalForm]],ExpressionUUID->
  "f485f4c6-fbe9-419c-ba19-0b0e4bf6d208"],
 " We say ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "c39b462c-8f9c-4815-b0dc-81927a07fa37"],
 " is similar to ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "142ab69f-fd7d-462a-b307-41239ab8f69d"],
 " if there exists an invertible matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "\[Element]", 
    RowBox[{
     SubscriptBox["M", 
      RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", 
     ")"}]}], TraditionalForm]],ExpressionUUID->
  "3b451150-718d-4bb6-8255-d4c69a857057"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     SuperscriptBox["Q", 
      RowBox[{"-", "1"}]], "B", " ", "Q"}]}], TraditionalForm]],
  ExpressionUUID->"f487e9b9-32c8-4c4a-9678-af12da955c2a"],
 "."
}], "Text",
 CellChangeTimes->{{3.6215979717656584`*^9, 3.6215980666403275`*^9}, {
   3.62159968582092*^9, 3.6215998179631133`*^9}, 3.621776440521792*^9, {
   3.874145794240554*^9, 3.8741457959122477`*^9}},
 FontSize->16,ExpressionUUID->"3b8d1dc3-d92c-4b12-8474-41077506ac6a"],

Cell["EQUIVALENCE RELATION \[TildeTilde]:", "Text",
 CellChangeTimes->{{3.9062153839088593`*^9, 3.9062153996691837`*^9}, 
   3.9062154525985518`*^9},ExpressionUUID->"404d1a8a-b320-4d25-a6f7-\
884eea4af3aa"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ForAll]", "A"}], ",", "B", ",", "C"}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"128f3c26-bcd6-4043-b342-016a04f9d36e"]], \
"Text",
 CellChangeTimes->{{3.9062156013151393`*^9, 
  3.9062156108934994`*^9}},ExpressionUUID->"d6cf79a2-a791-4ed1-8877-\
c87873569861"],

Cell[TextData[{
 "Reflexive: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[TildeTilde]", "A"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5eb4f610-b22e-467d-90a2-92a81e2e3580"]
}], "Text",
 CellChangeTimes->{{3.9062153839088593`*^9, 
  3.906215442990758*^9}},ExpressionUUID->"aa5b426a-4f59-4513-a123-\
dd52f76bfb09"],

Cell[TextData[{
 "Symmetric: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[TildeTilde]", "B"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "5263b1f4-07f7-4dc8-b5f5-be824989ef89"],
 " implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "\[TildeTilde]", "A"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "314cd8ff-d058-4f52-b345-7310eacd443e"]
}], "Text",
 CellChangeTimes->{{3.906215473967845*^9, 
  3.906215530141512*^9}},ExpressionUUID->"c8a053f8-7dcb-40b1-9476-\
c09f9f50ad97"],

Cell[TextData[{
 "Transitive: ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[TildeTilde]", "B"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d5b71e4e-fff8-4b84-9afd-d6f47f76f047"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "\[TildeTilde]", "C"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e2d46758-b79c-40e3-aa2e-0a594280674e"],
 " implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[TildeTilde]", "C"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "66dff662-a989-423b-ae16-a8c38e715c07"]
}], "Text",
 CellChangeTimes->{{3.9062155575588846`*^9, 
  3.906215588605863*^9}},ExpressionUUID->"686bfddd-1bf1-46b1-9805-\
25e7e09f99b5"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Observation: ",
  FontFamily->"Times New Roman",
  FontWeight->"Bold",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.6215981009575243`*^9, 3.62159821730051*^9}, 
   3.621598356761585*^9, {3.6216111387533464`*^9, 3.6216111400346584`*^9}, 
   3.8425223116722083`*^9, 3.8425223602552567`*^9, {3.8741464756267138`*^9, 
   3.8741464779644256`*^9}},
 FontSize->16,ExpressionUUID->"21fa46fe-b390-4f33-91b4-cbc0fc5f4749"],

Cell[TextData[{
 "Similarity forms an equivalence class on the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Cross]", "n"}], TraditionalForm]],ExpressionUUID->
  "037f1c67-6586-4e43-8078-75dbedc87fa3"],
 " matrices. It partitions the set of matrices into equivalence classes, \
where each equivalence class captures all the matrix representations of a \
particular linear transformation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "0126a09c-889c-4c2e-b0e1-9008a7c77d9f"],
 " where dim ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", "n"}], TraditionalForm]],ExpressionUUID->
  "be295dc1-5f45-45b7-8fc1-f8a6366ac2a9"],
 ","
}], "Text",
 CellChangeTimes->{{3.874409864140162*^9, 
  3.874409987070165*^9}},ExpressionUUID->"e5091ece-401a-44bc-b04b-\
bf62fa2b49f1"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     SuperscriptBox["I", 
      RowBox[{"-", "1"}]], "A", "\[VeryThinSpace]", "I"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "aa6cdcf6-5f72-471e-a3c3-9052234c1888"],
 " so reflexive"
}], "Text",
 CellChangeTimes->{{3.9062157710166283`*^9, 
  3.9062158139826117`*^9}},ExpressionUUID->"2d31601c-3d0a-4291-9103-\
2a258f542bb2"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     SuperscriptBox["Q", 
      RowBox[{"-", "1"}]], "B", " ", "Q"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b552ef3b-c2e1-4dbd-9027-f4c4191cd531"],
 " implies ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["Q", 
        RowBox[{"-", "1"}]], ")"}], 
      RowBox[{"-", "1"}]], "A", " ", 
     SuperscriptBox[
      RowBox[{"(", "Q", ")"}], 
      RowBox[{"-", "1"}]]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bf637366-6d6d-464d-821e-e3d1a0838363"]
}], "Text",
 CellChangeTimes->{{3.9062158186487083`*^9, 
  3.9062158625709786`*^9}},ExpressionUUID->"ea37ab15-9ce0-41cf-9611-\
81d18ad7e562"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     SuperscriptBox["Q", 
      RowBox[{"-", "1"}]], "B", " ", "Q"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d779c2ee-1f86-4df5-a9d9-7437963b078d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{
     SuperscriptBox["S", 
      RowBox[{"-", "1"}]], "C", "\[VeryThinSpace]", "S"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cf2ab5b4-2b39-4c75-aae2-7bcbe15d12f6"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["Q", 
       RowBox[{"-", "1"}]], 
      SuperscriptBox["S", 
       RowBox[{"-", "1"}]], "C", "\[VeryThinSpace]", "S", " ", "Q"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"S", "\[VeryThinSpace]", "Q"}], ")"}], 
       RowBox[{"-", "1"}]], 
      RowBox[{"C", "\[VeryThinSpace]", "(", 
       RowBox[{"S", "\[VeryThinSpace]", "Q"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7012a910-7754-4c57-9458-d776e5950b2e"]
}], "Text",
 CellChangeTimes->{{3.906215897354146*^9, 
  3.90621596525841*^9}},ExpressionUUID->"ded4cc48-6983-49f9-a180-\
46a30fc1e276"]
