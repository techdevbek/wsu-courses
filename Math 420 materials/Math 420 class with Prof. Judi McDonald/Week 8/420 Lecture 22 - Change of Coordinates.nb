Cell[TextData[{
 "Can every square matrix serve as a matrix representation of the identity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"matrix", "?"}], TraditionalForm]],ExpressionUUID->
  "a951d6f6-dbf9-45c6-ae2a-a0fbea56c1cf"],
 "   Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "V"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "00002ca2-3f05-40ae-9b2e-b38ff56931bc"],
 " is invertible, its matrix representations must be too."
}], "Text",
 CellChangeTimes->{{3.874408769045971*^9, 3.8744087796256404`*^9}, {
  3.906201818092966*^9, 3.9062019716301146`*^9}, {3.906202002250719*^9, 
