Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "92f38b9b-ed9c-4f87-b25c-3065b93eb368"],
 " be a finite dimensional vector space over a field \[DoubleStruckCapitalF] \
with ordered basis  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "498d7dae-76ac-42da-bd49-6b92aa6d8d79"],
 ".  The ",
 StyleBox["standard representation of ",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FontSlant->"Italic",
  FontColor->GrayLevel[0],ExpressionUUID->
  "a5eba7b3-2b9b-42f8-bf1e-2cf036ac9fd2"],
 StyleBox[" with respect to ",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 StyleBox["\[Beta]",
  FontColor->GrayLevel[0]],
 StyleBox[" ",
  FontColor->RGBColor[0, 0, 1]],
 "is the function ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Phi]", "\[Beta]"], TraditionalForm]],ExpressionUUID->
  "3a5ebc6e-45d3-4c22-b9f0-a1b1f90be186"],
 ":",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ef6f7fd8-48cf-4cb4-99ff-c55605e44f13"],
 " \[Rule]",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalF]", "n"], TraditionalForm]],
  ExpressionUUID->"c1e59c8c-90ca-4e7c-9ba0-7ae05f217211"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Phi]", "\[Beta]"], "(", "v", ")"}], " ", "=", " ", 
    SubscriptBox[
     RowBox[{"[", "v", "]"}], "\[Beta]"]}], TraditionalForm]],ExpressionUUID->
  "c903d7ba-089b-4af6-85f9-f17e04cd9cd1"],
 " and ",
