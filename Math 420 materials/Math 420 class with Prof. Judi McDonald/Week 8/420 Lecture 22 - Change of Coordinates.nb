5ececb69a878"],

Cell[TextData[{
 StyleBox["B",
  FontColor->RGBColor[0, 0, 1]],
 " means you are doing very well in the class and/or have checked in with me \
with requests for how I can assist in your learning.  I expect you to get an \
A, B, or C by the end of the semester."
}], "Text",
 CellChangeTimes->{{3.8745790397214456`*^9, 3.8745790959288445`*^9}, {
  3.9062007176742926`*^9, 
  3.9062007746559954`*^9}},ExpressionUUID->"4e622b87-41bd-437f-a89c-\
b4bef3b9f125"],

Cell[TextData[{
 StyleBox["C",
  FontColor->RGBColor[0, 0, 1]],
 " means you are encouraged to check in with me go over anything I can do to \
help you moving forward. "
}], "Text",
 CellChangeTimes->{{3.906200626888813*^9, 3.9062007114450674`*^9}, {
  3.9062011025085335`*^9, 
  3.9062011032598343`*^9}},ExpressionUUID->"277b61cc-2452-4405-9d27-\
f3d2b47929c8"],

Cell[TextData[{
 StyleBox["F",
  FontColor->RGBColor[0, 0, 1]],
 " means something in the way you are approaching this class needs to change \
for you to have any hope of passing. "
}], "Text",
 CellChangeTimes->{{3.8745790397214456`*^9, 
  3.8745791247656956`*^9}},ExpressionUUID->"0d621d8e-7c30-40d6-b42e-\
8d26a5d483a1"],

Cell[TextData[{
 StyleBox["Z",
  FontColor->RGBColor[0, 0, 1]],
 " means I do not see evidence that you are participating in the class.  This \
can lead to issues with immigration, student loans, etc. "
}], "Text",
 CellChangeTimes->{{3.8745790397214456`*^9, 3.8745791247656956`*^9}, {
  3.906031384123994*^9, 3.906031394921878*^9}, {3.9060314711610165`*^9, 
  3.9060314969230795`*^9}},ExpressionUUID->"9ea7127f-19c4-4f06-ad16-\
f891d341b349"],

Cell["\<\
NOTE:  The BS in math requirements are a 2.0 average in your math classes.  \
You can graduate with a D in this class as long as your other grades are high \
enough. \
\>", "Text",
