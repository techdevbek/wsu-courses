98d6942a970e"],

Cell["\<\
If we take the same basis for both the domain and the codomain, \
\>", "Text",
 CellChangeTimes->{{3.906473048490458*^9, 
  3.906473081983497*^9}},ExpressionUUID->"e69f71cc-d151-4375-a9c1-\
9e0eb7facdcd"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["I", "V"], "(", 
    SubscriptBox["v", "i"], ")"}], "=", 
   RowBox[{
    SubscriptBox["v", "i"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"0", 
             SubscriptBox["v", "1"]}], "+", 
            RowBox[{"0", 
             SubscriptBox["v", "2"]}], "+"}], "..."}], ".", " ", "1"}], 
         SubscriptBox["v", "i"]}], " ", "+"}], "..."}], ".", 
      RowBox[{"+", "0"}]}], 
     SubscriptBox["v", "n"]}]}]}], TraditionalForm]],
 FormatType->
  TraditionalForm,ExpressionUUID->"20beeb3c-2f5a-4699-93b2-18a7504e9e4a"]], \
"Text",
 CellChangeTimes->{{3.906473048490458*^9, 
  3.9064731329361515`*^9}},ExpressionUUID->"07188c12-1109-478b-84b2-\
516b434edc12"],

Cell["\<\
For a more general linear transformation, do we have particular vectors, say \
u,v, w,...\
\>", "Text",
 CellChangeTimes->{{3.8745783752979803`*^9, 3.8745783752979803`*^9}, {
  3.874580806734376*^9, 
  3.8745808450792065`*^9}},ExpressionUUID->"58b2c14b-03c1-4782-9983-\
35c8b04702b4"],

Cell[TextData[{
 "So that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "u", ")"}], "=", "u"}], TraditionalForm]],
  ExpressionUUID->"df91411e-f150-4d40-b448-62a1de6c60d0"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "v", ")"}], "=", "v"}], TraditionalForm]],
  ExpressionUUID->"96632c9e-4d8b-482a-993f-6ad6be55f56b"],
 ", but maybe ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "w", ")"}], "\[NotEqual]", "w"}], TraditionalForm]],
  ExpressionUUID->"56e609a6-c148-40d3-8734-19eee2c33933"],
 "?"
}], "Text",
 CellChangeTimes->{{3.87457837545998*^9, 3.87457837545998*^9}, {
  3.874580847766654*^9, 
  3.8745808940428267`*^9}},ExpressionUUID->"5d4331f8-0b22-40f3-b9f6-\
a2466d2ba519"],

Cell["DEFINITION", "Text",
 CellChangeTimes->{{3.874582119072874*^9, 
  3.8745821219104605`*^9}},ExpressionUUID->"43c68fca-9ec2-45e8-a564-\
d09ae84bf3e6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", ":", "V"}], "->", "V"}], TraditionalForm]],ExpressionUUID->
  "8e056408-8791-41d1-9e6d-b45394cd6ff8"],
 " be a linear operator (a linear transformation from a vector space back \
into itself) on a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ed43e77e-d8b3-4471-a63b-965ce7abf874"],
 ".  We say ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", 
    StyleBox["\[NotEqual]",
     FontColor->RGBColor[0, 0, 1]], 
    StyleBox["0",
     FontColor->RGBColor[0, 0, 1]]}], TraditionalForm]],ExpressionUUID->
  "28c244bb-9c63-4651-b676-8401b78baeb0"],
 " is an eigenvector of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2793a9af-9471-4409-9ccd-b11b88e8159f"],
 " with eigenvalue \[Lambda] provided "
}], "Text",
 CellChangeTimes->{{3.874578375804076*^9, 3.874578375804076*^9}, {
  3.8745809950013504`*^9, 3.874581076791139*^9}, {3.874582141875606*^9, 
  3.874582146219812*^9}},ExpressionUUID->"4a68f8eb-642d-4abb-8592-\
84c8b0beed55"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "u", ")"}], "=", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "u"}]}], TraditionalForm]],
  ExpressionUUID->"7b93e9e9-e04c-4d74-b08b-6bedf95bd025"],
 "."
}], "Text",
 CellChangeTimes->{{3.874578375804076*^9, 3.874578375804076*^9}, {
  3.8745809950013504`*^9, 3.874581087267873*^9}},
 TextAlignment->Center,ExpressionUUID->"d91a7aee-676c-4072-a160-a1416b049292"],

Cell[TextData[{
 "So if we can find a basis of eigenvectors, call them ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "1"], ",", 
    SubscriptBox["u", "2"], ",", " ", "...", ",", 
    SubscriptBox["u", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "684631cd-c573-4e3d-872f-899f65a3b992"],
 " for the vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "46bfd064-00ba-4979-ab27-4341aaf6644f"],
 " (of dimension ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "fc17cc19-90d9-48e4-a810-9c5cd931fe68"],
 "), with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", " ", 
    SubscriptBox["\[Lambda]", "2"], ",", "...", ",", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "3b7acc86-5554-4c11-87a2-853f7c9888e8"],
 ", then if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["u", "1"], ",", 
      SubscriptBox["u", "2"], ",", " ", "...", ",", 
      SubscriptBox["u", "n"]}], "}"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "413e15dc-a325-4e93-9551-7940c0e70c0f"],
 ", then"
}], "Text",
 CellChangeTimes->{{3.874578375975915*^9, 3.874578375975915*^9}, {
  3.8745811332192698`*^9, 
  3.874581260876584*^9}},ExpressionUUID->"286d161f-8d33-41b1-9080-\
5460a04b9b31"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]", "\[Beta]"], "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        SubscriptBox["\[Lambda]", "1"], "0", "\[CenterEllipsis]", 
        "\[CenterEllipsis]", "0"},
       {"0", 
        SubscriptBox["\[Lambda]", "2"], "\[DescendingEllipsis]", " ", 
        "\[VerticalEllipsis]"},
       {"\[VerticalEllipsis]", "0", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
       {"0", "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        SubscriptBox["\[Lambda]", 
         RowBox[{"n", "-", "1"}]], "0"},
       {"0", "0", "\[TripleDot]", "0", 
        SubscriptBox["\[Lambda]", "n"]}
      }], "\[NoBreak]", ")"}], " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4104082f-f383-42b6-a255-8627e2b2eb26"],
 "  almost as pretty as ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6c88c958-5b40-4f09-b1c3-c319eb099ebd"]
}], "Text",
 CellChangeTimes->{{3.8745783761634226`*^9, 3.8745783761634226`*^9}, {
  3.874581182681874*^9, 3.8745811836487813`*^9}, {3.874581265383273*^9, 
  3.8745813291452723`*^9}, {3.8745814798185787`*^9, 3.874581485202637*^9}, {
  3.8745815174172287`*^9, 
  3.8745816427460976`*^9}},ExpressionUUID->"d0e9864d-9cf5-41f4-b65f-\
4635809213c0"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["u", "1"], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], 
      SubscriptBox["u", "1"]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[Lambda]", "1"], 
         SubscriptBox["u", "1"]}], "+", 
        RowBox[{"0", 
         SubscriptBox["u", "2"]}], "+"}], " ", "..."}], "+", 
      RowBox[{"0", 
       SubscriptBox["u", "n"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "53f68553-d9c1-4fac-bdd6-cb962f9e238e"]
}], "Text",
 CellChangeTimes->{{3.8745813653331995`*^9, 3.8745813809264812`*^9}, {
   3.8745814501106234`*^9, 3.874581477414225*^9}, 
   3.906473657727805*^9},ExpressionUUID->"378b30e8-1e17-4753-bb22-\
5685932acd34"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", 
    SubscriptBox["u", "2"], ")"}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "2"], 
     SubscriptBox["u", "2"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"0", 
        SubscriptBox["u", "1"]}], "+", 
       RowBox[{
        SubscriptBox["\[Lambda]", "2"], 
        SubscriptBox["u", "2"]}], "+"}], " ", "..."}], "+", 
     RowBox[{"0", 
      SubscriptBox["u", "n"]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"f5a8bc96-0c45-4b66-9364-9eab1e47c511"]], \
"Text",
 CellChangeTimes->{{3.8745813653331995`*^9, 3.8745813809264812`*^9}, {
  3.8745814501106234`*^9, 3.874581477414225*^9}, {3.906473659618476*^9, 
  3.9064736854415684`*^9}},ExpressionUUID->"de0f2f47-c7e2-4186-b9ba-\
c6c308548d16"],

Cell[TextData[{
 "Can an eigenvalue have more than one eigenvector?  Can an eigenvector have \
more than one eigenvalue?  Can we always get a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b7580690-a3db-4d1e-b8ff-51b33c46227c"],
 " of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "d23b974d-7489-4435-a490-4df8b2dc1ba6"],
 "?"
}], "Text",
 CellChangeTimes->{{3.874578376335251*^9, 3.874578376335251*^9}, {
  3.8745813958440256`*^9, 3.8745814302637897`*^9}, {3.8745816731105976`*^9, 
  3.874581698445015*^9}},ExpressionUUID->"fb2a93d1-983a-4ff4-961c-\
8a17d0ed443c"],

Cell["Can an eigenvalue have more than one eigenvector?", "Text",
 CellChangeTimes->{
  3.9064737622664824`*^9},ExpressionUUID->"035441c6-c92b-4cfe-8698-\
1b3a63b706e6"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6f06ac2a-1030-4323-9a4c-dce4279a89c3"],
 ", what is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "(", 
    RowBox[{"3", "\[VeryThinSpace] ", "x"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b3656120-0a12-4bd7-8d7c-db828a7eabe2"],
 "?",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"3", "x"}], ")"}], "=", 
    RowBox[{
     RowBox[{"3", 
      RowBox[{"T", "(", "x", ")"}]}], "=", 
     RowBox[{
      RowBox[{"3", "\[Lambda]", "\[VeryThinSpace]", "x"}], "=", 
      RowBox[{"\[Lambda]", "(", 
       RowBox[{"3", "x"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65763473-589a-4fe1-818e-8434d1f4e512"],
 ".  There are infinitely many different eigenvectors for a given eigenvalue \
since, in particular, the nonzero scalar multiples of eigenvectors are \
eigenvectors. "
}], "Text",
 CellChangeTimes->{{3.9064737661243277`*^9, 
  3.9064739136631775`*^9}},ExpressionUUID->"a116ede3-a642-4958-b922-\
87a6cac0afc1"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x", " ", "and", " ", 
      RowBox[{"T", "(", "y", ")"}]}], "=", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "y"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "31ef9d79-0857-470e-8d96-95f8091910eb"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"x", "+", "y"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"T", "(", "x", ")"}], "+", 
      RowBox[{"T", "(", "y", ")"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Lambda]", " ", "x"}], "+", 
       RowBox[{"\[Lambda]", "\[VeryThinSpace]", "y"}]}], "=", 
      RowBox[{"\[Lambda]", "(", 
       RowBox[{"x", "+", "y"}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "50f1fb4f-fe77-4683-97ab-b8ef0c41f476"],
 "."
}], "Text",
 CellChangeTimes->{{3.9064737661243277`*^9, 
  3.9064739914450846`*^9}},ExpressionUUID->"0d78b9a8-54ba-4aaa-a8aa-\
8aa1f3e504bc"],

Cell["\<\
So adding to eigenvectors with the same eigenvalue, gives us another \
eigenvector (as long as the result is not zero).\
\>", "Text",
 CellChangeTimes->{{3.906473766298992*^9, 3.9064737662999954`*^9}, {
  3.9064739945450244`*^9, 
  3.9064740269012775`*^9}},ExpressionUUID->"6222d203-b807-4e94-abe3-\
b984d12e5a1d"],

Cell["\<\
Are they a subspace?  When we scale and add eigenvectors, we get eigenvectors.\
\>", "Text",
 CellChangeTimes->{{3.9064737664545436`*^9, 3.9064737664560895`*^9}, {
  3.9064740676551623`*^9, 
  3.9064741152117043`*^9}},ExpressionUUID->"46d117af-60d4-49ff-baa0-\
595c3624c5c9"],

Cell["DEFINITION and OBSERVATION", "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474143617124*^9}, {
  3.906474220548829*^9, 
  3.90647423059239*^9}},ExpressionUUID->"db8c5bc9-c782-4307-b500-\
0f48c3f9881c"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "42c71ea8-f7da-4eb0-8398-6bf77dd564b6"],
 " be an eigenvalue of a linear operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ecfdb537-5f21-4acf-8d3d-e863fa24c836"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "\[Lambda]"], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "\[Element]", "V"}], "|", 
       RowBox[{"T", "(", "x", ")"}]}], "=", 
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}], "}"}]}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "800031cd-a69c-4778-bf84-bcfd0580330d"],
 " is a subspace.  This subspace consists of all the eigenvectors associated \
with ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a1b8bbe2-d0fa-4361-a4c7-47635cbf2e23"],
 ", as well as the zero vector.   We refer to it as the eigenspace of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f416ecc1-3549-4147-8393-29d0e669f248"],
 " with eigenvalue \[Lambda]."
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474260788042*^9}, {
  3.906474327494382*^9, 3.9064743433123355`*^9}, {3.906474468611943*^9, 
  3.9064744705954456`*^9}},ExpressionUUID->"496daa89-2866-4c82-baaa-\
45dbe70f8440"],

Cell["QUESTION:  Can an eigenvector have more than one eigenvalue?", "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.9064741389867554`*^9}, {
  3.906474378940111*^9, 
  3.906474390638812*^9}},ExpressionUUID->"d1b5b855-a237-4a70-a655-\
328fc8726227"],

Cell[TextData[{
 "Suppose ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8c73aef0-be8b-4017-8099-59cc51aac5f8"],
 " has both ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", " ", "and", " ", "\[Mu]"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "a5870e5e-8fc1-4754-9912-a05b650fcd44"],
 " as eigenvalues for a given operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b81e8691-a54c-4426-aeab-d9a5af8fce79"],
 "."
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 
  3.9064744562386703`*^9}},ExpressionUUID->"29b67226-a2fe-4367-8bb2-\
9dd0bfbf8057"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}], "=", 
    RowBox[{
     RowBox[{"T", "(", "x", ")"}], "=", 
     RowBox[{"\[Mu]", "\[VeryThinSpace]", "x"}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f6fbecf0-0d7e-4d69-95a7-9ae8464de289"],
 ", but then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Lambda]", "-", "\[Mu]"}], ")"}], "x"}], "=", "0"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b5871ba4-f3c2-4936-807b-fe6f5eaf9714"],
 ".  So either ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Lambda]", "-", "\[Mu]"}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9569b5ab-2b69-49ee-a3df-09a367a5af39"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7f32e3c4-5347-40a4-9404-f5ca6929bfd7"],
 "."
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 3.906474408618503*^9}, {3.9064745833612957`*^9, 
  3.9064746575236473`*^9}},ExpressionUUID->"501dcd19-4951-4c7a-8321-\
6435368fbb65"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "0", ")"}], "=", "\[Mu]0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f8bc5141-505a-4318-9a53-42d43697add1"],
 " for every scalar ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "abd6cffb-304c-4ce8-a507-ba38e3d41d7b"],
 ", it doesn\[CloseCurlyQuote]t give us much information. Every scalar would \
be an eigenvalue for the 0 vector.  Moreover, nobody wants zero to show up in \
a basis because a set with the 0 vector is always linearly dependent and \
hence cannot be a basis.  "
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 3.906474408784133*^9}, {3.90647473987519*^9, 
  3.9064748556542406`*^9}},ExpressionUUID->"c3f6b6ca-7351-47c8-a745-\
33ee74ab4e88"],

Cell[TextData[{
 "QUESTION: Does every operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "165b5bbe-3491-419e-b916-0e80b78634f4"],
 " on a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "715b760c-28e5-4890-8ceb-05dacb8f8536"],
 " have a basis of eigenvectors?"
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 3.906474408949028*^9}, {3.9064749091633835`*^9, 
  3.9064749419830914`*^9}},ExpressionUUID->"3b9d27cd-170d-4cb8-9b0f-\
1fa921fbeeee"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "x", ")"}], "=", 
    RowBox[{"A", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8dc2c9d3-95c7-4149-8d41-6ae9743915b8"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "1"},
       {"0", "1"}
      }], "\[NoBreak]", ")"}], " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "602ada24-3502-464e-a37c-d52c4511827f"],
 ".  Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ":", 
    RowBox[{
     SuperscriptBox["\[DoubleStruckCapitalR]", "2"], "\[LongRightArrow]", " ", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "2"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c4ba7e4a-dc3c-4211-8717-7f48572166e8"],
 " is a linear operator, but ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1aca8d18-a318-4b1a-86fe-5575e0eaaa67"],
 " is the only eigenvalue."
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 3.906474409117669*^9}, {3.9064749570697184`*^9, 
  3.9064749807766285`*^9}, {3.906475011238332*^9, 
  3.9064750727681713`*^9}},ExpressionUUID->"b7414dfd-6f4a-43c7-84bb-\
08b1bf59894f"],

Cell["\<\
But to talk about this example we need to know how to find eigenvectors?\
\>", "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
  3.906474405834359*^9, 3.9064744067536364`*^9}, {3.9064751022021976`*^9, 
  3.9064751247833786`*^9}},ExpressionUUID->"1527bdc4-d02e-405d-a749-\
8b921e69871c"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", "x"}], "=", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "x"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cd559474-4ec7-4dd6-aa93-efda95a3e993"],
 ", the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"A", "-", 
       RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], "x"}], "=", 
    "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ab1e7407-4dae-4473-8c87-fe2d6ff7faf8"]
}], "Text",
 CellChangeTimes->{{3.9064741337613735`*^9, 3.906474138031576*^9}, {
