   3.906637142036875*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"57e47ab2-41b3-4b8e-ad10-f4744398636e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem : ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
  3.622379588146862*^9, 3.622379589318798*^9}, {3.6225483494953628`*^9, 
