}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof : ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
  3.622379588146862*^9, 3.622379589318798*^9}, {3.6225483494953628`*^9, 
  3.6225483602302732`*^9}, {3.843301871651741*^9, 3.8433018799701576`*^9}, {
  3.9066468658343763`*^9, 3.906646866436517*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b3f1bc8a-476b-40b1-9219-1d7f38731aec"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Det", 
     RowBox[{"(", 
      RowBox[{"A", "-", "\[Lambda]I"}], ")"}]}], "=", "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "92643b6b-c541-47ab-9a9f-126121567b41"],
 " if and only if there is a nonzero vector ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "33cddeb3-d42e-424b-8db0-91697e754afb"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"A", "-", 
       RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], "x"}], "=", 
    "0"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7d15f637-c401-49b2-a4c5-c6984af890f5"]
}], "Text",
 CellChangeTimes->{{3.9066468745289984`*^9, 3.906646946983313*^9}, {
