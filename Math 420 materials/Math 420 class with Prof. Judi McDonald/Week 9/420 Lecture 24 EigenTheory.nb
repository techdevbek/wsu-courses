Cell[TextData[StyleBox["Note:  ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
   3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
   3.6225485022323194`*^9}, {3.6225485524692397`*^9, 
   3.6225485524692397`*^9}, {3.6225486174881306`*^9, 
   3.6225486467126503`*^9}, {3.6225511997103195`*^9, 3.622551199741559*^9}, {
   3.6225513123003054`*^9, 3.622551330301228*^9}, {3.622551377520517*^9, 
   3.6225514526650333`*^9}, {3.622551496702791*^9, 3.6225514994529305`*^9}, 
   3.843301922376959*^9, {3.9066377368430743`*^9, 3.906637738476149*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"2596d768-3d43-4eb7-818b-12fb95d5f95c"],

Cell[TextData[{
 "The literature uses det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\[Lambda]", " ", "I"}], "-", "A"}], ")"}], ","}], 
   TraditionalForm]],ExpressionUUID->"8190b161-70cb-4b04-8c2e-e56a7c0bc1c3"],
 " but det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "-", 
     RowBox[{"\[Lambda]", " ", "I"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"84766ae1-8be9-42eb-a25a-7ba5a8d96ef5"],
 " is typically used in teaching texts."
}], "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
  3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
  3.6225485022323194`*^9}, {3.6225485524692397`*^9, 3.6225485524692397`*^9}, {
  3.6225486174881306`*^9, 3.6225486467126503`*^9}, {3.6225511997103195`*^9, 
  3.622551199741559*^9}, {3.6225513123003054`*^9, 3.622551330301228*^9}, {
  3.622551377520517*^9, 3.6225514526650333`*^9}, {3.622551496702791*^9, 
  3.6225514994529305`*^9}, {3.9066371750195475`*^9, 3.906637176069581*^9}, {
  3.9066372329500237`*^9, 3.9066372329500237`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"a104cf38-2a71-4653-92f7-1159d5354a60"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
   3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
   3.6225485022323194`*^9}, {3.6225485524692397`*^9, 
   3.6225485524692397`*^9}, {3.6225486174881306`*^9, 
   3.6225486467126503`*^9}, {3.6225511997103195`*^9, 
   3.6225512013983326`*^9}, {3.6225519381224537`*^9, 3.62255193977878*^9}, 
   3.8433020118752265`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"4156fd99-8e81-4586-a118-fcf19d580a16"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    RowBox[{
     RowBox[{
      SubscriptBox["M", 
       RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}],
      "."}]}], TraditionalForm]],ExpressionUUID->
  "9499d1cd-3535-4a22-bbf1-a181a4824464"],
 " The polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "\[Lambda]", ")"}], "="}], TraditionalForm]],
  ExpressionUUID->"4ad90560-1059-4903-8a91-44469f8c2494"],
 " det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "-", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], 
   TraditionalForm]],ExpressionUUID->"4dad47a4-618a-4416-a26e-a451978829b1"],
 " is called the ",
 StyleBox["characteristic polynomial",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "19b0ce9b-1e51-4d0a-8474-e529b9c83c75"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
   3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
   3.6225485022323194`*^9}, {3.6225485524692397`*^9, 
   3.6225485524692397`*^9}, {3.6225486174881306`*^9, 
   3.6225486467126503`*^9}, {3.6225511997103195`*^9, 
   3.6225512013983326`*^9}, {3.6225519381224537`*^9, 3.62255193977878*^9}, 
   3.843302013833135*^9, {3.9066472120789165`*^9, 3.9066472183286266`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"16c68569-726f-4683-b89f-5fca4b1d1846"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Remark: ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
  3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
  3.6225485022323194`*^9}, {3.6225485524692397`*^9, 3.622548609300214*^9}, {
  3.843554968025321*^9, 3.8435549706231117`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"de21bc36-7c73-4973-902a-f5644b1a52a0"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    RowBox[{
     RowBox[{
      SubscriptBox["M", 
       RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}],
      "."}]}], TraditionalForm]],ExpressionUUID->
  "112f0e28-a932-4ed6-a67e-af93da3b2bac"],
 " The roots of the ",
 StyleBox["characteristic polynomial",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "241cc956-0161-4d5d-89fa-388f0a4573aa"],
 " are precisely the eigenvalues of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "f7fc5c18-930b-421c-9e09-cfa00ede979c"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375920326746*^9}, {
  3.62254773394736*^9, 3.62254773394736*^9}, {3.6225484516939573`*^9, 
  3.6225485022323194`*^9}, {3.6225485524692397`*^9, 3.622548609300214*^9}, {
  3.843554968025321*^9, 3.8435549722010684`*^9}, {3.843555060150955*^9, 
  3.8435550705085645`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e197f1ba-7d5c-4c8b-b9b5-c312d34533a2"],

Cell["\<\
So how do we move from matrices to linear operator?  How would you find the \
characteristic polynomial of a linear operator?  We could find a matrix \
representation of the linear operator with respect to a basis.\
\>", "Text",
 CellChangeTimes->{{3.906647335738201*^9, 3.906647405996373*^9}, {
  3.906647443831394*^9, 
  3.9066474566184473`*^9}},ExpressionUUID->"5ee3d75f-80a8-491b-8a1f-\
294d4bdead92"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "Subsubsubsection",ExpressionUUID->"1865bd6a-7ef9-4bd9-9c8b-c1461e5d7a13"],

Cell[TextData[{
 "Recall:  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", 
    SuperscriptBox["Q", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "b1925b1b-c26c-4599-813b-2d6bd8ad74b3"],
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Gamma]"], TraditionalForm]],ExpressionUUID->
  "5db81b01-231b-49f0-9e75-6cfe4c2e7cd5"],
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "c70ad008-d16e-4739-8710-6f2dfe9107a8"],
 " so "
}], "Text",
 CellChangeTimes->{{3.8437467330741186`*^9, 3.843746844365362*^9}, {
  3.843746895448583*^9, 3.843747182868312*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"1f6657a7-d3d4-4a53-a7bf-8b35e3b2bcec"],

Cell[TextData[{
 "det",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}], "-", 
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Beta]"]}], ")"}], "="}], TraditionalForm]],
  ExpressionUUID->"b140b0c5-834e-42e2-bed8-8c57ebc32043"],
 " det ",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", 
       SuperscriptBox["Q", 
        RowBox[{"-", "1"}]], "I", "\[VeryThinSpace]", "Q"}], "-", 
      RowBox[{
       SubscriptBox[
        RowBox[{
         SuperscriptBox["Q", 
          RowBox[{"-", "1"}]], "[", "T", "]"}], "\[Gamma]"], "Q"}]}], ")"}], 
    " "}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"=", 
    RowBox[{"det", 
     FormBox[
      RowBox[{
       RowBox[{"(", "\[VeryThinSpace]", 
        RowBox[{
         RowBox[{
          SuperscriptBox["Q", 
           RowBox[{"-", "1"}]], "(", 
          RowBox[{
           RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}], "-", 
           SubscriptBox[
            RowBox[{"[", "T", "]"}], "\[Gamma]"]}], ")"}], "Q"}], ")"}], " ", 
       "\[IndentingNewLine]", 
       RowBox[{"=", 
        RowBox[{
         RowBox[{"det", "(", 
          SuperscriptBox["Q", 
           RowBox[{"-", "1"}]], ")"}], 
         RowBox[{"det", "(", 
          RowBox[{
           RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}], "-", 
           SubscriptBox[
            RowBox[{"[", "T", "]"}], "\[Gamma]"]}], ")"}], 
         RowBox[{"det", "(", "Q", ")"}]}]}]}],
      TraditionalForm]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{"=", 
    RowBox[{"det", "(", 
     RowBox[{
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}], "-", 
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Gamma]"]}], ")"}]}], TraditionalForm]}],
  ExpressionUUID->"f6674d41-2d44-477b-9548-730944be9f6e"]
}], "Text",
 CellChangeTimes->{{3.8437467330741186`*^9, 3.843746844365362*^9}, {
  3.843746895448583*^9, 3.843747207005163*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"b50164e6-9302-4f49-b48b-db25790bd684"],

Cell["\<\
The coefficients of the eigenvectors will look different because they are \
coefficients with respect to different bases.  When you translate them back \
into the original vector space, they will be the same.\
\>", "Text",
 CellChangeTimes->{{3.843747231798306*^9, 3.843747292054985*^9}, {
  3.9066378014897037`*^9, 3.906637805172826*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"56ecc9b0-c892-4c74-b581-b52866b3b225"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["Theorem:",
  FontFamily->"Times New Roman",
  FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]],
 StyleBox[" ",
  FontWeight->"Bold",
  FontColor->RGBColor[0, 0, 0.7]]
}], "Subsubsubsection",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
   3.6225493988262625`*^9, 3.622549398841859*^9}, 3.8435551375517645`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"5e5b565e-d033-462c-909d-f250e7f5a5a9"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "00bb3ffb-2f02-434e-8a04-9cc3bfd5e0dc"],
 " be a linear operator on a finite dimensional vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f6fc853a-6683-4e5f-9fb8-c4c24dfbab35"],
 " and let \[Lambda] be an eigenvalue of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "67b6a9a2-5008-4124-b583-fc6f055f7ed7"],
 "  Then ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "3438cf28-a170-453b-9174-3eb6d50311e2"],
 " is an eigenvector of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2b13bc29-3657-4000-96d1-1d40e24e4743"],
 " corresponding to \[Lambda] if and only if ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "c1513c08-36ae-455c-9aad-a40cf1fe4217"],
 " is a nonzero vector in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"N", "(", 
     RowBox[{
      RowBox[{"\[Lambda]", " ", 
       SubscriptBox["I", "V"]}], "-", "T"}], ")"}], "."}], TraditionalForm]],
  ExpressionUUID->"ee57ff0b-ab38-48b5-8ae2-dffd02c16dd7"],
 " "
}], "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
   3.6225493988262625`*^9, 3.622549398841859*^9}, 3.843555139245989*^9, {
   3.9066477800301547`*^9, 3.906647781315114*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4230ce7f-a773-46f8-994e-a33b29ed6d53"],

Cell[TextData[StyleBox["Proof:  ", "Subsubsubsection",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[0., 0.5019607843137255, 0.5019607843137255]]], "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
   3.6225493988262625`*^9, 3.6225493991231527`*^9}, {3.622552597382452*^9, 
   3.6225526079298706`*^9}, 3.8435551607476707`*^9, {3.9066377469343524`*^9, 
   3.906637748492622*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5a214e34-aba1-462e-8d78-10de7a30d788"],

Cell["Very similar to parts of the matrix proof above.", "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
  3.6225493988262625`*^9, 3.6225493991231527`*^9}, {3.622552597382452*^9, 
  3.6225526079298706`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"dee559f6-3659-42c9-bdbd-cc7d2b800e20"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition: ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.6225492814999084`*^9, 3.622549339866684*^9}, {
   3.6225493832942*^9, 3.6225493919040365`*^9}, {3.622552658103648*^9, 
   3.6225526617598667`*^9}, 3.8435551812459116`*^9, {3.906637490388244*^9, 
   3.9066374915046124`*^9}, {3.9066377518925*^9, 3.9066377569689665`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"71b60d13-3ce0-4877-b88a-8504c43ae8ab"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "fa06b3f0-3037-4c61-96d0-81bb0c8a0226"],
 " be a linear operator on a vector space ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "fce14979-b544-4f2b-b077-73ec58835584"],
 " and let \[Lambda] be an eigenvalue of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "4ef364ce-01d0-4046-bd30-aa645ca7d653"],
 "  Then  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "(", 
    RowBox[{
     RowBox[{"\[Lambda]", " ", "I"}], "-", "T"}], ")"}], TraditionalForm]],
  ExpressionUUID->"08fadc45-fdff-405f-bfcf-300df62f0ecf"],
 " is referred to as the ",
 StyleBox["eigenspace",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 " of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "e08c59e5-8734-4fd9-a9c6-8ba465d572b8"],
 " corresponding to the eigenvalue \[Lambda]. "
}], "Text",
 CellChangeTimes->{{3.6225492814999084`*^9, 3.622549339866684*^9}, {
  3.6225493832942*^9, 3.6225493919040365`*^9}, {3.622552658103648*^9, 
  3.6225526617598667`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"d1ed6c48-a402-4a4b-a01e-ab4caf571284"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Example:",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8437467240612755`*^9, 3.8437467255702195`*^9}, {
  3.9066375212698865`*^9, 3.9066375256851864`*^9}, {3.906637812753715*^9, 
  3.9066378147058496`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"7c14a222-d218-4a57-b1df-6d57e7cb458f"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"T", "(", 
   RowBox[{"a", " ", "+", 
    RowBox[{"b", " ", "x"}], "+", 
    RowBox[{"c", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"d", " ", 
     SuperscriptBox["x", "3"]}]}], ")"}], 
  TraditionalForm]],ExpressionUUID->"5d0942ff-c445-4bb5-bfa9-31004a235329"]], \
"Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.622376460393091*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"65baaaf0-00d4-4dfa-ba80-071d7e4b2f2a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"5", " ", "a"}], "+", "b", "-", "c", "-", "d"}], ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", 
        RowBox[{"5", " ", "b"}], "-", "c", "-", "d"}], ")"}], "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "c"}]}], ")"}], 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "d"}]}], ")"}], 
      SuperscriptBox["x", "3"]}]}]}], TraditionalForm]],
  CellChangeTimes->{3.622376264035672*^9},
  FontWeight->"Normal",ExpressionUUID->"4fdd3f3b-44a7-4b84-8f9e-c698f9b2e21f"],
 " "
}], "Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.6223764815660744`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f5ebc2f6-3bbe-4d55-b75e-5c4e868b5867"],

Cell[TextData[{
 "Is ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bd76824b-583a-4700-8dab-fb600097ae5c"],
 " diagonalizable?  If so, find a basis \[Beta] so that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "f232a0bd-c7de-4d34-95a2-c1dd0a499527"],
 " is a diagonal matrix. How many  different diagonal matrix representations \
can ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "23c0db37-fd63-4aa5-9f87-2d8cd4ebeebf"],
 " have?"
}], "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
  3.6225493988262625`*^9, 3.6225493993575397`*^9}, {3.9066375365763407`*^9, 
  3.9066376396974335`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9a4a0848-d55d-4608-a5fb-0f5572a0bbf8"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
},
