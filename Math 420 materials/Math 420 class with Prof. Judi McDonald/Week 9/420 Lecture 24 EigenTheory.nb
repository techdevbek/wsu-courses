  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8437467240612755`*^9, 3.8437467255702195`*^9}, {
  3.9066375212698865`*^9, 3.9066375256851864`*^9}, {3.906637812753715*^9, 
  3.9066378147058496`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"6242717c-56fe-45de-a661-77335f5119ef"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"T", "(", 
   RowBox[{"a", " ", "+", 
    RowBox[{"b", " ", "x"}], "+", 
    RowBox[{"c", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"d", " ", 
     SuperscriptBox["x", "3"]}]}], ")"}], 
  TraditionalForm]],ExpressionUUID->"42c2ccdc-268c-41f1-9359-6c44079579ec"]], \
"Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.622376460393091*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"2d05e962-71be-4d8b-8247-fa4deddafbde"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"5", " ", "a"}], "+", "b", "-", "c", "-", "d"}], ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", 
        RowBox[{"5", " ", "b"}], "-", "c", "-", "d"}], ")"}], "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "c"}]}], ")"}], 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "d"}]}], ")"}], 
      SuperscriptBox["x", "3"]}]}]}], TraditionalForm]],
  CellChangeTimes->{3.622376264035672*^9},
  FontWeight->"Normal",ExpressionUUID->"33d4cc2c-7218-4c84-9b81-5a6b946c1e15"],
 " "
}], "Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.6223764815660744`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"54667ba4-3278-4c3e-bf37-7910c5cc6ff4"],

Cell[TextData[{
 "Notice ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     RowBox[{"1", "+", "x", "+", 
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["x", "3"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"4", "+", 
      RowBox[{"4", "\[VeryThinSpace]", "x"}], "+", 
      RowBox[{"4", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"4", 
       SuperscriptBox["x", "3"]}]}], "=", 
     RowBox[{"4", 
      RowBox[{"(", 
       RowBox[{"1", "+", "x", "+", 
        SuperscriptBox["x", "2"], "+", 
        SuperscriptBox["x", "3"]}], ")"}]}]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4e6cebf8-a89b-4a0f-b82a-25c79a1fc697"]
}], "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
   3.6225493988262625`*^9, 3.6225493993575397`*^9}, {3.9066375365763407`*^9, 
   3.9066376396974335`*^9}, 3.906645507370347*^9, {3.906645674411996*^9, 
   3.9066457350818777`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"93cbb7d3-7877-4558-b24e-68587fba3b88"],

Cell[TextData[{
 "So for this transformation, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "+", "x", "+", 
    SuperscriptBox["x", "2"], "+", 
    SuperscriptBox["x", "3"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f7147fd-587c-499e-af2e-7deda89b6e04"],
 " is an eigenvector with eigenvalue 4. "
}], "Text",
 CellChangeTimes->{{3.9066457382969055`*^9, 
  3.9066457638531036`*^9}},ExpressionUUID->"f7c7613c-7a1b-4440-bb58-\
1b24e76a878d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Questions:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.843300989150785*^9, 3.8433009925852985`*^9}, {
  3.9066376924279804`*^9, 3.906637694295069*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"98b7bf05-c4f8-4a23-a4d3-4b3f3ccdddcc"],

Cell[TextData[{
 "How do we find these special \[OpenCurlyDoubleQuote]vectors\
\[CloseCurlyDoubleQuote] for ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "f0157567-3b14-4558-b848-cdc232cbf29c"],
 "?"
}], "Text",
 CellChangeTimes->{{3.6223766349830866`*^9, 3.622376651640234*^9}, {
  3.6223767411126814`*^9, 3.622376759144869*^9}, {3.6223789124139147`*^9, 
  3.622378953406479*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"824d6a4a-2e78-41a1-9929-49ecbfeea8cd"],

Cell[TextData[{
 "Does ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "387e868a-ec6e-44ea-ac0d-58d9e4b4916b"],
 " always have such special vectors?"
}], "Text",
 CellChangeTimes->{{3.6223766349830866`*^9, 3.622376651640234*^9}, {
  3.6223767411126814`*^9, 3.622376759144869*^9}, {3.6223789124139147`*^9, 
  3.6223789784390154`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"0380e158-901e-4deb-9b06-6bc37da21d5d"],

Cell["When are they linearly independent?", "Text",
 CellChangeTimes->{{3.6223766349830866`*^9, 3.622376651640234*^9}, {
  3.6223767411126814`*^9, 3.622376759144869*^9}, {3.6223789124139147`*^9, 
  3.622378987158224*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"d5b98ef7-855c-487f-8e55-28933ca7b37d"],

Cell[TextData[{
 "Are there enough linearly independent special vectors to make a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f7c1a373-a9e4-4230-9319-8cb2043c9910"],
 "?"
}], "Text",
 CellChangeTimes->{{3.622378988002016*^9, 3.6223790256636305`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"815ebbb4-1c5e-4fb4-b9be-8363f9347ae0"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Theorem:  ",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, 3.621599458231881*^9, {
   3.622375382511361*^9, 3.6223757076190605`*^9}, {3.6223758011742105`*^9, 
   3.6223758011742105`*^9}, {3.6223792309166665`*^9, 3.622379232151112*^9}, 
   3.8433014270379777`*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"311ccafd-65ab-4b6f-99b1-b30ee4ac9b7e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2f404517-3164-4ec5-a335-084c8ee992b1"],
 " be a linear operator on a finite dimensional vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "b9dd836b-317e-4993-9d29-59e276d6d3df"],
 "  Then ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "a9b9c250-9f84-4ffe-b8a2-e4cc0fc7abae"],
 " is diagonalizable if and only if there is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ee20d7b9-c79c-4c73-865a-1256662feb1f"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "."}], TraditionalForm]],ExpressionUUID->
  "6f5fbe4a-44e7-4fe4-8cbc-661b27d646db"],
 "  Moreover, when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", " ", 
      SubscriptBox["v", "2"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "662a9416-7418-4d91-99d3-ecab9e1774ea"],
 " is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "14cfd333-cfbc-4980-95e9-a32f520d0a5e"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ","}], TraditionalForm]],ExpressionUUID->
  "da53603a-d50a-45ce-8f98-ae9e02613e6c"],
 " then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", "D"}], TraditionalForm]],
  ExpressionUUID->"a45be131-11e5-40f2-b5cb-bed647ad03a5"],
 " where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    StyleBox["jj",
     FontSlant->"Italic"]], TraditionalForm]],ExpressionUUID->
  "1d4421c4-96b3-479e-8f48-26553ad1deae"],
 " is the eigenvalue corresponding to the eigenvector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "j"], TraditionalForm]],ExpressionUUID->
  "3b83d56c-4382-49ca-ac5c-0bc99450ed5e"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", "j", "\[LessEqual]", 
    RowBox[{"n", "."}]}], TraditionalForm]],ExpressionUUID->
  "90458ced-fcfa-41e7-bcac-7598357b0ec4"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, 3.621599458231881*^9, {
   3.622375382511361*^9, 3.6223757076190605`*^9}, {3.6223758011742105`*^9, 
   3.6223758011742105`*^9}, {3.6223792309166665`*^9, 3.622379232151112*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"e857b786-b1fa-4f14-b3a2-2c57b7e66068"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Proof:",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, 3.621599458231881*^9, {
   3.622375382511361*^9, 3.6223757076190605`*^9}, 3.6223758011742105`*^9, {
   3.622379705851779*^9, 3.622379707414343*^9}, {3.6223797794391994`*^9, 
   3.622379793475978*^9}, {3.906637706160962*^9, 3.906637715577449*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"d5564a45-cd06-4f4a-97ce-e58862d0b703"],

Cell["(\[DoubleLongRightArrow])  ", "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
   3.622379588146862*^9, 3.622379588881278*^9}, {3.6223807220121326`*^9, 
   3.622380733856495*^9}, {3.843574613450145*^9, 3.843574620389392*^9}, {
   3.8435746852472725`*^9, 3.8435746897421885`*^9}, {3.8435747404354296`*^9, 
   3.843574751832438*^9}, 3.9066462771670046`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"09d5822d-689b-4b11-bb7f-e62e267037a0"],

Cell[TextData[{
 "Assume ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "08f46435-5c94-4eab-ab74-0808d6fdd19b"],
 " is diagonalizable."
}], "Text",
 CellChangeTimes->{{3.8435748137214584`*^9, 3.843574822163575*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"dbb72c49-ecd9-4083-a5e3-e8cd771d7784"],

Cell[TextData[{
 "Then there is an ordered basis \[Beta] for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "49c970de-3786-4c65-b6ac-1ee7b4032262"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], "=", "D"}], TraditionalForm]],
  ExpressionUUID->"a027a42a-045b-4194-8784-876d1afd4d0e"],
 ", where ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "7a59bbc3-264b-4d4d-8456-a59149d07dac"],
 " is a diagonal matrix.  Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "9444234e-7d3d-4949-96c2-d85044b1410a"],
 ". For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", "j", "\[LessEqual]", "n"}], TraditionalForm]],
  ExpressionUUID->"0041c347-dd94-4980-9552-1b36bdcff261"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "j"], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "n"], 
      RowBox[{
       SubscriptBox["d", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["v", "i"]}]}], "=", 
     RowBox[{
      SubscriptBox["d", 
       RowBox[{"j", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox["v", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c31af48d-5dac-4dcc-a8dc-bd5b892c8d35"],
 ". Thus each vector in ",
 Cell[BoxData[
  FormBox["\[Beta]", TraditionalForm]],ExpressionUUID->
  "ca43a8a4-1d7c-4e04-80fe-7497237a7cf3"],
 " is an eigenvector of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "5fc51ba7-d9d5-4a39-bcb3-f54a285ca4d5"],
 ".  Moreover, the eigenvalue associated ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "j"], TraditionalForm]],ExpressionUUID->
  "efb0889f-1a69-45fd-a07c-ac9a3bd09fd3"],
 " is ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    RowBox[{"j", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "0b98c85b-3567-4c34-9a2d-0c34bc71b356"],
 "."
}], "Text",
 CellChangeTimes->{{3.8435748137214584`*^9, 3.8435748223584824`*^9}, {
  3.843574854130435*^9, 3.8435749045720267`*^9}, {3.8435749459176283`*^9, 
  3.8435749989971313`*^9}, {3.843575033481592*^9, 3.8435751598717303`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"74d04070-8d69-409d-adeb-a27e8073bba9"],

Cell[TextData[{
 "Hence \[Beta] is a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c893eaaf-5745-4a06-8e12-8791a7eb300d"],
 " consisting of eigenvectors."
}], "Text",
 CellChangeTimes->{{3.8435748137214584`*^9, 3.843574840378084*^9}, {
  3.8435751847628117`*^9, 3.8435752054621735`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"d71ac26d-716e-46c7-b81f-f111ff9c6e66"],

Cell[TextData[StyleBox["(\[DoubleLongLeftArrow])  ",
 FontFamily->"Times New Roman",
 FontSize->14,
 FontWeight->"Normal"]], "Text",
 CellChangeTimes->{{3.8435746250198946`*^9, 3.843574638084224*^9}, {
   3.843574761124096*^9, 3.8435747795985746`*^9}, 3.9066464359930887`*^9},
 FontFamily->"Times New Roman",
 FontWeight->"Normal",ExpressionUUID->"6e5d7717-2f88-4576-b208-da48da0610f8"],

Cell[TextData[{
 "Let \[Beta] be a basis for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "2fce368f-08ff-4d33-ae89-3848de0b6468"],
 " consisting of eigenvectors of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "f4793461-85b9-48a8-a6bf-d4978b186129"],
 ".  Write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Beta]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["v", "1"], ",", "...", ",", 
      SubscriptBox["v", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "946e9bfe-3160-4af2-b278-c03a139367b7"],
 ". Since each vector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "j"], TraditionalForm]],ExpressionUUID->
  "1033890e-001c-4d62-b73b-f95dead9f025"],
 " is an eigenvector, we know there exist scalars ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", 
    SubscriptBox["\[Lambda]", "2"], ",", "...", ",", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],ExpressionUUID->
  "b521f1f8-90e0-4a97-a6e7-f1399c5a439d"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "j"], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Lambda]", "j"], 
     SubscriptBox["v", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "2aabb6ce-a063-4c7d-aaa8-fe0f954b1bbf"],
 ".  In particular,"
}], "Text",
 CellChangeTimes->{{3.843575225441219*^9, 3.8435752583663073`*^9}, {
  3.8435752951730785`*^9, 3.843575410845223*^9}, {3.8435754889769545`*^9, 
  3.8435755590260725`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"91613be6-5319-46ba-8b07-2085f5728839"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", 
     SubscriptBox["v", "j"], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"0", 
          SubscriptBox["v", "1"]}], "+"}], "..."}], "+", 
       RowBox[{"0", 
        SubscriptBox["v", 
         RowBox[{"j", "-", "1"}]]}], "+", 
       RowBox[{
        SubscriptBox["\[Lambda]", "j"], 
        SubscriptBox["v", "j"]}], "+", 
       RowBox[{"0", 
        SubscriptBox["v", 
         RowBox[{"j", "+", "1"}]]}], "+"}], "..."}], "+", 
     RowBox[{"0", 
      SubscriptBox["v", "n"]}]}]}], TraditionalForm]],ExpressionUUID->
  "286eddd8-4a02-4932-a2da-7783d89434ab"]
}], "Text",
 CellChangeTimes->{{3.843575225441219*^9, 3.8435752583663073`*^9}, {
  3.8435752951730785`*^9, 3.843575410845223*^9}, {3.8435754889769545`*^9, 
  3.843575555616866*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ef0c7075-6b2d-48c4-aab8-db6323e2b167"],

Cell["\<\
Notice that this implies that all the off-diagonal entries in the j-th column \
will be zero.\
\>", "Text",
 CellChangeTimes->{{3.8435752256481996`*^9, 3.843575225649189*^9}, {
  3.843575579484185*^9, 3.8435756070482206`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"6924ec26-b467-431f-8091-9fab1f2b7dcf"],

Cell[TextData[{
 "Hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "T", "]"}], "\[Beta]"], " "}], TraditionalForm]],
  ExpressionUUID->"3939d84b-ccd0-4116-8f85-d6943f045925"],
 "is a diagonal matrix. "
}], "Text",
 CellChangeTimes->{{3.8435752655951824`*^9, 3.843575286566908*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"114f822a-e9a2-44e9-a517-1ee9ecaffbcb"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Recall (Theorem): ",
 FontFamily->"Times New Roman",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
   3.622379588146862*^9, 3.6223795893344135`*^9}, {3.622381062715165*^9, 
   3.622381119964916*^9}, {3.622547596725388*^9, 3.6225476500874753`*^9}, 
   3.843301868399843*^9},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"b389ba0c-cbe8-4be7-a3bc-f426493a1926"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    RowBox[{
     RowBox[{
      SubscriptBox["M", 
       RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}],
      "."}]}], TraditionalForm]],ExpressionUUID->
  "b035e39f-6305-4a61-a416-add1119adb0c"],
 " Then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", " ", "x"}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "7c315963-c79c-4b07-b16f-e0d71da6320a"],
 " has nontrivial solutions if and only if det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", ")"}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "88366a1a-8350-47be-8baa-e6cc50930d71"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
   3.622379588146862*^9, 3.6223795893344135`*^9}, {3.622381062715165*^9, 
