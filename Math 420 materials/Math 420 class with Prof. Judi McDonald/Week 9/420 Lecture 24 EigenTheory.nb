Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    RowBox[{
     RowBox[{
      SubscriptBox["M", 
       RowBox[{"n", "\[Cross]", "n"}]], "(", "\[DoubleStruckCapitalF]", ")"}],
      "."}]}], TraditionalForm]],ExpressionUUID->
  "7c97ade2-5b0b-46bf-b816-2766d2e5c1b7"],
 " Then \[Lambda] is an eigenvalue of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b3fd8de0-f0c0-45d6-8199-e6098ce35649"],
 " if and only if det(",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"A", "-", 
      RowBox[{"\[Lambda]", "\[VeryThinSpace]", "I"}]}], ")"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"e79a0658-c355-4ba7-be56-bab3862315d3"],
 ".  "
}], "Text",
 CellChangeTimes->{{3.62237581264359*^9, 3.622375909857458*^9}, {
