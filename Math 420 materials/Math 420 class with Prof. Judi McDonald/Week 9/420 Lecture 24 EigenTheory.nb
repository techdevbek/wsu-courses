Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "7611e07b-d880-421f-9e00-20c3d225b06b"],
 " be a linear operator on a vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "."}], TraditionalForm]],ExpressionUUID->
  "148290c9-013d-4585-ab7c-6a5c71d0a8f9"],
 "  A nonzero vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[Element]", "V"}], TraditionalForm]],ExpressionUUID->
  "8e547ca8-4cf5-4eff-89ef-bbbc003bf1e8"],
 " is said to be an ",
 StyleBox["eigenvector",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 " of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "27546241-e34e-462c-9131-52c8196147ab"],
 " if there is a scalar \[Lambda] such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "v", ")"}], "=", 
    RowBox[{"\[Lambda]", " ", 
     RowBox[{"v", "."}]}]}], TraditionalForm]],ExpressionUUID->
  "238842f9-b08a-4e46-a29c-e6b9c8966305"],
 "  The scalar \[Lambda] is referred to as the ",
 StyleBox["eigenvalue",
  FontSlant->"Italic",
  FontColor->GrayLevel[0]],
 " corresponding to the eigenvector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "."}], TraditionalForm]],ExpressionUUID->
  "20177510-7fdc-45b5-aee0-9a4b43ed1180"]
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.622375298178881*^9}, {
   3.62237534841584*^9, 3.622375360557118*^9}, {3.622379302178646*^9, 
   3.622379302725529*^9}, 3.6223794601658373`*^9},
 FontFamily->
  "Times New Roman",ExpressionUUID->"50fbf9b3-a442-404b-ad53-8451c58eea62"]
}, Open  ]],

