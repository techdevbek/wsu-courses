 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"8b1f33c9-aece-4692-8d2b-5acfad738161"],

Cell[TextData[{
 "A linear operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "b623de55-ea7b-420d-ac03-2f7677c6e3e3"],
 " on a finite dimensional vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", " "}], TraditionalForm]],ExpressionUUID->
  "1df2e088-17e4-4db5-bf19-77ede1f2f86c"],
 "is said to be ",
 StyleBox["diagonalizable",
  FontFamily->"Times New Roman",
  FontWeight->"Normal",
  FontSlant->"Italic",
  FontColor->RGBColor[0., 0., 0.]],
 " if there is an ordered basis \[Beta] for ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "15ca63eb-905e-4d53-a26d-5b2bf7855016"],
 " such that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]"], TraditionalForm]],ExpressionUUID->
  "72dff230-3f1e-46f1-b023-64f415e64013"],
 " is diagonal."
}], "Text",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
   3.621339399492181*^9, 3.621339484546337*^9}, 3.621343550024905*^9, {
   3.621599242985607*^9, 3.621599308617822*^9}, {3.621599458231881*^9, 
   3.621599464692874*^9}, 3.621775121619269*^9, {3.622375021667694*^9, 
   3.622375096941824*^9}, {3.6223751657166014`*^9, 3.6223751657166014`*^9}, {
   3.6223759980074515`*^9, 3.6223759985075116`*^9}, 3.622379358920253*^9, 
   3.8433010395895166`*^9, {3.8435548752423754`*^9, 3.8435548841372986`*^9}, {
   3.8435739668206596`*^9, 3.8435739796449966`*^9}, {3.8435741061074295`*^9, 
   3.8435741061074295`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c9f358d2-e598-4381-84d6-6bb114987aa5"],

Cell[TextData[{
 "NOTE: When we are using the same basis both time ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]", "\[Beta]"], TraditionalForm]],
  ExpressionUUID->"68aa7513-6302-4f86-973f-7a23015b384f"],
 ", we can omit the second \[Beta]: ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]"], TraditionalForm]],ExpressionUUID->
  "3f85836d-a2f4-429c-aa38-803c1ed19986"],
 "."
}], "Text",
 CellChangeTimes->{{3.8435741083067293`*^9, 3.843574150099575*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"738cf88a-9a3f-402e-a3b0-125dd968f351"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[StyleBox["Definition:  ", "Subsubsubsection",
 FontWeight->"Bold",
 FontColor->RGBColor[0, 0.5, 0.5]]], "Subsubsubsection",
 CellChangeTimes->{{3.621167080364156*^9, 3.6211670923648076`*^9}, {
   3.621338848168948*^9, 3.621338932751212*^9}, 3.6213389798589115`*^9, {
