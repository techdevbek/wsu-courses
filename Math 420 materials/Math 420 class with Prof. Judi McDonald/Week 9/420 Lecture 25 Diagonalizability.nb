     SuperscriptBox["x", "3"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "c9af36e8-5fed-4752-87fb-a81122fe8c9b"],
 " so in the original vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "1"}], "-", "x", "+", 
    SuperscriptBox["x", "2"], "+", 
    SuperscriptBox["x", "3"]}], TraditionalForm]],ExpressionUUID->
  "51037244-891b-4a9c-b05f-1714aebf4569"],
 " should be an eigenvector with eigenvalue 8."
}], "Text",
 CellChangeTimes->{{3.9068197721847315`*^9, 3.9068198456557665`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"4b530cef-7e2b-48be-bdae-430d7f70f0f5"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"T", "(", 
   RowBox[{"a", " ", "+", 
    RowBox[{"b", " ", "x"}], "+", 
    RowBox[{"c", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"d", " ", 
     SuperscriptBox["x", "3"]}]}], ")"}], 
  TraditionalForm]],ExpressionUUID->"8884fc79-5c7c-498d-bce8-714902c255c5"]], \
