Cell[CellGroupData[{

Cell[TextData[StyleBox["Example:",
 FontColor->RGBColor[
  0., 0.5019607843137255, 0.5019607843137255]]], "Subsubsubsection",
 CellChangeTimes->{{3.8437467240612755`*^9, 3.8437467255702195`*^9}, {
  3.9066375212698865`*^9, 3.9066375256851864`*^9}, {3.906637812753715*^9, 
  3.9066378147058496`*^9}},
 FontFamily->"Times New Roman",
 FontSize->12,ExpressionUUID->"7c14a222-d218-4a57-b1df-6d57e7cb458f"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"T", "(", 
   RowBox[{"a", " ", "+", 
    RowBox[{"b", " ", "x"}], "+", 
    RowBox[{"c", " ", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"d", " ", 
     SuperscriptBox["x", "3"]}]}], ")"}], 
  TraditionalForm]],ExpressionUUID->"5d0942ff-c445-4bb5-bfa9-31004a235329"]], \
"Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.622376460393091*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"65baaaf0-00d4-4dfa-ba80-071d7e4b2f2a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"5", " ", "a"}], "+", "b", "-", "c", "-", "d"}], ")"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"a", "+", 
        RowBox[{"5", " ", "b"}], "-", "c", "-", "d"}], ")"}], "x"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "c"}]}], ")"}], 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "-", "b", "+", 
        RowBox[{"6", " ", "d"}]}], ")"}], 
      SuperscriptBox["x", "3"]}]}]}], TraditionalForm]],
  CellChangeTimes->{3.622376264035672*^9},
  FontWeight->"Normal",ExpressionUUID->"4fdd3f3b-44a7-4b84-8f9e-c698f9b2e21f"],
 " "
}], "Text",
 CellChangeTimes->{{3.622376001257618*^9, 3.622376063229617*^9}, {
  3.6223762800833955`*^9, 3.6223764815660744`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"f5ebc2f6-3bbe-4d55-b75e-5c4e868b5867"],

Cell[TextData[{
 "Is ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "bd76824b-583a-4700-8dab-fb600097ae5c"],
 " diagonalizable?  If so, find a basis \[Beta] so that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Beta]"], TraditionalForm]],ExpressionUUID->
  "f232a0bd-c7de-4d34-95a2-c1dd0a499527"],
 " is a diagonal matrix. How many  different diagonal matrix representations \
can ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "23c0db37-fd63-4aa5-9f87-2d8cd4ebeebf"],
 " have?"
}], "Text",
 CellChangeTimes->{{3.622549073324427*^9, 3.622549158969363*^9}, {
  3.6225493988262625`*^9, 3.6225493993575397`*^9}, {3.9066375365763407`*^9, 
  3.9066376396974335`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"9a4a0848-d55d-4608-a5fb-0f5572a0bbf8"],

Cell[TextData[{
 "Step 1: Turn ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "2be11161-aa1c-4f24-b62a-74cb8ac71e55"],
 " into its matrix representation:"
}], "Text",
 CellChangeTimes->{{3.9068185110544786`*^9, 3.9068185441467843`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"2de66901-a57f-4b72-988d-72c0a0814b68"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"\[Alpha]", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "x", ",", 
     SuperscriptBox["x", "2"], ",", 
     SuperscriptBox["x", "3"]}], "}"}]}], 
  TraditionalForm]],ExpressionUUID->"f1cd4f01-4540-40e1-a053-555734461834"]], \
"Text",
 CellChangeTimes->{{3.9068185110544786`*^9, 3.9068185682760572`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"c50bd2e4-2e18-408c-b13f-d04cb799e946"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"T", "(", "1", ")"}], "=", 
    RowBox[{"5", "+", "x", "-", 
     SuperscriptBox["x", "2"], "-", 
     SuperscriptBox["x", "3"]}]}], TraditionalForm]],ExpressionUUID->
  "f0f8ab56-96da-410a-906a-5a94f8b31732"],
 "  (set ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"a", "=", "1"}], ",", " ", 
     RowBox[{"b", "=", 
      RowBox[{"c", "=", 
       RowBox[{"d", "=", "0"}]}]}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "ae719494-caed-4052-8e68-4b75286f5eff"]
}], "Text",
 CellChangeTimes->{{3.9068185110544786`*^9, 3.9068186215678835`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"a6a3f26f-9b58-42a2-b368-875029f22e71"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", "x", ")"}], "=", 
   RowBox[{"1", "+", 
    RowBox[{"5", "x"}], "-", 
    SuperscriptBox["x", "2"], "-", 
    SuperscriptBox["x", "3"]}]}], 
  TraditionalForm]],ExpressionUUID->"7e6d0a3f-992e-47d8-9e47-d43db5a8e227"]], \
"Text",
 CellChangeTimes->{{3.906818628542353*^9, 3.9068186539566984`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"ef8fdd08-c0cd-48d2-8748-4393c28d7dfc"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", 
    SuperscriptBox["x", "2"], ")"}], "=", 
   RowBox[{
    RowBox[{"-", "1"}], "-", "x", "+", 
    RowBox[{"6", 
     SuperscriptBox["x", "2"]}], "+", 
    RowBox[{"0", 
     SuperscriptBox["x", "3"]}]}]}], 
  TraditionalForm]],ExpressionUUID->"5b8b6559-9d01-4bdc-aaeb-b9ff09db19b0"]], \
"Text",
 CellChangeTimes->{{3.906818628542353*^9, 3.9068187081602974`*^9}, {
  3.90681877453069*^9, 3.9068187775447445`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"5dd724ef-6193-4e9c-a8bb-ec14751668f5"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"T", "(", 
    SuperscriptBox["x", "3"], ")"}], "=", Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      RowBox[{"-", "1"}], "-", "x", "+", 
      RowBox[{"0", 
       SuperscriptBox["x", "2"]}], "+", 
      RowBox[{"6", 
       SuperscriptBox["x", "3"]}]}], TraditionalForm]],ExpressionUUID->
    "c731336e-804c-4942-9df3-45bf87691763"]],ExpressionUUID->
    "9bafdf6a-b1af-4acb-85dc-583c16d82369"]}], 
  TraditionalForm]],ExpressionUUID->"87e9b019-0776-4a7b-902d-a9cfcf7ebf80"]], \
"Text",
 CellChangeTimes->{{3.906818628542353*^9, 3.9068187379525495`*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"58dff9dd-9f74-4dc5-bf1b-736a4fee49ea"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    RowBox[{"[", "T", "]"}], "\[Alpha]"], "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"5", "1", 
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}]},
      {"1", "5", 
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}]},
      {
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}], "6", "0"},
      {
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}], "0", "6"}
     }], "\[NoBreak]", ")"}], " "}], 
  TraditionalForm]],ExpressionUUID->"05da9d4f-8f73-4d11-a375-e9b352020cdd"]], \
"Text",
 CellChangeTimes->{{3.906818788683612*^9, 3.906818868881168*^9}},
 FontFamily->
  "Times New Roman",ExpressionUUID->"0086c191-66e5-41fa-86ba-408b82bdc02f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Det", "[", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"5", "-", "\[Lambda]"}], "1", 
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}]},
      {"1", 
       RowBox[{"5", "-", "\[Lambda]"}], 
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}]},
      {
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}], 
       RowBox[{"6", "-", "\[Lambda]"}], "0"},
      {
       RowBox[{"-", "1"}], 
       RowBox[{"-", "1"}], "0", 
       RowBox[{"6", "-", "\[Lambda]"}]}
     }], "\[NoBreak]", ")"}], "]"}], ",", " ", 
  RowBox[{"label", " ", "this", " ", Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      SubscriptBox[
       RowBox[{"[", "T", "]"}], "\[Alpha]"], "-", "\[Lambda]I"}], 
     TraditionalForm]],ExpressionUUID->
    "22fe25c0-ced5-4f3b-b5ac-44d74d5b9b41"]],ExpressionUUID->
    "f6d693c4-46d2-401c-87b9-4edc4b612952"]}]}]], "Input",
 CellChangeTimes->{{3.9068188883757877`*^9, 3.906818921490158*^9}, {
