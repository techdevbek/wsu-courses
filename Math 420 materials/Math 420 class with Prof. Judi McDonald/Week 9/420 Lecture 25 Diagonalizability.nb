Cell[TextData[{
 "Any nonzero choice of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "4"], TraditionalForm]],ExpressionUUID->
  "fd04d345-a5f4-4143-9dde-15a019574fbb"],
 " creates an eigenvector. For example: ",
 Cell[BoxData[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"-", "1"}]},
     {
      RowBox[{"-", "1"}]},
     {"1"},
