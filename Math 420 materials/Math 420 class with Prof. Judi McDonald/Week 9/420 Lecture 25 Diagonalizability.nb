Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"5", " ", "a"}], "+", "b", "-", "c", "-", "d"}], ")"}], "+", 
     RowBox[{
